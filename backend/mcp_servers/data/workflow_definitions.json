    "posture_cycle": {
      "group": "status",
      "description": "Cycle through all postures with output verification",
      "agents_needed": 1,
      "setup": ["teleport_to_test_room"],
      "steps": [
        { "action": "execute", "command": "stand" },
        { "action": "execute", "command": "sit", "expect_success": true, "output_contains": "sit" },
        { "action": "execute", "command": "lie", "expect_success": true, "output_contains": "lie" },
        { "action": "execute", "command": "stand", "expect_success": true, "output_contains": "stand" },
        { "action": "execute", "command": "sit", "expect_success": true },
        { "action": "execute", "command": "stand", "expect_success": true }
      ]
    },
