# Earth data import - shapefile and raster processing (only needed for one-time import scripts)
# Requires system libraries: libgdal-dev. Not needed on production game servers.
group :import do
  gem 'rgeo'
  gem 'rgeo-shapefile'
  gem 'gdal', '~> 3.0'       # Earth import only — requires libgdal-dev system library
  gem 'parallel', '~> 1.26'  # Earth import parallel processing
end

# HTTP Client for LLM APIs
gem 'faraday', '~> 2.9'
# faraday-retry: retry logic is handled in LlmRequestProcessor; remove this if not activating Faraday middleware

# Cloud Storage (Cloudflare R2 / S3-compatible)
gem 'aws-sdk-s3', '~> 1.0'

# Email (SendGrid)
gem 'sendgrid-ruby', '~> 6.7'

gem 'ruby-vips', '~> 2.2' # High-performance image processing for battle maps

# Fast PNG generation for terrain textures (ChunkyPNG is pure Ruby, no dependencies)
gem 'chunky_png', '~> 1.4'

# Google Cloud TTS (Chirp 3 HD voices)
