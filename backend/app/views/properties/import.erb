<!-- Page Banner -->
<section class="page-banner" style="background-image: url('/images/library.jpg');">
  <div class="container mx-auto px-4">
    <div class="page-banner-content">
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><a href="/properties/<%= @room.id %>"><%= h @room.name %></a></li>
          <li>Import Blueprint</li>
        </ul>
      </div>
      <h1>Import Property Blueprint</h1>
    </div>
  </div>
</section>

<section class="py-12">
  <div class="container mx-auto px-4">
    <div class="flex justify-center">
      <div class="w-full max-w-3xl">
        <!-- Info Alert -->
        <div class="alert alert-info mb-6">
          <i class="bi bi-info-circle text-xl"></i>
          <div>
            <h5 class="font-bold">What Gets Imported</h5>
            <p class="mb-2">Importing a property blueprint will update this room with:</p>
            <ul class="list-disc list-inside">
              <li><strong>Room Details:</strong> Descriptions, seasonal variants, and configuration</li>
              <li><strong>Places:</strong> Furniture and seating areas (scaled to fit)</li>
              <li><strong>Decorations:</strong> Decorative items and images</li>
              <li><strong>Room Features:</strong> Doors, windows, and structural elements</li>
              <li><strong>Battle Map:</strong> Hex grid configuration (if present)</li>
            </ul>
          </div>
        </div>

        <!-- Warning Alert -->
        <div class="alert alert-warning mb-6">
          <i class="bi bi-exclamation-triangle text-xl"></i>
          <div>
            <strong>Warning:</strong> Importing will <em>replace</em> existing room content.
            Current places, decorations, and features will be removed before importing.
            Make sure to export your current room first if you want to preserve it.
          </div>
        </div>

        <!-- Room Info -->
        <div class="card bg-base-200 shadow-xl mb-6">
          <div class="card-body">
            <h2 class="card-title"><i class="bi bi-house mr-2"></i>Target Room</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <p class="mb-1"><strong>Name:</strong> <%= h @room.name %></p>
                <p class="mb-1"><strong>Type:</strong> <%= @room.room_type || 'Standard' %></p>
              </div>
              <div>
                <p class="mb-1"><strong>Current Size:</strong>
                  <% if @room.max_x && @room.min_x %>
                    <%= (@room.max_x - @room.min_x + 1) %> x <%= (@room.max_y - @room.min_y + 1) rescue 'Unknown' %> units
                  <% else %>
                    Not configured
                  <% end %>
                </p>
                <p><strong>Places:</strong> <%= @room.places_dataset.count %></p>
              </div>
            </div>
          </div>
        </div>

        <!-- Import Form -->
        <div class="card bg-base-200 shadow-xl">
          <div class="card-body">
            <h2 class="card-title"><i class="bi bi-upload mr-2"></i>Upload Property Blueprint</h2>
            <form action="/properties/<%= @room.id %>/import" method="post" enctype="multipart/form-data">
              <%= csrf_tag %>

              <!-- ZIP Package -->
              <div class="form-control mb-6">
                <label for="content_package" class="label">
                  <span class="label-text">Property Package (ZIP) <span class="text-error">*</span></span>
                </label>
                <input type="file" class="file-input file-input-bordered w-full" id="content_package" name="content_package" accept=".zip" required>
                <label class="label">
                  <span class="label-text-alt text-base-content/70">
                    Select the ZIP file exported from another Firefly game. Contains room data and images.
                  </span>
                </label>
              </div>

              <!-- Alternative: Separate JSON + Images -->
              <div class="border-t border-base-content/10 pt-6 mt-6">
                <p class="text-base-content/70 mb-4">
                  <small><i class="bi bi-lightning mr-1"></i>Alternatively, upload JSON and images separately:</small>
                </p>

                <div class="form-control mb-4">
                  <label for="json_file" class="label">
                    <span class="label-text">JSON Data File</span>
                  </label>
                  <input type="file" class="file-input file-input-bordered w-full" id="json_file" name="json_file" accept=".json">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Property export data in JSON format</span>
                  </label>
                </div>

                <div class="form-control mb-4">
                  <label for="images_zip" class="label">
                    <span class="label-text">Images Archive (Optional)</span>
                  </label>
                  <input type="file" class="file-input file-input-bordered w-full" id="images_zip" name="images_zip" accept=".zip">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">ZIP file containing room images</span>
                  </label>
                </div>
              </div>

              <!-- Import Options -->
              <div class="border-t border-base-content/10 pt-6 mt-6">
                <h6 class="font-semibold mb-4"><i class="bi bi-gear mr-2"></i>Import Options</h6>

                <div class="form-control mb-2">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="checkbox" type="checkbox" id="scale_places" name="scale_places" value="1" checked>
                    <div>
                      <span class="label-text">Scale places to fit room bounds</span>
                      <p class="text-base-content/70 text-sm">Adjust furniture positions proportionally to fit this room's size</p>
                    </div>
                  </label>
                </div>

                <div class="form-control mb-2">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="checkbox" type="checkbox" id="import_battle_map" name="import_battle_map" value="1" checked>
                    <div>
                      <span class="label-text">Import battle map configuration</span>
                      <p class="text-base-content/70 text-sm">Include hex grid setup if present in the blueprint</p>
                    </div>
                  </label>
                </div>

                <div class="form-control">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="checkbox" type="checkbox" id="preserve_exits" name="preserve_exits" value="1" checked>
                    <div>
                      <span class="label-text">Preserve existing room exits</span>
                      <p class="text-base-content/70 text-sm">Keep current door and pathway connections intact</p>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Submit -->
              <div class="flex justify-between items-center mt-6">
                <a href="/properties/<%= @room.id %>" class="btn btn-ghost">
                  <i class="bi bi-arrow-left mr-1"></i>Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-upload mr-2"></i>Import Blueprint
                </button>
              </div>
            </form>
          </div>
        </div>

        <!-- Help Section -->
        <div class="card bg-base-200 shadow-xl mt-6">
          <div class="card-body">
            <h2 class="card-title"><i class="bi bi-question-circle mr-2"></i>Help</h2>
            <h6 class="font-semibold">How to Export a Property</h6>
            <p class="text-base-content/70 mb-4">
              To export a property from another Firefly game, visit the property's page and click
              the <strong>Export Blueprint</strong> button. This will download a ZIP file containing
              all room data and images.
            </p>

            <h6 class="font-semibold">Size Differences</h6>
            <p class="text-base-content/70 mb-4">
              If the source room and target room have different sizes, places will be scaled
              proportionally to fit. Some truncation may occur for very large blueprints imported
              to smaller rooms.
            </p>

            <h6 class="font-semibold">Supported Formats</h6>
            <p class="text-base-content/70">
              Property export packages use version 1.0.0 of the Firefly content format.
              Future versions will maintain backwards compatibility.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
