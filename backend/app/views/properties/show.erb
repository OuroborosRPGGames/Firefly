<!-- Page Banner -->
<section class="page-banner" style="background-image: url('<%= @room.default_background_url || '/images/library.jpg' %>');">
  <div class="container mx-auto px-4">
    <div class="page-banner-content">
      <div class="breadcrumbs text-sm mb-2">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/dashboard">Dashboard</a></li>
          <li><%= h @room.name %></li>
        </ul>
      </div>
      <h1><%= h @room.name %></h1>
    </div>
  </div>
</section>

<section class="py-12">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Main Content -->
      <div class="lg:col-span-8">
        <!-- Room Details Card -->
        <div class="card bg-base-200 shadow-xl mb-6">
          <div class="card-body">
            <div class="flex justify-between items-center mb-4">
              <h2 class="card-title"><i class="bi bi-house mr-2"></i>Property Details</h2>
              <a href="/room_builder/<%= @room.id %>" class="btn btn-primary btn-sm">
                <i class="bi bi-pencil mr-1"></i>Edit in Room Builder
              </a>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <h6 class="text-base-content/70 uppercase text-sm mb-2">Basic Information</h6>
                <div class="space-y-2">
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Name</dt>
                    <dd class="w-2/3"><%= h @room.name %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Type</dt>
                    <dd class="w-2/3"><%= @room.room_type || 'Standard' %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Outdoor</dt>
                    <dd class="w-2/3"><%= @room.is_outdoor ? 'Yes' : 'No' %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Safe Room</dt>
                    <dd class="w-2/3"><%= @room.safe_room ? 'Yes' : 'No' %></dd>
                  </div>
                </div>
              </div>
              <div>
                <h6 class="text-base-content/70 uppercase text-sm mb-2">Configuration</h6>
                <div class="space-y-2">
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Places</dt>
                    <dd class="w-2/3"><%= @room.places_dataset.count %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Decorations</dt>
                    <dd class="w-2/3"><%= @room.respond_to?(:decorations_dataset) ? @room.decorations_dataset.count : 0 %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Battle Map</dt>
                    <dd class="w-2/3"><%= @room.has_battle_map ? 'Configured' : 'None' %></dd>
                  </div>
                  <div class="flex">
                    <dt class="w-1/3 font-semibold">Size</dt>
                    <dd class="w-2/3">
                      <% if @room.max_x && @room.min_x %>
                        <%= (@room.max_x - @room.min_x + 1) %> x <%= (@room.max_y - @room.min_y + 1) rescue '?' %> units
                      <% else %>
                        Not configured
                      <% end %>
                    </dd>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Description -->
        <% if @room.long_description || @room.short_description %>
          <div class="card bg-base-200 shadow-xl mb-6">
            <div class="card-body">
              <h2 class="card-title"><i class="bi bi-card-text mr-2"></i>Description</h2>
              <% if @room.short_description %>
                <p class="text-base-content/70 mb-2"><em><%= h @room.short_description %></em></p>
              <% end %>
              <% if @room.long_description %>
                <p><%= h @room.long_description %></p>
              <% end %>
            </div>
          </div>
        <% end %>

        <!-- Places -->
        <% places = @room.places_dataset.order(:id).all %>
        <% if places.any? %>
          <div class="card bg-base-200 shadow-xl mb-6">
            <div class="card-body">
              <h2 class="card-title"><i class="bi bi-geo-alt mr-2"></i>Places (<%= places.count %>)</h2>
              <div class="overflow-x-auto">
                <table class="table table-zebra">
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Capacity</th>
                      <th>Type</th>
                      <th>Position</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% places.each do |place| %>
                      <tr>
                        <td><%= h place.name %></td>
                        <td><%= place.capacity %></td>
                        <td><%= place.is_furniture ? 'Furniture' : 'Area' %></td>
                        <td>(<%= place.x %>, <%= place.y %>, <%= place.z %>)</td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-4">
        <!-- Quick Actions Card -->
        <div class="card bg-base-200 shadow-xl mb-6">
          <div class="card-body">
            <h2 class="card-title"><i class="bi bi-lightning mr-2"></i>Quick Actions</h2>
            <div class="flex flex-col gap-2">
              <a href="/room_builder/<%= @room.id %>" class="btn btn-primary">
                <i class="bi bi-pencil-square mr-1"></i>Edit in Room Builder
              </a>
              <a href="/dashboard" class="btn btn-ghost">
                <i class="bi bi-arrow-left mr-1"></i>Back to Dashboard
              </a>
              <div class="divider my-2"></div>
              <a href="/properties/<%= @room.id %>/export" class="btn btn-outline btn-primary btn-sm">
                <i class="bi bi-download mr-1"></i>Export Blueprint
              </a>
              <a href="/properties/<%= @room.id %>/import" class="btn btn-outline btn-primary btn-sm">
                <i class="bi bi-upload mr-1"></i>Import Blueprint
              </a>
            </div>
          </div>
        </div>

        <!-- Owner Info -->
        <div class="card bg-base-200 shadow-xl">
          <div class="card-body">
            <h2 class="card-title"><i class="bi bi-person mr-2"></i>Ownership</h2>
            <% owner = @room.owner %>
            <% if owner %>
              <p><strong>Owner:</strong> <%= h(owner.respond_to?(:full_name) ? owner.full_name : owner.nickname) %></p>
            <% else %>
              <p class="text-base-content/70">No owner assigned</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
