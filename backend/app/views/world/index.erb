<div class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold mb-6"><i class="bi bi-globe mr-2"></i>The World of <%= game_name %></h1>

        <div class="card bg-base-200 mb-6">
            <div class="card-body">
                <p class="text-lg text-base-content/70">Discover the rich world of <%= game_name %>.</p>
                <p>Explore the lore, locations, and factions that make up our game universe.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="card bg-base-200 h-full">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-journal-text mr-2 text-primary"></i>Lore</h5>
                    <p class="text-base-content/70">The history and stories of our world.</p>
                    <div class="card-actions">
                        <a href="/world/lore" class="btn btn-outline btn-primary btn-sm">Explore Lore</a>
                    </div>
                </div>
            </div>
            <div class="card bg-base-200 h-full">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-geo-alt mr-2 text-success"></i>Locations</h5>
                    <p class="text-base-content/70">Notable places you can visit.</p>
                    <div class="card-actions">
                        <a href="/world/locations" class="btn btn-outline btn-success btn-sm">View Locations</a>
                    </div>
                </div>
            </div>
            <div class="card bg-base-200 h-full">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-people mr-2 text-warning"></i>Factions</h5>
                    <p class="text-base-content/70">Groups and organizations in the world.</p>
                    <div class="card-actions">
                        <a href="/world/factions" class="btn btn-outline btn-warning btn-sm">View Factions</a>
                    </div>
                </div>
            </div>
        </div>

        <% if @worlds && @worlds.any? %>
        <div class="divider my-8"></div>

        <h3 class="text-xl font-bold mb-4"><i class="bi bi-globe2 mr-2"></i>3D Globe Maps</h3>
        <p class="text-base-content/70 mb-6">Explore worlds in immersive 3D. See terrain, cities, and if you're logged in, your current location.</p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% @worlds.each do |world| %>
            <div class="card bg-base-200 h-full">
                <div class="card-body flex flex-col">
                    <h5 class="card-title">
                        <i class="bi bi-globe-americas mr-2 text-info"></i><%= h world.name %>
                    </h5>
                    <p class="text-base-content/70 text-sm mb-3">
                        <%= h world.universe&.name || 'Unknown Universe' %>
                    </p>
                    <div class="mt-auto">
                        <a href="/world/<%= world.id %>" class="btn btn-info btn-sm">
                            <i class="bi bi-box-arrow-up-right mr-1"></i>View in 3D
                        </a>
                    </div>
                </div>
            </div>
            <% end %>
        </div>
        <% end %>
    </div>
</div>
