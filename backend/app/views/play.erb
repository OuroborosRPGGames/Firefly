<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= @character ? "#{@character.full_name} — #{game_name}" : game_name %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap">
    <link rel="stylesheet" href="/css/play.css">
    <link rel="stylesheet" href="/css/grammar-checker.css">
    <%= content_for(:head) if respond_to?(:content_for) %>
</head>
<body class="play-body">
    <script src="/js/utils.js"></script>
    <script src="/js/grammar-checker.js"></script>
    <% if flash && flash['error'] %>
        <div class="play-flash play-flash--error"><%= flash['error'] %></div>
    <% end %>
    <% if flash && flash['success'] %>
        <div class="play-flash play-flash--success"><%= flash['success'] %></div>
    <% end %>

    <%= yield %>

    <%= content_for(:scripts) if respond_to?(:content_for) %>
</body>
</html>
