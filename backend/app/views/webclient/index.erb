    // Compute hex layout on mapData using the shared calculateLayout function.
    // This ensures the webclient uses identical hex sizing/viewBox as the template editor.
    // Display dimensions are overridden to fit the webclient's battle map panel.
    function ensureHexSizing(mapData) {
        if (mapData._hexSize) return; // already computed
        var layout = BattleMapRenderer.calculateLayout({
            arenaWidth: mapData.arena_width,
            arenaHeight: mapData.arena_height,
            imageWidth: mapData.background_image_width || null,
            imageHeight: mapData.background_image_height || null,
            maxDisplayWidth: 700
        });
        mapData._hexSize = layout.hexSize;
        mapData._hexHeight = layout.hexHeight;

        // Override display dimensions: use hex-grid-derived size so the SVG
        // fills the battle map panel naturally (the viewBox handles coordinate mapping).
        var hexBasedW = layout.hexSize * (mapData.arena_width * 1.5 + 0.5);
        var hexBasedH = (mapData.arena_height * layout.hexHeight) + layout.hexHeight;
        if (mapData.background_image_width && mapData.background_image_height) {
            // Scale display to image aspect ratio so background isn't distorted
            layout.displayWidth = hexBasedW;
            layout.displayHeight = hexBasedW * (mapData.background_image_height / mapData.background_image_width);
        } else {
            layout.displayWidth = hexBasedW;
            layout.displayHeight = hexBasedH;
        }
        mapData._layout = layout;
    }

    // Fetch battle map state from API
    async function fetchBattleMapState() {
        try {
            const response = await apiGet('/api/fight/battle_map');
            const data = await response.json();

            if (data.success) {
                ensureHexSizing(data);
                currentMapData = data; // Store for animation

                // Check if battle map is still generating - show loading UI instead
                if (data.battle_map_generating) {
                    // Battle map is being generated async - show loading UI with wireframe
                    console.log('[BattleMap] Map generation in progress, waiting for completion...');

                    // Show loading state with hex wireframe using BattleMapRenderer
                    const container = document.getElementById('battle-map-container');
                    const lobserve = document.getElementById('lobserve');
                    const leftwrapper = document.getElementById('leftwrapper');

                    // Make lobserve visible for battle map display
                    if (lobserve) {
                        if (inDelve) suspendDelveHud();
                        lobserve.style.display = 'block';
                        lobserve.classList.add('battle-map-active', 'visible');
                        adjustLobserveHeight();
                    }

                    // Use BattleMapRenderer to show loading UI with wireframe
                    if (typeof BattleMapRenderer !== 'undefined' && BattleMapRenderer.showGenerationLoading) {
                        BattleMapRenderer.showGenerationLoading(data);
                    }

                    // Fix: showGenerationLoading incorrectly hides the container, show it again
                    if (container) container.classList.remove('hidden');

                    // Don't render the map yet, let WebSocket updates handle completion
                    return;
                }

                // Round is being resolved/narrated — positions may be partially
                // updated so freeze the map until animation is ready.
                if (data.round_resolving && !animationInProgress) {
                    return;
                }

                // Check if we should animate a new round
                console.log('[BattleMap] Animation check:', {
                    pending: data.pending_animation,
                    animRound: data.animation_round,
                    lastAnim: lastAnimatedRound,
                    wouldTrigger: data.pending_animation && data.animation_round > lastAnimatedRound && !animationInProgress,
                    inProgress: animationInProgress
                });
                if (data.pending_animation &&
                    data.animation_round > lastAnimatedRound &&
                    !animationInProgress) {

                    // Claim animation slot immediately to prevent race with next poll
                    animationInProgress = true;
                    lastAnimatedRound = data.animation_round;

                    // Wait for dice animation to finish before moving icons
                    const now = Date.now();
                    if (now < diceAnimatingUntil) {
                        const waitMs = diceAnimatingUntil - now + 200;
                        await new Promise(r => setTimeout(r, waitMs));
                    } else {
                        // Grace period: give roll_display WebSocket messages time to arrive
                        // before we start animating, so rolls appear before movement
                        await new Promise(r => setTimeout(r, 1500));
                    }

                    // Fetch movement events for animation
                    const eventsResponse = await apiGet('/api/fight/round_events');
                    const eventsData = await eventsResponse.json();

                    const requestedRound = Number(data.animation_round);
                    const eventsRound = Number(eventsData.round);
                    if (eventsData.success &&
                        eventsData.events.length > 0 &&
                        eventsRound === requestedRound) {
                        await animateRoundMovement(eventsData.events, data);
                        return; // Animation handles the render
                    } else {
                        // No events to animate, release animation slot
                        if (eventsData.success && eventsData.events.length > 0 && eventsRound !== requestedRound) {
                            console.warn('[BattleMap] Ignoring stale round events', { eventsRound, requestedRound });
                        }
                        animationInProgress = false;
                        // Don't fall through to normal render — let the next poll handle it
                        // so positions don't snap before animation had a fair chance
                        return;
                    }
                }

                // Normal render (no animation or animation complete)
                // Exclude volatile fields (timestamp) from hash to prevent unnecessary re-renders
                const hashData = Object.assign({}, data);
                delete hashData.timestamp;
                const hash = JSON.stringify(hashData);
                if (hash !== lastBattleMapHash && !animationInProgress) {
                    lastBattleMapHash = hash;

                    // Structure hash: only visual map fields (hexes, background, arena).
                    // Changes here require a full SVG rebuild.
                    const structData = {
                        arena_width: data.arena_width,
                        arena_height: data.arena_height,
                        background_url: data.background_url,
                        background_image_width: data.background_image_width,
                        background_image_height: data.background_image_height,
                        hexes: data.hexes,
                        fight_id: data.fight_id
                    };
                    const structHash = JSON.stringify(structData);
                    const structureChanged = structHash !== lastMapStructureHash;
                    lastMapStructureHash = structHash;

                    // Participant visual hash: skip marker rebuild if only non-visual
                    // fields changed (e.g. input_complete, can_accept_combat_input)
                    const participantVisual = (data.participants || []).map(p => ({
                        id: p.id, x: p.hex_x, y: p.hex_y, hp: p.current_hp,
                        ko: p.is_knocked_out, rel: p.relationship
                    }));
                    const monsterVisual = (data.monsters || []).map(m => ({
                        id: m.id, x: m.hex_x, y: m.hex_y, hp: m.current_hp, mhp: m.max_hp
                    }));
                    const partHash = JSON.stringify({ p: participantVisual, m: monsterVisual });
                    const participantsChanged = partHash !== lastParticipantHash;
                    lastParticipantHash = partHash;

                    if (structureChanged) {
                        await renderBattleMap(data);
                    } else if (participantsChanged) {
                        // Only participant positions/HP changed — update markers in place
                        updateParticipantsOnly(data);
                    }
                    // If only non-visual fields changed, skip entirely (no flicker)

                    // Update fire effect based on combat state
                    updateFireEffectFromCombat(data);

                    // Track HP changes for blood effects
                    const viewerParticipant = data.participants?.find(p => p.is_viewer);
                    if (viewerParticipant) {
                        onCharacterHpUpdate(viewerParticipant.current_hp, viewerParticipant.max_hp);
                    }
                }
            } else if (data.error === 'not_in_combat') {
                if (battleMapActive) {
                    // Delay hiding so fight-end narrative arrives before map swaps
                    delayedHideBattleMap();
                }
            }
        } catch (err) {
            console.error('Battle map fetch error:', err);
        }
    }

    // Check combat status and show/hide map
    async function checkCombatStatus() {
        if (battleMapDismissed) return;

        try {
            const response = await apiGet('/api/fight/status');
            const data = await response.json();

            if (data.success && data.in_combat && data.fight_id) {
                if (!battleMapActive || currentFightId !== data.fight_id) {
                    currentFightId = data.fight_id;
                    battleMapActive = true;
                    battleMapDismissed = false;
                    if (inDelve) suspendDelveHud();
                    startBattleMapPolling();
                }
            } else if (battleMapActive) {
                // Delay hiding so fight-end narrative arrives before map swaps
                delayedHideBattleMap();
            }
        } catch (err) {
            console.error('Combat status check error:', err);
        }
    }

    // Start battle map polling
    function startBattleMapPolling() {
        if (battleMapPollInterval) return;
        fetchBattleMapState();
        battleMapPollInterval = setInterval(fetchBattleMapState, 2000);
    }

    // Stop battle map polling
    function stopBattleMapPolling() {
        if (battleMapPollInterval) {
            clearInterval(battleMapPollInterval);
            battleMapPollInterval = null;
        }
    }

    // Delayed hide - waits for combat message queue to drain before swapping map
    let _hideBattleMapTimer = null;
    let _hideBattleMapPending = false;
    function delayedHideBattleMap() {
        if (_hideBattleMapPending) return; // Already scheduled
        _hideBattleMapPending = true;
        stopBattleMapPolling(); // Stop polling immediately
        // Check if combat queue needs to drain first
        scheduleHideBattleMap();
    }

    function scheduleHideBattleMap() {
        if (_hideBattleMapTimer) { clearTimeout(_hideBattleMapTimer); _hideBattleMapTimer = null; }
        const now = Date.now();
        if (now < diceAnimatingUntil || combatMessageQueue.length > 0) {
            // Still animating or messages pending — re-check after animation ends
            const waitMs = Math.max(diceAnimatingUntil - now, 500) + 500;
            _hideBattleMapTimer = setTimeout(scheduleHideBattleMap, waitMs);
        } else {
            // Queue is drained, hide after a short grace period for final rendering
            _hideBattleMapTimer = setTimeout(() => {
                _hideBattleMapTimer = null;
                _hideBattleMapPending = false;
                hideBattleMap();
            }, 1500);
        }
    }

    // Hide battle map
    function hideBattleMap() {
        if (_hideBattleMapTimer) { clearTimeout(_hideBattleMapTimer); _hideBattleMapTimer = null; }
        _hideBattleMapPending = false;
        battleMapActive = false;
        currentFightId = null;
        lastBattleMapHash = null;
        lastMapStructureHash = null;
        lastParticipantHash = null;
        battleMapZoom = 1.0;
        stopBattleMapPolling();
        clearQuickmenuHandler();

        if (window._battleMapCompositor) {
          window._battleMapCompositor.destroy();
          window._battleMapCompositor = null;
        }
        window._battleMapEffects = null;
        window._battleMapParticles = null;

        // Turn off combat-triggered effects
        toggleFireEffect(false);
        previousCharacterHp = null;  // Reset HP tracking

        const container = document.getElementById('lobserve');
        if (container) {
            container.classList.remove('battle-map-active', 'media-active', 'media-size-small', 'media-size-large');

            // Preserve delve HUD element, then clear battle map content
            const delveHud = container.querySelector('#delve-hud');
            container.innerHTML = '';
            if (delveHud) container.appendChild(delveHud);

            // Restore delve HUD if still in a delve, otherwise hide lobserve
            if (inDelve) {
                restoreDelveHud();
            } else {
                container.classList.remove('visible');
                container.style.display = 'none';
            }
        }

        // Reset message window position
        if (lMessageWindow) {
            lMessageWindow.style.bottom = '';
            scrollToBottom(lMessageWindow);
        }

        // Remove tooltip if any
        const tooltip = document.getElementById('battleMapTooltip');
        if (tooltip) tooltip.remove();
    }

    // Dismiss battle map (user action)
    function dismissBattleMap() {
        battleMapDismissed = true;
        hideBattleMap();
    }

    // Reset battle map dismissed state (for new fights)
    function resetBattleMapDismissed() {
        battleMapDismissed = false;
    }

    // ========================================
    // BATTLE MAP ANIMATION
    // ========================================

    // Animate a round's movement events over ~4 seconds
    async function animateRoundMovement(events, mapData) {
        if (events.length === 0) return;

        animationInProgress = true;
        console.log('[BattleMap] Starting animation for', events.length, 'movement events');

        // Add animation indicator
        const wrapper = document.querySelector('.battle-map-wrapper');
        let indicator = null;
        if (wrapper) {
            indicator = document.createElement('div');
            indicator.className = 'animation-indicator';
            indicator.textContent = 'Resolving...';
            wrapper.appendChild(indicator);
        }

        try {
            // Build starting positions from first event for each actor
            const startPositions = {};
            events.forEach(e => {
                if (!startPositions[e.actor_id]) {
                    // Use old_x/old_y from first event as starting position
                    startPositions[e.actor_id] = {
                        x: e.old_x ?? e.new_x,
                        y: e.old_y ?? e.new_y
                    };
                }
            });

            // Set participants to starting positions.
            // If SVG already exists, update in-place (no flicker).
            // Otherwise do a full render (first load after page refresh).
            const animatedMapData = Object.assign({}, mapData);
            animatedMapData.participants = mapData.participants.map(p => {
                if (startPositions[p.id]) {
                    return Object.assign({}, p, { hex_x: startPositions[p.id].x, hex_y: startPositions[p.id].y });
                }
                return p;
            });
            animatedMapData.monsters = (mapData.monsters || []).map(m => {
                if (startPositions[m.id]) {
                    return Object.assign({}, m, { hex_x: startPositions[m.id].x, hex_y: startPositions[m.id].y });
                }
                return m;
            });
            const existingSvg = document.querySelector('.battle-map-svg');
            if (existingSvg) {
                updateParticipantsOnly(animatedMapData);
            } else {
                await renderBattleMap(animatedMapData);
            }
            // Let browser paint start positions before animation begins
            await new Promise(r => setTimeout(r, 50));

            // Calculate timing: distribute over 4 seconds
            const SEGMENT_DURATION = ANIMATION_DURATION / 100;

            // Group events by segment
            const eventsBySegment = {};
            events.forEach(e => {
                if (!eventsBySegment[e.segment]) eventsBySegment[e.segment] = [];
                eventsBySegment[e.segment].push(e);
            });

            // Get sorted segments
            const segments = Object.keys(eventsBySegment).map(Number).sort((a, b) => a - b);

            // Process each segment's events
            let lastSegment = 0;
            for (const segment of segments) {
                // Wait for time since last segment
                const delay = Math.max((segment - lastSegment) * SEGMENT_DURATION, 400);
                if (delay > 0) {
                    await new Promise(r => setTimeout(r, delay));
                }
                lastSegment = segment;

                // Animate all movements at this segment
                for (const event of eventsBySegment[segment]) {
                    animateParticipantStep(event, mapData);
                }
            }

            // Wait for final animations to complete
            await new Promise(r => setTimeout(r, 300));

            // Sync to canonical server state immediately after animation.
            updateParticipantsOnly(mapData);
            currentMapData = mapData;

            // Update hashes so the next poll doesn't trigger a redundant re-render
            lastMapStructureHash = JSON.stringify({
                arena_width: mapData.arena_width, arena_height: mapData.arena_height,
                background_url: mapData.background_url,
                background_image_width: mapData.background_image_width,
                background_image_height: mapData.background_image_height,
                hexes: mapData.hexes, fight_id: mapData.fight_id
            });
            const pv = (mapData.participants || []).map(p => ({
                id: p.id, x: p.hex_x, y: p.hex_y, hp: p.current_hp,
                ko: p.is_knocked_out, rel: p.relationship
            }));
            const mv = (mapData.monsters || []).map(m => ({
                id: m.id, x: m.hex_x, y: m.hex_y, hp: m.current_hp, mhp: m.max_hp
            }));
            lastParticipantHash = JSON.stringify({ p: pv, m: mv });
            // Also update the outer hash so the next poll doesn't re-trigger rendering
            const animHashData = Object.assign({}, mapData);
            delete animHashData.timestamp;
            lastBattleMapHash = JSON.stringify(animHashData);

            console.log('[BattleMap] Animation complete');
        } finally {
            if (indicator) indicator.remove();
            animationInProgress = false;
        }
    }

    // Animate a single movement step
    // Directly updates element positions (cx/cy/x/y) each frame instead of using
    // group translate(), which breaks clip-path rendering (the clip circle in defs
    // doesn't move with the translated group, so the portrait gets clipped away).
    function animateParticipantStep(event, mapData) {
        // Try participant marker first, then monster marker
        let marker = document.querySelector(`[data-participant-id="${event.actor_id}"]`);
        if (!marker) {
            marker = document.querySelector(`[data-monster-id="${event.actor_id}"]`);
        }
        if (!marker) {
            console.warn('[BattleMap] No marker found for participant or monster', event.actor_id);
            return;
        }

        const hexSize = mapData._hexSize || (mapData.hex_scale / 2);
        const hexHeight = mapData._hexHeight || (hexSize * Math.sqrt(3));
        _battleMapTotalRows = mapData.arena_height;

        const { px, py } = hexToPixel(event.new_x, event.new_y, hexSize, hexHeight);

        const firstCircle = marker.querySelector('circle');
        if (!firstCircle) return;

        const startCx = parseFloat(firstCircle.getAttribute('cx'));
        const startCy = parseFloat(firstCircle.getAttribute('cy'));
        console.log('[BattleMap] Step', event.actor_name, 'dx', (px-startCx).toFixed(0), 'dy', (py-startCy).toFixed(0));
        const dx = px - startCx;
        const dy = py - startCy;

        // Snapshot starting positions for all elements we need to move
        const animTargets = [];
        marker.querySelectorAll('circle, image, text, rect').forEach(el => {
            animTargets.push({
                el,
                cx: el.hasAttribute('cx') ? parseFloat(el.getAttribute('cx')) : null,
                cy: el.hasAttribute('cy') ? parseFloat(el.getAttribute('cy')) : null,
                x: el.hasAttribute('x') ? parseFloat(el.getAttribute('x')) : null,
                y: el.hasAttribute('y') ? parseFloat(el.getAttribute('y')) : null
            });
        });

        // Find and include all clip-path circles (live in defs, not in marker)
        const seenClipIds = new Set();
        marker.querySelectorAll('[clip-path]').forEach(clippedEl => {
            const clipAttr = clippedEl.getAttribute('clip-path');
            const idMatch = clipAttr && clipAttr.match(/url\(#([^)]+)\)/);
            if (idMatch && !seenClipIds.has(idMatch[1])) {
                seenClipIds.add(idMatch[1]);
                const clipPathEl = document.getElementById(idMatch[1]);
                if (clipPathEl) {
                    clipPathEl.querySelectorAll('circle').forEach(el => {
                        animTargets.push({
                            el,
                            cx: el.hasAttribute('cx') ? parseFloat(el.getAttribute('cx')) : null,
                            cy: el.hasAttribute('cy') ? parseFloat(el.getAttribute('cy')) : null,
                            x: null, y: null
                        });
                    });
                }
            }
        });

        const duration = 350;
        const startTime = performance.now();

        function step(now) {
            const elapsed = now - startTime;
            const t = Math.min(elapsed / duration, 1);
            const ease = 1 - Math.pow(1 - t, 3); // ease-out cubic

            const offsetX = dx * ease;
            const offsetY = dy * ease;

            animTargets.forEach(({ el, cx, cy, x, y }) => {
                if (cx !== null) el.setAttribute('cx', cx + offsetX);
                if (cy !== null) el.setAttribute('cy', cy + offsetY);
                if (x !== null) el.setAttribute('x', x + offsetX);
                if (y !== null) el.setAttribute('y', y + offsetY);
            });

            if (t < 1) {
                requestAnimationFrame(step);
            }
        }

        requestAnimationFrame(step);
    }

    // Main render function
    // NOTE: For async battle map generation, the structure will be:
    // <div id="battle-map-container">
    //   <div id="battle-map-loading" class="hidden">
    //     <svg id="hex-grid-wireframe"></svg>
    //     <div class="generation-overlay">
    //       <div class="progress-container">
    //         <div class="progress-bar">
    //           <div id="generation-progress-bar"></div>
    //         </div>
    //         <div id="generation-step">Starting generation...</div>
    //         <div id="generation-percentage">0%</div>
    //       </div>
    //     </div>
    //   </div>
    //   <div id="battle-map-actual">[map SVG goes here]</div>
    // </div>
    // Lightweight update: replace only participant/monster SVG markers without rebuilding the map.
    // Called when hexes/background haven't changed — avoids compositor flicker.
    function updateParticipantsOnly(mapData) {
        const container = document.getElementById('lobserve');
        if (!container) return;

        const svg = container.querySelector('.battle-map-svg');
        if (!svg) {
            // No SVG yet — fall through to a full render on next cycle
            lastMapStructureHash = null;
        lastParticipantHash = null;
            return;
        }

        const hexSize = mapData._hexSize || (mapData.hex_scale / 2);
        const hexHeight = mapData._hexHeight || (hexSize * Math.sqrt(3));

        // Remove old participant and monster markers
        svg.querySelectorAll('.character-marker, .monster-marker').forEach(el => el.remove());

        // Remove stale clip paths added by participants/monsters (charClip*, monsterClip*)
        const defs = svg.querySelector('defs');
        if (defs) {
            defs.querySelectorAll('clipPath[id^="charClip"], clipPath[id^="monsterClip"]').forEach(el => el.remove());
        }

        // Re-render monsters and participants using the shared render functions
        const tooltip = container._battleMapTooltip || null;
        if (mapData.monsters && mapData.monsters.length > 0) {
            mapData.monsters.forEach((monster, idx) => {
                renderMonster(svg, defs, monster, hexSize, hexHeight, '#FFFFFF', idx, tooltip);
            });
        }
        mapData.participants.forEach((participant, idx) => {
            renderParticipant(svg, defs, participant, hexSize, hexHeight, '#FFFFFF', idx, tooltip);
        });

        // Keep compositor alive — just update participant-driven effects if any
        if (window._battleMapCompositor) {
            window._battleMapCompositor.updateParticipants && window._battleMapCompositor.updateParticipants(mapData);
        }
    }

    async function renderBattleMap(mapData) {
        const container = document.getElementById('lobserve');
        if (!container) return;

        // Clean up old tooltip if exists (prevent memory leak)
        if (container._battleMapTooltip && container._battleMapTooltip.destroy) {
            container._battleMapTooltip.destroy();
            container._battleMapTooltip = null;
        }

        // Save scroll position from existing scroll container before clearing
        const existingScroll = container.querySelector('.battle-map-scroll-container');
        const savedScrollLeft = existingScroll ? existingScroll.scrollLeft : null;
        const savedScrollTop = existingScroll ? existingScroll.scrollTop : null;
        // Preserve zoom across re-renders (but not across new fights)
        const savedZoom = battleMapZoom;

        // Preserve delve HUD element, suspend it during combat
        const delveHud = container.querySelector('#delve-hud');
        container.innerHTML = '';
        if (delveHud) container.appendChild(delveHud);
        if (inDelve) suspendDelveHud();
        // Clear media sync classes that conflict with battle map sizing
        container.classList.remove('media-active', 'media-size-small', 'media-size-large', 'delve-map-active');
        container.classList.add('battle-map-active', 'visible');
        container.style.display = '';

        // Create toolbar (zoom controls left, dismiss right)
        const toolbar = document.createElement('div');
        toolbar.className = 'battle-map-toolbar';

        const toolbarLeft = document.createElement('div');
        toolbarLeft.className = 'bm-toolbar-left';

        const zoomOutBtn = document.createElement('button');
        zoomOutBtn.className = 'bm-toolbar-btn';
        zoomOutBtn.innerHTML = '−';
        zoomOutBtn.title = 'Zoom out';

        const zoomLabel = document.createElement('span');
        zoomLabel.className = 'bm-zoom-label';
        zoomLabel.textContent = Math.round(savedZoom * 100) + '%';

        const zoomInBtn = document.createElement('button');
        zoomInBtn.className = 'bm-toolbar-btn';
        zoomInBtn.innerHTML = '+';
        zoomInBtn.title = 'Zoom in';

        toolbarLeft.appendChild(zoomOutBtn);
        toolbarLeft.appendChild(zoomLabel);
        toolbarLeft.appendChild(zoomInBtn);
        toolbar.appendChild(toolbarLeft);

        const dismissBtn = document.createElement('button');
        dismissBtn.className = 'bm-toolbar-dismiss';
        dismissBtn.innerHTML = '&times;';
        dismissBtn.title = 'Hide battle map';
        dismissBtn.onclick = dismissBattleMap;
        toolbar.appendChild(dismissBtn);

        container.appendChild(toolbar);

        // Create wrapper
        const wrapper = document.createElement('div');
        wrapper.className = 'battle-map-wrapper';

        // Create scroll container for drag-to-pan
        const scrollContainer = document.createElement('div');
        scrollContainer.className = 'battle-map-scroll-container';

        // Determine effects quality before SVG creation (needed for skipBackground decision)
        var effectsQuality = (currentSettings && currentSettings.battleMapEffects) || 'high';
        // Skip SVG background rect when WebGL canvas will render the image with color grading
        var hasWebGLBackground = !!(
          mapData.background_url &&
          effectsQuality !== 'off' &&
          typeof BattleMapCompositor !== 'undefined'
        );

        // Create SVG and add to scroll container (now async)
        try {
            const svg = await createBattleMapSVG(mapData, container, { skipBackground: hasWebGLBackground });
            scrollContainer.appendChild(svg);
            wrapper.appendChild(scrollContainer);
            container.appendChild(wrapper);

            ensureHexSizing(mapData);
            var effectsLayout = mapData._layout;
            var effectsSvgWidth = effectsLayout.viewBoxW;
            var effectsSvgHeight = effectsLayout.viewBoxH;
            if (window._battleMapCompositor) {
              window._battleMapCompositor.destroy();
              window._battleMapCompositor = null;
            }
            if (typeof BattleMapCompositor !== 'undefined') {
              window._battleMapCompositor = new BattleMapCompositor(scrollContainer, { quality: effectsQuality });
              window._battleMapCompositor.init({
                mapData: mapData,
                quality: effectsQuality,
                svgWidth: effectsSvgWidth,
                svgHeight: effectsSvgHeight,
                viewBoxYOffset: effectsLayout.viewBoxY,
                hexSize: mapData._hexSize,
                hexHeight: mapData._hexHeight,
                totalRows: mapData.arena_height
              });
              // Backward-compatible handles for existing runtime hooks
              window._battleMapEffects = window._battleMapCompositor.effects;
              window._battleMapParticles = window._battleMapCompositor.particles;
            } else {
              window._battleMapEffects = null;
              window._battleMapParticles = null;
            }

            // Store base SVG dimensions for zoom calculations
            const baseSvgWidth = parseFloat(svg.getAttribute('width'));
            const baseSvgHeight = parseFloat(svg.getAttribute('height'));
            container._battleMapBaseDims = { w: baseSvgWidth, h: baseSvgHeight };

            // Apply zoom function
            function applyZoom(newZoom, centerX, centerY) {
                newZoom = Math.max(BATTLE_MAP_ZOOM_MIN, Math.min(BATTLE_MAP_ZOOM_MAX, newZoom));
                const oldZoom = battleMapZoom;
                battleMapZoom = newZoom;
                zoomLabel.textContent = Math.round(newZoom * 100) + '%';

                svg.setAttribute('width', baseSvgWidth * newZoom);
                svg.setAttribute('height', baseSvgHeight * newZoom);

                if (window._battleMapCompositor) {
                  window._battleMapCompositor.updateTransform(newZoom);
                } else {
                  if (window._battleMapEffects) {
                    window._battleMapEffects.updateTransform(newZoom);
                  }
                  if (window._battleMapParticles) {
                    window._battleMapParticles.updateTransform(newZoom);
                  }
                }

                // Adjust scroll to keep the zoom center point stable
                if (centerX !== undefined && centerY !== undefined) {
                    const ratio = newZoom / oldZoom;
                    scrollContainer.scrollLeft = centerX * ratio - (centerX - scrollContainer.scrollLeft);
                    scrollContainer.scrollTop = centerY * ratio - (centerY - scrollContainer.scrollTop);
                }
            }

            // Apply saved zoom
            applyZoom(savedZoom);

            // Zoom button handlers
            zoomInBtn.onclick = () => {
                const cx = scrollContainer.scrollLeft + scrollContainer.clientWidth / 2;
                const cy = scrollContainer.scrollTop + scrollContainer.clientHeight / 2;
                applyZoom(battleMapZoom + BATTLE_MAP_ZOOM_STEP, cx, cy);
            };
            zoomOutBtn.onclick = () => {
                const cx = scrollContainer.scrollLeft + scrollContainer.clientWidth / 2;
                const cy = scrollContainer.scrollTop + scrollContainer.clientHeight / 2;
                applyZoom(battleMapZoom - BATTLE_MAP_ZOOM_STEP, cx, cy);
            };

            // Mouse wheel zoom
            scrollContainer.addEventListener('wheel', (e) => {
                e.preventDefault();
                const delta = e.deltaY > 0 ? -BATTLE_MAP_ZOOM_STEP : BATTLE_MAP_ZOOM_STEP;
                const rect = scrollContainer.getBoundingClientRect();
                const cx = e.clientX - rect.left + scrollContainer.scrollLeft;
                const cy = e.clientY - rect.top + scrollContainer.scrollTop;
                applyZoom(battleMapZoom + delta, cx, cy);
            }, { passive: false });

            // Setup drag-to-pan
            setupBattleMapDrag(scrollContainer);

            // Restore scroll position or auto-scroll to player on first render
            requestAnimationFrame(() => {
                if (savedScrollLeft !== null && savedScrollTop !== null) {
                    // Restore previous scroll position (adjusted for zoom)
                    scrollContainer.scrollLeft = savedScrollLeft;
                    scrollContainer.scrollTop = savedScrollTop;
                } else {
                    // First render: auto-scroll to center on current player
                    const selfMarker = svg.querySelector('.character-marker[data-relationship="self"]');
                    if (selfMarker) {
                        const circle = selfMarker.querySelector('circle');
                        if (circle) {
                            const px = parseFloat(circle.getAttribute('cx')) * battleMapZoom;
                            const py = parseFloat(circle.getAttribute('cy')) * battleMapZoom;
                            scrollContainer.scrollTo(
                                Math.max(0, px - scrollContainer.clientWidth / 2),
                                Math.max(0, py - scrollContainer.clientHeight / 2)
                            );
                        }
                    }
                }
            });

            // Setup tooltips and click interactions
            setupBattleMapInteractions(container, mapData);

            // Adjust message window to make room for the battle map
            adjustLobserveHeight();
        } catch (err) {
            console.error('[BattleMap] Render failed:', err);
            container.innerHTML = '<div class="alert alert-danger">Failed to render battle map. Check console for details.</div>';
        }
    }

    // Create the SVG element
    async function createBattleMapSVG(mapData, container, opts) {
        opts = opts || {};

        // Set totalRows for Y-flip (north at top)
        _battleMapTotalRows = mapData.arena_height;
        _battleMapHasBackground = !!mapData.background_url;

        // Use shared layout calculation (identical to template editor)
        ensureHexSizing(mapData);
        const layout = mapData._layout;
        const hexSize = mapData._hexSize;
        const hexHeight = mapData._hexHeight;

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('viewBox', `${layout.viewBoxX} ${layout.viewBoxY} ${layout.viewBoxW} ${layout.viewBoxH}`);
        svg.setAttribute('width', layout.displayWidth);
        svg.setAttribute('height', layout.displayHeight);
        svg.setAttribute('class', 'battle-map-svg');

        // Add defs for patterns and clip paths
        const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
        svg.appendChild(defs);

        // Background — skip when WebGL canvas handles the image (opts.skipBackground)
        if (mapData.background_url && !opts.skipBackground) {
            const bgImage = document.createElementNS('http://www.w3.org/2000/svg', 'image');
            bgImage.setAttribute('href', mapData.background_url);
            bgImage.setAttribute('x', '0');
            bgImage.setAttribute('y', '0');
            bgImage.setAttribute('width', mapData.background_image_width || layout.viewBoxW);
            bgImage.setAttribute('height', mapData.background_image_height || layout.viewBoxH);
            bgImage.setAttribute('preserveAspectRatio', 'none');
            svg.appendChild(bgImage);
        }

        // Calculate outline color from background image
        let outlineColor = '#FFFFFF'; // Default to white
        if (mapData.background_url) {
            try {
                outlineColor = await BattleMapRenderer.OutlineColorCalculator.determineOutlineColor(mapData.background_url);
                console.log('[BattleMap] Calculated outline color:', outlineColor);
            } catch (error) {
                console.warn('[BattleMap] Failed to calculate outline color, using white:', error);
            }
        }

        // Create tooltip instance (singleton for all hexes)
        const tooltip = new BattleMapRenderer.HexTooltip();

        // Store tooltip reference on container for cleanup
        if (container) {
            container._battleMapTooltip = tooltip;
        }

        // Render hexes with new component-based architecture
        mapData.hexes.forEach(hex => {
            renderHex(svg, defs, hex, hexSize, hexHeight, outlineColor, tooltip, null, _battleMapHasBackground);
        });

        // Render monsters (before participants so participants appear on top)
        if (mapData.monsters && mapData.monsters.length > 0) {
            mapData.monsters.forEach((monster, idx) => {
                renderMonster(svg, defs, monster, hexSize, hexHeight, outlineColor, idx, tooltip);
            });
        }

        // Render participants
        mapData.participants.forEach((participant, idx) => {
            renderParticipant(svg, defs, participant, hexSize, hexHeight, outlineColor, idx, tooltip);
        });

        return svg;
    }

    // Hex math & rendering from shared module
    const _hexToPixel = BattleMapRenderer.hexToPixel;
    const hexPoints  = BattleMapRenderer.hexPoints;
    const _renderHex  = BattleMapRenderer.renderHex;

    // Battle map totalRows for Y-flip (set per-render, used by wrappers)
    let _battleMapTotalRows = null;
    let _battleMapHasBackground = false;
    function hexToPixel(x, y, hexSize, hexHeight) {
        return _hexToPixel(x, y, hexSize, hexHeight, _battleMapTotalRows);
    }
    function renderHex(svg, defs, hex, hexSize, hexHeight, outlineColor, tooltip) {
        return _renderHex(svg, defs, hex, hexSize, hexHeight, outlineColor, tooltip, _battleMapTotalRows, _battleMapHasBackground);
    }

    // Render wetness overlay (water drops) on character portrait
    function renderWetOverlay(group, defs, px, py, radius, wetnessLevel, clipId) {
        if (!wetnessLevel || wetnessLevel <= 0) return;

        // Opacity scales with wetness (0.3 at low, 0.7 at soaked)
        const opacity = Math.min(0.3 + (wetnessLevel / 100) * 0.4, 0.7);

        const overlay = document.createElementNS('http://www.w3.org/2000/svg', 'image');
        overlay.setAttribute('href', '/images/water_drops.png');
        overlay.setAttribute('x', px - radius);
        overlay.setAttribute('y', py - radius);
        overlay.setAttribute('width', radius * 2);
        overlay.setAttribute('height', radius * 2);
        overlay.setAttribute('opacity', opacity);
        if (clipId) {
            overlay.setAttribute('clip-path', `url(#${clipId})`);
        }
        overlay.setAttribute('preserveAspectRatio', 'xMidYMid slice');
        overlay.classList.add('portrait-overlay', 'wet-overlay');
        group.appendChild(overlay);
    }

    // Render blood spatter overlay based on injury level
    function renderBloodOverlay(group, defs, px, py, radius, injuryLevel, clipId) {
        if (!injuryLevel || injuryLevel <= 0) return;

        // Select overlay based on injury severity
        let imageSrc;
        let opacity;

        if (injuryLevel <= 2) {
            imageSrc = '/images/blood_light.png';
            opacity = 0.4;
        } else if (injuryLevel <= 4) {
            imageSrc = '/images/blood_medium.png';
            opacity = 0.6;
        } else {
            imageSrc = '/images/blood_heavy.png';
            opacity = 0.8;
        }

        const overlay = document.createElementNS('http://www.w3.org/2000/svg', 'image');
        overlay.setAttribute('href', imageSrc);
        overlay.setAttribute('x', px - radius);
        overlay.setAttribute('y', py - radius);
        overlay.setAttribute('width', radius * 2);
        overlay.setAttribute('height', radius * 2);
        overlay.setAttribute('opacity', opacity);
        if (clipId) {
            overlay.setAttribute('clip-path', `url(#${clipId})`);
        }
        overlay.setAttribute('preserveAspectRatio', 'xMidYMid slice');
        overlay.classList.add('portrait-overlay', 'blood-overlay');
        group.appendChild(overlay);
    }

    // Render a participant (character)
    function renderParticipant(svg, defs, participant, hexSize, hexHeight, borderColor, idx, tooltip) {
        const { px, py } = hexToPixel(participant.hex_x, participant.hex_y, hexSize, hexHeight);
        const radius = hexSize * 0.42;

        const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        group.setAttribute('class', 'character-marker');
        group.setAttribute('data-participant-id', participant.id);
        group.setAttribute('data-character-name', participant.name);
        group.setAttribute('data-character-intro', participant.intro || '');
        group.setAttribute('data-relationship', participant.relationship);

        // Transparent hit-area to capture mouse events before hex below
        const hitArea = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        hitArea.setAttribute('cx', px);
        hitArea.setAttribute('cy', py);
        hitArea.setAttribute('r', radius + 6);
        hitArea.setAttribute('fill', 'transparent');
        hitArea.setAttribute('stroke', 'none');
        group.appendChild(hitArea);

        // Relationship ring
        const ringColor = RELATIONSHIP_COLORS[participant.relationship] || RELATIONSHIP_COLORS.neutral;
        const ringWidth = participant.is_current_character ? 4 : 2;

        const ring = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        ring.setAttribute('cx', px);
        ring.setAttribute('cy', py);
        ring.setAttribute('r', radius + ringWidth);
        ring.setAttribute('fill', 'none');
        ring.setAttribute('stroke', ringColor);
        ring.setAttribute('stroke-width', ringWidth);
        ring.setAttribute('class', `character-ring character-ring-${participant.relationship}`);
        group.appendChild(ring);

        // Knocked out overlay
        if (participant.is_knocked_out) {
            const koCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            koCircle.setAttribute('cx', px);
            koCircle.setAttribute('cy', py);
            koCircle.setAttribute('r', radius);
            koCircle.setAttribute('fill', 'rgba(0, 0, 0, 0.6)');
            group.appendChild(koCircle);

            const koText = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            koText.setAttribute('x', px);
            koText.setAttribute('y', py + 4);
            koText.setAttribute('text-anchor', 'middle');
            koText.setAttribute('fill', '#ff4444');
            koText.setAttribute('font-size', `${radius * 0.8}px`);
            koText.setAttribute('font-weight', 'bold');
            koText.textContent = 'KO';
            group.appendChild(koText);
        } else if (participant.profile_pic_url) {
            // Profile picture
            const clipId = `charClip${idx}`;
            const clipPath = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
            clipPath.setAttribute('id', clipId);
            const clipCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            clipCircle.setAttribute('cx', px);
            clipCircle.setAttribute('cy', py);
            clipCircle.setAttribute('r', radius);
            clipPath.appendChild(clipCircle);
            defs.appendChild(clipPath);

            const image = document.createElementNS('http://www.w3.org/2000/svg', 'image');
            image.setAttribute('href', participant.profile_pic_url);
            image.setAttribute('x', px - radius);
            image.setAttribute('y', py - radius);
            image.setAttribute('width', radius * 2);
            image.setAttribute('height', radius * 2);
            image.setAttribute('clip-path', `url(#${clipId})`);
            image.setAttribute('preserveAspectRatio', 'xMidYMid slice');
            group.appendChild(image);

            // Add status overlays (wetness and injury)
            renderWetOverlay(group, defs, px, py, radius, participant.wetness_level, clipId);
            renderBloodOverlay(group, defs, px, py, radius, participant.injury_level, clipId);
        } else {
            // Name abbreviation (first letter large, others small)
            const shortName = participant.short_name || 'UNK';
            const sigColor = participant.signature_color;
            const bgCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            bgCircle.setAttribute('cx', px);
            bgCircle.setAttribute('cy', py);
            bgCircle.setAttribute('r', radius);
            bgCircle.setAttribute('fill', sigColor || '#2d3748');
            group.appendChild(bgCircle);

            // Pick text color based on background luminance for readability
            let textColor = '#e2e8f0';
            let subTextColor = '#a0aec0';
            if (sigColor) {
                const r = parseInt(sigColor.slice(1, 3), 16);
                const g = parseInt(sigColor.slice(3, 5), 16);
                const b = parseInt(sigColor.slice(5, 7), 16);
                const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
                if (luminance > 0.5) {
                    textColor = '#1a202c';
                    subTextColor = '#2d3748';
                }
            }

            // Large first letter
            const firstLetter = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            firstLetter.setAttribute('x', px - radius * 0.25);
            firstLetter.setAttribute('y', py + radius * 0.2);
            firstLetter.setAttribute('text-anchor', 'middle');
            firstLetter.setAttribute('fill', textColor);
            firstLetter.setAttribute('font-size', `${radius * 0.9}px`);
            firstLetter.setAttribute('font-weight', 'bold');
            firstLetter.textContent = shortName[0];
            group.appendChild(firstLetter);

            // Smaller remaining letters
            if (shortName.length > 1) {
                const restLetters = document.createElementNS('http://www.w3.org/2000/svg', 'text');
                restLetters.setAttribute('x', px + radius * 0.35);
                restLetters.setAttribute('y', py + radius * 0.15);
                restLetters.setAttribute('text-anchor', 'middle');
                restLetters.setAttribute('fill', subTextColor);
                restLetters.setAttribute('font-size', `${radius * 0.45}px`);
                restLetters.textContent = shortName.substring(1);
                group.appendChild(restLetters);
            }

            // Add status overlays for text fallback (clip to circle to prevent drag artifacts during animation)
            const textClipId = `charTextClip${idx}`;
            const textClipPath = document.createElementNS('http://www.w3.org/2000/svg', 'clipPath');
            textClipPath.setAttribute('id', textClipId);
            const textClipCircle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            textClipCircle.setAttribute('cx', px);
            textClipCircle.setAttribute('cy', py);
            textClipCircle.setAttribute('r', radius);
            textClipPath.appendChild(textClipCircle);
            defs.appendChild(textClipPath);
            renderWetOverlay(group, defs, px, py, radius, participant.wetness_level, textClipId);
            renderBloodOverlay(group, defs, px, py, radius, participant.injury_level, textClipId);
        }

        // Character tooltip on hover
        if (tooltip) {
            group.addEventListener('mouseenter', function(e) {
                e.stopPropagation();
                let content = `<strong>${participant.name}</strong>`;
                if (participant.relationship) {
                    content += ` <em>(${participant.relationship})</em>`;
                }
                if (participant.intro) {
                    content += `<br>${participant.intro}`;
                }
                if (participant.is_knocked_out) {
                    content += `<br><span style="color:#ff4444;font-weight:bold">Knocked Out</span>`;
                }
                tooltip.show({ x: e.clientX + 12, y: e.clientY + 12, content: content });
            });
            group.addEventListener('mousemove', function(e) {
                e.stopPropagation();
                tooltip.updatePosition(e.clientX + 12, e.clientY + 12);
            });
            group.addEventListener('mouseleave', function() {
                tooltip.hide();
            });
        }

        svg.appendChild(group);
    }

    // Monster type colors for fallback rendering
    const MONSTER_COLORS = {
        colossus: '#8b4513',   // Saddle brown
        dragon: '#dc143c',     // Crimson
        behemoth: '#2f4f4f',   // Dark slate gray
        titan: '#4682b4',      // Steel blue
        golem: '#696969',      // Dim gray
        hydra: '#228b22',      // Forest green
        serpent: '#9932cc'     // Dark orchid
    };

    // Facing direction to rotation angle (monster images face EAST by default)
    // Angles negated from original to account for Y-flip (north at top)
    const FACING_TO_ROTATION = {
        0: 0,      // E - no rotation
        1: 60,     // NE (was -60)
        2: 120,    // NW (was -120)
        3: 180,    // W  (unchanged, 180 = -180)
        4: -120,   // SW (was 120)
        5: -60     // SE (was 60)
    };

    // Render a multi-hex monster
    function renderMonster(svg, defs, monster, hexSize, hexHeight, borderColor, idx, tooltip) {
        const { px: centerPx, py: centerPy } = hexToPixel(monster.center_hex_x, monster.center_hex_y, hexSize, hexHeight);

        // Calculate bounding box from hex dimensions
        const monsterWidthPx = monster.hex_width * hexSize * 1.5;
        const monsterHeightPx = monster.hex_height * hexHeight;

        // Get rotation angle from facing direction
        const rotation = FACING_TO_ROTATION[monster.facing_direction] || 0;

        // Create monster group
        const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        group.setAttribute('class', 'monster-marker');
        group.setAttribute('data-monster-id', monster.id);
        group.setAttribute('data-monster-name', monster.name);

        // Apply rotation around center point
        if (rotation !== 0) {
            group.setAttribute('transform', `rotate(${rotation}, ${centerPx}, ${centerPy})`);
        }

        // Render monster image if available
        if (monster.image_url) {
            const image = document.createElementNS('http://www.w3.org/2000/svg', 'image');
            image.setAttribute('href', monster.image_url);
            image.setAttribute('x', centerPx - monsterWidthPx / 2);
            image.setAttribute('y', centerPy - monsterHeightPx / 2);
            image.setAttribute('width', monsterWidthPx);
            image.setAttribute('height', monsterHeightPx);
            image.setAttribute('preserveAspectRatio', 'xMidYMid meet');
            image.setAttribute('class', 'monster-image');

            // Apply opacity based on status
            if (monster.status === 'defeated') {
                image.setAttribute('opacity', '0.4');
            } else if (monster.status === 'collapsed') {
                image.setAttribute('opacity', '0.7');
            }

            group.appendChild(image);
        } else {
            // Fallback: render colored hexes
            renderMonsterFallback(group, monster, hexSize, hexHeight);
        }

        // Render segment hitboxes (invisible but interactive)
        monster.segments.forEach((segment, segIdx) => {
            renderSegmentHitbox(group, segment, hexSize, hexHeight, monster, segIdx, tooltip);
        });

        // HP bar removed per user request
        // renderMonsterHPBar(group, monster, centerPx, centerPy, monsterWidthPx, monsterHeightPx, hexSize);

        svg.appendChild(group);
    }

    // Fallback rendering when no monster image
    function renderMonsterFallback(group, monster, hexSize, hexHeight) {
        const monsterColor = MONSTER_COLORS[monster.monster_type] || '#555555';

        monster.occupied_hexes.forEach(([hx, hy]) => {
            const { px, py } = hexToPixel(hx, hy, hexSize, hexHeight);

            const hex = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
            hex.setAttribute('points', hexPoints(px, py, hexSize * 0.9));
            hex.setAttribute('fill', monsterColor);
            hex.setAttribute('fill-opacity', monster.status === 'defeated' ? '0.3' : '0.6');
            hex.setAttribute('stroke', '#000');
            hex.setAttribute('stroke-width', '2');
            hex.setAttribute('class', 'monster-hex');
            group.appendChild(hex);
        });

        // Add monster name in center
        const { px: centerPx, py: centerPy } = hexToPixel(monster.center_hex_x, monster.center_hex_y, hexSize, hexHeight);
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', centerPx);
        label.setAttribute('y', centerPy);
        label.setAttribute('text-anchor', 'middle');
        label.setAttribute('dominant-baseline', 'middle');
        label.setAttribute('font-size', `${hexSize * 0.4}px`);
        label.setAttribute('font-weight', 'bold');
        label.setAttribute('fill', '#fff');
        label.setAttribute('class', 'monster-fallback-name');
        label.setAttribute('style', 'text-shadow: 1px 1px 2px black;');
        label.textContent = monster.name.substring(0, 8);
        group.appendChild(label);
    }

    // Render invisible hitbox for segment tooltip detection
    function renderSegmentHitbox(group, segment, hexSize, hexHeight, monster, idx, tooltip) {
        const { px, py } = hexToPixel(segment.hex_x, segment.hex_y, hexSize, hexHeight);

        // Create hitbox polygon (hex shape)
        const hitbox = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
        hitbox.setAttribute('points', hexPoints(px, py, hexSize * 0.9));
        hitbox.setAttribute('class', `monster-segment-hitbox segment-${segment.status}`);
        hitbox.setAttribute('data-segment-id', segment.id);
        hitbox.setAttribute('data-segment-name', segment.name);
        hitbox.setAttribute('data-segment-type', segment.segment_type);
        hitbox.setAttribute('data-segment-hp', segment.hp_percent);
        hitbox.setAttribute('data-segment-status', segment.status);
        hitbox.setAttribute('data-weak-point', segment.is_weak_point ? 'true' : 'false');
        hitbox.setAttribute('data-monster-id', monster.id);

        // Make mostly transparent but catch mouse events
        hitbox.setAttribute('fill', 'rgba(0,0,0,0.01)');
        hitbox.setAttribute('stroke', 'none');

        // Segment tooltip on hover
        if (tooltip) {
            hitbox.addEventListener('mouseenter', function(e) {
                e.stopPropagation();
                let content = `<strong>${monster.name}</strong> - ${segment.name}`;
                content += `<br>Type: ${segment.segment_type}`;
                if (segment.is_weak_point) {
                    content += `<br><span style="color:#ff4444;font-weight:bold">Weak Point</span>`;
                }
                if (segment.status !== 'intact') {
                    content += `<br>Status: ${segment.status}`;
                }
                content += `<br>HP: ${segment.hp_percent}%`;
                tooltip.show({ x: e.clientX + 12, y: e.clientY + 12, content: content });
            });
            hitbox.addEventListener('mousemove', function(e) {
                e.stopPropagation();
                tooltip.updatePosition(e.clientX + 12, e.clientY + 12);
            });
            hitbox.addEventListener('mouseleave', function() {
                tooltip.hide();
            });
        }

        group.appendChild(hitbox);

        // Visual indicator for weak points
        if (segment.is_weak_point && segment.status !== 'destroyed') {
            const indicator = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
            indicator.setAttribute('cx', px);
            indicator.setAttribute('cy', py);
            indicator.setAttribute('r', hexSize * 0.15);
            indicator.setAttribute('fill', '#ff4444');
            indicator.setAttribute('class', 'weak-point-indicator');
            group.appendChild(indicator);
        }

        // Visual indicator for damaged segments
        if (segment.status === 'damaged' || segment.status === 'broken') {
            const damageIndicator = document.createElementNS('http://www.w3.org/2000/svg', 'text');
            damageIndicator.setAttribute('x', px);
            damageIndicator.setAttribute('y', py + hexSize * 0.1);
            damageIndicator.setAttribute('text-anchor', 'middle');
            damageIndicator.setAttribute('font-size', `${hexSize * 0.3}px`);
            damageIndicator.setAttribute('fill', segment.status === 'broken' ? '#ff4444' : '#ffaa00');
            damageIndicator.setAttribute('class', 'segment-damage-indicator');
            damageIndicator.setAttribute('pointer-events', 'none');
            damageIndicator.textContent = segment.status === 'broken' ? '!' : '*';
            group.appendChild(damageIndicator);
        }
    }

    // Render HP bar below monster
    function renderMonsterHPBar(group, monster, cx, cy, width, height, hexSize) {
        const barWidth = Math.min(width * 0.8, 100);
        const barHeight = 6;
        const barY = cy + height / 2 + 10;
        const barX = cx - barWidth / 2;

        // Background
        const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        bg.setAttribute('x', barX);
        bg.setAttribute('y', barY);
        bg.setAttribute('width', barWidth);
        bg.setAttribute('height', barHeight);
        bg.setAttribute('fill', 'rgba(0,0,0,0.6)');
        bg.setAttribute('rx', '2');
        group.appendChild(bg);

        // HP fill
        const hpWidth = (monster.hp_percent / 100) * barWidth;
        const hpColor = monster.hp_percent > 50 ? '#28a745' :
                        monster.hp_percent > 25 ? '#ffc107' : '#dc3545';

        const hp = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        hp.setAttribute('x', barX);
        hp.setAttribute('y', barY);
        hp.setAttribute('width', hpWidth);
        hp.setAttribute('height', barHeight);
        hp.setAttribute('fill', hpColor);
        hp.setAttribute('rx', '2');
        group.appendChild(hp);

        // Name label
        const label = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        label.setAttribute('x', cx);
        label.setAttribute('y', barY - 3);
        label.setAttribute('text-anchor', 'middle');
        label.setAttribute('font-size', '10px');
        label.setAttribute('fill', '#ffffff');
        label.setAttribute('class', 'monster-name-label');
        label.setAttribute('pointer-events', 'none');
        label.setAttribute('style', 'text-shadow: 1px 1px 2px black;');
        label.textContent = monster.name;
        group.appendChild(label);
    }

    // Setup tooltips for battle map
    function setupBattleMapTooltips(container, mapData) {
        // Create or get tooltip element
        let tooltip = document.getElementById('battleMapTooltip');
        if (!tooltip) {
            tooltip = document.createElement('div');
            tooltip.id = 'battleMapTooltip';
            tooltip.className = 'battle-map-tooltip';
            document.body.appendChild(tooltip);
        }

        // Hex tooltips
        container.querySelectorAll('.hex-group').forEach(hex => {
            hex.addEventListener('mouseenter', (e) => {
                const x = hex.getAttribute('data-hex-x');
                const y = hex.getAttribute('data-hex-y');
                const type = hex.getAttribute('data-hex-type');
                const desc = hex.getAttribute('data-hex-desc');

                const hexData = mapData.hexes.find(h => h.x == x && h.y == y);
                let content = `<strong>Hex (${x}, ${y})</strong><br>${desc}`;

                if (hexData) {
                    if (hexData.has_cover) {
                        content += `<br><span class="tooltip-cover">Has cover${hexData.cover_object ? ': ' + hexData.cover_object : ''}</span>`;
                    }
                    if (hexData.elevation && hexData.elevation !== 0) {
                        content += `<br><span class="tooltip-elevation">Elevation: ${hexData.elevation > 0 ? '+' : ''}${hexData.elevation}</span>`;
                    }
                    if (hexData.hazard_type) {
                        content += `<br><span class="tooltip-hazard">Hazard: ${hexData.hazard_type}</span>`;
                    }
                    if (hexData.water_type) {
                        content += `<br><span class="tooltip-water">Water: ${hexData.water_type}</span>`;
                    }
                    if (!hexData.traversable) {
                        content += `<br><span class="tooltip-blocked">⛔ Impassable</span>`;
                    }
                }

                showBattleMapTooltip(tooltip, content, e);
            });

            hex.addEventListener('mouseleave', () => {
                tooltip.style.display = 'none';
            });
        });

        // Character tooltips
        container.querySelectorAll('.character-marker').forEach(marker => {
            marker.addEventListener('mouseenter', (e) => {
                const name = marker.getAttribute('data-character-name');
                const intro = marker.getAttribute('data-character-intro');
                const relationship = marker.getAttribute('data-relationship');

                const participant = mapData.participants.find(p => p.id == marker.getAttribute('data-participant-id'));

                let content = `<strong>${name}</strong>`;
                if (relationship && relationship !== 'neutral') {
                    const relLabels = { self: '(You)', ally: '(Ally)', enemy: '(Enemy)' };
                    content += ` <span class="tooltip-${relationship}">${relLabels[relationship] || ''}</span>`;
                }
                if (intro) {
                    content += `<br><em>${intro}</em>`;
                }
                if (participant && participant.is_knocked_out) {
                    content += `<br><span class="tooltip-ko">KNOCKED OUT</span>`;
                }

                showBattleMapTooltip(tooltip, content, e);
            });

            marker.addEventListener('mouseleave', () => {
                tooltip.style.display = 'none';
            });
        });

        // Monster segment tooltips
        container.querySelectorAll('.monster-segment-hitbox').forEach(hitbox => {
            hitbox.addEventListener('mouseenter', (e) => {
                const monsterId = hitbox.getAttribute('data-monster-id');
                const segmentName = hitbox.getAttribute('data-segment-name');
                const segmentType = hitbox.getAttribute('data-segment-type');
                const hpPercent = hitbox.getAttribute('data-segment-hp');
                const status = hitbox.getAttribute('data-segment-status');
                const isWeakPoint = hitbox.getAttribute('data-weak-point') === 'true';

                const monster = mapData.monsters?.find(m => m.id == monsterId);

                let content = `<strong>${monster?.name || 'Monster'}</strong><br>`;
                content += `<span class="tooltip-segment">${segmentName} (${segmentType})</span><br>`;
                content += `HP: ${hpPercent}% [${status}]`;

                if (isWeakPoint) {
                    content += `<br><span class="tooltip-weak-point">⚠ WEAK POINT</span>`;
                }

                if (status === 'destroyed') {
                    content += `<br><span class="tooltip-destroyed">DESTROYED</span>`;
                }

                showBattleMapTooltip(tooltip, content, e);
            });

            hitbox.addEventListener('mouseleave', () => {
                tooltip.style.display = 'none';
            });

            // Add click handler for monster segments
            hitbox.style.cursor = 'pointer';
            hitbox.addEventListener('click', (e) => {
                e.stopPropagation();

                const monsterId = parseInt(hitbox.getAttribute('data-monster-id'));
                const segmentId = parseInt(hitbox.getAttribute('data-segment-id'));
                const segmentName = hitbox.getAttribute('data-segment-name');
                const isWeakPoint = hitbox.getAttribute('data-weak-point') === 'true';

                const monster = mapData.monsters?.find(m => m.id === monsterId);
                handleMonsterSegmentClick(e, monster, segmentId, segmentName, isWeakPoint, mapData);
            });
        });
    }

    // Handle monster segment click - show attack options
    function handleMonsterSegmentClick(e, monster, segmentId, segmentName, isWeakPoint, mapData) {
        hideCombatDropdown();

        const menuItems = [];

        // Header info
        menuItems.push({
            label: `${monster.name} - ${segmentName}`,
            info: true
        });

        if (isWeakPoint) {
            menuItems.push({
                label: '⚠ WEAK POINT',
                info: true
            });
        }

        menuItems.push({ separator: true });

        // Attack segment
        menuItems.push({
            action: 'attack_monster_segment',
            value: { monster_id: monster.id, segment_id: segmentId },
            label: `Attack ${segmentName}`,
            description: 'Target this segment'
        });

        // Attack monster generally
        menuItems.push({
            action: 'attack_monster',
            value: { monster_id: monster.id },
            label: 'Attack Monster',
            description: 'Auto-target nearest segment'
        });

        // Mount option (if adjacent - simplified check)
        const selfParticipant = mapData.participants?.find(p => p.relationship === 'self');
        if (selfParticipant && !selfParticipant.is_mounted) {
            const isAdjacent = selfParticipant.adjacent_monsters?.some(m => m.id === monster.id);
            if (isAdjacent) {
                menuItems.push({ separator: true });
                menuItems.push({
                    action: 'mount',
                    value: monster.id,
                    label: `Mount ${monster.name}`,
                    description: 'Climb onto the monster'
                });
            }
        }

        showCombatDropdown(e.pageX, e.pageY, menuItems, { type: 'monster', monster, segmentId });
    }

    // Show tooltip at mouse position
    function showBattleMapTooltip(tooltip, content, event) {
        tooltip.innerHTML = content;
        tooltip.style.display = 'block';

        const rect = tooltip.getBoundingClientRect();
        let x = event.pageX + 10;
        let y = event.pageY + 10;

        // Keep tooltip on screen
        if (x + rect.width > window.innerWidth) {
            x = event.pageX - rect.width - 10;
        }
        if (y + rect.height > window.innerHeight) {
            y = event.pageY - rect.height - 10;
        }

        tooltip.style.left = x + 'px';
        tooltip.style.top = y + 'px';
    }

    // Integrate battle map checks with existing polling
    function integratesBattleMapWithPolling() {
        // Check combat status every 5 seconds
        setInterval(checkCombatStatus, 5000);
        // Initial check
        checkCombatStatus();
    }

    // Initialize battle map system
    function initBattleMap() {
        integratesBattleMapWithPolling();
    }

    // === Interactive Combat Controls ===
    // Click-based combat action selection via battle map

    // State for combat dropdown
    let combatDropdown = null;
    // currentMapData is already declared in the battle map section above

    // Create the dropdown element
    function createCombatDropdown() {
        if (combatDropdown) return combatDropdown;

        const dropdown = document.createElement('div');
        dropdown.id = 'combatActionDropdown';
        dropdown.className = 'combat-dropdown';
        dropdown.style.display = 'none';
        document.body.appendChild(dropdown);

        // Close on click elsewhere
        document.addEventListener('click', (e) => {
            if (!dropdown.contains(e.target) && !e.target.closest('.hex-group') && !e.target.closest('.character-marker')) {
                hideCombatDropdown();
            }
        });

        // Close on Escape
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') hideCombatDropdown();
        });

        combatDropdown = dropdown;
        return dropdown;
    }

    // Show dropdown at position with menu items
    function showCombatDropdown(x, y, menuItems, context) {
        const dropdown = createCombatDropdown();
        dropdown.innerHTML = buildDropdownHTML(menuItems, context);
        dropdown.style.display = 'block';

        // Position dropdown
        const rect = dropdown.getBoundingClientRect();
        let posX = x + 10;
        let posY = y + 10;

        // Keep on screen
        if (posX + rect.width > window.innerWidth) {
            posX = x - rect.width - 10;
        }
        if (posY + rect.height > window.innerHeight) {
            posY = y - rect.height - 10;
        }

        dropdown.style.left = posX + 'px';
        dropdown.style.top = posY + 'px';

        // Setup click handlers for menu items
        dropdown.querySelectorAll('.combat-dropdown-item:not(.disabled):not(.has-submenu)').forEach(item => {
            item.addEventListener('click', (e) => {
                e.stopPropagation();
                const action = item.dataset.action;
                const value = item.dataset.value;
                if (action) {
                    submitCombatAction(action, value ? JSON.parse(value) : null);
                }
            });
        });

        // Setup hover for submenus
        dropdown.querySelectorAll('.has-submenu').forEach(item => {
            item.addEventListener('mouseenter', () => {
                const submenu = item.querySelector('.combat-submenu');
                if (submenu) submenu.style.display = 'block';
            });
            item.addEventListener('mouseleave', () => {
                const submenu = item.querySelector('.combat-submenu');
                if (submenu) submenu.style.display = 'none';
            });
        });
    }

    // Build dropdown HTML
    function buildDropdownHTML(items, context) {
        let html = '';

        items.forEach(item => {
            if (item.separator) {
                html += '<div class="combat-dropdown-separator"></div>';
                return;
            }

            if (item.info) {
                html += `<div class="combat-dropdown-info">${item.label}</div>`;
                return;
            }

            const disabledClass = item.disabled ? ' disabled' : '';
            const hasSubmenu = item.submenu && item.submenu.length > 0;
            const submenuClass = hasSubmenu ? ' has-submenu' : '';

            html += `<div class="combat-dropdown-item${disabledClass}${submenuClass}"
                         data-action="${item.action || ''}"
                         data-value='${item.value ? JSON.stringify(item.value) : ''}'>`;
            html += `<span class="combat-dropdown-label">${item.label}</span>`;
            if (item.description) {
                html += `<span class="combat-dropdown-desc">${item.description}</span>`;
            }
            if (hasSubmenu) {
                html += '<span class="combat-dropdown-arrow">▶</span>';
                html += '<div class="combat-submenu">';
                html += buildDropdownHTML(item.submenu, context);
                html += '</div>';
            }
            html += '</div>';
        });

        return html;
    }

    // Hide dropdown
    function hideCombatDropdown() {
        if (combatDropdown) {
            combatDropdown.style.display = 'none';
        }
    }

    // Handle hex click - movement options
    function handleHexClick(e, hexX, hexY, hexData, mapData) {
        e.stopPropagation();
        hideCombatDropdown();

        const menuItems = [];

        // Movement options
        if (hexData && hexData.traversable !== false) {
            menuItems.push({
                action: 'move_to_hex',
                value: { hex_x: hexX, hex_y: hexY },
                label: 'Move Here',
                description: `Hex (${hexX}, ${hexY})`
            });
        } else {
            menuItems.push({
                label: 'Impassable',
                description: 'Cannot move here',
                disabled: true
            });
        }

        // Cover info
        if (hexData && hexData.has_cover) {
            menuItems.push({ separator: true });
            menuItems.push({
                label: `Has cover${hexData.cover_object ? ': ' + hexData.cover_object : ''}`,
                info: true
            });
        }

        // Elevation info
        if (hexData && hexData.elevation && hexData.elevation !== 0) {
            const sign = hexData.elevation > 0 ? '+' : '';
            menuItems.push({
                label: `Elevation: ${sign}${hexData.elevation}`,
                info: true
            });
        }

        // Hazard info
        if (hexData && hexData.hazard_type) {
            menuItems.push({
                label: `⚠️ Hazard: ${hexData.hazard_type}`,
                info: true
            });
        }

        showCombatDropdown(e.pageX, e.pageY, menuItems, { type: 'hex', hexX, hexY });
    }

    // Handle character click - attack/ability options
    function handleCharacterClick(e, participant, relationship, mapData) {
        e.stopPropagation();
        hideCombatDropdown();

        const menuItems = [];
        const selfParticipant = mapData.participants.find(p => p.relationship === 'self');

        // Enemy/neutral - attack options
        if (relationship !== 'self') {
            menuItems.push({
                action: 'attack',
                value: participant.id,
                label: `Attack ${participant.name}`,
                description: 'Set as attack target'
            });

            menuItems.push({ separator: true });

            // Movement toward/away
            menuItems.push({
                action: 'move_toward',
                value: participant.id,
                label: `Move Toward`,
                description: `Close distance to ${participant.name}`
            });

            menuItems.push({
                action: 'move_away',
                value: participant.id,
                label: `Move Away`,
                description: `Retreat from ${participant.name}`
            });

            menuItems.push({
                action: 'maintain_distance',
                value: participant.id,
                label: `Maintain 6 hex`,
                description: 'Keep optimal ranged distance'
            });
        }

        // Self options - main actions
        if (relationship === 'self') {
            menuItems.push({
                action: 'stand_still',
                value: null,
                label: 'Stand Still',
                description: 'Hold position this round'
            });

            menuItems.push({
                action: 'defend',
                value: null,
                label: 'Full Defense',
                description: 'Focus on defense, no attack'
            });

            menuItems.push({
                action: 'dodge',
                value: null,
                label: 'Dodge',
                description: '-5 to each incoming attack against you'
            });

            menuItems.push({
                action: 'sprint',
                value: null,
                label: 'Sprint',
                description: '+3 movement (7 total), no attack'
            });

            menuItems.push({
                action: 'pass',
                value: null,
                label: 'Pass',
                description: 'Take no action (fight ends if all pass)'
            });

            // Conditional: Extinguish when burning
            if (selfParticipant && selfParticipant.is_burning) {
                menuItems.push({
                    action: 'extinguish',
                    value: null,
                    label: 'Extinguish',
                    description: 'Put out flames (uses your action)'
                });
            }

            // Conditional: Stand Up when prone
            if (selfParticipant && selfParticipant.is_prone) {
                menuItems.push({
                    action: 'stand_up',
                    value: null,
                    label: 'Stand Up',
                    description: 'Get up from prone (uses movement)'
                });
            }

            // Combat abilities submenu (main action abilities)
            if (selfParticipant && selfParticipant.main_abilities && selfParticipant.main_abilities.length > 0) {
                menuItems.push({ separator: true });
                const abilityItems = selfParticipant.main_abilities.map(ability => ({
                    action: 'use_ability',
                    value: ability.id,
                    label: ability.name,
                    description: ability.description || 'Use this ability',
                    disabled: ability.on_cooldown
                }));
                menuItems.push({
                    label: '⚔ Abilities',
                    submenu: abilityItems
                });
            }

            // Mount nearby monsters
            if (selfParticipant && selfParticipant.adjacent_monsters && selfParticipant.adjacent_monsters.length > 0) {
                menuItems.push({ separator: true });
                selfParticipant.adjacent_monsters.forEach(monster => {
                    menuItems.push({
                        action: 'mount',
                        value: monster.id,
                        label: `Mount ${monster.name}`,
                        description: 'Climb onto the monster'
                    });
                });
            }

            // Mounted movement options
            if (selfParticipant && selfParticipant.is_mounted) {
                menuItems.push({ separator: true });
                menuItems.push({
                    action: 'climb',
                    value: null,
                    label: 'Climb',
                    description: 'Progress toward weak point'
                });
                menuItems.push({
                    action: 'cling',
                    value: null,
                    label: 'Cling',
                    description: 'Hold position (immune to shake-off)'
                });
                menuItems.push({
                    action: 'dismount',
                    value: null,
                    label: 'Dismount',
                    description: 'Drop to adjacent hex'
                });
            }
        }

        // Willpower submenu (for self or when attacking)
        if (selfParticipant) {
            const wpAvailable = parseFloat(selfParticipant.willpower_dice) || 0;
            if (wpAvailable > 0) {
                menuItems.push({ separator: true });
                const wpItems = buildWillpowerSubmenu(wpAvailable, selfParticipant);
                menuItems.push({
                    label: `Willpower (${Math.floor(wpAvailable)} dice)`,
                    submenu: wpItems
                });
            }
        }

        // Tactical options submenu - stances and tactical abilities
        menuItems.push({ separator: true });
        const tacticalSubmenuItems = [];

        // Add tactical abilities first (healing, buffs, etc.)
        if (selfParticipant && selfParticipant.tactical_abilities && selfParticipant.tactical_abilities.length > 0) {
            selfParticipant.tactical_abilities.forEach(ability => {
                tacticalSubmenuItems.push({
                    action: 'use_tactical_ability',
                    value: { ability_id: ability.id, target_id: participant ? participant.id : null },
                    label: ability.name,
                    description: ability.description || 'Use this ability',
                    disabled: ability.on_cooldown
                });
            });
            tacticalSubmenuItems.push({ separator: true });
        }

        // Add stances
        tacticalSubmenuItems.push(
            { action: 'tactical', value: 'aggressive', label: 'Aggressive', description: '+2 damage dealt, +2 damage taken' },
            { action: 'tactical', value: 'defensive', label: 'Defensive', description: '-2 damage dealt, -2 damage taken' },
            { action: 'tactical', value: 'quick', label: 'Quick', description: '+1 movement, -1 dealt, +1 taken' },
            { action: 'tactical', value: 'guard', label: 'Guard', description: 'Protect adjacent ally (50% redirect)' },
            { action: 'tactical', value: 'back_to_back', label: 'Back to Back', description: 'Mutual 25%/50% redirect' },
            { separator: true },
            { action: 'tactical', value: 'none', label: 'None', description: 'No tactical stance' }
        );

        menuItems.push({
            label: 'Tactical Action',
            submenu: tacticalSubmenuItems
        });

        // Options submenu (for self only)
        if (relationship === 'self' && selfParticipant) {
            menuItems.push({ separator: true });
            const optionsItems = [
                { action: 'select_melee', value: null, label: 'Melee Weapon', description: selfParticipant.current_melee || 'Unarmed' },
                { action: 'select_ranged', value: null, label: 'Ranged Weapon', description: selfParticipant.current_ranged || 'None' },
                { separator: true },
                { action: 'toggle_autobattle', value: null, label: `Autobattle [${selfParticipant.autobattle || 'OFF'}]`, description: 'AI control' },
                { action: 'toggle_hazard', value: null, label: `Hazards [${selfParticipant.ignore_hazard ? 'Ignore' : 'Avoid'}]`, description: 'Path through hazards' },
                { separator: true },
                { action: 'change_side', value: null, label: `Side [${selfParticipant.side || 1}]`, description: 'Switch faction' }
            ];
            menuItems.push({
                label: '⚙ Options',
                submenu: optionsItems
            });

            // Done button (only when main action is set)
            if (selfParticipant.main_action_set) {
                menuItems.push({ separator: true });
                menuItems.push({
                    action: 'submit_round',
                    value: null,
                    label: '✓ Done',
                    description: 'Submit combat input'
                });
            }
        }

        showCombatDropdown(e.pageX, e.pageY, menuItems, { type: 'character', participant });
    }

    // Build willpower submenu
    function buildWillpowerSubmenu(available, selfParticipant) {
        const items = [];
        const maxSpend = Math.min(Math.floor(available), 2);

        // Attack options
        for (let i = 1; i <= maxSpend; i++) {
            items.push({
                action: 'willpower_attack',
                value: i,
                label: `Attack +${i * 2}`,
                description: `${i} ${i === 1 ? 'die' : 'dice'} for +${i * 2} damage`
            });
        }

        // Ability willpower (when using an ability instead of basic attack)
        if (selfParticipant && selfParticipant.selected_ability) {
            items.push({ separator: true });
            for (let i = 1; i <= maxSpend; i++) {
                items.push({
                    action: 'willpower_ability',
                    value: i,
                    label: `Ability +${i * 2}`,
                    description: `${i} ${i === 1 ? 'die' : 'dice'} for +${i * 2} ability damage`
                });
            }
        }

        items.push({ separator: true });

        // Defense options
        for (let i = 1; i <= maxSpend; i++) {
            items.push({
                action: 'willpower_defense',
                value: i,
                label: `Defense ${i}d8`,
                description: `${i} ${i === 1 ? 'die' : 'dice'} for ${i}d8 defense`
            });
        }

        items.push({ separator: true });
        items.push({
            action: 'willpower_skip',
            value: null,
            label: 'Skip',
            description: 'Save dice for later'
        });

        return items;
    }

    // Submit combat action to API
    async function submitCombatAction(action, value) {
        hideCombatDropdown();

        try {
            const response = await apiPost('/api/fight/action', { action, value });

            const data = await response.json();

            if (data.success) {
                // Refresh battle map to show updated state
                fetchBattleMapState();
            } else {
                showSystemMessage(`❌ ${data.error || 'Action failed'}`, 'left');
            }
        } catch (err) {
            console.error('Combat action error:', err);
            showSystemMessage('❌ Failed to submit action', 'left');
        }
    }

    // Setup drag-to-pan for battle map scroll container
    function setupBattleMapDrag(container) {
        let isDragging = false;
        let startX, startY, scrollLeft, scrollTop;
        let hasMoved = false;
        const DRAG_THRESHOLD = 5; // px - distinguish click from drag

        // Mouse down - start drag
        container.addEventListener('mousedown', (e) => {
            isDragging = true;
            hasMoved = false;
            startX = e.pageX - container.offsetLeft;
            startY = e.pageY - container.offsetTop;
            scrollLeft = container.scrollLeft;
            scrollTop = container.scrollTop;
            container.style.cursor = 'grabbing';
        });

        // Mouse move - pan if dragging
        container.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            const x = e.pageX - container.offsetLeft;
            const y = e.pageY - container.offsetTop;
            const walkX = x - startX;
            const walkY = y - startY;

            if (Math.abs(walkX) > DRAG_THRESHOLD || Math.abs(walkY) > DRAG_THRESHOLD) {
                hasMoved = true;
            }

            container.scrollLeft = scrollLeft - walkX;
            container.scrollTop = scrollTop - walkY;
        });

        // Mouse up - end drag
        container.addEventListener('mouseup', () => {
            isDragging = false;
            container.style.cursor = 'grab';
        });

        // Mouse leave - end drag
        container.addEventListener('mouseleave', () => {
            isDragging = false;
            container.style.cursor = 'grab';
        });

        // Touch events for mobile
        container.addEventListener('touchstart', (e) => {
            isDragging = true;
            hasMoved = false;
            startX = e.touches[0].pageX - container.offsetLeft;
            startY = e.touches[0].pageY - container.offsetTop;
            scrollLeft = container.scrollLeft;
            scrollTop = container.scrollTop;
        }, { passive: true });

        container.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            const x = e.touches[0].pageX - container.offsetLeft;
            const y = e.touches[0].pageY - container.offsetTop;
            const walkX = x - startX;
            const walkY = y - startY;

            if (Math.abs(walkX) > DRAG_THRESHOLD || Math.abs(walkY) > DRAG_THRESHOLD) {
                hasMoved = true;
            }

            container.scrollLeft = scrollLeft - walkX;
            container.scrollTop = scrollTop - walkY;
        }, { passive: true });

        container.addEventListener('touchend', () => {
            isDragging = false;
        });

        // Expose hasMoved for click handlers to check
        container.battleMapDragState = { hasMoved: () => hasMoved };
    }

    // Setup battle map interactions (enhanced tooltips + click handlers)
    function setupBattleMapInteractions(container, mapData) {
        // Store map data for click handlers
        currentMapData = mapData;

        // NOTE: Old tooltip system disabled - now using BattleMapRenderer.HexTooltip
        // which is initialized in createBattleMapSVG and attached to hexes via renderHex.
        // This prevents duplicate tooltip systems and memory leaks.
        // setupBattleMapTooltips(container, mapData);

        // Add click handlers to hexes
        container.querySelectorAll('.hex-group').forEach(hex => {
            const hexX = parseInt(hex.getAttribute('data-hex-x'));
            const hexY = parseInt(hex.getAttribute('data-hex-y'));
            const hexData = mapData.hexes.find(h => h.x == hexX && h.y == hexY);

            hex.style.cursor = 'pointer';
            hex.addEventListener('click', (e) => {
                // Skip if this was a drag, not a click
                const dragState = e.currentTarget.closest('.battle-map-scroll-container')?.battleMapDragState;
                if (dragState?.hasMoved()) return;
                // Don't show menu if clicking a character on this hex
                if (e.target.closest('.character-marker')) return;
                handleHexClick(e, hexX, hexY, hexData, mapData);
            });
        });

        // Add click handlers to character markers
        container.querySelectorAll('.character-marker').forEach(marker => {
            const participantId = marker.getAttribute('data-participant-id');
            const relationship = marker.getAttribute('data-relationship');
            const participant = mapData.participants.find(p => p.id == participantId);

            marker.style.cursor = 'pointer';
            marker.addEventListener('click', (e) => {
                // Skip if this was a drag, not a click
                const dragState = e.currentTarget.closest('.battle-map-scroll-container')?.battleMapDragState;
                if (dragState?.hasMoved()) return;
                handleCharacterClick(e, participant, relationship, mapData);
            });
        });
    }

    // Export for external access
    window.battleMap = {
        show: startBattleMapPolling,
        hide: hideBattleMap,
        dismiss: dismissBattleMap,
        reset: resetBattleMapDismissed,
        checkStatus: checkCombatStatus,
        submitAction: submitCombatAction,
        refresh: fetchBattleMapState
    };

    // Expose refreshFightState for battle-map-renderer.js completion callback
    window.refreshFightState = fetchBattleMapState;
})();
</script>
<% end %>
