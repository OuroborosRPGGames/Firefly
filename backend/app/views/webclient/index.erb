<% content_for :scripts do %>
<script>
(function() {
    const characterIdEl = document.getElementById('character_id');
    const characterInstanceIdEl = document.getElementById('character_instance_id');
    const characterId = characterIdEl ? characterIdEl.textContent : '';
    const characterInstanceId = characterInstanceIdEl ? characterInstanceIdEl.textContent : '';
    const characterShortName = <%= (character_short_name || '').to_json %>;
    let currentChannelName = <%= current_channel.to_json %>;
    let currentRoomName = <%= (@room&.name || 'Unknown Location').to_json %>;
    const availableChannels = <%= available_channels.to_json %>;

    // Multi-tab support: include character_instance_id in all API requests
    // Must send as query param because Roda's request.params doesn't parse JSON bodies
    function apiPost(url, body = {}) {
        const separator = url.includes('?') ? '&' : '?';
        return fetch(`${url}${separator}character_instance_id=${characterInstanceId}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...body, character_instance_id: characterInstanceId })
        });
    }

    function apiGet(url) {
        const separator = url.includes('?') ? '&' : '?';
        return fetch(`${url}${separator}character_instance_id=${characterInstanceId}`);
    }

    let messageInput;
    let messageSide;
    let lMessages;
    let rMessages;
    let lMessageWindow;
    let rMessageWindow;
    let statusTimeEl;
    let statusLocationEl;
    let imprintEl;
    let consentNoticeBadgeEl;
    let consentNoticeTriggerEl;
    let consentNoticeTooltipEl;

    // Sticky mode - makes temp/observe output go to main message feed instead
    let stickyMode = false;

    // Delve status tracking
    let delveActive = false;
    let delveTimeRemaining = 0;  // in seconds
    // delveLastUpdate removed - delve time is action-based, not real-time

    // ====== FAVICON NOTIFICATION SYSTEM ======
    // Tracks unseen messages in left/right panels to change favicon color
    let rchange = 0;  // Right panel has unseen messages
    let lchange = 0;  // Left panel has unseen messages

    // Change the favicon dynamically
    function changeFavicon(src) {
        const link = document.createElement('link');
        const oldLink = document.getElementById('dynamic-favicon');
        link.id = 'dynamic-favicon';
        link.rel = 'shortcut icon';
        link.href = src;
        if (oldLink) {
            document.head.removeChild(oldLink);
        }
        document.head.appendChild(link);
    }

    // Reset favicon when window becomes visible
    document.addEventListener('visibilitychange', function() {
        if (!document.hidden) {
            changeFavicon('/favicon.ico');
            lchange = 0;
            rchange = 0;
        }
    });

    // Update favicon based on panel activity
    function updateFaviconForPanel(panel) {
        // Only show notification favicon when window is hidden
        if (document.hidden) {
            if (panel === 'right') {
                rchange = 1;
                if (lchange === 1) {
                    changeFavicon('/bbfavicon.ico');  // Both panels have unseen
                } else {
                    changeFavicon('/rbfavicon.ico');  // Only right panel has unseen
                }
            } else if (panel === 'left') {
                lchange = 1;
                if (rchange === 1) {
                    changeFavicon('/bbfavicon.ico');  // Both panels have unseen
                } else {
                    changeFavicon('/lbfavicon.ico');  // Only left panel has unseen
                }
            }
        } else {
            // Window is visible - reset everything
            changeFavicon('/favicon.ico');
            rchange = 0;
            lchange = 0;
        }
    }

    // ====== STATUS BAR DATA ======
    // Game time and weather data from server
    <%
      location = @room&.location
      weather = location ? (Weather.for_location(location) rescue nil) : nil
      game_hour = GameTimeService.hour(location) rescue 12
      game_time_formatted = begin
        weekday = GameTimeService.weekday(location).capitalize[0..2]
        day = GameTimeService.current_time(location).day
        month = GameTimeService.current_time(location).strftime('%b')
        time = GameTimeService.formatted_time(location, format: :long)
        "#{weekday} #{day} #{month} #{time}"
      rescue StandardError => e
        warn "[WebclientView] Failed to format game time for character #{@character&.id}: #{e.message}"
        Time.now.strftime('%a %-d %b %l:%M %p')
      end
      sunrise_hour = GameTimeService.sunrise_hour(location) rescue 6
      sunset_hour = GameTimeService.sunset_hour(location) rescue 18
      viewer_instance = @character_instance
      viewer_status_line = begin
        if viewer_instance && @room
          RoomDisplayService.for(@room, viewer_instance).send(:build_status_line, viewer_instance)
        else
          nil
        end
      rescue StandardError => e
        warn "[WebclientView] Failed to build status line for character #{@character&.id}: #{e.message}"
        nil
      end
    %>
    let gameTimeData = {
        hour: <%= game_hour.to_json %>,
        formatted: <%= game_time_formatted.to_json %>,
        sunrise_hour: <%= sunrise_hour.to_json %>,
        sunset_hour: <%= sunset_hour.to_json %>
    };
    let weatherData = <% if weather %>{
        condition: <%= weather.condition.to_json %>,
        temperature_f: <%= weather.temperature_f.round.to_json %>,
        temperature_c: <%= weather.temperature_c.round.to_json %>,
        intensity: <%= weather.intensity.to_json %>,
        is_outdoor: <%= (@room&.room_environment_type == :outdoor).to_json %>
    }<% else %>null<% end %>;
    let characterStatusLine = <%= (viewer_status_line || '').to_json %>;
    let characterPresence = { status: 'present', display: null };
    let combatStatusData = <%= initial_combat_status ? initial_combat_status.to_json : 'null' %>;
    let privateModeActive = <%= (@character_instance&.private_mode? || false).to_json %>;
    let roomConsentInfo = null;

    // Combat message queue - delays narrative/summary until dice animation finishes
    let diceAnimatingUntil = 0;
    let combatMessageQueue = [];
    let combatQueueTimer = null;

    function queueCombatMessage(fn) {
        const now = Date.now();
        if (now >= diceAnimatingUntil) {
            fn();
            return;
        }
        const waitMs = diceAnimatingUntil - now;
        combatMessageQueue.push(fn);
        if (!combatQueueTimer) {
            combatQueueTimer = setTimeout(flushCombatQueue, waitMs + 1000);
        }
    }

    function flushCombatQueue() {
        combatQueueTimer = null;
        const now = Date.now();
        if (now < diceAnimatingUntil) {
            // Dice animation still running (timer was extended) — reschedule
            const remainMs = diceAnimatingUntil - now;
            combatQueueTimer = setTimeout(flushCombatQueue, remainMs + 1000);
            return;
        }
        // Reset so next round's combat messages don't slip through using stale timestamp
        diceAnimatingUntil = 0;
        const pending = combatMessageQueue.splice(0);
        pending.forEach(fn => fn());
        // If battle map hide is pending and queue just drained, trigger it now
        if (_hideBattleMapPending) scheduleHideBattleMap();
    }

    // Channel color map (from Ravencroft)
    const CHANNEL_COLORS = {
        'ooc': '#daa520',      // Goldenrod
        'dm': '#00cccc',       // Cyan
        'questions': '#66cc99', // Mint
        'school': '#eeeeee',   // White
        'chat': '#336666',     // Teal
        'radio': '#555555',    // Dark Gray
        'adults only': '#cc33cc', // Magenta
        'arena': '#35C0C4'     // Bright Teal
    };

    // Weather emoji map
    const WEATHER_SYMBOLS = {
        'clear': '☀',
        'cloudy': '☁',
        'overcast': '☁',
        'rain': '☂',
        'storm': '⛈',
        'thunderstorm': '⛈',
        'snow': '❄',
        'blizzard': '❄',
        'fog': '▒',
        'wind': '≋',
        'hail': '⛆',
        'hurricane': '⚡',
        'tornado': '⚡'
    };

    const seenMessageIds = new Set();
    const renderedMessageIds = new Set();
    let outgoingRecall = '';

    // ====== MESSAGE SYNC SYSTEM ======
    // Track message sequence and send acknowledgments
    let lastSequenceNumber = 0;
    let sequenceBaselineSet = false;
    let lastGapLogAt = 0;
    let lastGapRecoverAt = 0;
    const MAX_TARGETED_RESYNC_GAP = 200;
    const pendingAcks = [];
    let ackDebounceTimer = null;

    function acknowledgeMessage(messageId, sequenceNumber) {
        if (!messageId) return;

        // Track sequence number for gap detection
        if (sequenceNumber !== undefined && sequenceNumber !== null) {
            if (!sequenceBaselineSet) {
                // First seen sequence in this client session may start at an arbitrary point.
                // Establish a baseline without triggering noisy large-gap warnings/resync.
                lastSequenceNumber = sequenceNumber;
                sequenceBaselineSet = true;
            } else if (sequenceNumber > lastSequenceNumber + 1) {
                const gap = sequenceNumber - lastSequenceNumber - 1;
                const now = Date.now();

                // Small gaps can be patched directly via targeted resync.
                if (gap <= MAX_TARGETED_RESYNC_GAP) {
                    requestMissingMessages(lastSequenceNumber + 1, sequenceNumber - 1);
                } else if (now - lastGapRecoverAt > 3000) {
                    // Large gaps usually indicate reconnect/session jumps; fetch missed messages once.
                    lastGapRecoverAt = now;
                    fetchMissedMessages();
                }

                // Rate-limit console noise for expected reconnect/session gaps.
                if (gap > 10 && now - lastGapLogAt > 30_000) {
                    console.info(`[MessageSync] Sequence gap detected: expected ${lastSequenceNumber + 1}, got ${sequenceNumber} (${gap} missing)`);
                    lastGapLogAt = now;
                }
            }
            lastSequenceNumber = Math.max(lastSequenceNumber, sequenceNumber);
        }

        // Queue the ack
        pendingAcks.push(messageId);

        // Debounce sending acks to batch them
        if (ackDebounceTimer) clearTimeout(ackDebounceTimer);
        ackDebounceTimer = setTimeout(sendPendingAcks, 100);
    }

    function sendPendingAcks() {
        if (pendingAcks.length === 0) return;

        const acksToSend = pendingAcks.splice(0, pendingAcks.length);

        apiPost('/api/messages/ack', { acks: acksToSend, last_sequence: lastSequenceNumber })
        .catch(error => {
            console.warn('Failed to send message acks:', error);
            // Re-queue failed acks
            pendingAcks.push(...acksToSend);
        });
    }

    function requestMissingMessages(fromSeq, toSeq) {
        apiGet(`/api/messages/resync?from=${fromSeq}&to=${toSeq}`)
            .then(response => response.json())
            .then(messages => {
                if (Array.isArray(messages)) {
                    messages.forEach(msg => {
                        // Route message based on type, preserving id/sequence for dedup+ack
                        let content = msg.message || msg;
                        if (msg.id || msg.sequence_number) {
                            if (typeof content === 'string') {
                                content = { content: content, id: msg.id, sequence_number: msg.sequence_number };
                            } else if (typeof content === 'object' && content !== null) {
                                if (!content.id && msg.id) content.id = msg.id;
                                if (!content.sequence_number && msg.sequence_number) content.sequence_number = msg.sequence_number;
                            }
                        }
                        const panel = getMessagePanel(msg.message_type || msg.type);
                        const msgType = msg.message_type || msg.type || (msg.message && msg.message.type);
                        if (msgType === 'combat') {
                            queueCombatMessage(() => addMessage(content, panel));
                        } else {
                            addMessage(content, panel);
                        }

                        // Handle room arrival metadata from resynced messages
                        const arrivalData = content?.room_arrival ? content : null;
                        if (arrivalData) {
                            if (arrivalData.room_name) {
                                currentRoomName = arrivalData.room_name;
                                updateRightStatus(arrivalData.room_name);
                            }
                            // Handle delve map in resync
                            if (arrivalData.delve_map_svg) {
                                handleDelveMapUpdate(arrivalData);
                            } else if (arrivalData.in_delve === false && inDelve) {
                                exitDelveMap();
                            }
                            if (!inDelve) {
                                if (arrivalData.minimap_data && arrivalData.minimap_data.svg) {
                                    drawMinimapSvg(arrivalData.minimap_data.svg, arrivalData.minimap_data.metadata);
                                    showMinimap();
                                } else if (arrivalData.minimap_data && arrivalData.minimap_data.current_room) {
                                    drawSpatialMinimap(arrivalData.minimap_data);
                                } else if (arrivalData.exits) {
                                    drawSimpleMinimap(arrivalData.room_name || currentRoomName, arrivalData.exits);
                                }
                            }
                            if (arrivalData.room_id && wsManager && wsManager.currentRoomId !== arrivalData.room_id) {
                                wsManager.updateRoom(arrivalData.room_id);
                            }
                        }
                    });
                }
            })
            .catch(error => console.error('Failed to resync messages:', error));
    }

    // Fallback poll for timed movement arrival messages
    // If the WebSocket misses the arrival broadcast, poll for it after the expected duration
    let movementArrivalTimer = null;
    function scheduleMovementArrivalPoll(durationMs) {
        if (movementArrivalTimer) clearTimeout(movementArrivalTimer);
        // Poll after duration + scheduler tick (5s) + buffer (2s)
        const pollDelay = durationMs + 7000;
        movementArrivalTimer = setTimeout(() => {
            movementArrivalTimer = null;
            // Request any messages beyond our last known sequence
            requestMissingMessages(lastSequenceNumber + 1, lastSequenceNumber + 50);
        }, pollDelay);
    }

    function showConnectionToast(message, type = 'info', duration = 5000) {
        // Create toast container if it doesn't exist
        let container = document.getElementById('connection-toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'connection-toast-container';
            container.className = 'toast toast-top toast-end z-50';
            container.style.position = 'fixed';
            container.style.top = '1rem';
            container.style.right = '1rem';
            document.body.appendChild(container);
        }

        const alertClass = type === 'success' ? 'alert-success' : 'alert-info';
        const iconClass = type === 'success' ? 'bi-check-circle' : 'bi-info-circle';

        const alert = document.createElement('div');
        alert.className = `alert ${alertClass} shadow-lg text-sm py-2 px-4`;
        alert.innerHTML = `<i class="bi ${iconClass}"></i><span>${message}</span>`;

        container.appendChild(alert);

        setTimeout(() => {
            alert.classList.add('animate__animated', 'animate__fadeOut');
            setTimeout(() => alert.remove(), 500);
        }, duration);
    }

    // Fetch messages missed during a WebSocket disconnect.
    // Uses sequence numbers for precise gap detection, falls back to recent messages.
    function fetchMissedMessages() {
        if (lastSequenceNumber > 0) {
            // We have a sequence number - use the reconnect endpoint for precise delivery
            apiPost('/api/messages/reconnect', { last_sequence: lastSequenceNumber })
                .then(response => response.json())
                .then(data => {
                    if (data.missed_messages && data.missed_messages.length > 0) {
                        console.log(`[Reconnect] Received ${data.missed_messages.length} missed message(s)`);
                        data.missed_messages.forEach(msg => {
                            const content = msg.message || msg;
                            const panel = getMessagePanel(msg.message_type || msg.type);
                            addMessage(content, panel);
                        });
                    }
                })
                .catch(error => {
                    console.warn('[Reconnect] Failed to fetch missed messages, falling back:', error);
                    loadRecentMessages();
                });
        } else {
            // No sequence number yet - fall back to loading recent messages
            loadRecentMessages();
        }
    }

    // ====== CLIENT INFO SYSTEM ======
    // Send client details (timezone, screen info, etc.) to backend on connect
    function sendClientInfo() {
        const clientInfo = {
            timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
            timezone_offset: new Date().getTimezoneOffset(),
            locale: navigator.language || navigator.userLanguage,
            screen_width: window.screen.width,
            screen_height: window.screen.height,
            viewport_width: window.innerWidth,
            viewport_height: window.innerHeight,
            user_agent: navigator.userAgent,
            platform: navigator.platform,
            online: navigator.onLine,
            connection_type: navigator.connection?.effectiveType || 'unknown',
            referrer: document.referrer || null,
            timestamp: new Date().toISOString()
        };

        apiPost('/api/client/info', clientInfo).catch(error => {
            console.warn('Failed to send client info:', error);
        });
    }

    // Re-send client info on visibility change (when user returns to tab)
    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
            sendClientInfo();
        }
    });

    // ====== TYPING INDICATOR SYSTEM ======
    // Track typing state and send to server
    let typingState = {
        status: 'idle',        // 'typing', 'paused', 'idle'
        commandType: null,     // 'emote', 'say', or null (don't send)
        startTime: null,       // When typing started
        lastKeystroke: null,   // Last keystroke timestamp
        sendInterval: null,    // Interval for sending updates
        pauseTimeout: null,    // Timeout for pause detection
        expireTimeout: null    // Timeout for auto-expire (3 min)
    };

    const TYPING_SEND_INTERVAL = 2000;   // Send status every 2 seconds
    const TYPING_PAUSE_DELAY = 20000;   // Pause after 20 seconds of no input
    const TYPING_EXPIRE_DELAY = 180000; // Expire (go idle) after 3 minutes of no input

    // RP command prefix lists for typing indicator filtering
    const EMOTE_PREFIXES = ['emote', 'pose', 'emit', 'semote', 'smartemote', 'sem', 'subtle',
                             'pemit', 'semit'];
    const EMOTE_CHARS = ['.', ':'];

    const SAY_PREFIXES = ['say', 'yell', 'shout', 'mutter', 'grumble', 'scream', 'moan', 'gasp',
                           'sob', 'stutter', 'murmur', 'flirt', 'lecture', 'argue', 'confess',
                           'sayto', 'tell', 'order', 'instruct', 'beg', 'demand', 'tease', 'mock',
                           'taunt', 'saythrough', 'yellthrough', 'whisper', 'whi', 'wh',
                           'think', 'hope', 'ponder', 'wonder', 'worry', 'wish', 'feel', 'remember',
                           'attempt', 'propose', 'knock'];
    const SAY_CHARS = ['"', "'"];

    const NON_RP_PREFIXES = ['look', 'l', 'north', 'south', 'east', 'west', 'up', 'down',
                              'enter', 'leave', 'exits', 'go', 'inventory', 'inv', 'score',
                              'map', 'help', 'who', 'sit', 'stand', 'lie', 'recline',
                              'fight', 'cast', 'flee', 'use', 'get', 'drop', 'put', 'give',
                              'wear', 'remove', 'open', 'close', 'lock', 'unlock',
                              'shop', 'buy', 'sell', 'ooc', 'msg', 'dm', 'channel', 'chan',
                              'mail', 'bb', 'places', 'describe', 'undress', 'dress'];

    function detectCommandType(text, side) {
        if (!text || text.length === 0) return null;

        // Left panel is OOC - don't trigger typing indicator
        if (side === 'l') return null;

        const firstChar = text.charAt(0);

        // Single-char prefixes
        if (EMOTE_CHARS.includes(firstChar)) return 'emote';
        if (SAY_CHARS.includes(firstChar)) return 'say';

        // Extract first word for prefix matching
        const firstWord = text.split(/\s+/)[0].toLowerCase();

        if (EMOTE_PREFIXES.includes(firstWord)) return 'emote';
        if (SAY_PREFIXES.includes(firstWord)) return 'say';
        if (NON_RP_PREFIXES.includes(firstWord)) return null;

        // Right panel with unknown command - default to say (right panel is RP)
        return 'say';
    }

    function startTypingIndicator() {
        // Detect command type first - skip non-RP commands
        const text = messageInput?.textContent || '';
        const side = messageSide?.value || 'r';
        const cmdType = detectCommandType(text, side);

        if (!cmdType) {
            // Non-RP command or empty - stop any active indicator
            if (typingState.status !== 'idle') {
                stopTypingIndicator();
            }
            return;
        }

        if (typingState.status === 'idle') {
            typingState.startTime = Date.now();
        }
        typingState.status = 'typing';
        typingState.lastKeystroke = Date.now();
        typingState.commandType = cmdType;

        // Clear any existing pause timeout
        if (typingState.pauseTimeout) {
            clearTimeout(typingState.pauseTimeout);
        }

        // Set timeout to transition to paused (20s)
        typingState.pauseTimeout = setTimeout(() => {
            if (typingState.status === 'typing') {
                typingState.status = 'paused';
                sendTypingStatus();
            }
        }, TYPING_PAUSE_DELAY);

        // Set timeout to auto-expire (3 min) - clear indicator entirely
        if (typingState.expireTimeout) {
            clearTimeout(typingState.expireTimeout);
        }
        typingState.expireTimeout = setTimeout(() => {
            stopTypingIndicator();
        }, TYPING_EXPIRE_DELAY);

        // Start sending interval if not already running
        if (!typingState.sendInterval) {
            sendTypingStatus(); // Send immediately
            typingState.sendInterval = setInterval(sendTypingStatus, TYPING_SEND_INTERVAL);
        }
    }

    function stopTypingIndicator() {
        typingState.status = 'idle';
        typingState.commandType = null;
        typingState.startTime = null;

        if (typingState.pauseTimeout) {
            clearTimeout(typingState.pauseTimeout);
            typingState.pauseTimeout = null;
        }

        if (typingState.expireTimeout) {
            clearTimeout(typingState.expireTimeout);
            typingState.expireTimeout = null;
        }

        if (typingState.sendInterval) {
            clearInterval(typingState.sendInterval);
            typingState.sendInterval = null;
        }

        // Send final idle status
        sendTypingStatus();
    }

    function sendTypingStatus() {
        const duration = typingState.startTime
            ? Date.now() - typingState.startTime
            : 0;

        const typingData = {
            status: typingState.status,
            command_type: typingState.commandType,
            duration_ms: duration
        };

        apiPost('/api/typing', { typing: typingData }).catch(error => {
            // Silently ignore typing indicator failures
        });
    }

    // Attach typing event listeners to input
    function setupTypingIndicator() {
        if (!messageInput) return;

        // Track input events
        messageInput.addEventListener('input', () => {
            const text = messageInput.textContent || '';
            if (text.length > 0) {
                startTypingIndicator();
            } else {
                stopTypingIndicator();
            }
        });

        // Track keydown for more accurate timing
        messageInput.addEventListener('keydown', (e) => {
            // Don't track Enter (sending) or Tab (switching)
            if (e.key === 'Enter' || e.key === 'Tab') return;

            const text = messageInput.textContent || '';
            if (text.length > 0 || (e.key.length === 1 && !e.ctrlKey && !e.metaKey)) {
                startTypingIndicator();
            }
        });

        // Replay buffer hotkey navigation (screen reader accessibility)
        messageInput.addEventListener('keydown', (e) => {
            if (typeof replayBuffer === 'undefined') return;

            const pressed = [];
            if (e.altKey) pressed.push('alt');
            if (e.ctrlKey) pressed.push('ctrl');
            if (e.shiftKey) pressed.push('shift');
            if (e.metaKey) pressed.push('meta');
            if (!['Alt', 'Control', 'Shift', 'Meta'].includes(e.key)) {
                pressed.push(e.key);
            }
            const combo = pressed.join('+');
            if (!combo) return;

            const prevKey = currentA11ySettings.a11y_replay_prev || 'alt+ArrowUp';
            const nextKey = currentA11ySettings.a11y_replay_next || 'alt+ArrowDown';

            const side = messageSide?.value || 'r';
            const pane = side === 'l' ? 'left' : 'right';

            if (combo === prevKey) {
                e.preventDefault();
                e.stopPropagation();
                replayBuffer.navigatePrev(pane);
            } else if (combo === nextKey) {
                e.preventDefault();
                e.stopPropagation();
                replayBuffer.navigateNext(pane);
            } else if (e.key === 'Escape' && replayBuffer.isNavigating(pane)) {
                e.preventDefault();
                replayBuffer.resetNavigation(pane);
                if (typeof announceToScreenReader === 'function') {
                    announceToScreenReader('Replay ended.');
                }
            }
        });

        // Stop typing indicator when input is cleared or blurred
        messageInput.addEventListener('blur', () => {
            // Don't immediately stop - they might just be clicking something
            setTimeout(() => {
                if (document.activeElement !== messageInput) {
                    const text = messageInput.textContent || '';
                    if (text.length === 0) {
                        stopTypingIndicator();
                    }
                }
            }, 500);
        });

        // Start polling for room typing indicators
        startTypingPoll();
    }

    // ====== ROOM TYPING INDICATOR DISPLAY ======
    // Poll for other players' typing status in the room
    // Indicators appear inline at the bottom of #rmessages
    let typingPollInterval = null;
    let activeTypingIds = new Set(); // Track currently displayed character IDs

    function startTypingPoll() {
        // Poll every 3 seconds
        typingPollInterval = setInterval(pollRoomTyping, 3000);
    }

    function pollRoomTyping() {
        apiGet('/api/typing')
            .then(response => response.json())
            .then(data => {
                if (data.success && data.room_typing) {
                    displayRoomTyping(data.room_typing);
                }
            })
            .catch(error => {
                // Silently fail - typing indicators are not critical
            });
    }

    function displayRoomTyping(typingList) {
        const container = document.getElementById('rmessages');
        if (!container) return;

        const currentIds = new Set();

        if (typingList && typingList.length > 0) {
            typingList.forEach(info => {
                const charId = info.character_id || info.character_name;
                const name = info.character_name || 'Someone';
                const status = info.status || 'typing';
                const cmdType = info.command_type || 'say';
                const elId = 'typing-ind-' + charId;

                currentIds.add(String(charId));

                let action = 'is typing';
                if (cmdType === 'emote') {
                    action = status === 'paused' ? 'is paused acting' : 'is acting';
                } else if (cmdType === 'say') {
                    action = status === 'paused' ? 'is paused speaking' : 'is speaking';
                }

                let el = document.getElementById(elId);
                if (!el) {
                    el = document.createElement('div');
                    el.id = elId;
                    el.className = 'typing-indicator-inline';
                    container.appendChild(el);
                }

                el.innerHTML = '<span class="typing-name">' + escapeHtml(name) + '</span> ' +
                               action + '<span class="typing-dots">...</span>';

                // Move to end of container (below latest messages)
                if (el.nextSibling) {
                    container.appendChild(el);
                }
            });
        }

        // Remove indicators for characters no longer typing
        activeTypingIds.forEach(id => {
            if (!currentIds.has(id)) {
                const el = document.getElementById('typing-ind-' + id);
                if (el) el.remove();
            }
        });

        activeTypingIds = currentIds;

        // Auto-scroll if near bottom
        if (container.scrollHeight - container.scrollTop - container.clientHeight < 100) {
            container.scrollTop = container.scrollHeight;
        }
    }

    const commandHistory = {
        left: { commands: [], index: -1, current: '' },
        right: { commands: [], index: -1, current: '' }
    };

    // Message types that go to LEFT (OOC) panel
    const OOC_TYPES = ['ooc', 'chat', 'tell', 'channel', 'questions', 'newbie', 'social', 'whisper', 'page'];

    // Message types that go to RIGHT (RP) panel
    const RP_TYPES = ['say', 'emote', 'pose', 'look', 'room', 'narrate', 'action', 'game', 'combat', 'system'];

    // Types that trigger notify_message setting (direct messages)
    const NOTIFY_MESSAGE_TYPES = ['ooc', 'dm', 'msg'];

    // Types that trigger notify_emote setting (RP activity)
    const NOTIFY_EMOTE_TYPES = ['say', 'emote', 'whisper', 'subtle', 'private_emote', 'pemit', 'quickmenu'];

    // Panel targeting system - maps target_panel values to UI elements
    const PANEL_TARGETS = {
        'left_main_feed': 'left',
        'right_main_feed': 'right',
        'left_observe_window': 'lobserve',
        'right_observe_window': 'observe',
        'left_status_bar': 'lstatus',
        'right_status_bar': 'rstatus',
        'left_minimap': 'minimap',
        'right_effect_dropdown': 'effects',
        'popout_form': 'popout',
        'imprint': 'imprint'
    };

    // ====== WEBSOCKET CONNECTION ======
    // WebSocket connection manager for real-time message delivery
    let gameSocket = null;

    class GameWebSocket {
        constructor(charInstanceId) {
            this.characterInstanceId = charInstanceId;
            this.ws = null;
            this.reconnectAttempts = 0;
            this.maxReconnectAttempts = 10;
            this.reconnectDelay = 1000;
            this.pingInterval = null;
            this.currentRoomId = null;
            this.kicked = false;  // True if we were kicked (logged in elsewhere)
            this.hasConnectedBefore = false;  // Track if this is a reconnect
        }

        connect() {
            // Don't reconnect if we were kicked
            if (this.kicked) {
                console.log('[WebSocket] Not reconnecting - kicked from server');
                return;
            }

            const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
            const url = `${protocol}//${window.location.host}/cable?character_instance=${this.characterInstanceId}`;

            try {
                this.ws = new WebSocket(url);
            } catch (e) {
                console.error('[WebSocket] Connection error:', e);
                this.scheduleReconnect();
                return;
            }

            this.ws.onopen = () => {
                console.log('[WebSocket] Connected');
                const isReconnect = this.hasConnectedBefore;
                this.hasConnectedBefore = true;
                this.reconnectAttempts = 0;
                this.startPing();
                updateConnectionStatus(true);

                // On reconnect, fetch messages missed during the disconnect gap
                if (isReconnect) {
                    console.log('[WebSocket] Reconnected - fetching missed messages');
                    fetchMissedMessages();
                    showConnectionToast('Connection restored.', 'success', 5000);
                }
            };

            this.ws.onmessage = (event) => {
                try {
                    const msg = JSON.parse(event.data);
                    this.handleMessage(msg);
                } catch (e) {
                    console.warn('[WebSocket] Invalid message:', e);
                }
            };

            this.ws.onclose = (event) => {
                console.log('[WebSocket] Disconnected', event.code, event.reason);
                this.stopPing();
                updateConnectionStatus(false, this.kicked);

                // Don't reconnect if we were kicked
                if (!this.kicked) {
                    this.scheduleReconnect();
                }
            };

            this.ws.onerror = (error) => {
                console.error('[WebSocket] Error:', error);
            };
        }

        handleMessage(msg) {
            // Handle connection confirmation
            if (msg.type === 'connected') {
                console.log('[WebSocket] Authenticated for character:', msg.character_instance_id);
                // Auto-activate delve HUD if character was in a delve on page load
                if (initialInDelve && !inDelve) {
                    setTimeout(function() { sendCommand('delve map', {skipHistory: true}); }, 300);
                }
                return;
            }

            // Handle pong response
            if (msg.type === 'pong') {
                return;
            }

            // Handle TTS audio messages
            if (msg.type === 'tts_audio') {
                if (audioQueueManager && msg.data) {
                    audioQueueManager.enqueue({
                        id: msg.data.request_id,
                        audio_url: msg.data.audio_url,
                        content_type: msg.data.narration_type
                    });
                }
                return;
            }

            // Handle TTS control commands
            if (msg.type === 'tts_control') {
                if (audioQueueManager && msg.data) {
                    switch (msg.data.action) {
                        case 'pause': audioQueueManager.pause(); break;
                        case 'resume': audioQueueManager.resume(); break;
                        case 'clear': audioQueueManager.clear(); break;
                        case 'skip_to_current': audioQueueManager.skipToCurrent(); break;
                    }
                }
                return;
            }

            // Handle kicked message (logged in from another tab/browser)
            if (msg.type === 'kicked') {
                this.handleKicked(msg);
                return;
            }

            // Handle turn indicator updates
            if (msg.type === 'turn_update') {
                const input = document.getElementById('message_content');
                if (currentSettings.emoteremind && msg.message?.turn_instance_id == characterInstanceId) {
                    input?.classList.add('turn-indicator');
                } else {
                    input?.classList.remove('turn-indicator');
                }
                return;
            }

            // Handle undo/delete message events
            if (msg.type === 'delete_message') {
                const bid = msg.broadcast_id || msg.message?.broadcast_id;
                if (bid) {
                    document.querySelectorAll(`[data-broadcast-id="${bid}"]`).forEach(el => {
                        el.style.transition = 'opacity 0.3s';
                        el.style.opacity = '0';
                        setTimeout(() => {
                            el.remove();
                            renderedMessageIds.delete(el.id?.replace('message_', ''));
                        }, 300);
                    });
                }
                return;
            }

            // Handle lightweight minimap position updates (moves character dots without full re-render)
            if (msg.type === 'minimap_position') {
                handleMinimapPositionUpdate(msg);
                return;
            }

            // Handle quickmenu/form messages with structured data (e.g., attempt consent)
            if ((msg.type === 'quickmenu' || msg.type === 'form') && msg.data) {
                const side = 'right';
                // During combat dice animations, delay quickmenu until after narrative
                if (msg.type === 'quickmenu' && diceAnimatingUntil > Date.now()) {
                    queueCombatMessage(() => showObservationPanel(msg.type, msg.data, side));
                } else {
                    showObservationPanel(msg.type, msg.data, side);
                }
                // Acknowledge the message for sequence tracking
                if (msg.id) {
                    acknowledgeMessage(msg.id, msg.sequence_number);
                }
                return;
            }

            const wsPrivateMode = msg?.data?.private_mode ?? msg?.message?.data?.private_mode;
            if (wsPrivateMode !== undefined) {
                privateModeActive = !!wsPrivateMode;
                applyPrivateModeStatusStyling();
            }

            // Handle dice roll messages with animated display
            if (msg.type === 'dice_roll' || (msg.message && msg.message.type === 'dice_roll')) {
                const rollData = msg.message || msg;
                if (rollData.animation_data) {
                    // Skip self-rolls via websocket for non-combat rolls
                    // (stat checks come via both HTTP and WS, combat rolls only via WS)
                    if (!rollData.combat_roll && String(rollData.character_id) === String(characterId)) {
                        if (msg.id) acknowledgeMessage(msg.id, msg.sequence_number);
                        return;
                    }

                    const animDiv = document.createElement('div');
                    animDiv.id = `roll-ws-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
                    animDiv.dataset.modifier = rollData.roll_modifier || 0;
                    animDiv.dataset.total = rollData.roll_total || 0;
                    animDiv.dataset.characterName = rollData.character_name || '';
                    animDiv.dataset.scrollTarget = 'rmessagewindow';

                    if (rMessages) {
                        rMessages.appendChild(animDiv);
                        scrollToBottom(rMessageWindow);
                    }

                    const animDuration = new DiceAnimator().animate(animDiv.id, rollData.animation_data);
                    const endTime = Date.now() + (animDuration || 3000) + 1000;
                    if (endTime > diceAnimatingUntil) diceAnimatingUntil = endTime;

                    if (msg.id) acknowledgeMessage(msg.id, msg.sequence_number);
                    return;
                }
            }

            // Handle combat damage summary (ephemeral, small grey text, not logged)
            if (msg.type === 'combat_damage_summary' ||
                (msg.message && msg.message.type === 'combat_damage_summary')) {
                // Dedup: skip if already rendered (can arrive via both WebSocket and polling)
                const msgId = msg.id || msg.broadcast_id;
                if (msgId && renderedMessageIds.has(String(msgId))) {
                    if (msg.id) acknowledgeMessage(msg.id, msg.sequence_number);
                    return;
                }
                if (msgId) renderedMessageIds.add(String(msgId));

                const summaryData = msg.message || msg;
                const summaryContent = summaryData.content || '';
                queueCombatMessage(() => {
                    const summaryDiv = document.createElement('div');
                    summaryDiv.className = 'combat-damage-summary';
                    summaryDiv.innerHTML = formatDamageSummary(summaryContent);
                    summaryDiv.dataset.ephemeral = 'true';
                    if (rMessages) {
                        rMessages.appendChild(summaryDiv);
                        scrollToBottom(rMessageWindow);
                    }
                });
                if (msg.id) acknowledgeMessage(msg.id, msg.sequence_number);
                return;
            }

            // Handle status bar updates (pushed after combat rounds)
            // During combat dice animations, delay HP bar update until after narrative
            if (msg.type === 'status_bar_update' ||
                (msg.message && msg.message.type === 'status_bar_update')) {
                const sbData = (msg.message && msg.message.status_bar) || msg.status_bar;
                if (sbData) {
                    if (diceAnimatingUntil > Date.now()) {
                        queueCombatMessage(() => updateStatusBarFromServer(sbData));
                    } else {
                        updateStatusBarFromServer(sbData);
                    }
                }
                if (msg.id) acknowledgeMessage(msg.id, msg.sequence_number);
                return;
            }

            // Route message to appropriate panel using existing routing logic
            const panel = getPanelTarget(msg);
            let content = msg.message || msg;

            // Ensure id, sequence_number, broadcast_id, and notification metadata from the
            // outer WebSocket payload are propagated to the content passed to addMessage, so that:
            // 1. Dedup works (renderedMessageIds uses message.id)
            // 2. Acks get sent (removes from msg_pending in Redis)
            // 3. lastSequenceNumber stays in sync (prevents false gap detection)
            // 4. broadcast_id enables undo (stored as data-broadcast-id on DOM elements)
            // 5. sender_portrait_url / sender_display_name reach maybeNotify for notifications
            if (msg.id || msg.sequence_number || msg.broadcast_id || msg.notification) {
                if (typeof content === 'string') {
                    content = { content: content, id: msg.id, sequence_number: msg.sequence_number, broadcast_id: msg.broadcast_id, type: msg.type, notification: msg.notification };
                } else if (typeof content === 'object' && content !== null) {
                    if (!content.id && msg.id) content.id = msg.id;
                    if (!content.sequence_number && msg.sequence_number) content.sequence_number = msg.sequence_number;
                    if (!content.broadcast_id && msg.broadcast_id) content.broadcast_id = msg.broadcast_id;
                    if (!content.type && msg.type) content.type = msg.type;
                }
            }
            if (msg.sender_portrait_url && typeof content === 'object' && content !== null && !content.sender_portrait_url)
                content.sender_portrait_url = msg.sender_portrait_url;
            if (msg.sender_display_name && typeof content === 'object' && content !== null && !content.sender_display_name)
                content.sender_display_name = msg.sender_display_name;
            if (msg.notification && typeof content === 'object' && content !== null && !content.notification)
                content.notification = msg.notification;

            // Use existing routeToPanel for specialized targets
            if (panel !== 'left' && panel !== 'right') {
                routeToPanel(panel, content);
            } else if (msg.type === 'combat' || (msg.message && msg.message.type === 'combat') ||
                       msg.type === 'activity_result' || (msg.message && msg.message.type === 'activity_result')) {
                // Always queue combat messages to ensure they appear after dice animations.
                // Server includes dice_duration_ms — the exact calculated animation time for this round's dice.
                // Use it to set/extend the wait deadline so narrative waits for dice to finish.
                const serverDiceDuration = msg.dice_duration_ms || (msg.message && msg.message.dice_duration_ms) || 0;
                const nowTs = Date.now();
                // Grace period: even if no dice_roll has arrived yet, wait at least 2s
                // for dice messages to arrive (handles network jitter/ordering).
                const graceDeadline = nowTs + 2000;
                if (graceDeadline > diceAnimatingUntil) {
                    diceAnimatingUntil = graceDeadline;
                }
                if (serverDiceDuration > 0) {
                    const serverDeadline = nowTs + serverDiceDuration;
                    if (serverDeadline > diceAnimatingUntil) {
                        diceAnimatingUntil = serverDeadline;
                    }
                }
                const queuedContent = content;
                const queuedPanel = panel;
                queueCombatMessage(() => addMessage(queuedContent, queuedPanel));
            } else {
                // Normal message - add to panel
                addMessage(content, panel);
            }

            // Handle room arrival metadata (minimap, status bar, room subscription)
            const arrivalData = content?.room_arrival ? content : null;
            if (arrivalData) {
                // Cancel the fallback poll since the arrival message arrived via WebSocket
                if (movementArrivalTimer) {
                    clearTimeout(movementArrivalTimer);
                    movementArrivalTimer = null;
                }
                if (arrivalData.room_name) {
                    currentRoomName = arrivalData.room_name;
                    updateRightStatus(arrivalData.room_name);
                }
                // Handle delve map in room arrivals
                if (arrivalData.delve_map_svg) {
                    handleDelveMapUpdate(arrivalData);
                } else if (arrivalData.in_delve === false && inDelve) {
                    exitDelveMap();
                }
                if (!inDelve) {
                    if (arrivalData.minimap_data && arrivalData.minimap_data.svg) {
                        drawMinimapSvg(arrivalData.minimap_data.svg, arrivalData.minimap_data.metadata);
                        showMinimap();
                    } else if (arrivalData.minimap_data && arrivalData.minimap_data.current_room) {
                        drawSpatialMinimap(arrivalData.minimap_data);
                    } else if (arrivalData.exits) {
                        drawSimpleMinimap(arrivalData.room_name || currentRoomName, arrivalData.exits);
                    }
                }
                if (arrivalData.room) {
                    updateWardrobeVisibility(arrivalData.room);
                }
                setRoomConsentNotice(arrivalData.content_consent || null);
                if (arrivalData.background_image) {
                    updateRoomBackgroundImage(arrivalData.background_image, arrivalData.mask_url);
                } else {
                    clearRoomBackgroundImage();
                }
                if (arrivalData.room_id && this.currentRoomId !== arrivalData.room_id) {
                    this.updateRoom(arrivalData.room_id);
                }
            }
        }

        handleKicked(msg) {
            this.kicked = true;
            this.stopPing();

            console.warn('[WebSocket] Kicked:', msg.reason, msg.message);

            // Display kicked message in both panels
            const kickedHtml = `
                <div class="system-message kicked-message" style="background: #4a1c1c; border: 1px solid #8b0000; padding: 15px; margin: 10px 0; border-radius: 5px;">
                    <strong style="color: #ff6b6b;">⚠️ Disconnected</strong><br>
                    <span style="color: #ffaaaa;">${escapeHtml(msg.message || 'You logged in from another location.')}</span><br>
                    <small style="color: #888;">Refresh this page to reconnect here.</small>
                </div>
            `;

            addMessage({ content: kickedHtml, html: kickedHtml }, 'right');
            addMessage({ content: kickedHtml, html: kickedHtml }, 'left');

            // Update connection status with kicked state
            updateConnectionStatus(false, true);
        }

        startPing() {
            this.pingInterval = setInterval(() => {
                if (this.ws && this.ws.readyState === WebSocket.OPEN) {
                    this.ws.send(JSON.stringify({ type: 'ping' }));
                }
            }, 30000); // Ping every 30 seconds
        }

        stopPing() {
            if (this.pingInterval) {
                clearInterval(this.pingInterval);
                this.pingInterval = null;
            }
        }

        scheduleReconnect() {
            if (this.reconnectAttempts >= this.maxReconnectAttempts) {
                console.error('[WebSocket] Max reconnect attempts reached');
                showReconnectUI();
                return;
            }

            this.reconnectAttempts++;
            const delay = this.reconnectDelay * Math.pow(2, this.reconnectAttempts - 1);
            const delayCapped = Math.min(delay, 30000); // Cap at 30 seconds

            console.log(`[WebSocket] Reconnecting in ${delayCapped}ms (attempt ${this.reconnectAttempts})`);
            setTimeout(() => this.connect(), delayCapped);
        }

        // Called when character moves to a new room
        updateRoom(newRoomId) {
            if (this.currentRoomId === newRoomId) return;
            this.currentRoomId = newRoomId;

            if (this.ws && this.ws.readyState === WebSocket.OPEN) {
                this.ws.send(JSON.stringify({
                    type: 'subscribe_room',
                    room_id: newRoomId
                }));
            }
        }

        isConnected() {
            return this.ws && this.ws.readyState === WebSocket.OPEN;
        }
    }

    // Update connection status indicator
    function updateConnectionStatus(connected, kicked = false) {
        const indicator = document.getElementById('connection-status');
        if (indicator) {
            if (kicked) {
                indicator.className = 'kicked';
                indicator.title = 'Disconnected - logged in elsewhere';
            } else {
                indicator.className = connected ? 'connected' : 'disconnected';
                indicator.title = connected ? 'Connected' : 'Reconnecting...';
            }
        }
    }

    // Show reconnect UI when WebSocket fails completely
    function showReconnectUI() {
        // Add a message to both panels
        const reconnectMsg = {
            content: '<i class="bi bi-exclamation-triangle"></i> Connection lost. <a href="javascript:location.reload()">Click to reconnect</a>',
            message_type: 'system'
        };
        addMessage(reconnectMsg, 'left');
        addMessage(reconnectMsg, 'right');
    }

    // Get the appropriate panel/element from target_panel or fall back to type-based routing
    function getPanelTarget(data) {
        // If target_panel is specified, use it
        if (data && data.target_panel && PANEL_TARGETS[data.target_panel]) {
            return PANEL_TARGETS[data.target_panel];
        }
        // Also check inside message (BroadcastService wraps content in message field)
        if (data?.message?.target_panel && PANEL_TARGETS[data.message.target_panel]) {
            return PANEL_TARGETS[data.message.target_panel];
        }
        // Fall back to type-based routing
        return getMessagePanel(data?.message_type || data?.type);
    }

    // Determine which panel a message should go to based on its type
    function getMessagePanel(messageType) {
        // Single screen mode: route everything to RP panel
        if (currentSettings.single_screen) return 'right';

        if (!messageType) return 'right'; // Default to RP panel
        const type = messageType.toLowerCase();
        if (OOC_TYPES.includes(type)) return 'left';
        if (RP_TYPES.includes(type)) return 'right';
        // Default: if message type contains 'ooc' or 'chat', go left
        if (type.includes('ooc') || type.includes('chat') || type.includes('tell')) return 'left';
        return 'right'; // Default to RP panel
    }

    // Route content to the appropriate panel element
    function routeToPanel(target, content, options = {}) {
        switch (target) {
            case 'left':
            case 'right':
                addMessage(content, target);
                break;
            case 'lobserve':
                showLeftObservationPanel(content);
                break;
            case 'observe':
                showInObserveWindow(content);
                break;
            case 'lstatus':
                updatePanelLeftStatus(content);
                break;
            case 'rstatus':
                updatePanelRightStatus(content);
                break;
            case 'minimap':
                updateMinimap(content);
                break;
            case 'effects':
                updateEffectsDropdown(content);
                break;
            case 'popout':
                showPopoutForm(content);
                break;
            case 'imprint':
                showImprint(content);
                break;
            default:
                addMessage(content, 'right');
        }
    }

    // Helper functions for special panel targets
    function showInLeftObserve(content) {
        // Route through the rich left observation panel
        showLeftObservationPanel(content);
    }

    function updateEffectsDropdown(content) {
        const el = document.getElementById('effectDropdown');
        if (el) {
            const listEl = el.querySelector('.effect-list');
            if (listEl && content.effects) {
                listEl.innerHTML = content.effects.map(e =>
                    `<div class="effect-item ${e.type || ''}">${e.name}: ${e.remaining || e.description || ''}</div>`
                ).join('');
            }
            el.classList.add('visible');
        }
    }

    function updatePanelLeftStatus(content) {
        const el = document.getElementById('lstatusfield');
        if (el && content.status) {
            el.innerHTML = content.status;
        }
    }

    function updatePanelRightStatus(content) {
        const el = document.getElementById('rstatusfield');
        if (el && content.status) {
            el.innerHTML = content.status;
        }
    }

    // Initial room data from server (same as 'look' command output)
    const initialRoomData = <%= (@initial_room_data || {}).to_json %>;
    const initialInDelve = <%= @in_delve ? 'true' : 'false' %>;

    function renderInitialRoom() {
