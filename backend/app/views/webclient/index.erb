    // ====== TEST INPUT MENU SYSTEM ======
    // For testing various client-side features
    let testInputMenuActive = false;

    // ====== BACKGROUND MASK SYSTEM ======
    // Loads companion mask PNGs for background images.
    // Red channel = sky, Green channel = windows, Blue channel = wood/flammable
    const BackgroundMask = {
        loaded: false,
        maskUrl: null,
        width: 0,
        height: 0,
        pixels: null,
        bgWidth: 0,
        bgHeight: 0,

        load(maskUrl, bgWidth, bgHeight) {
            if (!maskUrl || maskUrl === this.maskUrl) return;
            this.clear();
            this.maskUrl = maskUrl;
            this.bgWidth = bgWidth;
            this.bgHeight = bgHeight;

            const img = new Image();
            img.crossOrigin = 'anonymous';
            img.onload = () => {
                const offscreen = document.createElement('canvas');
                offscreen.width = img.width;
                offscreen.height = img.height;
                const ctx = offscreen.getContext('2d', { willReadFrequently: true }) || offscreen.getContext('2d');
                ctx.drawImage(img, 0, 0);
                const imageData = ctx.getImageData(0, 0, img.width, img.height);

                this.width = img.width;
                this.height = img.height;
                this.pixels = imageData.data;
                this.loaded = true;
            };
            img.onerror = () => {
                this.clear();
            };
            img.src = maskUrl;
        },

        clear() {
            this.loaded = false;
            this.maskUrl = null;
            this.pixels = null;
            this.width = 0;
            this.height = 0;
        },

        _toMaskCoords(screenX, screenY) {
            if (!this.loaded || !this.bgWidth || !this.bgHeight) return null;
            const mx = Math.floor((screenX / this.bgWidth) * this.width);
            const my = Math.floor((screenY / this.bgHeight) * this.height);
            if (mx < 0 || mx >= this.width || my < 0 || my >= this.height) return null;
            return (my * this.width + mx) * 4;
        },

        hasMask() { return this.loaded; },

        isSky(screenX, screenY) {
            const offset = this._toMaskCoords(screenX, screenY);
            if (offset === null) return false;
            return this.pixels[offset] > 128;
        },

        isWindow(screenX, screenY) {
            const offset = this._toMaskCoords(screenX, screenY);
            if (offset === null) return false;
            return this.pixels[offset + 1] > 128;
        },

        isWood(screenX, screenY) {
            const offset = this._toMaskCoords(screenX, screenY);
            if (offset === null) return false;
            return this.pixels[offset + 2] > 128;
        }
    };

    // ====== RAIN CANVAS SYSTEM ======
    // Canvas-based rain for better performance (replaces DOM-based rain)
    class RainCanvas {
        constructor(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.drops = [];
            this.running = false;
            this.intensity = 1.0;
            this.windAngle = 0;
            this.baseCount = 120;
        }

        setIntensity(level) {
            const intensityMap = { light: 0.3, moderate: 0.6, heavy: 1.0, extreme: 1.5 };
            this.intensity = intensityMap[level] || 1.0;
            if (this.running) {
                this.adjustDropCount();
            }
        }

        setWind(active) {
            this.windAngle = active ? 0.2 : 0;
        }

        adjustDropCount() {
            const targetCount = Math.floor(this.baseCount * this.intensity);
            while (this.drops.length < targetCount) {
                this.drops.push(this.createDrop());
            }
            while (this.drops.length > targetCount) {
                this.drops.pop();
            }
        }

        createDrop() {
            return {
                x: Math.random() * this.canvas.width,
                y: Math.random() * this.canvas.height - this.canvas.height,
                length: 15 + Math.random() * 25,
                speed: 12 + Math.random() * 8,
                opacity: 0.15 + Math.random() * 0.25
            };
        }

        update() {
            if (!this.running) return;

            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

            const windOffset = Math.sin(this.windAngle);

            for (const drop of this.drops) {
                this.ctx.beginPath();
                this.ctx.strokeStyle = `rgba(180, 200, 255, ${drop.opacity})`;
                this.ctx.lineWidth = 1;

                const endX = drop.x + windOffset * drop.length;
                const endY = drop.y + drop.length;

                this.ctx.moveTo(drop.x, drop.y);
                this.ctx.lineTo(endX, endY);
                this.ctx.stroke();

                drop.y += drop.speed;
                drop.x += windOffset * drop.speed * 0.5;

                if (drop.y > this.canvas.height) {
                    drop.y = -drop.length;
                    drop.x = Math.random() * this.canvas.width;
                }
                if (drop.x < 0) drop.x = this.canvas.width;
                if (drop.x > this.canvas.width) drop.x = 0;
            }

            requestAnimationFrame(() => this.update());
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        start(intensity = 'moderate') {
            this.setIntensity(intensity);
            this.resize();
            this.drops = [];
            const count = Math.floor(this.baseCount * this.intensity);
            for (let i = 0; i < count; i++) {
                this.drops.push(this.createDrop());
                // Distribute drops across the screen initially
                this.drops[i].y = Math.random() * this.canvas.height;
            }
            this.running = true;
            this.update();
        }

        stop() {
            this.running = false;
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.drops = [];
        }
    }

    // ====== SNOW PARTICLE SYSTEM ======
    class SnowCanvas {
        constructor(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.flakes = [];
            this.running = false;
            this.intensity = 1.0;
            this.time = 0;
            this.lastTime = 0;
            this.baseCount = 120;

            // Pre-render a soft circle sprite for cheap drawImage calls
            this.sprite = document.createElement('canvas');
            this.sprite.width = 8;
            this.sprite.height = 8;
            const sctx = this.sprite.getContext('2d');
            const grad = sctx.createRadialGradient(4, 4, 0, 4, 4, 4);
            grad.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
            grad.addColorStop(0.5, 'rgba(255, 255, 255, 0.4)');
            grad.addColorStop(1, 'rgba(255, 255, 255, 0)');
            sctx.fillStyle = grad;
            sctx.fillRect(0, 0, 8, 8);
        }

        setIntensity(level) {
            const map = { light: 0.5, moderate: 1.0, heavy: 1.7, extreme: 2.5 };
            this.intensity = map[level] || 1.0;
            if (this.running) this.adjustFlakeCount();
        }

        adjustFlakeCount() {
            const target = Math.floor(this.baseCount * this.intensity);
            while (this.flakes.length < target) this.flakes.push(this.createFlake(true));
            while (this.flakes.length > target) this.flakes.pop();
        }

        createFlake(randomY = false) {
            const w = this.canvas.width;
            const h = this.canvas.height;
            const radius = 1 + Math.random() * 3;
            return {
                x: Math.random() * w,
                y: randomY ? Math.random() * h : -10,
                radius: radius,
                speed: 0.5 + radius * 0.4,
                drift: Math.random() * Math.PI * 2,
                driftSpeed: 0.3 + Math.random() * 0.7,
                driftAmount: 0.3 + Math.random() * 0.5,
                opacity: 0.3 + (radius / 4) * 0.6
            };
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        start(intensity = 'moderate') {
            this.setIntensity(intensity);
            this.resize();
            this.flakes = [];
            const count = Math.floor(this.baseCount * this.intensity);
            for (let i = 0; i < count; i++) this.flakes.push(this.createFlake(true));
            this.running = true;
            this.lastTime = performance.now();
            this.update();
        }

        stop() {
            this.running = false;
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.flakes = [];
        }

        update() {
            if (!this.running) return;

            const now = performance.now();
            const dt = Math.min((now - this.lastTime) / 16.67, 3);
            this.lastTime = now;
            this.time += dt * 0.02;

            const w = this.canvas.width;
            const h = this.canvas.height;

            this.ctx.clearRect(0, 0, w, h);

            for (const f of this.flakes) {
                f.x += Math.sin(this.time * f.driftSpeed + f.drift) * f.driftAmount * dt;
                f.y += f.speed * dt;

                if (f.y > h + 10) { f.y = -10; f.x = Math.random() * w; }
                if (f.x < -10) f.x = w + 10;
                if (f.x > w + 10) f.x = -10;

                this.ctx.globalAlpha = f.opacity;
                const size = f.radius * 2;
                this.ctx.drawImage(this.sprite, f.x - f.radius, f.y - f.radius, size, size);
            }

            this.ctx.globalAlpha = 1;
            requestAnimationFrame(() => this.update());
        }
    }

    // ====== FIRE EMBER PARTICLE SYSTEM ======
    class FireCanvas {
        constructor(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.embers = [];
            this.running = false;
            this.baseCount = 60;
            this.lastTime = 0;

            this.colors = [
                [255, 180, 50],
                [255, 120, 20],
                [255, 80, 10],
                [255, 200, 80],
                [255, 100, 30],
                [230, 60, 10]
            ];
        }

        createEmber(randomAge = false) {
            const w = this.canvas.width;
            const h = this.canvas.height;

            let x, y;
            const zone = Math.random();
            if (zone < 0.6) {
                x = Math.random() * w;
                y = h + 5;
            } else if (zone < 0.8) {
                x = -5;
                y = h * (0.4 + Math.random() * 0.6);
            } else {
                x = w + 5;
                y = h * (0.4 + Math.random() * 0.6);
            }

            const maxLife = 60 + Math.random() * 120;
            const color = this.colors[Math.floor(Math.random() * this.colors.length)];

            return {
                x, y,
                size: 2 + Math.random() * 4,
                speedY: -(1 + Math.random() * 3),
                speedX: (Math.random() - 0.5) * 1.0,
                life: randomAge ? Math.random() * maxLife : 0,
                maxLife,
                color,
                flicker: Math.random() * Math.PI * 2
            };
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        start() {
            this.resize();
            this.embers = [];
            for (let i = 0; i < this.baseCount; i++) {
                this.embers.push(this.createEmber(true));
            }
            this.running = true;
            this.lastTime = performance.now();
            this.update();
        }

        stop() {
            this.running = false;
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.embers = [];
        }

        update() {
            if (!this.running) return;

            const now = performance.now();
            const dt = Math.min((now - this.lastTime) / 16.67, 3);
            this.lastTime = now;

            const w = this.canvas.width;
            const h = this.canvas.height;

            this.ctx.clearRect(0, 0, w, h);

            const prevComp = this.ctx.globalCompositeOperation;
            this.ctx.globalCompositeOperation = 'lighter';

            for (let i = 0; i < this.embers.length; i++) {
                const e = this.embers[i];
                e.life += dt;

                if (e.life >= e.maxLife) {
                    this.embers[i] = this.createEmber(false);
                    continue;
                }

                e.y += e.speedY * dt;
                e.x += e.speedX * dt;
                e.speedY -= 0.02 * dt;
                e.speedX += (Math.random() - 0.5) * 0.1 * dt;

                const lifeRatio = e.life / e.maxLife;
                const fade = lifeRatio < 0.1 ? lifeRatio / 0.1 :
                             lifeRatio > 0.6 ? 1 - ((lifeRatio - 0.6) / 0.4) :
                             1;

                const flicker = 0.7 + 0.3 * Math.sin(e.life * 0.5 + e.flicker);
                const alpha = fade * flicker * 0.6;

                if (alpha <= 0) continue;

                const [r, g, b] = e.color;
                this.ctx.globalAlpha = alpha;
                this.ctx.fillStyle = `rgb(${r}, ${g}, ${b})`;
                this.ctx.beginPath();
                this.ctx.arc(e.x, e.y, e.size * (0.5 + fade * 0.5), 0, Math.PI * 2);
                this.ctx.fill();
            }

            this.ctx.globalCompositeOperation = prevComp;
            this.ctx.globalAlpha = 1;
            requestAnimationFrame(() => this.update());
        }
    }

    // ====== UNDERWATER CAUSTIC + BUBBLE SYSTEM ======
    class UnderwaterCanvas {
        constructor(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.caustics = [];
            this.bubbles = [];
            this.running = false;
            this.time = 0;
            this.lastTime = 0;
        }

        createCaustic() {
            const w = this.canvas.width;
            const h = this.canvas.height;
            return {
                x: Math.random() * w,
                y: Math.random() * h,
                radius: 30 + Math.random() * 60,
                driftX: (Math.random() - 0.5) * 0.3,
                driftY: (Math.random() - 0.5) * 0.2,
                phase: Math.random() * Math.PI * 2,
                scaleSpeed: 0.3 + Math.random() * 0.5,
                baseOpacity: 0.03 + Math.random() * 0.05
            };
        }

        createBubble(randomY = false) {
            const w = this.canvas.width;
            const h = this.canvas.height;
            return {
                x: Math.random() * w,
                y: randomY ? Math.random() * h : h + 10,
                radius: 2 + Math.random() * 6,
                speed: 0.5 + Math.random() * 1.5,
                drift: Math.random() * Math.PI * 2,
                driftSpeed: 0.5 + Math.random() * 1.0,
                driftAmount: 0.3 + Math.random() * 0.4,
                pulsePhase: Math.random() * Math.PI * 2,
                opacity: 0.2 + Math.random() * 0.3
            };
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        start() {
            this.resize();
            this.caustics = [];
            this.bubbles = [];
            for (let i = 0; i < 18; i++) this.caustics.push(this.createCaustic());
            for (let i = 0; i < 25; i++) this.bubbles.push(this.createBubble(true));
            this.running = true;
            this.lastTime = performance.now();
            this.update();
        }

        stop() {
            this.running = false;
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.caustics = [];
            this.bubbles = [];
        }

        update() {
            if (!this.running) return;

            const now = performance.now();
            const dt = Math.min((now - this.lastTime) / 16.67, 3);
            this.lastTime = now;
            this.time += dt * 0.015;

            const w = this.canvas.width;
            const h = this.canvas.height;
            this.ctx.clearRect(0, 0, w, h);

            // Draw caustics
            this.ctx.globalCompositeOperation = 'overlay';
            for (const c of this.caustics) {
                c.x += c.driftX * dt;
                c.y += c.driftY * dt;

                if (c.x < -c.radius) c.x = w + c.radius;
                if (c.x > w + c.radius) c.x = -c.radius;
                if (c.y < -c.radius) c.y = h + c.radius;
                if (c.y > h + c.radius) c.y = -c.radius;

                const scale = 0.8 + 0.4 * Math.sin(this.time * c.scaleSpeed + c.phase);
                const r = c.radius * scale;
                const opacity = c.baseOpacity * (0.7 + 0.3 * Math.sin(this.time * c.scaleSpeed * 1.5 + c.phase));

                this.ctx.globalAlpha = opacity;
                const grad = this.ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, r);
                grad.addColorStop(0, 'rgba(150, 220, 255, 0.3)');
                grad.addColorStop(0.5, 'rgba(180, 240, 255, 0.1)');
                grad.addColorStop(1, 'transparent');
                this.ctx.fillStyle = grad;
                this.ctx.beginPath();
                this.ctx.arc(c.x, c.y, r, 0, Math.PI * 2);
                this.ctx.fill();
            }

            // Draw bubbles
            this.ctx.globalCompositeOperation = 'source-over';
            for (let i = 0; i < this.bubbles.length; i++) {
                const b = this.bubbles[i];

                b.y -= b.speed * dt;
                b.x += Math.sin(this.time * b.driftSpeed + b.drift) * b.driftAmount * dt;

                const pulse = 1 + 0.1 * Math.sin(this.time * 2 + b.pulsePhase);
                const r = b.radius * pulse;

                if (b.y < -r * 2) {
                    b.y = h + r * 2;
                    b.x = Math.random() * w;
                }

                this.ctx.globalAlpha = b.opacity;
                this.ctx.strokeStyle = 'rgba(200, 230, 255, 0.5)';
                this.ctx.lineWidth = 1;
                this.ctx.beginPath();
                this.ctx.arc(b.x, b.y, r, 0, Math.PI * 2);
                this.ctx.stroke();

                this.ctx.globalAlpha = b.opacity * 0.6;
                this.ctx.strokeStyle = 'rgba(255, 255, 255, 0.6)';
                this.ctx.lineWidth = 1;
                this.ctx.beginPath();
                this.ctx.arc(b.x - r * 0.25, b.y - r * 0.25, r * 0.5, -0.8, 0.8);
                this.ctx.stroke();
            }

            this.ctx.globalAlpha = 1;
            this.ctx.globalCompositeOperation = 'source-over';
            requestAnimationFrame(() => this.update());
        }
    }

    // ====== LIGHTNING BOLT RENDERER ======
    const LightningRenderer = {
        canvas: null,
        ctx: null,
        activeBolts: [],
        flashOpacity: 0,
        animating: false,

        init(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
            window.addEventListener('resize', () => {
                if (this.canvas) {
                    this.canvas.width = window.innerWidth;
                    this.canvas.height = window.innerHeight;
                }
            });
        },

        generateBolt(x1, y1, x2, y2, displace, minSegment) {
            if (displace < minSegment) {
                return [{ x: x1, y: y1 }, { x: x2, y: y2 }];
            }
            const midX = (x1 + x2) / 2 + (Math.random() - 0.5) * displace;
            const midY = (y1 + y2) / 2 + (Math.random() - 0.5) * displace * 0.5;
            const left = this.generateBolt(x1, y1, midX, midY, displace / 2, minSegment);
            const right = this.generateBolt(midX, midY, x2, y2, displace / 2, minSegment);
            return [...left, ...right.slice(1)];
        },

        createBolt() {
            const w = this.canvas.width;
            const h = this.canvas.height;

            let startX, startY;

            if (typeof BackgroundMask !== 'undefined' && BackgroundMask.hasMask()) {
                // Try to find sky region points (max 20 attempts)
                let found = false;
                for (let attempt = 0; attempt < 20; attempt++) {
                    const sx = Math.random() * w;
                    const sy = Math.random() * h * 0.3;
                    if (BackgroundMask.isSky(sx, sy)) {
                        startX = sx;
                        startY = sy;
                        found = true;
                        break;
                    }
                }
                if (!found) {
                    // Fallback to top of screen
                    startX = Math.random() * w;
                    startY = Math.random() * h * 0.2;
                }
            } else {
                startX = Math.random() * w;
                startY = Math.random() * h * 0.2;
            }
            const endX = startX + (Math.random() - 0.5) * w * 0.4;
            const endY = h * 0.4 + Math.random() * h * 0.5;

            const mainBolt = this.generateBolt(startX, startY, endX, endY, w * 0.15, 8);

            const branches = [];
            const branchCount = 2 + Math.floor(Math.random() * 2);
            for (let i = 0; i < branchCount; i++) {
                const idx = Math.floor(mainBolt.length * (0.2 + Math.random() * 0.5));
                const branchStart = mainBolt[idx];
                if (!branchStart) continue;

                const angle = (Math.random() > 0.5 ? 1 : -1) * (20 + Math.random() * 20) * Math.PI / 180;
                const branchLen = 50 + Math.random() * 100;
                const branchEndX = branchStart.x + Math.sin(angle) * branchLen;
                const branchEndY = branchStart.y + Math.cos(angle) * branchLen;

                branches.push(this.generateBolt(
                    branchStart.x, branchStart.y,
                    branchEndX, branchEndY,
                    branchLen * 0.3, 6
                ));
            }

            return {
                main: mainBolt,
                branches,
                life: 0,
                maxLife: 12,
                holdFrames: 3
            };
        },

        strike() {
            this.activeBolts.push(this.createBolt());
            this.flashOpacity = 0.3;
            if (!this.animating) {
                this.animating = true;
                this.render();
            }
        },

        drawBoltPath(points, opacity, lineWidth) {
            if (points.length < 2) return;
            const ctx = this.ctx;

            ctx.save();
            ctx.globalAlpha = opacity;
            ctx.strokeStyle = 'white';
            ctx.lineWidth = lineWidth;
            ctx.shadowBlur = 15;
            ctx.shadowColor = 'rgba(180, 200, 255, 0.8)';
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';

            ctx.beginPath();
            ctx.moveTo(points[0].x, points[0].y);
            for (let i = 1; i < points.length; i++) {
                ctx.lineTo(points[i].x, points[i].y);
            }
            ctx.stroke();
            ctx.restore();
        },

        render() {
            const w = this.canvas.width;
            const h = this.canvas.height;

            this.ctx.clearRect(0, 0, w, h);

            // Flash — radial gradient with cyan-white tint (brighter at bolt origin)
            if (this.flashOpacity > 0) {
                this.ctx.save();
                const cx = w * 0.5, cy = h * 0.25;
                const grad = this.ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.max(w, h) * 0.75);
                const f = this.flashOpacity;
                grad.addColorStop(0,   `rgba(235, 245, 255, ${Math.min(f, 1)})`);
                grad.addColorStop(0.35, `rgba(200, 225, 255, ${Math.min(f * 0.65, 1)})`);
                grad.addColorStop(1,   `rgba(160, 200, 255, ${Math.min(f * 0.15, 1)})`);
                this.ctx.fillStyle = grad;
                this.ctx.fillRect(0, 0, w, h);
                this.ctx.restore();
                this.flashOpacity *= 0.72;
                if (this.flashOpacity < 0.01) this.flashOpacity = 0;
            }

            // Draw bolts
            for (let i = this.activeBolts.length - 1; i >= 0; i--) {
                const bolt = this.activeBolts[i];
                bolt.life++;

                let opacity;
                if (bolt.life <= bolt.holdFrames) {
                    opacity = 1;
                } else {
                    opacity = 1 - ((bolt.life - bolt.holdFrames) / (bolt.maxLife - bolt.holdFrames));
                }

                if (opacity <= 0) {
                    this.activeBolts.splice(i, 1);
                    continue;
                }

                this.drawBoltPath(bolt.main, opacity, 3);
                this.drawBoltPath(bolt.main, opacity * 0.5, 1);

                for (const branch of bolt.branches) {
                    this.drawBoltPath(branch, opacity * 0.7, 2);
                }
            }

            if (this.activeBolts.length > 0 || this.flashOpacity > 0) {
                requestAnimationFrame(() => this.render());
            } else {
                this.animating = false;
                this.ctx.clearRect(0, 0, w, h);
            }
        }
    };

    // ====== BLOOD SPATTER SYSTEM ======
    // Canvas-based blood spatters for damage visualization
    class BloodCanvas {
        constructor(canvas) {
            this.canvas = canvas;
            this.ctx = canvas.getContext('2d');
            this.spatters = [];
            this.running = false;
            this.lastHp = null;
        }

        resize() {
            this.canvas.width = window.innerWidth;
            this.canvas.height = window.innerHeight;
        }

        // Call when HP changes
        onHpChange(currentHp, maxHp, previousHp) {
            if (previousHp === null) {
                this.lastHp = currentHp;
                return;
            }

            const hpLost = previousHp - currentHp;
            if (hpLost <= 0) {
                this.lastHp = currentHp;
                return;
            }

            // Create spatters based on HP lost
            const spatterCount = Math.min(hpLost * 3, 12);
            for (let i = 0; i < spatterCount; i++) {
                this.createSpatter(hpLost);
            }

            this.lastHp = currentHp;

            if (!this.running) {
                this.running = true;
                this.update();
            }
        }

        // Simulate taking damage for testing
        simulateDamage(hpLost = 1) {
            const spatterCount = Math.min(hpLost * 3, 12);
            for (let i = 0; i < spatterCount; i++) {
                this.createSpatter(hpLost);
            }
            if (!this.running) {
                this.running = true;
                this.update();
            }
        }

        createSpatter(intensity) {
            const w = this.canvas.width;
            const h = this.canvas.height;

            // Full screen random placement
            const x = Math.random() * w;
            const y = Math.random() * h;

            // Size based on damage intensity
            const baseSize = 20 + Math.random() * 30;
            const size = baseSize * (0.5 + intensity * 0.25);

            this.spatters.push({
                x: x,
                y: y,
                size: size,
                opacity: 0.25 + Math.random() * 0.15,  // Start faded for readability
                fadeRate: 0.002 + Math.random() * 0.003,
                rotation: Math.random() * Math.PI * 2,
                shape: Math.floor(Math.random() * 3)  // Different splatter shapes
            });
        }

        drawSpatter(spatter) {
            const ctx = this.ctx;
            ctx.save();
            ctx.translate(spatter.x, spatter.y);
            ctx.rotate(spatter.rotation);
            ctx.globalAlpha = spatter.opacity;

            // Dark red blood color
            ctx.fillStyle = 'rgb(100, 20, 20)';

            // Draw irregular splatter shape
            ctx.beginPath();
            const s = spatter.size;

            if (spatter.shape === 0) {
                // Blob shape
                ctx.ellipse(0, 0, s, s * 0.7, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(s * 0.3, s * 0.2, s * 0.4, s * 0.3, 0.5, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(-s * 0.4, -s * 0.1, s * 0.3, s * 0.25, -0.3, 0, Math.PI * 2);
            } else if (spatter.shape === 1) {
                // Star burst
                for (let i = 0; i < 5; i++) {
                    const angle = (i / 5) * Math.PI * 2;
                    const len = s * (0.6 + Math.random() * 0.4);
                    ctx.lineTo(Math.cos(angle) * len, Math.sin(angle) * len);
                    const midAngle = angle + Math.PI / 5;
                    ctx.lineTo(Math.cos(midAngle) * s * 0.3, Math.sin(midAngle) * s * 0.3);
                }
                ctx.closePath();
            } else {
                // Drip shape
                ctx.ellipse(0, 0, s * 0.5, s * 0.5, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(0, s * 0.6, s * 0.3, s * 0.4, 0, 0, Math.PI * 2);
                ctx.fill();
                ctx.beginPath();
                ctx.ellipse(0, s * 1.1, s * 0.2, s * 0.25, 0, 0, Math.PI * 2);
            }

            ctx.fill();
            ctx.restore();
        }

        update() {
            if (!this.running) return;

            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

            // Update and draw spatters
            for (let i = this.spatters.length - 1; i >= 0; i--) {
                const spatter = this.spatters[i];
                spatter.opacity -= spatter.fadeRate;

                if (spatter.opacity <= 0) {
                    this.spatters.splice(i, 1);
                } else {
                    this.drawSpatter(spatter);
                }
            }

            // Stop animation when no spatters left
            if (this.spatters.length === 0) {
                this.running = false;
            } else {
                requestAnimationFrame(() => this.update());
            }
        }

        clear() {
            this.spatters = [];
            this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
            this.running = false;
        }
    }

