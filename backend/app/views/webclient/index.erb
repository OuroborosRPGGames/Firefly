        // Initialize media sync (screen share, YouTube watch parties)
        if (window.MediaSync) {
            window.MediaSync.init();
        }

        // Panels are now visible by default (no visibility:hidden in CSS)

        // Focus on the input
        if (messageInput) {
            messageInput.focus();
        }

        // Scroll both panels to bottom
        scrollToBottom(lMessageWindow);
        scrollToBottom(rMessageWindow);

        // Draw initial minimap with current room's exits (spatial adjacency)
        <% spatial_exits = @room&.passable_spatial_exits || [] %>
        const initialExits = <%= (spatial_exits.map { |e| { direction: e[:direction].to_s, to_room_name: e[:room]&.name, direction_arrow: CanvasHelper::DIRECTION_ARROWS[e[:direction].to_s] } }).to_json %>;
        <%
          begin
            _minimap_result = CityMapRenderService.render(viewer: @character_instance, mode: :minimap)
            minimap_data = { svg: _minimap_result[:svg], metadata: _minimap_result[:metadata] }
          rescue StandardError => e
            warn "[Webclient] Initial minimap generation failed: #{e.message}"
            minimap_data = nil
          end
        %>
        <% if minimap_data && minimap_data[:svg] %>
        drawMinimapSvg(<%= minimap_data[:svg].to_json %>, <%= (minimap_data[:metadata] || {}).to_json %>);
        showMinimap();
        <% elsif spatial_exits.any? %>
        drawSimpleMinimap(currentRoomName, initialExits);
        <% end %>

        // Initialize panel status bars
        updateStatusBars();

        // Apply initial weather effects (snow, rain, etc.) based on server data
        if (weatherData) {
            applyWeatherEffects(weatherData);
        }

        // Update time display every minute
        setInterval(() => {
            updateLeftStatusBar();
        }, 60000);

        // Periodic minimap refresh (every 5 seconds when not in a delve)
        setInterval(async () => {
            if (inDelve) return;
            try {
                const resp = await apiGet('/api/minimap');
                if (!resp.ok) return;
                const data = await resp.json();
                // Server returns in_delve:true when character is in a delve
                // (handles race condition where inDelve isn't set yet on client)
                if (data.in_delve) return;
                if (data.success && data.minimap_data && data.minimap_data.svg) {
                    drawMinimapSvg(data.minimap_data.svg, data.minimap_data.metadata);
                    if (data.room_name) {
                        currentRoomName = data.room_name;
                        updateRightStatus(data.room_name);
                    }
                }
            } catch (e) {
                // Silent fail - background poll
            }
        }, 5000);

        // Periodic delve state refresh (every 5 seconds when in a delve)
        setInterval(async () => {
            if (!inDelve) return;
            try {
                const resp = await apiGet('/api/delve_state');
                if (!resp.ok) return;
                const data = await resp.json();
                if (data.success && data.in_delve) {
                    handleDelveMapUpdate(data, true);
                } else if (data.in_delve === false && inDelve) {
                    exitDelveMap();
                }
            } catch (e) {
                // Silent fail - background poll
            }
        }, 5000);
    });

