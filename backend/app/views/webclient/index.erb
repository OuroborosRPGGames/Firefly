        messageEl.innerHTML = escapeHtml(content);

        const targetContainer = panel === 'left' ? lMessages : rMessages;
        const targetWindow = panel === 'left' ? lMessageWindow : rMessageWindow;

        if (targetContainer) {
            targetContainer.appendChild(messageEl);
            scrollToBottom(targetWindow);
        }
    }

    // Add a temporary message that disappears after a few seconds
    function addTempMessage(content, panel, duration = 4000) {
        const messageEl = document.createElement('div');
        messageEl.className = 'message message-system temp-message';
        messageEl.innerHTML = escapeHtml(content);

        const targetContainer = panel === 'left' ? lMessages : rMessages;
        const targetWindow = panel === 'left' ? lMessageWindow : rMessageWindow;

        if (targetContainer) {
            targetContainer.appendChild(messageEl);
            scrollToBottom(targetWindow);

            // Remove after animation completes
            setTimeout(() => {
                if (messageEl.parentNode) {
                    messageEl.parentNode.removeChild(messageEl);
