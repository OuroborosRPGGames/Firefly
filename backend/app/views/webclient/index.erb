    // ====== WEATHER EFFECTS ======

    function toggleRainEffect(intensity = 'moderate') {
        weatherState.rain = !weatherState.rain;
        const rainAudio = document.getElementById('rainAudio');

        if (weatherState.rain) {
            // Use WebGL rain if available
            if (weatherGL && !prefersReducedMotion) {
                weatherGL.startRain({ intensity, windEnabled: weatherState.wind });
            }

            // Play rain sound
            if (rainAudio && !weatherState.ambientMuted) {
                rainAudio.volume = getVolume(0.3);
                rainAudio.play().catch(() => {});
            }
            showImprint('Rain started', 3000, '🌧️');
        } else {
            // Stop WebGL rain
            if (weatherGL) weatherGL.stop();

            // Stop rain sound (unless thunderstorm is active)
            if (rainAudio && !weatherState.thunderstorm) {
                rainAudio.pause();
            }
            showImprint('Rain stopped', 3000, '☀️');
        }
    }

    function toggleWindEffect() {
        weatherState.wind = !weatherState.wind;
        const windAudio = document.getElementById('windAudio');

        // Update rain wind angle if rain is active
        if (weatherGL && weatherState.rain) {
            weatherGL.setWind(weatherState.wind);
        }

        if (weatherState.wind) {
            // Play wind sound
            if (windAudio && !weatherState.ambientMuted) {
                windAudio.volume = getVolume(0.3);
                windAudio.play().catch(() => {});
            }
            showImprint('Wind started', 3000, '💨');
        } else {
            // Stop wind sound (unless thunderstorm is active)
            if (windAudio && !weatherState.thunderstorm) {
                windAudio.pause();
            }
            showImprint('Wind stopped', 3000, '🍃');
        }
    }

    // Note: createRaindrops (DOM-based) replaced by RainCanvas (canvas-based)
    // for better performance. Old DOM rain divs kept for fallback.

    function toggleSnowEffect(intensity = 'moderate') {
        weatherState.snow = !weatherState.snow;

        if (weatherState.snow) {
            if (weatherGL && !prefersReducedMotion) {
                weatherGL.startSnow({ intensity });
            }
            showImprint('Snow started', 3000, '\u2744\uFE0F');
        } else {
            if (weatherGL) weatherGL.stop();
            showImprint('Snow stopped', 3000, '\u2600\uFE0F');
        }
    }

    function toggleThunderstormEffect() {
        weatherState.thunderstorm = !weatherState.thunderstorm;
        const thunderOverlay = document.getElementById('thunderstormOverlay');
        const rainAudio = document.getElementById('rainAudio');
        const windAudio = document.getElementById('windAudio');

        if (weatherState.thunderstorm) {
            if (thunderOverlay) thunderOverlay.classList.add('active');

            // Activate extreme rain with wind for thunderstorm
            if (weatherGL && !prefersReducedMotion) {
                weatherGL.startRain({ intensity: 'extreme', windEnabled: true });
            }
            weatherState.rain = true;
            weatherState.wind = true;

            // Play rain and wind sounds
            if (!weatherState.ambientMuted) {
                if (rainAudio) {
                    rainAudio.volume = getVolume(0.4);
                    rainAudio.play().catch(() => {});
                }
                if (windAudio) {
                    windAudio.volume = getVolume(0.4);
                    windAudio.play().catch(() => {});
                }
            }

            // Start lightning flashes
            startLightning();
            showImprint('Thunderstorm started', 3000, '⛈️');
        } else {
            if (thunderOverlay) thunderOverlay.classList.remove('active');
            // Stop lightning
            stopLightning();

            // Turn off wind and rain with the storm
            weatherState.rain = false;
            weatherState.wind = false;
            if (weatherGL) weatherGL.stop();
            if (rainAudio) rainAudio.pause();
            if (windAudio) windAudio.pause();

            showImprint('Thunderstorm stopped', 3000, '☀️');
        }
    }

    function toggleAmbientMute() {
        weatherState.ambientMuted = !weatherState.ambientMuted;
        const rainAudio = document.getElementById('rainAudio');
        const windAudio = document.getElementById('windAudio');

        if (weatherState.ambientMuted) {
            // Mute all ambient sounds
            if (rainAudio) rainAudio.pause();
            if (windAudio) windAudio.pause();
            showImprint('Ambient sounds muted', 3000, '🔇');
        } else {
            // Resume sounds if weather effects are active
            if (weatherState.rain || weatherState.thunderstorm) {
                if (rainAudio) {
                    rainAudio.volume = getVolume(weatherState.thunderstorm ? 0.4 : 0.3);
                    rainAudio.play().catch(() => {});
                }
            }
            if (weatherState.wind || weatherState.thunderstorm) {
                if (windAudio) {
                    windAudio.volume = getVolume(weatherState.thunderstorm ? 0.4 : 0.3);
                    windAudio.play().catch(() => {});
                }
            }
            showImprint('Ambient sounds unmuted', 3000, '🔊');
        }
    }

    function playRandomThunder() {
        if (weatherState.ambientMuted) return;

        const thunderNum = Math.floor(Math.random() * 3) + 1;
        const thunderAudio = document.getElementById(`thunder${thunderNum}Audio`);
        if (thunderAudio) {
            // Random delay like distant thunder
            const delay = Math.floor(Math.random() * 1000);
            setTimeout(() => {
                thunderAudio.currentTime = 0;
                thunderAudio.volume = getVolume(0.3 + Math.random() * 0.4);
                thunderAudio.play().catch(() => {});
            }, delay);
        }
    }

    function startLightning() {
        // Random lightning strikes
        const triggerLightning = () => {
            if (!weatherState.thunderstorm) return;

            // Draw lightning bolt on canvas
            if (LightningRenderer.canvas) {
                LightningRenderer.strike();
            }

            // Play random thunder sound
            playRandomThunder();

            // Schedule next lightning
            const nextDelay = 2000 + Math.random() * 8000;
            weatherState.thunderInterval = setTimeout(triggerLightning, nextDelay);
        };

        // Start first lightning after a short delay
        weatherState.thunderInterval = setTimeout(triggerLightning, 1000 + Math.random() * 3000);
    }

    function stopLightning() {
        if (weatherState.thunderInterval) {
            clearTimeout(weatherState.thunderInterval);
            weatherState.thunderInterval = null;
        }
    }

    // ====== ENVIRONMENT EFFECTS ======
    // Mist, fire, underwater - triggered by room type or combat state

    function toggleMistEffect(active, intensity = 'moderate') {
        if (prefersReducedMotion) return;
        const mistDiv = document.getElementById('mistdiv');
        if (!mistDiv) return;

        environmentState.mist = active;
        mistDiv.style.display = active ? 'block' : 'none';

        if (active) {
            mistDiv.className = `environment-mist intensity-${intensity}`;
        }
    }

    function toggleFireEffect(active) {
        if (prefersReducedMotion) return;
        const fireDiv = document.getElementById('firediv');

        environmentState.fire = active;

        // CSS edge glow
        if (fireDiv) fireDiv.style.display = active ? 'block' : 'none';

        // Canvas embers
        if (active) {
            if (fireCanvas) fireCanvas.start();
        } else {
            if (fireCanvas) fireCanvas.stop();
        }
    }

    // mode: 'submerged' (full-screen), 'inwater' (bottom third), or falsy (off)
    function toggleUnderwaterEffect(active, mode) {
        if (prefersReducedMotion) return;
        const underwaterDiv = document.getElementById('underwaterdiv');
        const bgEl = document.getElementById('backgroundimage');

        environmentState.underwater = active;

        // CSS overlay (blue tint + light rays) — only for full submersion
        if (underwaterDiv) underwaterDiv.style.display = (active && mode === 'submerged') ? 'block' : 'none';

        // SVG distortion filter on background — only for full submersion
        if (bgEl) {
            bgEl.style.filter = (active && mode === 'submerged') ? 'url(#underwater-distort)' : '';
        }

        // WebGL caustic light patterns
        if (active && underwaterGL) {
            if (mode === 'inwater') {
                underwaterGL.startInWater();
            } else {
                underwaterGL.start();
            }
        } else if (underwaterGL) {
            underwaterGL.stop();
        }
    }

    // Track current room environment for effects
    let currentRoomEnvironment = {
        roomType: null,
        hasFireHazard: false,
        isUnderwater: false
    };

    // Apply environment effects based on room data
    function applyEnvironmentEffects(roomData) {
        if (!roomData || currentSettings.simpleui || prefersReducedMotion) return;

        const roomType = roomData.room_type || roomData.room?.room_type;

        // Underwater / in-water effects based on room type.
        // Full submersion (whole-screen caustics) vs in-water (bottom-third only).
        const submergedTypes = ['water', 'ocean', 'underwater'];
        const inWaterTypes   = ['lake', 'river', 'pool', 'bath', 'hot_spring', 'spring'];
        if (submergedTypes.includes(roomType)) {
            toggleUnderwaterEffect(true, 'submerged');
        } else if (inWaterTypes.includes(roomType)) {
            toggleUnderwaterEffect(true, 'inwater');
        } else {
            toggleUnderwaterEffect(false);
        }

        // Mist: for caves/underground rooms (fog weather is handled separately)
        const undergroundTypes = ['cave', 'sewer', 'tunnel', 'mine', 'crypt', 'dungeon'];
        const isMisty = undergroundTypes.includes(roomType);
        // Only enable if fog weather not already active
        if (!weatherState.fog) {
            toggleMistEffect(isMisty, 'light');
        }

        currentRoomEnvironment = {
            roomType,
            hasFireHazard: false,  // Fire is handled by battle map
            isUnderwater: environmentState.underwater
        };
    }

    // Check if character is on fire hazard or has burning status
    function updateFireEffectFromCombat(battleMapData) {
        if (!battleMapData || currentSettings.simpleui || prefersReducedMotion) {
            toggleFireEffect(false);
            return;
        }

        // Find the viewer's participant
        const viewerParticipant = battleMapData.participants?.find(p => p.is_viewer);
        if (!viewerParticipant) {
            toggleFireEffect(false);
            return;
        }

        // Check for burning status effect
        const hasBurningStatus = viewerParticipant.status_effects?.some(
            e => e.name?.toLowerCase().includes('burning') || e.name?.toLowerCase().includes('on fire')
        );

        // Check if standing on a fire hazard hex
        const hexes = battleMapData.hexes || [];
        const onFireHex = hexes.some(hex =>
            hex.x === viewerParticipant.hex_x &&
            hex.y === viewerParticipant.hex_y &&
            (hex.hazard_type === 'fire' || hex.type === 'fire')
        );

        toggleFireEffect(hasBurningStatus || onFireHex);
    }

    // ====== HP TRACKING FOR BLOOD EFFECTS ======
    let previousCharacterHp = null;

    function onCharacterHpUpdate(currentHp, maxHp) {
        if (bloodCanvas && previousCharacterHp !== null && !prefersReducedMotion) {
            bloodCanvas.onHpChange(currentHp, maxHp, previousCharacterHp);
        }
        previousCharacterHp = currentHp;
    }

    // ====== SERVER-TRIGGERED WEATHER EFFECTS ======

    let currentWeatherEffects = { condition: null, isOutdoor: false };

    const WEATHER_EFFECT_MAP = {
        'rain': { effect: 'rain', requires: 'outdoor' },
        'storm': { effect: 'thunderstorm', requires: 'outdoor' },
        'thunderstorm': { effect: 'thunderstorm', requires: 'outdoor' },
        'snow': { effect: 'snow', requires: 'outdoor' },
        'blizzard': { effect: 'snow', requires: 'outdoor' },
        'wind': { effect: 'wind', requires: 'outdoor' },
        'fog': { effect: 'fog', requires: 'outdoor' },
        'clear': { effect: null },
        'cloudy': { effect: null },
        'overcast': { effect: null },
        'hail': { effect: 'rain', requires: 'outdoor' },
        'hurricane': { effect: 'thunderstorm', requires: 'outdoor' },
        'tornado': { effect: 'thunderstorm', requires: 'outdoor' },
        'heat_wave': { effect: null },
        'cold_snap': { effect: null }
    };

    function applyWeatherEffects(weatherData) {
        if (!weatherData || currentSettings.simpleui || prefersReducedMotion) return;

        const condition = weatherData.condition;
        const isOutdoor = weatherData.is_outdoor;
        const intensity = weatherData.intensity || 'moderate';

        // Skip if nothing changed
        if (currentWeatherEffects.condition === condition &&
            currentWeatherEffects.isOutdoor === isOutdoor &&
            currentWeatherEffects.intensity === intensity) return;

        // Stop all current effects first
        stopAllWeatherEffects();

        // Only apply effects if outdoors
        if (isOutdoor) {
            const mapping = WEATHER_EFFECT_MAP[condition];
            if (mapping && mapping.effect) {
                startWeatherEffect(mapping.effect, intensity);
            }
        }

        currentWeatherEffects = { condition, isOutdoor, intensity };
    }

    function startWeatherEffect(effectType, intensity = 'moderate') {
        switch (effectType) {
            case 'rain':
                if (!weatherState.rain) {
                    toggleRainEffect(intensity);
                } else if (weatherGL) {
                    weatherGL.setIntensity(intensity);
                }
                break;
            case 'snow':
                if (!weatherState.snow) {
                    toggleSnowEffect(intensity);
                } else if (weatherGL) {
                    weatherGL.setIntensity(intensity);
                }
                break;
            case 'thunderstorm':
                if (!weatherState.thunderstorm) toggleThunderstormEffect();
                break;
            case 'wind':
                if (!weatherState.wind) toggleWindEffect();
                break;
            case 'fog':
                // WebGL animated FBM fog on dedicated canvas
                if (fogGL) {
                    fogGL.startFog({ intensity });
                } else {
                    // CSS fallback
                    const bgEl = document.getElementById('backgroundimage');
                    if (bgEl) {
                        bgEl.classList.add('foggy');
                        bgEl.classList.remove('intensity-light', 'intensity-moderate', 'intensity-heavy', 'intensity-extreme');
                        bgEl.classList.add(`intensity-${intensity}`);
                    }
                }
                weatherState.fog = true;
                break;
        }
    }

    function stopAllWeatherEffects() {
        if (weatherState.rain && !weatherState.thunderstorm) {
            toggleRainEffect();
        }
        if (weatherState.snow) {
            toggleSnowEffect();
        }
        if (weatherState.thunderstorm) {
            toggleThunderstormEffect();
        }
        if (weatherState.wind && !weatherState.thunderstorm) {
            toggleWindEffect();
        }
        // Stop WebGL fog (or CSS fallback)
        if (fogGL) {
            fogGL.stop();
        } else {
            const bgEl = document.getElementById('backgroundimage');
            if (bgEl) {
                bgEl.classList.remove('foggy', 'intensity-light', 'intensity-moderate', 'intensity-heavy', 'intensity-extreme');
            }
        }
        weatherState.fog = false;
    }

    // Handle keyboard shortcuts for test input menu
    document.addEventListener('keydown', (e) => {
        if (!testInputMenuActive) return;

        if (e.key === 'Escape') {
            testInputMenuActive = false;
            if (tempResultPaneEl) {
                tempResultPaneEl.classList.remove('compact-menu');
            }
            hideTempResult();
            return;
        }

        // Handle digit keys 1-9 for immediate selection
        if (/^[1-9]$/.test(e.key)) {
            e.preventDefault();
            handleTestInputOption(parseInt(e.key));
            return;
        }

        // Handle 0 key for thunderstorm (option 10)
        if (e.key === '0') {
            e.preventDefault();
            handleTestInputOption(10);
            return;
        }

        // Handle M key for mute toggle (option 11)
        if (e.key.toLowerCase() === 'm') {
            e.preventDefault();
            handleTestInputOption(11);
            return;
        }

        // Handle I key for mist toggle (option 12)
        if (e.key.toLowerCase() === 'i') {
            e.preventDefault();
            handleTestInputOption(12);
            return;
        }

        // Handle F key for fire toggle (option 13)
        if (e.key.toLowerCase() === 'f') {
            e.preventDefault();
            handleTestInputOption(13);
            return;
        }

        // Handle U key for underwater toggle (option 14)
        if (e.key.toLowerCase() === 'u') {
            e.preventDefault();
            handleTestInputOption(14);
            return;
        }

        // Handle B key for blood spatter (option 15)
        if (e.key.toLowerCase() === 'b') {
            e.preventDefault();
            handleTestInputOption(15);
            return;
        }
    });

    let backgroundImageEl;
    let currentBackgroundImage = '';
    let tempResultPaneEl;
    let minimapWindowEl;
    let minimapCanvasEl;
    let observeWindowEl;
    let lobserveEl;
    let lobserveContentEl;

    // Track observation state
    let currentObservation = null;
    let leftObserveActive = false;
    let inDelve = false;

    function cacheElements() {
        messageInput = document.getElementById('message_content');
        messageSide = document.getElementById('message_side');
        lMessages = document.getElementById('lmessages');
        rMessages = document.getElementById('rmessages');
        lMessageWindow = document.getElementById('lmessagewindow');
        rMessageWindow = document.getElementById('rmessagewindow');
        imprintEl = document.getElementById('imprint');
        consentNoticeBadgeEl = document.getElementById('consentNoticeBadge');
        consentNoticeTriggerEl = document.getElementById('consentNoticeTrigger');
        consentNoticeTooltipEl = document.getElementById('consentNoticeTooltip');
        backgroundImageEl = document.getElementById('backgroundimage');
        tempResultPaneEl = document.getElementById('tempResultPane');
        minimapWindowEl = document.getElementById('minimapwindow');
        minimapCanvasEl = document.getElementById('minimapCanvas');
        observeWindowEl = document.getElementById('observeWindow');
        lobserveEl = document.getElementById('lobserve');
        lobserveContentEl = lobserveEl?.querySelector('.lobserve-content');
    }

    // ====== BACKGROUND IMAGE ======
    // Update the room background image with Ravencroft-style fade
    function updateRoomBackgroundImage(imageUrl, maskUrl) {
        if (!backgroundImageEl) return;

        // Don't update if same image
        if (imageUrl === currentBackgroundImage) return;

        if (imageUrl && imageUrl.length > 2) {
            currentBackgroundImage = imageUrl;
            backgroundImageEl.style.backgroundImage = `url('${imageUrl}')`;

            // Restart the fade animation
            backgroundImageEl.style.animation = 'none';
            setTimeout(() => {
                backgroundImageEl.style.animation = 'backgroundFadeIn 12s ease-out forwards';
            }, 10);

            // Load mask if provided
            if (maskUrl) {
                const bgRect = backgroundImageEl.getBoundingClientRect();
                BackgroundMask.load(maskUrl, bgRect.width, bgRect.height);
            } else {
                BackgroundMask.clear();
            }
        }
    }

    // Clear room background image
    function clearRoomBackgroundImage() {
        if (backgroundImageEl) {
            backgroundImageEl.style.backgroundImage = '';
            currentBackgroundImage = '';
        }
    }

    // ====== TEMPORARY RESULT PANE ======
    // Shows command results (look, examine, etc.) - disappears on Enter or new command

    let tempPaneSide = 'right'; // Track which side the temp pane is currently on

    // Keep message window bottom in sync with temp pane height (handles image loads, content reflow)
    function adjustMessageWindowForTempPane() {
        if (!tempResultPaneEl || !tempResultPaneEl.classList.contains('visible')) return;
        const tempHeight = tempResultPaneEl.offsetHeight;
        const baseBottom = 116; // input (90) + status bar (26)
        const newBottom = baseBottom + tempHeight;
        const targetMsgWindow = tempPaneSide === 'left' ? lMessageWindow : rMessageWindow;
        if (targetMsgWindow) {
            targetMsgWindow.style.bottom = newBottom + 'px';
            // Scroll immediately and again after the CSS transition (150ms) completes,
            // since the window shrinks from the bottom and the scroll position drifts
            scrollToBottom(targetMsgWindow);
            setTimeout(() => scrollToBottom(targetMsgWindow), 160);
        }
    }

    // ResizeObserver re-adjusts message window whenever temp pane content changes height
    if (typeof ResizeObserver !== 'undefined') {
        const tempPaneObserver = new ResizeObserver(() => {
            adjustMessageWindowForTempPane();
        });
        if (tempResultPaneEl) {
            tempPaneObserver.observe(tempResultPaneEl);
        }
    }

    function showTempResult(title, content, side = 'right') {
        if (!tempResultPaneEl) return;

        tempPaneSide = side;

        const titleEl = tempResultPaneEl.querySelector('.temp-title');
        const contentEl = tempResultPaneEl.querySelector('.temp-content');

        if (titleEl) titleEl.textContent = title;
        // SVG content must not go through processContentForDisplay (newline→<br> breaks SVG)
        const isSvg = typeof content === 'string' && content.includes('<svg');
        if (contentEl) contentEl.innerHTML = isSvg ? content : processContentForDisplay(content);

        // Attach map click handler to SVG now that it's in the DOM
        if (isSvg && contentEl) {
            const svg = contentEl.querySelector('svg');
            if (svg) svg.addEventListener('click', handleMapClick);
        }

        // Position based on side
        if (side === 'left') {
            tempResultPaneEl.classList.add('left-side');
        } else {
            tempResultPaneEl.classList.remove('left-side');
        }

        tempResultPaneEl.classList.add('visible');

        // After render, measure temp pane height and adjust message window
        requestAnimationFrame(() => {
            adjustMessageWindowForTempPane();
        });

        // Setup close button
        const closeBtn = tempResultPaneEl.querySelector('.temp-close');
        if (closeBtn) {
            closeBtn.onclick = hideTempResult;
        }
    }

    function hideTempResult() {
        if (tempResultPaneEl) {
            tempResultPaneEl.classList.remove('visible');

            // Reset message window bottoms to default (116px = input + status bar)
            // But don't reset left if left observe panel is active (it manages its own height)
            if (lMessageWindow && !leftObserveActive) lMessageWindow.style.bottom = '';
            if (rMessageWindow) rMessageWindow.style.bottom = '';
        }
    }

    // ====== LEFT OBSERVE PANEL (PERSISTENT) ======
    // Shows observe command results - persists until "observe stop"
    // Does NOT dismiss on Enter like tempResultPane

    function showLobserve(title, html) {
        if (!lobserveEl) return;
        const titleEl = lobserveEl.querySelector('.lobserve-title');
        const contentEl = lobserveEl.querySelector('.lobserve-content');
        if (titleEl) titleEl.textContent = title;
        // SVG content must not go through processContentForDisplay
        const isSvg = typeof html === 'string' && html.includes('<svg');
        if (contentEl) contentEl.innerHTML = isSvg ? html : processContentForDisplay(html);

        // Show header + content, hide battle-map stuff
        const headerEl = lobserveEl.querySelector('.lobserve-header');
        if (headerEl) headerEl.style.display = '';
        if (contentEl) contentEl.style.display = '';

        lobserveEl.classList.add('visible');
        leftObserveActive = true;
        requestAnimationFrame(() => adjustLobserveHeight());
    }

    function hideLobserve() {
        if (!lobserveEl) return;
        lobserveEl.classList.remove('visible');
        leftObserveActive = false;
        if (lMessageWindow) lMessageWindow.style.bottom = '';
        scrollToBottom(lMessageWindow);
    }

    function adjustLobserveHeight() {
        if (!lobserveEl) return;
        if (!lobserveEl.classList.contains('visible') && !lobserveEl.classList.contains('battle-map-active') && !lobserveEl.classList.contains('delve-map-active')) return;
        const height = lobserveEl.offsetHeight;
        const baseBottom = 116;
        if (lMessageWindow) {
            lMessageWindow.style.bottom = (baseBottom + height) + 'px';
            scrollToBottom(lMessageWindow);
            setTimeout(() => scrollToBottom(lMessageWindow), 160);
        }
    }

    // ====== DELVE HUD ======
    // Shows dungeon HUD during delve exploration (stats bar, map, controls)

    function handleDelveMapUpdate(data) {
        if (!data) return;

        const hud = document.getElementById('delve-hud');
        if (!hud) return;

        // Track delve state even if we can't show HUD right now
        var wasInDelve = inDelve;
        inDelve = true;
        delveActive = true;

        // Don't show the delve HUD if battle map is active — it will restore when combat ends
        if (battleMapActive) return;

        // Enter/restore delve mode (also re-shows HUD if it was closed for any reason)
        if (!wasInDelve || hud.classList.contains('hidden')) {
            hideMinimap();
            hud.classList.remove('hidden');

            // Hide normal lobserve content
            if (lobserveEl) {
                const headerEl = lobserveEl.querySelector('.lobserve-header');
                const contentEl = lobserveEl.querySelector('.lobserve-content');
                if (headerEl) headerEl.style.display = 'none';
                if (contentEl) contentEl.style.display = 'none';
                lobserveEl.classList.add('visible', 'delve-map-active');
                lobserveEl.style.display = '';
                leftObserveActive = true;
            }

            // Init map panel (re-init if restoring)
            const mapContainer = document.getElementById('delve-map-container');
            if (mapContainer && typeof DelveMapPanel !== 'undefined') {
                if (wasInDelve) DelveMapPanel.destroy();
                DelveMapPanel.init(mapContainer);
            }
        }

        // Update stats bar
        updateDelveStatsBar(data);

        // Update map SVG (soft update preserves user's pan/zoom position)
        if (data.delve_map_svg) {
            const mapContainer = document.getElementById('delve-map-container');
            if (mapContainer && typeof DelveMapPanel !== 'undefined') {
                DelveMapPanel.softUpdateMap(data.delve_map_svg);
            }
        }

        // Update controls bar
        if (data.current_room) {
            updateDelveControls(data.current_room);
        }

        requestAnimationFrame(() => adjustLobserveHeight());
    }

    function updateDelveStatsBar(data) {
        const nameEl = document.getElementById('delve-dungeon-name');
        const timerEl = document.getElementById('delve-timer');
        const hpEl = document.getElementById('delve-hp');
        const wpEl = document.getElementById('delve-willpower');
        const lootEl = document.getElementById('delve-loot');

        if (nameEl && data.delve_name) {
            const level = data.current_level || 1;
            nameEl.textContent = data.delve_name + ' L' + level;
        }

        if (timerEl && data.time_remaining != null) {
            delveTimeRemaining = data.time_remaining;
            updateDelveTimer();
        }

        if (hpEl && data.current_hp != null) {
            const cur = data.current_hp;
            const max = data.max_hp || 6;
            hpEl.textContent = '\u2764 ' + cur + '/' + max;
            hpEl.className = 'delve-stat delve-hp';
            if (cur <= 2) hpEl.classList.add('low');
            else if (cur <= max / 2) hpEl.classList.add('half');
        }

        if (wpEl && data.willpower_dice != null) {
            wpEl.textContent = '\u26A1 ' + data.willpower_dice;
        }

        if (lootEl && data.loot_collected != null) {
            lootEl.textContent = '\uD83D\uDCB0 ' + data.loot_collected + 'g';
        }
    }

    function updateDelveTimer() {
        const timerEl = document.getElementById('delve-timer');
        if (!timerEl || !delveActive) return;

        // Display server-provided time in seconds (delve time is action-based, not real-time)
        const totalSecs = Math.max(0, Math.floor(delveTimeRemaining));

        const mins = Math.floor(totalSecs / 60);
        const secs = totalSecs % 60;
        const timeStr = mins + ':' + secs.toString().padStart(2, '0');

        if (totalSecs <= 0) {
            timerEl.textContent = '\u23F1 TIME UP!';
            timerEl.className = 'delve-stat delve-timer critical';
        } else if (totalSecs <= 180) {
            timerEl.textContent = '\u23F1 ' + timeStr;
            timerEl.className = 'delve-stat delve-timer critical';
        } else if (totalSecs <= 600) {
            timerEl.textContent = '\u23F1 ' + timeStr;
            timerEl.className = 'delve-stat delve-timer warning';
        } else {
            timerEl.textContent = '\u23F1 ' + timeStr;
            timerEl.className = 'delve-stat delve-timer';
        }
    }

    function updateDelveControls(roomData) {
        // Update direction pad
        var dirs = { north: 'n', south: 's', east: 'e', west: 'w' };
        for (var dir in dirs) {
            if (!dirs.hasOwnProperty(dir)) continue;
            var short = dirs[dir];
            var btn = document.getElementById('delve-dir-' + short);
            if (!btn) continue;

            var exitInfo = roomData.exits ? roomData.exits[dir] : null;
            var available = exitInfo ? (exitInfo.available || false) : false;
            btn.disabled = !available;
            btn.className = 'delve-dir-btn';

            var arrow = dir === 'north' ? '\u2191' : dir === 'south' ? '\u2193' : dir === 'west' ? '\u2190' : '\u2192';
            var label = arrow + ' ' + short.toUpperCase();

            if (available) {
                if (exitInfo.trap) {
                    btn.classList.add('has-trap');
                    label += ' \u26A0';
                } else if (exitInfo.blocker) {
                    btn.classList.add('has-blocker');
                    label += ' \uD83D\uDD12';
                }
                if (exitInfo.puzzle) {
                    btn.classList.add('has-puzzle');
                    label += ' \uD83E\uDDE9';
                }
            }
            btn.textContent = label;
        }

        // Build action buttons
        var actionsEl = document.getElementById('delve-actions');
        if (!actionsEl) return;
        actionsEl.innerHTML = '';

        if (roomData.has_monster) {
            addDelveActionBtn(actionsEl, '\u2694 Fight', 'delve fight', 'fight');
            if (roomData.can_study && roomData.monster_name) {
                addDelveActionBtn(actionsEl, '\uD83D\uDD0D Study', 'delve study ' + roomData.monster_name.toLowerCase(), 'study');
            }
        }

        if (roomData.has_treasure) {
            var amt = roomData.treasure_amount ? ' (' + roomData.treasure_amount + 'g)' : '';
            addDelveActionBtn(actionsEl, '\uD83D\uDCB0 Grab' + amt, 'delve grab', 'grab');
        }

        if (roomData.has_puzzle && !roomData.puzzle_solved) {
            addDelveActionBtn(actionsEl, '\uD83E\uDDE9 Puzzle', 'delve study puzzle', 'puzzle');
        }

        // Blocker action buttons per exit direction
        if (roomData.exits) {
            for (var bDir in roomData.exits) {
                if (!roomData.exits.hasOwnProperty(bDir)) continue;
                var bExit = roomData.exits[bDir];
                if (bExit && bExit.blocker && !bExit.blocker.cleared) {
                    var bShort = bDir[0];
                    var bDirCap = bDir.charAt(0).toUpperCase() + bDir.slice(1);
                    var wpDice = roomData.willpower_dice || 0;
                    if (wpDice > 0) {
                        // Show submenu with willpower option
                        addDelveActionBtn(actionsEl, '\uD83D\uDD12 Cross ' + bDirCap, 'cross ' + bShort, 'blocker');
                        addDelveActionBtn(actionsEl, '\u26A1 Cross ' + bDirCap + ' +WP', 'cross ' + bShort + ' wp', 'blocker willpower');
                    } else {
                        addDelveActionBtn(actionsEl, '\uD83D\uDD12 Cross ' + bDirCap, 'cross ' + bShort, 'blocker');
                    }
                    addDelveActionBtn(actionsEl, '\uD83D\uDD0D Easier ' + bDirCap, 'easier ' + bShort, 'blocker easier');
                }
                if (bExit && bExit.trap) {
                    var tShort = bDir[0];
                    addDelveActionBtn(actionsEl, '\u26A0 Listen ' + bDir.charAt(0).toUpperCase() + bDir.slice(1), 'listen ' + tShort, 'trap');
                }
            }
        }

        if (roomData.hp_below_max) {
            addDelveActionBtn(actionsEl, '\u2764 Recover', 'delve recover', 'recover');
        }

        addDelveActionBtn(actionsEl, '\u26A1 Focus', 'delve focus', 'focus');
        addDelveActionBtn(actionsEl, '\uD83C\uDFC3 Flee', 'delve flee', 'flee');
    }

    function addDelveActionBtn(container, label, command, cssClass) {
        var btn = document.createElement('button');
        btn.className = 'delve-action-btn ' + (cssClass || '');
        btn.textContent = label;
        btn.onclick = function() { sendCommand(command); };
        container.appendChild(btn);
    }

    // Direction pad click delegation
    document.addEventListener('click', function(e) {
        var dirBtn = e.target.closest('.delve-dir-btn');
        if (dirBtn && !dirBtn.disabled) {
            var dir = dirBtn.dataset.dir;
            if (dir) sendCommand('delve ' + dir);
        }
    });

    // Hide delve HUD temporarily (e.g. during combat) without exiting delve state
    function suspendDelveHud() {
        const hud = document.getElementById('delve-hud');
        if (hud) hud.classList.add('hidden');
        if (lobserveEl) lobserveEl.classList.remove('delve-map-active');
    }

    // Restore delve HUD after temporary hide (e.g. combat ended)
    function restoreDelveHud() {
        if (!inDelve) return;
        const hud = document.getElementById('delve-hud');
        if (!hud) return;
        hud.classList.remove('hidden');
        if (lobserveEl) {
            lobserveEl.classList.add('delve-map-active', 'visible');
            lobserveEl.style.display = '';
            adjustLobserveHeight();
        }
        // Refresh delve map to re-render in restored container
        if (typeof sendCommand === 'function') {
            sendCommand('delve map', {skipHistory: true});
        }
    }

    function exitDelveMap() {
        if (!inDelve) return;
        inDelve = false;
        delveActive = false;

        if (typeof DelveMapPanel !== 'undefined') {
            DelveMapPanel.destroy();
        }

        var hud = document.getElementById('delve-hud');
        if (hud) hud.classList.add('hidden');

        if (lobserveEl) {
            lobserveEl.classList.remove('delve-map-active');
            var headerEl = lobserveEl.querySelector('.lobserve-header');
            var contentEl = lobserveEl.querySelector('.lobserve-content');
            if (headerEl) headerEl.style.display = '';
            if (contentEl) contentEl.style.display = '';
        }

        if (!currentObservation) {
            hideLobserve();
        }

        showMinimap();
        updateLeftStatus();
    }

    // ResizeObserver for left observe panel
    if (typeof ResizeObserver !== 'undefined') {
        const lobserveObserver = new ResizeObserver(() => {
            adjustLobserveHeight();
        });
        if (lobserveEl) {
            lobserveObserver.observe(lobserveEl);
        }
    }

    // Route observe content through rich renderers for the LEFT panel
    function showLeftObservationPanel(content) {
        const displayType = content?.structured?.display_type || content?.display_type || content?.type;
        let displayData = content?.structured || content?.data || content;

        // Handle stop_observing action
        if (content?.data?.action === 'stop_observing' || displayData?.action === 'stop_observing') {
            hideLobserve();
            return;
        }

        // For SVG types, ensure svg data is available in displayData
        if (displayType === 'svg' && !displayData?.svg && content?.message?.content) {
            displayData = { ...displayData, svg: content.message.content };
        }

        if (displayType && OBSERVATION_PANEL_TYPES.includes(displayType)) {
            let html = '', title = 'Observe';
            switch (displayType) {
                case 'room_display':
                case 'room':
                    html = renderRoomDisplay(displayData);
                    title = displayData.room?.name || 'Room';
                    break;
                case 'character_display':
                case 'character':
                    html = renderCharacterDisplay(displayData);
                    title = displayData.name || 'Character';
                    break;
                case 'place_display':
                case 'place':
                    html = renderPlaceDisplay(displayData);
                    title = displayData.name || 'Place';
                    break;
                case 'item_display':
                case 'item':
                    html = renderItemDisplay(displayData);
                    title = displayData.name || 'Item';
                    break;
                case 'feature_display':
                case 'feature':
                    html = renderFeatureDisplay(displayData);
                    title = displayData.name || 'Feature';
                    break;
                case 'decoration_display':
                case 'decoration':
                    html = renderDecorationDisplay(displayData);
                    title = displayData.name || 'Decoration';
                    break;
                default:
                    html = content?.message?.content || '';
                    break;
            }
            showLobserve(title, html);
        } else if (content?.message?.content) {
            // Fallback for plain text
            showLobserve('Observe', content.message.content);
        }
    }

    // Close button sends observe stop - called from DOMContentLoaded after cacheElements
    function setupLobserveCloseButton() {
        if (!lobserveEl) return;
        const lobserveClose = lobserveEl.querySelector('.lobserve-close');
        if (lobserveClose) {
            lobserveClose.onclick = () => {
                // sendMessage() reads from the input field, so set it first
                if (messageInput) {
                    messageInput.textContent = 'observe stop';
                    sendMessage();
                }
            };
        }
    }

    // Response types that should use the observation panel (temp pane with rich rendering)
    const OBSERVATION_PANEL_TYPES = [
        'room', 'room_display', 'blindfolded_room',
        'character', 'character_display',
        'place', 'place_display',
        'item', 'item_display',
        'exit', 'exit_display',
        'feature', 'feature_display',
        'decoration', 'decoration_display',
        'disambiguation', 'quickmenu', 'form',
        'shop_list', 'canvas', 'svg', 'puzzle'
    ];

    // Handle observe window panel targeting (look commands)
    function showInObserveWindow(content) {
        // For rich structured content (character, room, etc.), use observation panel
        const displayType = content?.structured?.display_type || content?.display_type || content?.type;
        let displayData = content?.structured || content?.data || content;

        // For canvas types, inject the canvas command string from message content
        if (displayType === 'canvas' && content?.message?.content) {
            displayData = { ...displayData, canvas_data: content.message.content };
        }

        // For SVG types, ensure svg data is available in displayData
        if (displayType === 'svg' && !displayData?.svg && content?.message?.content) {
            displayData = { ...displayData, svg: content.message.content };
        }

        if (displayType && OBSERVATION_PANEL_TYPES.includes(displayType)) {
            showObservationPanel(displayType, displayData, 'right');
            // Update wardrobe visibility based on room data
            if (displayType === 'room' && displayData?.room) {
                updateWardrobeVisibility(displayData.room);
            }
        } else {
            // Fallback: show as simple temp result
            const title = content?.structured?.name || content?.name || 'Look';
            const htmlContent = typeof content === 'string' ? content :
                (content?.message?.content || content?.output || JSON.stringify(content));
            showTempResult(title, htmlContent, 'right');
        }
    }

    // ====== MENU SYSTEM ======
    // Display server-sent menus in temp pane
    let currentMenu = null;
    let menuKeyHandler = null;

    function showMenu(menuData, side = 'right') {
        if (!menuData || !menuData.options || !tempResultPaneEl) return;

        currentMenu = menuData;
        const options = menuData.options;
        const isQuickMenu = options.length <= 10;

        // Build menu HTML
        let html = `<div class="menu-container">`;
        if (menuData.title) {
            html += `<div class="menu-title">${escapeHtml(menuData.title)}</div>`;
        }
        html += `<ul class="menu-options">`;
        options.forEach((option, index) => {
            const num = index + 1;
            const displayNum = num === 10 ? '0' : num.toString();
            html += `
                <li class="menu-option" data-index="${index}" data-command="${escapeHtml(option)}">
                    <span class="menu-option-number">[${displayNum}]</span>
                    <span class="menu-option-text">${escapeHtml(option)}</span>
                </li>
            `;
        });
        html += `</ul>`;

        // Add hint text based on menu size
        if (isQuickMenu) {
            html += `<div class="menu-hint">Press 1-${options.length === 10 ? '0' : options.length} to select (0 = 10)</div>`;
        } else {
            html += `
                <div class="menu-input">
                    <input type="text" id="menuNumberInput" placeholder="Type number and press Enter..." maxlength="3">
                </div>
                <div class="menu-hint">Type the number and press Enter to select</div>
            `;
        }
        html += `</div>`;

        showTempResult('Menu', html, side);

        // Set up click handlers for menu options
        const menuOptions = tempResultPaneEl.querySelectorAll('.menu-option');
        menuOptions.forEach(opt => {
            opt.addEventListener('click', () => {
                const command = opt.dataset.command;
                selectMenuOption(command);
            });
        });

        // Set up keyboard handler
        removeMenuKeyHandler();
        if (isQuickMenu) {
            // Quick mode: single keypress without Enter
            menuKeyHandler = (e) => {
                // Only handle if no input field is focused (except our menu input)
                if (document.activeElement === messageInput) {
                    const key = e.key;
                    let selectedIndex = -1;

                    if (key >= '1' && key <= '9') {
                        selectedIndex = parseInt(key) - 1;
                    } else if (key === '0') {
                        selectedIndex = 9; // 0 = option 10
                    }

                    if (selectedIndex >= 0 && selectedIndex < options.length) {
                        e.preventDefault();
                        selectMenuOption(options[selectedIndex]);
                    } else if (key === 'Escape') {
                        e.preventDefault();
                        closeMenu();
                    }
                }
            };
            document.addEventListener('keydown', menuKeyHandler);
        } else {
            // Extended mode: type number and press Enter
            setTimeout(() => {
                const menuInput = document.getElementById('menuNumberInput');
                if (menuInput) {
                    menuInput.focus();
                    menuKeyHandler = (e) => {
                        if (e.key === 'Enter') {
                            const num = parseInt(menuInput.value);
                            if (num >= 1 && num <= options.length) {
                                e.preventDefault();
                                selectMenuOption(options[num - 1]);
                            }
                        } else if (e.key === 'Escape') {
                            e.preventDefault();
                            closeMenu();
                            messageInput.focus();
                        }
                    };
                    menuInput.addEventListener('keydown', menuKeyHandler);
                }
            }, 50);
        }
    }

    function selectMenuOption(command) {
        if (!command) return;

        // Send the command to the server
        apiPost('/api/messages', { content: command, type: 'command', menu_selection: true })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Handle response like normal command
                const panel = getMessagePanel(data.message?.message_type || 'system');
                if (data.message) {
                    addMessage(data.message, panel);
                }
            }
        })
        .catch(error => console.error('Menu selection error:', error));

        // Close the menu
        closeMenu();
        messageInput.focus();
    }

    function closeMenu() {
        hideTempResult();
        removeMenuKeyHandler();
        currentMenu = null;
    }

    function removeMenuKeyHandler() {
        if (menuKeyHandler) {
            document.removeEventListener('keydown', menuKeyHandler);
            const menuInput = document.getElementById('menuNumberInput');
            if (menuInput) {
                menuInput.removeEventListener('keydown', menuKeyHandler);
            }
            menuKeyHandler = null;
        }
    }

    // Make menu functions globally available
    window.showMenu = showMenu;
    window.closeMenu = closeMenu;

    // ====== POPUP FORM SYSTEM ======
    // Display server-sent forms in a modal popup
    let currentPopup = null;
    let popupOverlayEl = null;
    let popupContainerEl = null;

    function initPopupForm() {
        popupOverlayEl = document.getElementById('popupFormOverlay');
        popupContainerEl = document.getElementById('popupFormContainer');

        if (!popupOverlayEl || !popupContainerEl) return;

        // Close button handler
        const closeBtn = popupContainerEl.querySelector('.popup-close');
        if (closeBtn) {
            closeBtn.addEventListener('click', closePopupForm);
        }

        // Cancel button handler
        const cancelBtn = popupContainerEl.querySelector('.popup-btn-cancel');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', closePopupForm);
        }

        // Submit button handler
        const submitBtn = popupContainerEl.querySelector('.popup-btn-submit');
        if (submitBtn) {
            submitBtn.addEventListener('click', submitPopupForm);
        }

        // Close on overlay click (outside the form)
        popupOverlayEl.addEventListener('click', (e) => {
            if (e.target === popupOverlayEl) {
                closePopupForm();
            }
        });

        // Close on Escape key
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && currentPopup) {
                closePopupForm();
            }
        });
    }

    function showPopupForm(popupData) {
        if (!popupData || !popupOverlayEl || !popupContainerEl) return;

        currentPopup = popupData;

        // Set title
        const titleEl = popupContainerEl.querySelector('.popup-title');
        if (titleEl) {
            titleEl.textContent = popupData.title || 'Form';
        }

        // Set submit button label
        const submitBtn = popupContainerEl.querySelector('.popup-btn-submit');
        if (submitBtn) {
            submitBtn.textContent = popupData.submitLabel || 'Submit';
        }

        // Build fields HTML
        const bodyEl = popupContainerEl.querySelector('.popup-body');
        if (bodyEl && popupData.fields) {
            let fieldsHtml = '';
            popupData.fields.forEach((field, index) => {
                fieldsHtml += buildPopupField(field, index);
            });
            bodyEl.innerHTML = fieldsHtml;
        }

        // Show the popup
        popupOverlayEl.classList.add('visible');

        // Initialize richtext editors and focus first input
        setTimeout(() => {
            initPopupRichTextEditors();
            const firstInput = popupContainerEl.querySelector('input, textarea, select, .desc-editor-content');
            if (firstInput) firstInput.focus();
        }, 100);
    }

    // Initialize rich text editors in popup forms
    function initPopupRichTextEditors() {
        document.querySelectorAll('.popup-richtext-container').forEach(container => {
            const fieldName = container.dataset.field;
            const placeholder = container.dataset.placeholder;
            const hiddenInput = document.getElementById(`popup_${fieldName}`);

            if (typeof DescriptionEditor !== 'undefined') {
                // Use the full-featured DescriptionEditor
                const editor = new DescriptionEditor(container, {
                    placeholder: placeholder,
                    onChange: (content) => {
                        if (hiddenInput) hiddenInput.value = content;
                    }
                });
                // Set initial value if present
                if (hiddenInput && hiddenInput.value) {
                    editor.setContent(hiddenInput.value);
                }
                container._editor = editor;
            } else {
                // Fallback to simple contenteditable
                container.innerHTML = `<div class="desc-editor">
                    <div class="desc-editor-content" contenteditable="true" data-placeholder="${escapeHtml(placeholder)}"></div>
                </div>`;
                const content = container.querySelector('.desc-editor-content');
                if (hiddenInput && hiddenInput.value) {
                    content.innerHTML = hiddenInput.value;
                }
                content.addEventListener('input', () => {
                    if (hiddenInput) hiddenInput.value = content.innerHTML;
                });
            }
        });
    }

    function buildPopupField(field, index) {
        const name = field.name || `field_${index}`;
        const label = field.label || name;
        const type = field.type || 'text';
        const value = field.value || field.default || '';
        const hint = field.hint || '';
        const required = field.required ? 'required' : '';
        const options = field.options || [];

        let html = `<div class="popup-field">`;
        html += `<label for="popup_${name}">${escapeHtml(label)}</label>`;

        switch (type) {
            case 'textarea':
                html += `<textarea id="popup_${name}" name="${name}" ${required}>${escapeHtml(value)}</textarea>`;
                break;
            case 'richtext':
                // Rich text editor with formatting toolbar
                const placeholder = field.placeholder || 'Enter your description...';
                html += `<div id="popup_${name}_editor" class="popup-richtext-container" data-field="${name}" data-placeholder="${escapeHtml(placeholder)}"></div>`;
                html += `<input type="hidden" id="popup_${name}" name="${name}" value="${escapeHtml(value)}">`;
                break;
            case 'select':
                html += `<select id="popup_${name}" name="${name}" ${required}>`;
                options.forEach(opt => {
                    const optValue = typeof opt === 'object' ? opt.value : opt;
                    const optLabel = typeof opt === 'object' ? opt.label : opt;
                    const selected = optValue === value ? 'selected' : '';
                    html += `<option value="${escapeHtml(optValue)}" ${selected}>${escapeHtml(optLabel)}</option>`;
                });
                html += `</select>`;
                break;
            case 'checkbox':
                const checked = value === true || value === 'true' || value === '1' ? 'checked' : '';
                html += `
                    <label class="checkbox-label">
                        <input type="checkbox" id="popup_${name}" name="${name}" ${checked}>
                        <span>${escapeHtml(field.checkboxLabel || label)}</span>
                    </label>
                `;
                break;
            case 'number':
                html += `<input type="number" id="popup_${name}" name="${name}" value="${escapeHtml(value)}" ${required} min="${field.min || ''}" max="${field.max || ''}" step="${field.step || '1'}">`;
                break;
            default:
                html += `<input type="${type}" id="popup_${name}" name="${name}" value="${escapeHtml(value)}" ${required} placeholder="${escapeHtml(field.placeholder || '')}">`;
        }

        if (hint) {
            html += `<div class="field-hint">${escapeHtml(hint)}</div>`;
        }

        html += `</div>`;
        return html;
    }

    function submitPopupForm() {
        if (!currentPopup || !popupContainerEl) return;

        const values = {};
        const fields = currentPopup.fields || [];

        // Collect values from all fields
        fields.forEach((field, index) => {
            const name = field.name || `field_${index}`;
            const input = popupContainerEl.querySelector(`[name="${name}"]`);
            if (input) {
                if (input.type === 'checkbox') {
                    values[name] = input.checked;
                } else {
                    values[name] = input.value;
                }
            }
        });

        // Send response to server
        const response = {
            popup_response: {
                popup_id: currentPopup.popup_id || currentPopup.id,
                values: values
            }
        };

        apiPost('/api/popup/response', response)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Handle any response message
                if (data.message) {
                    const panel = getMessagePanel(data.message?.message_type || 'system');
                    addMessage(data.message, panel);
                }
            } else {
                showSystemMessage(`Form error: ${data.error || 'Unknown error'}`, 'right');
            }
        })
        .catch(error => {
            console.error('Popup form submission error:', error);
        });

        closePopupForm();
    }

    function closePopupForm() {
        if (popupOverlayEl) {
            popupOverlayEl.classList.remove('visible');
        }
        currentPopup = null;
        messageInput?.focus();
    }

    // Make popup functions globally available
    window.showPopupForm = showPopupForm;
    window.closePopupForm = closePopupForm;

    // ====== SETTINGS PAGE ======
    // Comprehensive settings with localStorage persistence

    const settingsDefaults = {
        llheight: '140',
        rlheight: '140',
        lfontsize: '14',
        rfontsize: '14',
        lfont: 'inherit',
        rfont: 'inherit',
        simpleui: false,
        single_screen: false,
        noback: false,
        notify_message: 'hidden',
        notify_emote: 'hidden',
        emoteremind: false,
        show_full: false,
        noambi: false,
        volume: 50,
        emailmissed: false,
        emailscene: false,
        temp_unit: 'F',
        battleMapEffects: 'high'
    };

    let currentSettings = { ...settingsDefaults };

    // Accessibility settings (stored server-side on user record, not localStorage)
    const a11yDefaults = {
        a11y_mode: false,
        a11y_reader: false,
        a11y_contrast: false,
        a11y_reduced: false,
        a11y_typing: true,
        a11y_resume: true,
        a11y_speed: '1.0',
        a11y_colorblind: '',
        a11y_dyslexia: false,
        a11y_replay_prev: 'alt+ArrowUp',
        a11y_replay_next: 'alt+ArrowDown'
    };
    let currentA11ySettings = {
        a11y_mode: <%= a11y_settings[:accessibility_mode] ? 'true' : 'false' %>,
        a11y_reader: <%= a11y_settings[:screen_reader_optimized] ? 'true' : 'false' %>,
        a11y_contrast: <%= a11y_settings[:high_contrast_mode] ? 'true' : 'false' %>,
        a11y_reduced: <%= a11y_settings[:reduced_visual_effects] ? 'true' : 'false' %>,
        a11y_typing: <%= a11y_settings[:tts_pause_on_typing] != false ? 'true' : 'false' %>,
        a11y_resume: <%= a11y_settings[:tts_auto_resume] != false ? 'true' : 'false' %>,
        a11y_speed: '<%= narrator_settings[:voice_speed] || 1.0 %>',
        a11y_colorblind: '<%= a11y_settings[:color_blindness_mode] || '' %>',
        a11y_dyslexia: <%= a11y_settings[:dyslexia_font] ? 'true' : 'false' %>,
        a11y_replay_prev: '<%= a11y_settings[:replay_prev_key] || "alt+ArrowUp" %>',
        a11y_replay_next: '<%= a11y_settings[:replay_next_key] || "alt+ArrowDown" %>'
    };

    // Initialize replay buffer for screen reader message history navigation
    const replayBuffer = new ReplayBufferManager({
        size: 25,
        announcer: document.getElementById('srAnnouncer'),
        onNavigate: (pane, position, total) => {
            const label = pane === 'left' ? 'OOC' : 'RP';
            showImprint(`Replaying ${label}: ${position}/${total}`, 2000, '◀');
        }
    });
    window.replayBuffer = replayBuffer;

    // Initialize TTS AudioQueueManager for accessibility narration
    let audioQueueManager = new AudioQueueManager({
        enabled: currentA11ySettings.a11y_mode,
        pauseOnTyping: currentA11ySettings.a11y_typing,
        autoResumeDelay: 1500,
        playbackRate: parseFloat(currentA11ySettings.a11y_speed) || 1.0,
        volume: 1.0,
        onError: (err, item) => {
            console.warn('[TTS] Playback error:', err);
        }
    });

    function initSettings() {
        // Load settings from localStorage
        loadSettings();

        // Setup event handlers
        const settingsTrigger = document.getElementById('settingsTrigger');
        const settingsClose = document.getElementById('settingsClose');
        const settingsOverlay = document.getElementById('settingsOverlay');
        const saveBtn = document.getElementById('saveSettingsBtn');

        if (settingsTrigger) {
            settingsTrigger.addEventListener('click', openSettings);
        }

        if (settingsClose) {
            settingsClose.addEventListener('click', closeSettings);
        }

        if (settingsOverlay) {
            settingsOverlay.addEventListener('click', (e) => {
                if (e.target === settingsOverlay) {
                    closeSettings();
                }
            });
        }

        if (saveBtn) {
            saveBtn.addEventListener('click', saveSettings);
        }

        // Section toggles
        const sectionHeaders = document.querySelectorAll('#settingsContainer .section-header');
        sectionHeaders.forEach(header => {
            header.addEventListener('click', () => {
                const section = header.closest('.settings-section');
                if (section) {
                    section.classList.toggle('expanded');
                }
            });
        });

        // Hotkey capture for replay buffer key binding
        document.querySelectorAll('.hotkey-input').forEach(input => {
            input.addEventListener('focus', () => {
                input.dataset.originalValue = input.value;
                input.value = 'Press key combo...';
                input.dataset.capturing = 'true';
            });
            input.addEventListener('blur', () => {
                if (input.dataset.capturing === 'true') {
                    input.value = input.dataset.originalValue || input.value;
                    delete input.dataset.capturing;
                }
            });
            input.addEventListener('keydown', (e) => {
                if (input.dataset.capturing !== 'true') return;
                e.preventDefault();
                e.stopPropagation();
                const parts = [];
                if (e.altKey) parts.push('alt');
                if (e.ctrlKey) parts.push('ctrl');
                if (e.shiftKey) parts.push('shift');
                if (e.metaKey) parts.push('meta');
                if (['Alt', 'Control', 'Shift', 'Meta'].includes(e.key)) return;
                parts.push(e.key);
                input.value = parts.join('+');
                delete input.dataset.capturing;
                input.blur();
            });
        });

        // Apply settings on load
        applySettings();
    }

    function coerceNotifySetting(val) {
        if (val === true  || val === 'true')  return 'hidden';
        if (val === false || val === 'false') return 'off';
        if (['off', 'hidden', 'always'].includes(val)) return val;
        return 'hidden';
    }

    function loadSettings() {
        try {
            const saved = localStorage.getItem('fireflySettings');
            if (saved) {
                currentSettings = { ...settingsDefaults, ...JSON.parse(saved) };
            }
        } catch (e) {
            console.warn('Failed to load settings:', e);
        }

        // Coerce legacy boolean notify settings to string values
        currentSettings.notify_message = coerceNotifySetting(currentSettings.notify_message);
        currentSettings.notify_emote   = coerceNotifySetting(currentSettings.notify_emote);

        // Populate form fields
        populateSettingsForm();
    }

    function populateSettingsForm() {
        for (const [key, value] of Object.entries(currentSettings)) {
            const element = document.getElementById(`setting_${key}`);
            if (!element) continue;

            if (element.type === 'checkbox') {
                element.checked = value;
            } else if (element.type === 'range') {
                element.value = value;
            } else {
                element.value = value;
            }
        }

        // Populate accessibility settings
        for (const [key, value] of Object.entries(currentA11ySettings)) {
            const element = document.getElementById(`setting_${key}`);
            if (!element) continue;

            if (element.type === 'checkbox') {
                element.checked = value;
            } else {
                element.value = value;
            }
        }
    }

    function saveSettings() {
        // Collect settings from form
        const newSettings = {};
        for (const key of Object.keys(settingsDefaults)) {
            const element = document.getElementById(`setting_${key}`);
            if (!element) continue;

            if (element.type === 'checkbox') {
                newSettings[key] = element.checked;
            } else if (element.type === 'range') {
                newSettings[key] = parseInt(element.value);
            } else {
                newSettings[key] = element.value;
            }
        }

        currentSettings = newSettings;

        // Save to localStorage
        try {
            localStorage.setItem('fireflySettings', JSON.stringify(currentSettings));
        } catch (e) {
            console.warn('Failed to save settings:', e);
        }

        // Collect accessibility settings
        const newA11ySettings = {};
        for (const key of Object.keys(a11yDefaults)) {
            const element = document.getElementById(`setting_${key}`);
            if (!element) continue;

            if (element.type === 'checkbox') {
                newA11ySettings[key] = element.checked;
            } else {
                newA11ySettings[key] = element.value;
            }
        }
        currentA11ySettings = newA11ySettings;

        // Send webclient settings to server
        apiPost('/api/settings', currentSettings).catch(error => {
            console.warn('Failed to sync settings to server:', error);
        });

        // Send accessibility settings to server
        apiPost('/api/accessibility', currentA11ySettings).catch(error => {
            console.warn('Failed to sync accessibility settings to server:', error);
        });

        // Apply settings immediately
        applySettings();

        // Show confirmation
        showImprint('Settings saved successfully!', 3000, '✓');

        closeSettings();
    }

    function applySettings() {
        // Apply display settings
        const lMessageWindow = document.getElementById('lmessagewindow');
        const rMessageWindow = document.getElementById('rmessagewindow');

        if (lMessageWindow) {
            lMessageWindow.style.lineHeight = `${currentSettings.llheight}%`;
            lMessageWindow.style.fontFamily = currentSettings.lfont;
            lMessageWindow.style.fontSize = `${currentSettings.lfontsize}px`;
        }

        if (rMessageWindow) {
            rMessageWindow.style.lineHeight = `${currentSettings.rlheight}%`;
            rMessageWindow.style.fontFamily = currentSettings.rfont;
            rMessageWindow.style.fontSize = `${currentSettings.rfontsize}px`;
        }

        // Apply right panel settings to observe/temp result pane too
        const tempResultPane = document.getElementById('tempResultPane');
        if (tempResultPane) {
            tempResultPane.style.fontSize = `${currentSettings.rfontsize}px`;
            tempResultPane.style.fontFamily = currentSettings.rfont;
            tempResultPane.style.lineHeight = `${currentSettings.rlheight}%`;
        }

        // Set content line height as CSS variable so all content areas respect it
        // Use the left panel setting as the primary content line height
        document.documentElement.style.setProperty('--ff-content-line-height', `${currentSettings.llheight}%`);

        // Apply background image setting
        const backgroundEl = document.getElementById('backgroundimage');
        if (backgroundEl) {
            backgroundEl.style.display = currentSettings.noback ? 'none' : 'block';
        }

        // Apply simple UI (disable weather effects)
        if (currentSettings.simpleui) {
            const rainFront = document.querySelector('.rain.front-grid grid-cols-12 gap-4');
            const rainBack = document.querySelector('.rain.back-grid grid-cols-12 gap-4');
            const snowDiv = document.getElementById('snowdiv');
            if (rainFront) rainFront.style.display = 'none';
            if (rainBack) rainBack.style.display = 'none';
            if (snowDiv) snowDiv.style.display = 'none';
        }

        // Apply audio settings
        if (currentSettings.noambi) {
            const rainAudio = document.getElementById('rainAudio');
            const windAudio = document.getElementById('windAudio');
            if (rainAudio) rainAudio.pause();
            if (windAudio) windAudio.pause();
        } else {
            // Apply master volume to currently playing ambient audio
            const rainA = document.getElementById('rainAudio');
            const windA = document.getElementById('windAudio');
            if (rainA && !rainA.paused) rainA.volume = getVolume(weatherState.thunderstorm ? 0.4 : 0.3);
            if (windA && !windA.paused) windA.volume = getVolume(weatherState.thunderstorm ? 0.4 : 0.3);
        }

        // Apply battle map effects quality setting
        if (window._battleMapCompositor) {
            window._battleMapCompositor.setQuality(currentSettings.battleMapEffects || 'high');
        } else {
            if (window._battleMapEffects) {
                window._battleMapEffects.setQuality(currentSettings.battleMapEffects || 'high');
            }
            if (window._battleMapParticles) {
                window._battleMapParticles.setQuality(currentSettings.battleMapEffects || 'high');
            }
        }

        // Apply accessibility settings to DOM
        applyAccessibilitySettings();
    }

    function applyAccessibilitySettings() {
        document.body.dataset.a11yContrast = currentA11ySettings.a11y_contrast ? 'true' : 'false';
        document.body.dataset.a11yReduced = currentA11ySettings.a11y_reduced ? 'true' : 'false';
        document.body.dataset.a11yReader = currentA11ySettings.a11y_reader ? 'true' : 'false';
        document.body.dataset.a11yColorblind = currentA11ySettings.a11y_colorblind || '';
        document.body.dataset.a11yDyslexia = currentA11ySettings.a11y_dyslexia ? 'true' : 'false';

        // Sync TTS settings to AudioQueueManager
        if (typeof audioQueueManager !== 'undefined') {
            audioQueueManager.setEnabled(currentA11ySettings.a11y_mode);
            audioQueueManager.setPauseOnTyping(currentA11ySettings.a11y_typing);
            audioQueueManager.setPlaybackRate(parseFloat(currentA11ySettings.a11y_speed) || 1.0);
        }
    }

    function announceToScreenReader(text) {
        const announcer = document.getElementById('srAnnouncer');
        if (announcer) {
            announcer.textContent = '';
            setTimeout(() => { announcer.textContent = text; }, 50);
        }
    }

    function openSettings() {
        const overlay = document.getElementById('settingsOverlay');
        if (overlay) {
            overlay.classList.add('visible');
            populateSettingsForm();
        }
    }

    function closeSettings() {
        const overlay = document.getElementById('settingsOverlay');
        if (overlay) {
            overlay.classList.remove('visible');
        }
        messageInput?.focus();
    }

    // Make settings functions globally available
    window.openSettings = openSettings;
    window.closeSettings = closeSettings;
    window.announceToScreenReader = announceToScreenReader;

