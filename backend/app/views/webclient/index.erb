    // Battle map state
    let battleMapActive = false;
    let currentFightId = null;
    let battleMapPollInterval = null;
    let lastBattleMapHash = null;
    let battleMapDismissed = false;
    let battleMapZoom = 1.0;
    const BATTLE_MAP_ZOOM_MIN = 0.25;
    const BATTLE_MAP_ZOOM_MAX = 3.0;
    const BATTLE_MAP_ZOOM_STEP = 0.25;

    // Animation state
    let animationInProgress = false;
    let lastAnimatedRound = 0;
    let currentMapData = null; // Store for animation calculations
    const ANIMATION_DURATION = 8000; // 8 seconds total for round animation

    // Incremental update tracking (avoids full re-render when only participants moved)
    let lastMapStructureHash = null; // hash of hexes + background + arena dims
    let lastParticipantHash = null;  // hash of participant/monster visual state (positions, HP)

    // Hazard symbols & water fills from shared module
    const HAZARD_SYMBOLS = BattleMapRenderer.HAZARD_SYMBOLS;
    const WATER_FILLS = BattleMapRenderer.WATER_FILLS;

