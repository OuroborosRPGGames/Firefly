<% content_for :head do %>
    <!-- Shared Lightbox -->
    <link rel="stylesheet" href="/css/lightbox.css">
    <script src="/js/lightbox.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/magic/1.4.6/magic.min.css">
    <link rel="stylesheet" href="/css/gradient-components.css">
    <link rel="stylesheet" href="/css/dice_animations.css?v=2">
    <link rel="stylesheet" href="/css/media_sync.css">
    <link rel="stylesheet" href="/css/journey.css?v=2">
    <script src="/js/gradient-ciede2000.js"></script>
    <script src="/js/gradient-creator.js?v=3"></script>
    <script src="/js/gradient-picker.js?v=4"></script>
    <script src="/js/description-editor.js?v=5"></script>
    <script src="/js/dice_animation.js?v=3"></script>
    <!-- PeerJS for WebRTC screen sharing -->
    <script src="https://unpkg.com/peerjs@1.5.5/dist/peerjs.min.js"></script>
    <!-- Media sync for watch parties -->
    <script src="/js/media_sync.js"></script>
    <!-- Journey planning modal -->
    <script src="/js/journey/journey-hex-map.js?v=2"></script>
    <script src="/js/journey/journey-config-panel.js?v=2"></script>
    <script src="/js/journey/journey-modal.js?v=2"></script>
    <!-- Battle map renderer -->
    <link rel="stylesheet" href="/css/battle-map-loading.css">
    <script src="/js/battle-map-renderer.js?v=<%= Time.now.to_i %>"></script>
    <script src="/js/battle-map-particles.js?v=1"></script>
    <script src="/js/battle-map-effects.js?v=9"></script>
    <script src="/js/battle-map-compositor.js?v=1"></script>
    <!-- WebGL weather effects (rain/snow shaders from Map-Shine) -->
    <script src="/js/weather-effects.js?v=1"></script>
    <!-- Delve map panel (dungeon exploration) -->
    <script src="/js/delve-map-panel.js"></script>
    <!-- TTS audio queue for accessibility mode -->
    <script src="/js/audio_queue_manager.js"></script>
    <!-- Screen reader replay buffer for message history navigation -->
    <script src="/js/replay_buffer.js"></script>
<% end %>

<%
  character_display_name = @character.full_name
  character_short_name = @character.forename || @character.full_name
  current_room_name = @room&.name || 'Unknown Location'
  raw_climate = @room&.location&.zone&.climate
  temperature_label = raw_climate && !raw_climate.empty? ? raw_climate.capitalize : 'Temperate'
  ci = @character_instance
  mode = ci&.messaging_mode || 'channel'
  if mode == 'ooc' && ci&.ooc_target_names && !ci.ooc_target_names.to_s.strip.empty?
    current_channel = "[OOC: #{ci.ooc_target_names}]"
  elsif mode == 'msg' && ci&.msg_target_names && !ci.msg_target_names.to_s.strip.empty?
    current_channel = "[MSG: #{ci.msg_target_names}]"
  else
    ooc_channel = ChannelBroadcastService.default_ooc_channel rescue nil
    current_channel = ooc_channel ? "[#{ooc_channel.name}]" : '[OOC]'
  end
  # Get available channel names for client-side channel switching
  available_channels = (ChannelBroadcastService.available_channels(@character) rescue []).map { |ch| ch.respond_to?(:name) ? ch.name : (ch[:name] || ch['name']) }.compact.map(&:downcase)
  a11y_settings = @character.user&.accessibility_settings || {}
  narrator_settings = @character.user&.narrator_settings || {}
  # Build initial combat status for HP display on page load
  initial_combat_status = begin
    StatusBarService.new(ci).send(:build_combat_status)
  rescue StandardError => e
    warn "[WebclientView] Failed to build initial combat status for character #{@character&.id}: #{e.message}"
    nil
  end
%>

<div id="clientwrapper"
     data-media-autoplay="<%= @character.user&.media_autoplay? != false %>"
     data-media-start-muted="<%= @character.user&.media_start_muted? == true %>">
    <!-- Skip links for keyboard navigation -->
    <nav class="skip-links" aria-label="Skip navigation">
        <a href="#message_content">Skip to message input</a>
        <a href="#rmessages">Skip to game output</a>
        <a href="#lmessages">Skip to OOC chat</a>
    </nav>

    <!-- Screen reader announcer for urgent messages -->
    <div id="srAnnouncer" role="alert" aria-live="assertive" class="sr-only"></div>

    <!-- SVG filters for environment effects -->
    <svg style="position: absolute; width: 0; height: 0;">
        <defs>
            <filter id="underwater-distort" x="0" y="0" width="100%" height="100%">
                <feTurbulence type="turbulence" baseFrequency="0.015" numOctaves="3" seed="1" result="turbulence">
                    <animate attributeName="seed" from="1" to="100" dur="10s" repeatCount="indefinite"/>
                </feTurbulence>
                <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="8" xChannelSelector="R" yChannelSelector="G"/>
            </filter>
        </defs>
    </svg>

    <!-- Weather canvas - used for canvas-based rain (better performance) -->
    <canvas id="canvas"></canvas>

    <!-- Legacy DOM rain divs - kept for fallback, but canvas is preferred -->
    <div class="rain front-grid grid-cols-12 gap-4"></div>
    <div class="rain back-grid grid-cols-12 gap-4"></div>

    <!-- Snow effect - CSS radial gradients with 3-layer parallax -->
    <div id="snowdiv" class="winter-is-coming">
        <div class="snow snow--near"></div>
        <div class="snow snow--mid"></div>
        <div class="snow snow--far"></div>
    </div>
    <div id="thunderstormOverlay">
        <div class="thunderstorm-rain"></div>
    </div>

    <!-- Environment effects - mist, fire, underwater -->
    <div id="mistdiv" class="environment-mist" style="display: none;">
        <div class="mist-wisp mist-wisp--1"></div>
        <div class="mist-wisp mist-wisp--2"></div>
        <div class="mist-wisp mist-wisp--3"></div>
        <div class="mist-wisp mist-wisp--4"></div>
        <div class="mist-wisp mist-wisp--5"></div>
        <div class="mist-wisp mist-wisp--6"></div>
        <div class="mist-wisp mist-wisp--7"></div>
    </div>
    <div id="firediv" class="environment-fire" style="display: none;">
        <div class="fire-edge fire-edge--bottom"></div>
        <div class="fire-edge fire-edge--left"></div>
        <div class="fire-edge fire-edge--right"></div>
    </div>
    <div id="underwaterdiv" class="environment-underwater" style="display: none;">
        <div class="underwater-rays"></div>
    </div>

    <!-- Blood spatter canvas - for combat damage visualization -->
    <canvas id="blood-canvas" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 3;"></canvas>

    <!-- Fire ember canvas - for fire environment visualization -->
    <canvas id="fire-canvas" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 3;"></canvas>

    <!-- Underwater caustic/bubble canvas -->
    <canvas id="underwater-canvas" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 3;"></canvas>

    <!-- Lightning bolt canvas -->
    <canvas id="lightning-canvas" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 4;"></canvas>

    <!-- WebGL fog canvas - sits between background and UI (z-index 2 = above bg, below panels at 10+) -->
    <canvas id="fog-canvas" style="position: fixed; top: 0; left: 0; pointer-events: none; z-index: 2;"></canvas>

    <!-- Background image - full screen with vertical gradient fade -->
    <div id="backgroundimage" class="backgroundimage"></div>

    <!-- TOP IMPRINT/STATUS BAR - Yellow notifications -->
    <div id="impwrapper">
        <div id="imprint" role="status" aria-live="polite"></div>
        <div id="consentNoticeBadge" class="consent-notice-badge" aria-hidden="true">
            <button type="button" id="consentNoticeTrigger" class="consent-notice-trigger" aria-describedby="consentNoticeTooltip">
                <span class="consent-notice-dot">●</span>
                <span class="consent-notice-label">Consent</span>
            </button>
            <div id="consentNoticeTooltip" class="consent-notice-tooltip" role="tooltip"></div>
        </div>
    </div>

    <!-- MINIMAP - Area layout on left side -->
    <div id="minimapwindow">
        <div class="minimap-header">
            <span>Map</span>
            <span class="minimap-close" title="Close minimap">×</span>
        </div>
        <canvas id="minimapCanvas" width="400" height="376"></canvas>
    </div>

    <!-- OBSERVATION BOX - Temporary left side panel -->
    <div id="observeWindow">
        <div class="observe-header">
            <span>Observing: <span class="observe-target"></span></span>
            <span class="observe-close" title="Stop observing">×</span>
        </div>
        <div class="observe-content"></div>
    </div>

    <!-- TEMPORARY RESULT PANE - Shows command results -->
    <div id="tempResultPane">
        <div class="temp-header">
            <span class="temp-title">Look</span>
            <span class="temp-close" title="Close">×</span>
        </div>
        <div class="temp-content"></div>
    </div>

    <!-- EFFECT DROPDOWN - Combat effects, buffs, debuffs -->
    <div id="effectDropdown">
        <div class="effect-header">
            <span>Effects</span>
            <span class="effect-toggle" title="Toggle effects">▼</span>
        </div>
        <div class="effect-list"></div>
    </div>

    <!-- IMAGE LIGHTBOX - Full screen image viewer -->
    <div id="imageLightbox">
        <span class="lightbox-close">×</span>
        <img src="" alt="Enlarged image">
    </div>

    <!-- POPUP FORM - Server-sent modal forms -->
    <div id="popupFormOverlay">
        <div id="popupFormContainer">
            <div class="popup-header">
                <h3 class="popup-title">Form</h3>
                <span class="popup-close" title="Close">×</span>
            </div>
            <div class="popup-body">
                <!-- Fields will be dynamically inserted here -->
            </div>
            <div class="popup-footer">
                <button type="button" class="popup-btn popup-btn-cancel">Cancel</button>
                <button type="button" class="popup-btn popup-btn-submit">Submit</button>
            </div>
        </div>
    </div>

    <!-- SETTINGS PAGE - Comprehensive settings overlay -->
    <div id="settingsOverlay">
        <div id="settingsContainer">
            <div class="settings-header">
                <h2 class="settings-title">Settings</h2>
                <span class="settings-close" id="settingsClose" title="Close">×</span>
            </div>

            <!-- DISPLAY SETTINGS -->
            <div class="settings-section expanded">
                <div class="section-header">
                    <span class="section-title">Display Settings</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Left Line Height</label>
                            <select id="setting_llheight">
                                <option value="100">100%</option>
                                <option value="110">110%</option>
                                <option value="120">120%</option>
                                <option value="130">130%</option>
                                <option value="140" selected>140%</option>
                                <option value="150">150%</option>
                                <option value="160">160%</option>
                            </select>
                            <div class="setting-hint">Vertical size of text on OOC panel</div>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Right Line Height</label>
                            <select id="setting_rlheight">
                                <option value="100">100%</option>
                                <option value="110">110%</option>
                                <option value="120">120%</option>
                                <option value="130">130%</option>
                                <option value="140" selected>140%</option>
                                <option value="150">150%</option>
                                <option value="160">160%</option>
                            </select>
                            <div class="setting-hint">Vertical size of text on RP panel</div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Left Font Size</label>
                            <select id="setting_lfontsize">
                                <option value="10">10px</option>
                                <option value="11">11px</option>
                                <option value="12">12px</option>
                                <option value="13">13px</option>
                                <option value="14" selected>14px</option>
                                <option value="15">15px</option>
                                <option value="16">16px</option>
                                <option value="18">18px</option>
                                <option value="20">20px</option>
                            </select>
                            <div class="setting-hint">Text size on OOC panel</div>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Right Font Size</label>
                            <select id="setting_rfontsize">
                                <option value="10">10px</option>
                                <option value="11">11px</option>
                                <option value="12">12px</option>
                                <option value="13">13px</option>
                                <option value="14" selected>14px</option>
                                <option value="15">15px</option>
                                <option value="16">16px</option>
                                <option value="18">18px</option>
                                <option value="20">20px</option>
                            </select>
                            <div class="setting-hint">Text size on RP panel</div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Left Font</label>
                            <select id="setting_lfont">
                                <option value="inherit" selected>Default</option>
                                <option value="Georgia">Georgia</option>
                                <option value="Palatino">Palatino</option>
                                <option value="Times New Roman">Times New Roman</option>
                                <option value="Arial">Arial</option>
                                <option value="Verdana">Verdana</option>
                                <option value="Tahoma">Tahoma</option>
                                <option value="Courier New">Courier New</option>
                                <option value="OpenDyslexic">OpenDyslexic (Dyslexia-friendly)</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Right Font</label>
                            <select id="setting_rfont">
                                <option value="inherit" selected>Default</option>
                                <option value="Georgia">Georgia</option>
                                <option value="Palatino">Palatino</option>
                                <option value="Times New Roman">Times New Roman</option>
                                <option value="Arial">Arial</option>
                                <option value="Verdana">Verdana</option>
                                <option value="Tahoma">Tahoma</option>
                                <option value="Courier New">Courier New</option>
                                <option value="OpenDyslexic">OpenDyslexic (Dyslexia-friendly)</option>
                            </select>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_simpleui">
                            <div class="checkbox-label">
                                <span>Simple/Mobile UI</span>
                                <div class="setting-hint">Remove weather effects for better performance</div>
                            </div>
                        </div>
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_single_screen">
                            <div class="checkbox-label">
                                <span>Single Screen Mode</span>
                                <div class="setting-hint">All output to right panel</div>
                            </div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_noback">
                            <div class="checkbox-label">
                                <span>No Background Images</span>
                                <div class="setting-hint">Disable room background pictures</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- NOTIFICATION SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Notifications</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label for="setting_notify_message" class="setting-label">Message Notifications</label>
                            <div class="setting-hint">Desktop notifications for DMs and OOCs</div>
                            <select id="setting_notify_message" class="select select-sm w-full">
                                <option value="off">Off</option>
                                <option value="hidden">When tab is hidden</option>
                                <option value="always">Always</option>
                            </select>
                        </div>
                        <div class="setting-item">
                            <label for="setting_notify_emote" class="setting-label">Emote Notifications</label>
                            <div class="setting-hint">Notify when there's new RP activity</div>
                            <select id="setting_notify_emote" class="select select-sm w-full">
                                <option value="off">Off</option>
                                <option value="hidden">When tab is hidden</option>
                                <option value="always">Always</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- GAMEPLAY SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Gameplay</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_emoteremind">
                            <div class="checkbox-label">
                                <span>Show Turn Indicator</span>
                                <div class="setting-hint">Highlight input when it's your turn to emote</div>
                            </div>
                        </div>
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_show_full">
                            <div class="checkbox-label">
                                <span>Movement Descriptions</span>
                                <div class="setting-hint">Show full room details on movement</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AUDIO SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Audio</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_noambi">
                            <div class="checkbox-label">
                                <span>Mute Environment Sounds</span>
                                <div class="setting-hint">Disable weather and ambient sounds</div>
                            </div>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Master Volume</label>
                            <input type="range" id="setting_volume" min="0" max="100" value="50" style="width:100%">
                        </div>
                    </div>
                </div>
            </div>

            <!-- WEATHER SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Weather</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Temperature Unit</label>
                            <select id="setting_temp_unit">
                                <option value="F">Fahrenheit (°F)</option>
                                <option value="C">Celsius (°C)</option>
                            </select>
                            <div class="setting-hint">Display temperature in Fahrenheit or Celsius</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- KEYBINDINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Keybindings</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Switch Panes</label>
                            <input type="text" id="setting_key_tab" value="Tab" readonly>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Send Message</label>
                            <input type="text" id="setting_key_send" value="Enter" readonly>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Command History (Previous)</label>
                            <input type="text" id="setting_key_histup" value="ArrowUp" readonly>
                        </div>
                        <div class="setting-item">
                            <label class="setting-label">Command History (Next)</label>
                            <input type="text" id="setting_key_histdown" value="ArrowDown" readonly>
                        </div>
                    </div>
                </div>
            </div>

            <!-- BATTLE MAP SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Battle Map</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Animated Effects</label>
                            <select id="setting_battleMapEffects">
                                <option value="high">High (all effects)</option>
                                <option value="low">Low (water + lights only)</option>
                                <option value="off">Off</option>
                            </select>
                            <div class="setting-hint">Water flow, torch flicker, foliage sway</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ACCESSIBILITY SETTINGS -->
            <div class="settings-section">
                <div class="section-header">
                    <span class="section-title">Accessibility</span>
                    <span class="section-toggle">▼</span>
                </div>
                <div class="section-body">
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_mode">
                            <div class="checkbox-label">
                                <span>Accessibility Mode</span>
                                <div class="setting-hint">Optimize output for screen readers with TTS auto-queue</div>
                            </div>
                        </div>
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_reader">
                            <div class="checkbox-label">
                                <span>Screen Reader Optimization</span>
                                <div class="setting-hint">Simplify output formatting for screen readers</div>
                            </div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_contrast">
                            <div class="checkbox-label">
                                <span>High Contrast Mode</span>
                                <div class="setting-hint">Increase visual contrast for better readability</div>
                            </div>
                        </div>
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_reduced">
                            <div class="checkbox-label">
                                <span>Reduced Visual Effects</span>
                                <div class="setting-hint">Minimize animations and visual effects</div>
                            </div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_typing">
                            <div class="checkbox-label">
                                <span>Pause TTS on Typing</span>
                                <div class="setting-hint">Pause narration when you start typing</div>
                            </div>
                        </div>
                        <div class="setting-item checkbox-setting">
                            <input type="checkbox" id="setting_a11y_resume">
                            <div class="checkbox-label">
                                <span>Auto-Resume TTS</span>
                                <div class="setting-hint">Automatically resume narration after typing stops</div>
                            </div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">TTS Speed</label>
                            <select id="setting_a11y_speed">
                                <option value="0.5">0.5x (Slow)</option>
                                <option value="0.75">0.75x</option>
                                <option value="1.0" selected>1.0x (Normal)</option>
                                <option value="1.25">1.25x</option>
                                <option value="1.5">1.5x</option>
                                <option value="1.75">1.75x</option>
                                <option value="2.0">2.0x (Fast)</option>
                            </select>
                            <div class="setting-hint">Narration playback speed</div>
                        </div>
                    </div>
                    <div class="settings-grid grid-cols-12 gap-4">
                        <div class="setting-item">
                            <label class="setting-label">Color Blindness Mode</label>
                            <select id="setting_a11y_colorblind">
                                <option value="">None</option>
                                <option value="protanopia">Protanopia (Red-blind)</option>
                                <option value="deuteranopia">Deuteranopia (Green-blind)</option>
                                <option value="tritanopia">Tritanopia (Blue-blind)</option>
                            </select>
