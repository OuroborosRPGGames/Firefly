    let currentEmojiCategory = 'frequent';
    let recentEmojis = [];

    function setupEmojiPicker() {
        const emojiPopup = document.getElementById('emojiPickerPopup');
        const emojiGrid = document.getElementById('emojiGrid');
        const emojiSearch = document.getElementById('emojiSearch');
        const moreEmojiBtn = document.getElementById('emojiMoreBtn');

        if (!emojiPopup) return;

        // Load recent emojis from localStorage
        try {
            const stored = localStorage.getItem('recentEmojis');
            if (stored) recentEmojis = JSON.parse(stored);
        } catch (e) {}

        // Category buttons
        const categoryBtns = emojiPopup.querySelectorAll('.emoji-category');
        categoryBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                categoryBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentEmojiCategory = btn.dataset.category;
                renderEmojiGrid();
            });
        });

        // Search
        if (emojiSearch) {
            emojiSearch.addEventListener('input', (e) => {
                const query = e.target.value.toLowerCase();
                if (query) {
                    renderFilteredEmojis(query);
                } else {
                    renderEmojiGrid();
                }
            });
        }

        // Initial render
        renderEmojiGrid();

        // Click outside to close
        document.addEventListener('click', (e) => {
            if (emojiPopup.classList.contains('visible')) {
                // Check if click is outside popup and not on the "More Emoji" button
                if (!emojiPopup.contains(e.target) && e.target !== moreEmojiBtn && !moreEmojiBtn?.contains(e.target)) {
                    hideEmojiPicker();
                }
            }
        });
    }

    function toggleEmojiPicker() {
        const popup = document.getElementById('emojiPickerPopup');
        if (popup) {
            popup.classList.toggle('visible');
            hideColorPicker(); // Close color picker if open
        }
    }

    function hideEmojiPicker() {
        const popup = document.getElementById('emojiPickerPopup');
        if (popup) popup.classList.remove('visible');
    }

    function renderEmojiGrid() {
        const grid = document.getElementById('emojiGrid');
        if (!grid) return;

        let emojis;
        if (currentEmojiCategory === 'frequent' && recentEmojis.length > 0) {
            emojis = recentEmojis.slice(0, 32);
        } else {
            emojis = emojiData[currentEmojiCategory] || emojiData.smileys;
        }

        grid.innerHTML = emojis.map(emoji =>
            `<span class="emoji-item" data-emoji="${emoji}">${emoji}</span>`
        ).join('');

        // Add click handlers
        grid.querySelectorAll('.emoji-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                insertEmoji(item.dataset.emoji);
            });
        });
    }

    function renderFilteredEmojis(query) {
        const grid = document.getElementById('emojiGrid');
        if (!grid) return;

        // Simple search - just filter all emojis
        const allEmojis = Object.values(emojiData).flat();
        // For now, just show a subset since we can't search by name easily
        grid.innerHTML = allEmojis.slice(0, 64).map(emoji =>
            `<span class="emoji-item" data-emoji="${emoji}">${emoji}</span>`
        ).join('');

        grid.querySelectorAll('.emoji-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                insertEmoji(item.dataset.emoji);
            });
        });
    }

    function insertEmoji(emoji) {
        if (!messageInput || !emoji) return;

        // Focus the input
        messageInput.focus();

        // Insert emoji at cursor position
        const sel = window.getSelection();
        if (sel.rangeCount > 0) {
            const range = sel.getRangeAt(0);
            range.deleteContents();
            range.insertNode(document.createTextNode(emoji));
            range.collapse(false);
            sel.removeAllRanges();
            sel.addRange(range);
        } else {
            messageInput.innerHTML += emoji;
        }

        // Add to recent emojis
        recentEmojis = recentEmojis.filter(e => e !== emoji);
        recentEmojis.unshift(emoji);
        recentEmojis = recentEmojis.slice(0, 32);
        try {
            localStorage.setItem('recentEmojis', JSON.stringify(recentEmojis));
        } catch (e) {}

        // Close picker
        hideEmojiPicker();
    }

