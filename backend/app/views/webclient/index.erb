    function applyColor(colorCode) {
        if (!messageInput) return;

        // Focus the contenteditable
        messageInput.focus();

        // Get the color value
        let colorValue;
        if (colorCode.startsWith('#')) {
            colorValue = colorCode;
        } else {
            // Map single-letter codes to actual colors
            const colorMap = {
                'r': '#ff6b6b',
                'o': '#ff922b',
                'y': '#ffd43b',
                'g': '#51cf66',
                'c': '#66d9ef',
                'b': '#74c0fc',
                'm': '#da77f2',
                'w': '#ffffff'
            };
            colorValue = colorMap[colorCode.toLowerCase()] || '#00bcd4';
        }

        // Apply foreground color using execCommand
        document.execCommand('foreColor', false, colorValue);

        // Keep focus on the input
        messageInput.focus();
    }

    // ====== GRADIENT PICKER ======
    let gradientPicker = null;
    let savedSelectionForGradient = null;

    function setupGradientPicker() {
        const container = document.getElementById('gradientPickerContainer');
        if (!container) return;

        // Check if GradientPicker class is available
        if (typeof GradientPicker === 'undefined') {
            console.warn('GradientPicker not loaded - gradient features disabled');
            return;
        }

        gradientPicker = new GradientPicker({
            buttonContainer: container,
            apiEndpoint: '/api/gradients',
            position: 'above',
            onSelect: (gradient) => applyGradientToSelection(gradient)
        });
    }

    function saveSelectionForGradient() {
        const selection = window.getSelection();
        if (selection.rangeCount > 0) {
            savedSelectionForGradient = selection.getRangeAt(0).cloneRange();
        }
    }

    function restoreSelectionForGradient() {
        if (!savedSelectionForGradient) return false;
        const selection = window.getSelection();
        selection.removeAllRanges();
        selection.addRange(savedSelectionForGradient);
        return true;
    }

    function applyGradientToSelection(gradient) {
        if (!messageInput) return;
        if (!gradient || !gradient.colors || gradient.colors.length < 2) {
            console.warn('Invalid gradient provided');
            return;
        }

        // Focus the editor
        messageInput.focus();

        // Restore selection if saved
        restoreSelectionForGradient();

        const selection = window.getSelection();
        if (!selection.rangeCount) return;

        const range = selection.getRangeAt(0);

        // Check if selection is within our editor
        if (!messageInput.contains(range.commonAncestorContainer)) {
            console.warn('Selection is not within the message input');
            return;
        }

        // Get selected text
        const selectedText = range.toString();
        if (!selectedText) {
            console.warn('No text selected for gradient');
            return;
        }

        // Generate gradient HTML using GradientGenerator
        let gradientHtml;
        if (typeof GradientGenerator !== 'undefined') {
            gradientHtml = GradientGenerator.applyToText(
                selectedText,
                gradient.colors,
                gradient.easings || []
            );
        } else {
            // Fallback: simple alternating colors
            const chars = selectedText.split('');
            gradientHtml = chars.map((char, i) => {
                if (/\s/.test(char)) return char;
                const colorIndex = Math.floor(i * gradient.colors.length / chars.length);
                const color = gradient.colors[Math.min(colorIndex, gradient.colors.length - 1)];
                const escaped = char.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                return `<span style="color:${color}">${escaped}</span>`;
            }).join('');
        }

        // Delete selected content and insert gradient HTML
        range.deleteContents();

        // Create a temporary container to parse the HTML
        const temp = document.createElement('div');
        temp.innerHTML = gradientHtml;

        // Insert nodes
        const fragment = document.createDocumentFragment();
        while (temp.firstChild) {
            fragment.appendChild(temp.firstChild);
        }

        range.insertNode(fragment);

        // Clear selection
        selection.removeAllRanges();

        // Keep focus on input
        messageInput.focus();
    }

    function handleFormat(action) {
        if (!messageInput) return;

        // Focus the contenteditable if not already focused
        messageInput.focus();

        // Use document.execCommand for WYSIWYG formatting
        switch(action) {
            case 'bold':
                document.execCommand('bold', false, null);
                break;
            case 'italic':
                document.execCommand('italic', false, null);
                break;
            case 'underline':
                document.execCommand('underline', false, null);
                break;
            case 'strike':
            case 'strikethrough':
                document.execCommand('strikeThrough', false, null);
                break;
            default:
                return;
        }

        // Keep focus on the input
        messageInput.focus();
    }

    // ====== COMMAND PREFIX SYSTEM ======
    // sticky <cmd> - Make temp output stay in main window (for this command only)
    // asleft <cmd> - Send as if typed in left (OOC) pane
    // asright <cmd> - Send as if typed in right (RP) pane
    // onleft <cmd> - Execute normally but display result in left pane
    // onright <cmd> - Execute normally but display result in right pane
    // Prefixes can be combined: sticky asleft say Hello

    function parseCommandPrefix(text) {
        const prefixes = ['sticky', 'asleft', 'asright', 'atleft', 'atright', 'onleft', 'onright'];
        const lowerText = text.toLowerCase();
        const result = { prefixes: [], command: text };

        let remaining = text;
        let lowerRemaining = lowerText;

        // Parse multiple prefixes (e.g., "sticky asleft say hello")
        let foundPrefix = true;
        while (foundPrefix) {
            foundPrefix = false;
            for (const prefix of prefixes) {
                if (lowerRemaining.startsWith(prefix + ' ')) {
                    // Normalize atleft/atright to asleft/asright
                    const normalizedPrefix = prefix === 'atleft' ? 'asleft' :
                                            prefix === 'atright' ? 'asright' : prefix;
                    result.prefixes.push(normalizedPrefix);
                    remaining = remaining.slice(prefix.length + 1).trim();
                    lowerRemaining = remaining.toLowerCase();
                    foundPrefix = true;
                    break;
                }
            }
        }

        result.command = remaining;
        return result.prefixes.length > 0 ? result : null;
    }

    // Programmatically send a game command (used by canvas click handlers, etc.)
    // skipHistory: if true, don't add to command history (for UI-triggered actions)
    var skipNextHistory = false;
    function sendCommand(command, options) {
        if (!command) return;
        if (options && options.skipHistory) skipNextHistory = true;
        messageInput.innerHTML = command;
        sendMessage();
    }
    // Expose sendCommand globally for external JS modules (e.g. delve-map-panel.js)
    window.sendCommand = sendCommand;

    async function sendMessage() {
        // Hide temp result pane when sending a new command
        hideTempResult();

        // Stop typing indicator when message is sent
        stopTypingIndicator();

        // Get HTML content from contenteditable
        const htmlContent = messageInput.innerHTML.trim();
        const textContent = messageInput.textContent.trim();

        if (!textContent) {
            // Empty input (just hitting Enter) re-shows any active quickmenu
            // Only if the quickmenu key handler is still active (in a fight or activity)
            if (quickmenuData && quickmenuKeyHandler) {
                showObservationPanel('quickmenu', quickmenuData, 'right');
            }
            return;
        }

        // Handle client-side commands first
        const lowerText = textContent.toLowerCase();
        if (lowerText === 'minimap') {
            messageInput.innerHTML = '';
            toggleMinimap();
            return;
        }
        if (lowerText === 'stickymode') {
            messageInput.innerHTML = '';
            stickyMode = !stickyMode;
            showImprint(
                `Sticky mode ${stickyMode ? 'ON' : 'OFF'}: temp output will ${stickyMode ? 'stay in main feed' : 'go to observe pane'}.`,
                3500,
                '📌'
            );
            return;
        }
        if (lowerText === '/testinput') {
            messageInput.innerHTML = '';
            showTestInputMenu();
            return;
        }
        // Handle test input menu number selections (1-9)
        if (testInputMenuActive && /^[1-9]$/.test(textContent)) {
            messageInput.innerHTML = '';
            handleTestInputOption(parseInt(textContent));
            return;
        }

        // Check for command prefixes (sticky, asleft, asright, onleft, onright)
        const prefixData = parseCommandPrefix(textContent);
        let forcedInputSide = null;  // For 'asleft'/'asright' - changes what type gets sent
        let forcedOutputSide = null; // For 'onleft'/'onright' - changes where result displays
        let isSticky = false;        // For 'sticky' - makes temp output stay in main window

        if (prefixData) {
            const prefixes = prefixData.prefixes;
            if (prefixes.includes('asleft')) {
                forcedInputSide = 'l';
            } else if (prefixes.includes('asright')) {
                forcedInputSide = 'r';
            }
            if (prefixes.includes('onleft')) {
                forcedOutputSide = 'left';
            } else if (prefixes.includes('onright')) {
                forcedOutputSide = 'right';
            }
            if (prefixes.includes('sticky')) {
                isSticky = true;
            }
        }

        // Use the actual command (without prefix) if prefix was found
        const actualTextContent = prefixData ? prefixData.command : textContent;
        const actualHtmlContent = prefixData ? prefixData.command : htmlContent;

        if (!actualTextContent) return;

        const currentInputSide = forcedInputSide || messageSide.value; // 'l' for OOC, 'r' for RP

        // Channel switching: bare channel name switches, channel name + message switches AND sends
        if (currentInputSide === 'l') {
            const lowerText = actualTextContent.toLowerCase().trim();
            const matchedChannel = availableChannels.find(ch =>
                lowerText === ch || lowerText.startsWith(ch + ' ')
            );

            if (matchedChannel) {
                messageInput.innerHTML = '';

                if (lowerText === matchedChannel) {
                    // Bare channel name → switch only
                    try {
                        const response = await apiPost('/api/messages', { content: `channel ${matchedChannel} `, type: 'switch_channel' });
                        const data = await response.json();
                        if (data.success) {
                            if (data.status_bar) {
                                updateStatusBarFromServer(data.status_bar);
                            }
                            addMessage({
                                id: `switch-${Date.now()}`,
                                content: `Switched to ${matchedChannel} channel.`,
                                created_at: new Date().toISOString()
                            }, 'left');
                        } else {
                            addMessage({
                                id: `switch-error-${Date.now()}`,
                                content: data.error || 'Failed to switch channel.',
                                created_at: new Date().toISOString()
                            }, 'left');
                        }
                    } catch (error) {
                        console.warn('Failed to switch channel:', error);
                    }
                } else {
                    // Channel name + message → switch AND send
                    const message = actualTextContent.trim().substring(matchedChannel.length).trim();
                    try {
                        // First switch channel
                        const switchResponse = await apiPost('/api/messages', { content: `channel ${matchedChannel} `, type: 'switch_channel' });
                        const switchData = await switchResponse.json();
                        if (switchData.success) {
                            if (switchData.status_bar) {
                                updateStatusBarFromServer(switchData.status_bar);
                            }
                            // Then send the message to the new channel
                            const msgResponse = await apiPost('/api/messages', { content: message, type: 'ooc' });
                            const msgData = await msgResponse.json();
                            if (msgData.success && msgData.status_bar) {
                                updateStatusBarFromServer(msgData.status_bar);
                            }
                        }
                    } catch (error) {
                        console.warn('Failed to switch channel and send:', error);
                    }
                }
                return;
            }
        }

        const isEmote = actualTextContent.startsWith('.');
        const commandContent = isEmote ? actualTextContent.slice(1).trim() : actualTextContent;

        if (!commandContent) return;

        // Extract command word for display purposes
        const commandWord = actualTextContent.toLowerCase().split(/\s+/)[0];

        // Save to history based on which side we're typing on (original side, not forced)
        // Skip history for programmatic UI commands (puzzle solves, map clicks, etc.)
        if (skipNextHistory) {
            skipNextHistory = false;
        } else {
            const historyKey = messageSide.value === 'l' ? 'left' : 'right';
            addToHistory(htmlContent, historyKey);
            outgoingRecall = htmlContent;
        }

        // Reset channel history cursor when sending from left panel
        if (currentInputSide === 'l') {
            channelHistoryCursor = 0;
        }

        // Clear input and show last command as placeholder
        messageInput.innerHTML = '';
        // Suppress encoded puzzle solve commands from appearing in placeholder
        var placeholderText = actualTextContent;
        if (/^delve\s+solve\s+\S{10,}/i.test(placeholderText)) {
            placeholderText = 'delve solve [answer]';
        }
        lastSent[messageSide.value] = placeholderText;
        messageInput.dataset.placeholder = placeholderText;
        updateInactivePlaceholder();

        // Clear turn indicator when sending a message
        messageInput.classList.remove('turn-indicator');

        // Determine message type based on which side we're sending from
        let payloadType;
        if (currentInputSide === 'l') {
            // Left side = OOC chat
            payloadType = 'ooc';
        } else {
            // Right side = RP (say or emote)
            payloadType = isEmote ? 'emote' : 'say';
        }

        // Always send plain text for commands. Using innerHTML would HTML-encode
        // special characters (& → &amp;, < → &lt;) breaking room names like
        // "Main Road & Oak Avenue". Say/emote don't need HTML formatting either.
        const processedContent = isEmote ? commandContent : actualTextContent;

        try {
            const cmdStartTime = performance.now();
            const response = await apiPost('/api/messages', { content: processedContent, type: payloadType });

            const data = await response.json();
            const networkTime = Math.round(performance.now() - cmdStartTime);
            if (networkTime > 500 || data.server_time_ms > 200) {
                console.warn(`[Perf] "${commandWord}" total=${networkTime}ms server=${data.server_time_ms || '?'}ms client=${networkTime - (data.server_time_ms || 0)}ms`);
            }

            if (data.success) {
                // Handle quit/logout — redirect to dashboard
                if (data.data?.close_play_window) {
                    if (data.message?.content) {
                        const panel = forcedOutputSide || getMessagePanel(data.message?.message_type || payloadType);
                        addMessage(data.message, panel);
                    }
                    setTimeout(() => { window.location.href = '/dashboard'; }, 1500);
                    return;
                }
                // Handle popup form responses from server
                if (data.popup) {
                    showPopupForm(data.popup);
                }
                // Handle menu responses from server
                else if (data.menu) {
                    const menuSide = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                    showMenu(data.menu, menuSide);
                }
                // Handle left observe panel targeting (observe command)
                else if (data.target_panel === 'left_observe_window') {
                    if ((isSticky || stickyMode) && data.message?.content) {
                        addMessage(data.message, 'left');
                    } else {
                        showLeftObservationPanel(data);
                    }
                }
                // Handle right observe window panel targeting (look commands)
                else if (data.target_panel === 'right_observe_window') {
                    // Sticky: route observe window content to main feed instead
                    if ((isSticky || stickyMode) && data.message?.content) {
                        addMessage(data.message, 'right');
                    } else {
                        showInObserveWindow(data);
                    }
                    // Update wardrobe visibility for room data regardless of sticky mode
                    const roomData = data.data?.room || data.structured?.room;
                    if ((data.type === 'room' || data.display_type === 'room') && roomData) {
                        updateWardrobeVisibility(roomData);
                        setRoomConsentNotice(data.data?.content_consent || data.structured?.content_consent || null);
                    }
                }
                // Handle minimap toggle from server
                else if (data.data?.action === 'minimap') {
                    toggleMinimap();
                    if (data.message?.content) {
                        const side = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                        showTempResult('', data.message.content, side);
                    }
                }
                // Handle battle map show from server (map command during fight)
                else if (data.data?.action === 'show_battle_map') {
                    if (window.battleMap) {
                        window.battleMap.reset();
                        window.battleMap.refresh();
                    }
                }
                // Handle info-category output → temp window
                // Server sets output_category: 'info' for look, inventory, help, etc.
                else if (data.output_category === 'info') {
                    const side = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');

                    // Sticky: route info output to main feed instead of temp/observe pane
                    if (isSticky || stickyMode) {
                        if ((data.display_type === 'room' || data.type === 'room') && (data.data?.room || data.structured?.room)) {
                            setRoomConsentNotice(data.data?.content_consent || data.structured?.content_consent || null);
                        }
                        if (data.message?.content) {
                            addMessage(data.message, side);
                        }
                    } else {
                        const displayType = data.display_type || data.type;
                        let displayData = data.data || data.structured;

                        // For canvas types, inject canvas command string from message
                        if (displayType === 'canvas' && data.message?.content) {
                            displayData = { ...displayData, canvas_data: data.message.content };
                        }

                        // For SVG types, ensure svg data is available
                        if (displayType === 'svg' && !displayData?.svg && data.message?.content) {
                            displayData = { ...displayData, svg: data.message.content };
                        }

                        // Rich types (room, character, etc.) use observation panel
                        if (displayType && displayData && OBSERVATION_PANEL_TYPES.includes(displayType)) {
                            showObservationPanel(displayType, displayData, side);
                            // Update wardrobe visibility based on room data
                            if (displayType === 'room' && displayData?.room) {
                                updateWardrobeVisibility(displayData.room);
                            }
                        }
                        // Simple info messages use temp pane
                        else if (data.message?.content) {
                            showTempResult('', data.message.content, side);
                        }
                    }
                }
                // Quickmenu/form responses → observation panel (even without output_category)
                else if ((data.display_type === 'quickmenu' || data.type === 'quickmenu') && data.data) {
                    const side = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                    showObservationPanel('quickmenu', data.data, side);
                }
                // Embedded quickmenu (fight/spar commands bundle quickmenu alongside a message)
                else if (data.quickmenu) {
                    const side = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                    if (data.message?.content) {
                        addMessage(data.message, side === 'left' ? 'left' : 'right');
                    }
                    showObservationPanel('quickmenu', data.quickmenu, side);
                }
                else if ((data.display_type === 'form' || data.type === 'form') && data.data) {
                    const side = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                    showObservationPanel('form', data.data, side);
                }
                // Dice roll with animation data → animated display (self-view)
                else if (data.animation_data) {
                    const panel = forcedOutputSide || 'right';
                    const targetContainer = panel === 'left' ? lMessages : rMessages;
                    const targetWindow = panel === 'left' ? lMessageWindow : rMessageWindow;
                    const scrollId = panel === 'left' ? 'lmessagewindow' : 'rmessagewindow';

                    const animDiv = document.createElement('div');
                    animDiv.id = `roll-self-${Date.now()}-${Math.random().toString(36).slice(2, 6)}`;
                    animDiv.dataset.modifier = data.roll_modifier || 0;
                    animDiv.dataset.total = data.roll_total || 0;
                    animDiv.dataset.characterName = data.message?.character_name || characterShortName || '';
                    animDiv.dataset.scrollTarget = scrollId;

                    if (targetContainer) {
                        targetContainer.appendChild(animDiv);
                        scrollToBottom(targetWindow);
                    }

                    const selfAnimDuration = new DiceAnimator().animate(animDiv.id, data.animation_data);
                    const selfEndTime = Date.now() + (selfAnimDuration || 3000) + 1000;
                    if (selfEndTime > diceAnimatingUntil) diceAnimatingUntil = selfEndTime;

                    // Show the text message after the dice animation (e.g. skill check results)
                    if (data.message?.content) {
                        const msgPanel = panel === 'left' ? 'left' : 'right';
                        setTimeout(() => {
                            addMessage(data.message, msgPanel);
                        }, selfAnimDuration || 3000);
                    }
                }
                // Action-category output → main message feed
                else {
                    // Route message to correct panel based on its type or forced output
                    const panel = forcedOutputSide || getMessagePanel(data.message?.message_type || payloadType);
                    addMessage(data.message, panel);
                }

                // Handle movement (updates room, minimap, etc.)
                if (data.moved_to != null) {
                    handleMovementResult(data);
                }

                // Schedule fallback poll for timed movement arrival
                if (data.moving && data.duration) {
                    scheduleMovementArrivalPoll(data.duration);
                }

                // Handle imprint messages from server
                if (data.imprint) {
                    showImprint(data.imprint, data.imprint_duration || 5000, data.imprint_icon || '⚡');
                }

                // Handle observation updates from server
                if (data.observe) {
                    if (data.observe.action === 'start') {
                        startObservation(data.observe.target, data.observe.content);
                    } else if (data.observe.action === 'update') {
                        updateObservation(data.observe.content);
                    } else if (data.observe.action === 'stop') {
                        stopObservation();
                    }
                }

                // Handle delve HUD updates (before minimap - delve takes priority)
                // Delve data may be at top level or inside data.data (structured response)
                const delveSource = data.data || data;
                const delveMapSvg = data.delve_map_svg || delveSource.delve_map_svg;
                const delveInDelve = data.in_delve !== undefined ? data.in_delve : delveSource.in_delve;
                if (delveMapSvg || delveInDelve === true) {
                    handleDelveMapUpdate({
                        delve_map_svg: delveMapSvg,
                        in_delve: true,
                        delve_name: data.delve_name || delveSource.delve_name,
                        current_level: data.current_level || delveSource.current_level,
                        time_remaining: data.time_remaining != null ? data.time_remaining : delveSource.time_remaining,
                        current_hp: data.current_hp != null ? data.current_hp : delveSource.current_hp,
                        max_hp: data.max_hp || delveSource.max_hp,
                        willpower_dice: data.willpower_dice != null ? data.willpower_dice : delveSource.willpower_dice,
                        loot_collected: data.loot_collected != null ? data.loot_collected : delveSource.loot_collected,
                        current_room: data.current_room || delveSource.current_room
                    });
                } else if (delveInDelve === false && inDelve) {
                    exitDelveMap();
                }

                // Handle minimap updates from server (skip if in delve)
                // Exits may be at top-level (data.exits) or inside structured data
                if (!inDelve) {
                    const minimapExits = data.exits || data.structured?.exits || data.data?.exits;
                    if (data.minimap_data && data.minimap_data.svg) {
                        drawMinimapSvg(data.minimap_data.svg, data.minimap_data.metadata);
                        showMinimap();
                    } else if (data.minimap_data && data.minimap_data.current_room) {
                        drawSpatialMinimap(data.minimap_data);
                    } else if (data.minimap) {
                        drawMinimap(data.minimap);
                    } else if (minimapExits) {
                        const minimapRoomName = data.room_name || data.structured?.room?.name || currentRoomName;
                        drawSimpleMinimap(minimapRoomName, minimapExits);
                    }
                }

                // Handle delve status updates
                if (data.delve_status !== undefined) {
                    updateDelveStatus(data.delve_status);
                }

                // Handle media sync actions (screen sharing, YouTube watch parties)
                if (data.type === 'media_action' && data.data && window.MediaSync) {
                    window.MediaSync.handleMediaAction(data.data);
                }

                // Handle GUI open requests (travel map, descriptions, etc.)
                if (data.type === 'open_gui' && data.data?.gui) {
                    const guiType = data.data.gui;
                    if (guiType === 'travel_map' && window.openTravelMap) {
                        window.openTravelMap();
                    } else if (guiType === 'descriptions') {
                        window.openDescriptionsPopout(data.data.character_id);
                    } else if (guiType === 'media') {
                        window.openMediaPopout();
                    }
                }

                // Handle status bar updates from server
                if (data.status_bar) {
                    updateStatusBarFromServer(data.status_bar);
                }

                const responsePrivateMode = data.data?.private_mode ?? data.private_mode;
                if (responsePrivateMode !== undefined) {
                    privateModeActive = !!responsePrivateMode;
                    applyPrivateModeStatusStyling();
                }
            } else {
                const errorPanel = forcedOutputSide || (currentInputSide === 'l' ? 'left' : 'right');
                // Restore input text if server requests it (e.g., emote with no self-reference)
                if (data.restore_input) {
                    messageInput.textContent = data.restore_input;
                    // Move cursor to end
                    const range = document.createRange();
                    range.selectNodeContents(messageInput);
                    range.collapse(false);
                    const sel = window.getSelection();
                    sel.removeAllRanges();
                    sel.addRange(range);
                }
                // Route info-category errors (invalid commands, etc.) to temp window
                if (data.output_category === 'info' || data.target_panel === 'right_observe_window' || data.target_panel === 'left_observe_window') {
                    showTempResult('', data.error || 'Command failed', errorPanel);
                } else {
                    showSystemMessage(`Error: ${data.error || 'Command failed'}`, errorPanel);
                }
            }
        } catch (error) {
            console.error('Error sending command:', error);
            const errorPanel = currentInputSide === 'l' ? 'left' : 'right';
            showSystemMessage('Connection error. Please try again.', errorPanel);
        }
    }

    function handleMovementResult(response) {
        const lookContent = response.message?.content;
        const derivedRoomName = extractRoomNameFromMessage(lookContent);
        if (derivedRoomName) {
            currentRoomName = derivedRoomName;
            updateRightStatus(derivedRoomName);
        }

        // Update background image if provided in response
        const roomImage = response.room_image || response.background_image || response.bpic
            || response.data?.room?.background_picture_url || response.structured?.room?.background_picture_url;
        const maskImage = response.mask_url || response.data?.room?.mask_url || response.structured?.room?.mask_url;
        if (roomImage) {
            updateRoomBackgroundImage(roomImage, maskImage);
        }

        // Update wardrobe visibility based on room data
        if (response.structured?.room) {
            updateWardrobeVisibility(response.structured.room);
        }

        const consentInfo = response.content_consent || response.data?.content_consent || response.structured?.content_consent || null;
        if (response.moved_to != null) {
            setRoomConsentNotice(consentInfo);
        }
    }

    // Update wardrobe button visibility based on room vault access
    function updateWardrobeVisibility(roomData) {
        const wardrobeBtn = document.getElementById('wardrobeTrigger');
        if (!wardrobeBtn) return;

        const hasVaultAccess = roomData?.vault_accessible === true;
        wardrobeBtn.style.display = hasVaultAccess ? 'inline-flex' : 'none';
    }

    function extractRoomNameFromMessage(messageContent) {
        if (typeof messageContent !== 'string') return null;
        const lines = messageContent.split('\n');
        for (const rawLine of lines) {
            const line = rawLine.trim();
            if (line.startsWith('[') && line.endsWith(']')) {
                const match = line.match(/^\[\s*(.+?)\s*\]$/);
                if (match) return match[1];
            }
        }
        return null;
    }

    function processMessageFormatting(text) {
        return text
            .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
            .replace(/\*([^*]+)\*/g, '<em>$1</em>')
            .replace(/__([^_]+?)__/g, '<span class="text-underline">$1</span>')
            .replace(/~~([^~]+?)~~/g, '<span class="text-strike">$1</span>')
            .replace(/%([rgybmcwRGYBMCW])([^%]*)%/g, '<span class="color-$1">$2</span>');
    }

    function maybeNotify(message, panel) {
        if (!('Notification' in window) || Notification.permission !== 'granted') return;

        // Notification payload built server-side — includes title, body, icon, setting key
        const notif = message.notification;
        if (!notif || !notif.title || !notif.body) return;

        const setting = currentSettings[notif.setting] || 'off';
        if (setting === 'off') return;
        if (setting === 'hidden' && !document.hidden) return;

        const icon = notif.icon || '/favicon.ico';
        const tag  = notif.setting === 'notify_message' ? 'firefly-message' : 'firefly-emote';

        const n = new Notification(notif.title, { body: notif.body, icon, tag });
        setTimeout(() => n.close(), 10 * 1000);
        n.onclick = () => { window.focus(); };
    }

    function addMessage(message, panel) {
        if (!message) return;
        // Normalize: if message is a plain string, wrap it
        if (typeof message === 'string') {
            message = { content: message, id: null };
        }
        // Skip empty content to avoid blank lines
        if (!message.content || !message.content.trim()) return;

        const cacheKey = message.id ? String(message.id) : null;
        if (cacheKey && renderedMessageIds.has(cacheKey)) return;
        if (cacheKey) renderedMessageIds.add(cacheKey);

        if (shouldSuppressRightPanelSystemMessage(message, panel)) {
            if (message.id) {
                seenMessageIds.add(message.id);
                acknowledgeMessage(message.id, message.sequence_number);
            }
            return;
        }

        const messageEl = document.createElement('div');
        messageEl.className = 'message';
        if (message.id) messageEl.id = `message_${message.id}`;
        if (message.broadcast_id) messageEl.dataset.broadcastId = message.broadcast_id;

        const timestamp = formatTimestamp(message.created_at);
        messageEl.title = timestamp;
        // Use styled HTML for auto-gm messages when available, plain content otherwise
        const displayContent = (message.html && message.type && message.type.startsWith('auto_gm'))
            ? message.html
            : processContentForDisplay(message.content);
        messageEl.innerHTML = displayContent;

        // Route to correct panel
        const targetContainer = panel === 'left' ? lMessages : rMessages;
        const targetWindow = panel === 'left' ? lMessageWindow : rMessageWindow;

        if (targetContainer) {
            targetContainer.appendChild(messageEl);
            scrollToBottom(targetWindow);

            // Push to replay buffer for screen reader navigation
            if (typeof replayBuffer !== 'undefined') {
                const replayPane = panel === 'left' ? 'left' : 'right';
                replayBuffer.push(replayPane, messageEl.textContent || '');
            }

            cleanupOldMessages(targetContainer);

            // Update favicon notification for unseen messages
            updateFaviconForPanel(panel);
            maybeNotify(message, panel);
        }

        if (message.id) {
            seenMessageIds.add(message.id);
            // Send acknowledgment for message sync
            acknowledgeMessage(message.id, message.sequence_number);
        }

        // Immediate combat detection - trigger battle map without waiting for poll
        const messageContent = message.content || '';
        if (messageContent.includes('engage') && messageContent.includes('combat') ||
            messageContent.includes('in combat') ||
            messageContent.match(/You engage .+ in combat/i)) {
            // Combat started - immediately check status and show battle map
            if (window.battleMap && typeof window.battleMap.checkStatus === 'function') {
                window.battleMap.checkStatus();
            }
        }
    }

    // Drop low-signal system acknowledgements from the right RP feed.
    // These are UI/control confirmations that add scroll noise but little gameplay value.
    function shouldSuppressRightPanelSystemMessage(message, panel) {
        if (panel !== 'right') return false;
        if ((message.message_type || 'system').toLowerCase() !== 'system') return false;
        if (message.type && String(message.type).startsWith('auto_gm')) return false;

        const plain = String(message.content || '')
            .replace(/<[^>]*>/g, ' ')
            .replace(/\s+/g, ' ')
            .trim()
            .toLowerCase();

        if (!plain) return false;

        const lowSignalPatterns = [
            /^menu closed\.?$/,
            /^cancelled\.?$/,
            /^(action|combat|roll|purchase|taxi|journey) cancelled\.?$/,
            /^calendar closed\.?$/,
            /^inbox closed\.?$/,
            /^your choice has been recorded\.?$/,
            /^selected:\s+/,
            /^locatability unchanged\.?$/
        ];

        return lowSignalPatterns.some((pattern) => pattern.test(plain));
    }

    function processContentForDisplay(content) {
        if (content == null) return '';
        // First convert newlines to <br>
        let processed = String(content).replace(/\r\n/g, '\n').split('\n').join('<br>');
        // Then process rich content (images, videos)
        processed = processRichContent(processed);
        // Convert <dmg>...</dmg> tags to styled damage summary
        // Strip any HTML tags (like <strong> from personalization) before formatting,
        // since formatDamageSummary applies its own escaping and styling
        processed = processed.replace(/<dmg>(.*?)<\/dmg>/g, (match, inner) => {
            const plainInner = inner.replace(/<[^>]*>/g, '');
            return '<span class="combat-damage-summary">' + formatDamageSummary(plainInner) + '</span>';
        });
        return processed;
    }

    function showSystemMessage(content, panel) {
        const messageEl = document.createElement('div');
        messageEl.className = 'message-system';
        messageEl.innerHTML = escapeHtml(content);

        const targetContainer = panel === 'left' ? lMessages : rMessages;
        const targetWindow = panel === 'left' ? lMessageWindow : rMessageWindow;

        if (targetContainer) {
            targetContainer.appendChild(messageEl);
            scrollToBottom(targetWindow);
        }
    }

    function addToHistory(command, side) {
        if (!command?.trim()) return;
        const hist = commandHistory[side];
        const existingIndex = hist.commands.indexOf(command);
        if (existingIndex !== -1) hist.commands.splice(existingIndex, 1);
        hist.commands.push(command);
        if (hist.commands.length > 50) hist.commands.shift();
        hist.index = -1;
    }

    function navigateHistory(direction, side) {
        const hist = commandHistory[side];
        if (hist.commands.length === 0) return;

        if (hist.index === -1) {
            hist.current = messageInput.innerHTML || '';
            hist.index = hist.commands.length;
        }

        if (direction === 'up' && hist.index > 0) {
            hist.index--;
            messageInput.innerHTML = hist.commands[hist.index];
        } else if (direction === 'down') {
            if (hist.index < hist.commands.length - 1) {
                hist.index++;
                messageInput.innerHTML = hist.commands[hist.index];
            } else {
                hist.index = -1;
                messageInput.innerHTML = hist.current;
            }
        }

        // Move cursor to end
        const range = document.createRange();
        const sel = window.getSelection();
        if (messageInput.childNodes.length > 0) {
            range.selectNodeContents(messageInput);
            range.collapse(false);
            sel.removeAllRanges();
            sel.addRange(range);
        }
    }

    // Channel history cursor (tracks position during arrow-key cycling)
    let channelHistoryCursor = 0;

    // Cycle through address history (channels/PMs) for left panel
    async function cycleAddressHistory(direction) {
        try {
            const response = await apiPost('/api/messages/cycle', { direction });
            const data = await response.json();
            if (data.success && data.status_bar) {
                updateStatusBarFromServer(data.status_bar);
                channelHistoryCursor = data.cursor || 0;
            }
        } catch (error) {
            console.warn('Failed to cycle address history:', error);
        }
    }

    // Load recent messages and route them to correct panels based on type
    async function loadRecentMessages() {
        try {
            const response = await apiGet('/api/messages');
            const messages = await response.json();

            messages.forEach((msg) => {
                // Route each message based on its type
                const panel = getMessagePanel(msg.message_type);
                addMessage(msg, panel);
            });
        } catch (error) {
            console.error('Error loading messages:', error);
        }
    }

    // Load roleplay history - always goes to RIGHT (RP) panel
    function loadRoleplayHistory() {
        apiGet('/api/messages/roleplay')
            .then((response) => {
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                return response.json();
            })
            .then((rpLogs) => {
                if (!Array.isArray(rpLogs) || rpLogs.length === 0) return;

                const separatorEl = document.createElement('div');
                separatorEl.className = 'message-system';
                separatorEl.innerHTML = '<i>--- Previous roleplay history ---</i>';
                rMessages?.appendChild(separatorEl);

                rpLogs.forEach((log) => {
                    const text = log.html_content || log.content || log.text;
                    if (!log || !text) return;

                    const messageEl = document.createElement('div');
                    messageEl.className = 'message history';
                    const timestamp = log.timestamp ? new Date(log.timestamp).toLocaleString() : '';
                    messageEl.title = timestamp;
                    messageEl.innerHTML = '<span style="opacity: 0.8">' + text + '</span>';
                    rMessages?.appendChild(messageEl);
                });

                const currentSeparatorEl = document.createElement('div');
                currentSeparatorEl.className = 'message-system';
                currentSeparatorEl.innerHTML = '<i>--- Current session begins ---</i>';
                rMessages?.appendChild(currentSeparatorEl);

                scrollToBottom(rMessageWindow);
            })
            .catch((error) => console.warn('Failed to load roleplay history:', error));
    }

    function cleanupOldMessages(container) {
        const messages = container.querySelectorAll('.message, .message-system, .room-entry');
        if (messages.length > 200) {
            for (let i = 0; i < messages.length - 200; i++) {
                container.removeChild(messages[i]);
            }
        }
    }

    function setupAutoRefresh() {
        // Update left status time every second
        setInterval(() => {
            updateLeftStatus();
        }, 1000);

        // Poll for new messages (fallback when WebSocket is unavailable)
        // WebSocket handles real-time delivery; polling catches anything missed
        // Uses sequence-based resync to avoid re-delivering messages from RpLog
        // that the user already saw (RpLog IDs differ from WebSocket message IDs)
        setInterval(() => {
            if (!gameSocket || !gameSocket.isConnected()) {
                if (lastSequenceNumber > 0) {
                    requestMissingMessages(lastSequenceNumber + 1, lastSequenceNumber + 50);
                } else {
                    loadRecentMessages();
                }
            }
        }, 10000); // 10 second fallback polling

        // Poll status bar every 5 seconds for live HP/weather/time updates
        setInterval(async () => {
            try {
                const resp = await apiGet('/api/status');
                if (resp.ok) {
                    const data = await resp.json();
                    if (data && (data.left || data.right || data.combat)) {
                        updateStatusBarFromServer(data);
                    }
                }
            } catch (e) { /* silent - next poll will retry */ }
        }, 5000);

        // Update presence countdowns every minute
        setInterval(() => {
            updatePresenceCountdowns();
        }, 60000); // 1 minute
    }

    // Update presence countdown displays without server round-trip
    function updatePresenceCountdowns() {
        const presenceElements = document.querySelectorAll('.obs-presence[data-until]');
        presenceElements.forEach(el => {
            const untilStr = el.getAttribute('data-until');
            if (!untilStr) return;

            const untilTime = new Date(untilStr);
            const now = new Date();
            const diffMs = untilTime - now;
            const diffMins = Math.ceil(diffMs / 60000);

            if (diffMins <= 0) {
                // Expired - remove the element
                el.remove();
            } else {
                // Update the displayed minutes
                const statusMatch = el.textContent.match(/\(([^)]+?)(\s+\d+)?\)/);
                if (statusMatch) {
                    const status = statusMatch[1].replace(/\s+\d+$/, '').trim();
                    el.textContent = `(${status} ${diffMins})`;
                }
            }
        });
    }

