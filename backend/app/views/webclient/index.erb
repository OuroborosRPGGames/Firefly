    // ====== QUICKMENU RENDERER ======

    let quickmenuData = null;
    let quickmenuKeyHandler = null;

    function renderQuickmenuDisplay(data) {
        let html = '<div class="obs-quickmenu">';

        html += `<div class="obs-quickmenu-prompt">${escapeHtml(data.prompt || 'Choose an option')}</div>`;
        html += '<ol class="obs-quickmenu-options">';

        const options = data.options || [];
        let currentSection = null;
        options.forEach((opt, index) => {
            // Render section headers when section field changes
            if (opt.section && opt.section !== currentSection) {
                currentSection = opt.section;
                html += `<div class="font-bold text-base-content/80 mt-2 mb-1 border-b border-base-300 pb-1">${escapeHtml(currentSection)}</div>`;
            }
            const key = opt.key || (index + 1).toString();
            // Use html_label if available (preserves color markup), otherwise escape plain label
            const labelHtml = opt.html_label || escapeHtml(opt.label || 'Option');
            html += `<li class="obs-quickmenu-option" data-key="${escapeHtml(key)}" data-interaction-id="${escapeHtml(data.interaction_id || '')}" onclick="selectQuickmenuOption(this)">`;
            html += `<span class="obs-option-number">${index + 1}.</span>`;
            html += `<span class="obs-option-label">${labelHtml}</span>`;
            if (opt.description) {
                html += `<span class="obs-option-desc">${escapeHtml(opt.description)}</span>`;
            }
            html += `</li>`;
        });

        html += '</ol>';
        html += '<div class="obs-quickmenu-hint">Press 1-9 to select, Escape to cancel</div>';
        html += '</div>';

        // Set up keyboard handler for quickmenu
        setupQuickmenuKeyHandler(data);

        return html;
    }

    function renderCanvasDisplay(data) {
        // data contains canvas command string in the message field,
        // or the canvas data is the message content passed as the observation content
        // The canvas format is: width|||height|||cmd1;;;cmd2;;;cmd3
        const canvasId = 'obs-canvas-' + Date.now();
        const canvasData = data.canvas_data || data.message || '';

        // Parse canvas dimensions from the command string
        // If data has width/height from the structured data, use those
        const width = data.width || 400;
        const height = data.height || 400;

        let html = '<div class="obs-canvas-display" style="text-align:center;padding:8px 0">';
        html += `<canvas id="${canvasId}" width="${width}" height="${height}" style="max-width:100%;border:1px solid #333;border-radius:4px;"></canvas>`;
        html += '</div>';

        // Schedule canvas drawing after DOM insert
        setTimeout(() => {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            // Try to find canvas data from the temp pane content or from data
            drawCanvasInElement(canvas, canvasData, width, height);
        }, 50);

        return html;
    }

    function drawCanvasInElement(canvas, mapData, fallbackWidth, fallbackHeight) {
        if (!canvas || !mapData) return;

        const parts = mapData.split('|||');
        if (parts.length < 3) return;

        const width = parseInt(parts[0]) || fallbackWidth;
        const height = parseInt(parts[1]) || fallbackHeight;
        const commands = parts[2].split(';;;');

        canvas.width = width;
        canvas.height = height;

        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, width, height);

        for (const cmd of commands) {
            if (cmd.trim()) {
                executeCanvasCommand(ctx, cmd.trim(), width, height);
            }
        }
    }

    // SVG display renderer for observation panel (city maps, etc.)
    function renderSvgDisplay(data) {
        const svgContent = data.svg || '';
        if (!svgContent.includes('<svg')) return '<p>No map data</p>';

        let html = '<div class="obs-svg-display">';
        html += svgContent;
        html += '</div>';

        return html;
    }

    // ====== PUZZLE RENDERERS ======

    function renderPuzzleDisplay(data) {
        const puzzleType = data.puzzle_type || data.type;
        let html = '';
        // Show hint message if present
        if (data.help_message) {
            html += `<div class="puzzle-help-message">${escapeHtml(data.help_message)}</div>`;
        }
        switch (puzzleType) {
            case 'symbol_grid': html += renderSymbolGridPuzzle(data); break;
            case 'pipe_network': html += renderPipeNetworkPuzzle(data); break;
            case 'toggle_matrix': html += renderToggleMatrixPuzzle(data); break;
            default:
                html += `<div class="puzzle-container"><p class="puzzle-desc">${escapeHtml(data.description || 'A puzzle blocks the way.')}</p></div>`;
        }
        return html;
    }

    function submitPuzzleAnswer(answer) {
        const encoded = btoa(JSON.stringify(answer));
        sendCommand('delve solve ' + encoded, {skipHistory: true});
    }

    // --- Symbol Grid ---
    function renderSymbolGridPuzzle(data) {
        const size = data.size || 4;
        const symbols = data.symbols || ['A', 'B', 'C', 'D'];
        const clues = data.clues || [];
        const pid = data.puzzle_id || 0;

        // Build clue map: "x,y" -> { symbol, locked }
        const clueMap = {};
        clues.forEach(c => { clueMap[c.x + ',' + c.y] = { symbol: c.symbol, locked: c.locked }; });

        let html = '<div class="puzzle-container">';
        html += `<p class="puzzle-desc">${escapeHtml(data.description || 'Fill the grid with symbols.')}</p>`;
        html += `<p class="puzzle-info">Symbols: ${symbols.map(s => `<span class="puzzle-symbol">${escapeHtml(s)}</span>`).join(' ')} <span style="opacity:0.6;font-size:0.85em;">(click cells to cycle)</span></p>`;
        html += `<div class="symbol-grid" id="sgrid-${pid}" style="grid-template-columns: repeat(${size}, 1fr);" data-symbols='${JSON.stringify(symbols)}' data-size="${size}">`;

        for (let y = 0; y < size; y++) {
            for (let x = 0; x < size; x++) {
                const key = x + ',' + y;
                if (clueMap[key]) {
                    const helpClass = clueMap[key].locked ? ' help-locked' : '';
                    html += `<div class="puzzle-cell clue${helpClass}" data-x="${x}" data-y="${y}">${escapeHtml(clueMap[key].symbol)}</div>`;
                } else {
                    html += `<div class="puzzle-cell editable" data-x="${x}" data-y="${y}" data-idx="0" onclick="cyclePuzzleSymbol(this, '${pid}')"></div>`;
                }
            }
        }

        html += '</div>';
        html += '<div class="puzzle-actions">';
        html += `<button class="puzzle-btn submit" onclick="submitSymbolGrid('${pid}', ${size})">Submit</button>`;
        html += `<button class="puzzle-btn reset" onclick="resetSymbolGrid('${pid}')">Reset</button>`;
        html += `<button class="puzzle-btn help" onclick="sendCommand('delve help', {skipHistory: true})">Help (30s)</button>`;
        html += '</div></div>';
        return html;
    }

    function cyclePuzzleSymbol(el, pid) {
        const grid = document.getElementById('sgrid-' + pid);
        if (!grid) return;
        const symbols = JSON.parse(grid.dataset.symbols);
        let idx = parseInt(el.dataset.idx || '0');
        idx = (idx + 1) % (symbols.length + 1);
        el.dataset.idx = idx;
        el.textContent = idx === 0 ? '' : symbols[idx - 1];
        el.classList.toggle('filled', idx > 0);
    }

    function submitSymbolGrid(pid, size) {
        const grid = document.getElementById('sgrid-' + pid);
        if (!grid) return;
        const symbols = JSON.parse(grid.dataset.symbols);
        const answer = [];
        const cells = grid.querySelectorAll('.puzzle-cell');

        for (let y = 0; y < size; y++) {
            const row = [];
            for (let x = 0; x < size; x++) {
                const cell = cells[y * size + x];
                if (cell.classList.contains('clue')) {
                    row.push(cell.textContent);
                } else {
                    const idx = parseInt(cell.dataset.idx || '0');
                    if (idx === 0) {
                        appendMessage('system', 'Fill in all cells before submitting.', 'error');
                        return;
                    }
                    row.push(symbols[idx - 1]);
                }
            }
            answer.push(row);
        }
        submitPuzzleAnswer(answer);
    }

    function resetSymbolGrid(pid) {
        const grid = document.getElementById('sgrid-' + pid);
        if (!grid) return;
        grid.querySelectorAll('.puzzle-cell.editable').forEach(cell => {
            cell.dataset.idx = '0';
            cell.textContent = '';
            cell.classList.remove('filled');
        });
    }

    // --- Pipe Network ---
    function renderPipeNetworkPuzzle(data) {
        const size = data.size || 4;
        const grid = data.grid || [];
        const source = data.source || [0, 0];
        const drain = data.drain || [size - 1, size - 1];
        const pid = data.puzzle_id || 0;
        const lockedPipes = data.locked_pipes || [];
        const lockedSet = new Set(lockedPipes.map(c => c.x + ',' + c.y));

        let html = '<div class="puzzle-container">';
        html += `<p class="puzzle-desc">${escapeHtml(data.description || 'Rotate pipes to connect source to drain.')}</p>`;
        html += `<div class="pipe-grid" id="pgrid-${pid}" style="grid-template-columns: repeat(${size}, 1fr);" data-size="${size}">`;

        for (let y = 0; y < size; y++) {
            for (let x = 0; x < size; x++) {
                const pipe = grid[y] && grid[y][x] ? grid[y][x] : { type: 'straight', rotation: 0 };
                const ptype = pipe.type || 'straight';
                const rot = pipe.rotation || 0;
                const isSource = (y === source[0] && x === source[1]);
                const isDrain = (y === drain[0] && x === drain[1]);
                const isLocked = lockedSet.has(x + ',' + y);
                const marker = isSource ? '<div class="pipe-marker source">S</div>' : isDrain ? '<div class="pipe-marker drain">D</div>' : '';
                const lockIcon = isLocked ? '<div class="pipe-lock-icon"><i class="bi bi-lock-fill"></i></div>' : '';
                const clickHandler = isLocked ? '' : ` onclick="rotatePipe(this, '${pid}')"`;

                html += `<div class="pipe-cell${isSource ? ' source' : ''}${isDrain ? ' drain' : ''}${isLocked ? ' locked' : ''}" data-x="${x}" data-y="${y}" data-type="${ptype}" data-rot="${rot}"${clickHandler}>`;
                html += pipeSvg(ptype, rot);
                html += marker;
                html += lockIcon;
                html += '</div>';
            }
        }

        html += '</div>';
        html += '<div class="puzzle-actions">';
        html += `<button class="puzzle-btn submit" onclick="submitPipeNetwork('${pid}', ${size})">Submit</button>`;
        html += `<button class="puzzle-btn help" onclick="sendCommand('delve help', {skipHistory: true})">Help (30s)</button>`;
        html += '</div></div>';
        return html;
    }

    function pipeSvg(type, rotation) {
        const r = rotation * 90;
        let paths = '';
        switch (type) {
            case 'straight':
                paths = '<line x1="20" y1="0" x2="20" y2="40" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>';
                break;
            case 'bend':
                paths = '<path d="M20 0 L20 20 L40 20" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>';
                break;
            case 'cross':
                paths = '<line x1="20" y1="0" x2="20" y2="40" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>' +
                        '<line x1="0" y1="20" x2="40" y2="20" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>';
                break;
            default:
                paths = '<line x1="20" y1="0" x2="20" y2="40" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>';
        }
        return `<svg class="pipe-svg" viewBox="0 0 40 40" style="transform: rotate(${r}deg)">${paths}</svg>`;
    }

    function rotatePipe(el, pid) {
        if (el.classList.contains('locked')) return;
        let rot = parseInt(el.dataset.rot || '0');
        rot = (rot + 1) % 4;
        el.dataset.rot = rot;
        const type = el.dataset.type || 'straight';
        // Re-render SVG, keep markers and lock icon
        const marker = el.querySelector('.pipe-marker');
        const markerHtml = marker ? marker.outerHTML : '';
        el.innerHTML = pipeSvg(type, rot) + markerHtml;
    }

    function submitPipeNetwork(pid, size) {
        const grid = document.getElementById('pgrid-' + pid);
        if (!grid) return;
        const answer = [];
        const cells = grid.querySelectorAll('.pipe-cell');

        for (let y = 0; y < size; y++) {
            const row = [];
            for (let x = 0; x < size; x++) {
                const cell = cells[y * size + x];
                row.push({ type: cell.dataset.type, rotation: parseInt(cell.dataset.rot || '0') });
            }
            answer.push(row);
        }
        submitPuzzleAnswer(answer);
    }

    // --- Toggle Matrix ---
    function renderToggleMatrixPuzzle(data) {
        const size = data.size || 3;
        const grid = data.grid || [];
        const pid = data.puzzle_id || 0;
        const lockedCells = data.locked || [];
        const lockedSet = new Set(lockedCells.map(c => c.x + ',' + c.y));

        let html = '<div class="puzzle-container">';
        html += `<p class="puzzle-desc">${escapeHtml(data.description || 'Toggle all cells to the same state.')}</p>`;
        html += `<p class="puzzle-info">Goal: Light up all cells</p>`;
        html += `<div class="toggle-grid" id="tgrid-${pid}" style="grid-template-columns: repeat(${size}, 1fr);" data-size="${size}" data-locked='${JSON.stringify(lockedCells)}'>`;

        for (let y = 0; y < size; y++) {
            for (let x = 0; x < size; x++) {
                const on = grid[y] && grid[y][x] ? true : false;
                const isLocked = lockedSet.has(x + ',' + y);
                const lockClass = isLocked ? ' locked' : '';
                const clickHandler = isLocked ? '' : ` onclick="toggleMatrixCell('${pid}', ${x}, ${y}, ${size})"`;
                html += `<div class="toggle-cell ${on ? 'on' : 'off'}${lockClass}" data-x="${x}" data-y="${y}"${clickHandler}>${isLocked ? '<i class="bi bi-lock-fill" style="font-size:10px;opacity:0.5;"></i>' : ''}</div>`;
            }
        }

        html += '</div>';
        html += '<div class="puzzle-actions">';
        html += `<button class="puzzle-btn submit" onclick="submitToggleMatrix('${pid}', ${size})">Submit</button>`;
        html += `<button class="puzzle-btn help" onclick="sendCommand('delve help', {skipHistory: true})">Help (30s)</button>`;
        html += '</div></div>';
        return html;
    }

    function toggleMatrixCell(pid, x, y, size) {
        const grid = document.getElementById('tgrid-' + pid);
        if (!grid) return;
        const cells = grid.querySelectorAll('.toggle-cell');

        // Toggle center + 4 neighbors (skip locked cells)
        const toggleAt = (tx, ty) => {
            if (tx < 0 || tx >= size || ty < 0 || ty >= size) return;
            const cell = cells[ty * size + tx];
            if (cell && !cell.classList.contains('locked')) {
                cell.classList.toggle('on');
                cell.classList.toggle('off');
            }
        };

        toggleAt(x, y);
        toggleAt(x - 1, y);
        toggleAt(x + 1, y);
        toggleAt(x, y - 1);
        toggleAt(x, y + 1);

        // Check win condition: all cells on
        const allOn = Array.from(cells).every(c => c.classList.contains('on'));
        if (allOn) {
            submitToggleMatrix(pid, size);
        }
    }

    function submitToggleMatrix(pid, size) {
        const grid = document.getElementById('tgrid-' + pid);
        if (!grid) return;
        const cells = grid.querySelectorAll('.toggle-cell');
        const answer = [];

        for (let y = 0; y < size; y++) {
            const row = [];
            for (let x = 0; x < size; x++) {
                row.push(cells[y * size + x].classList.contains('on'));
            }
            answer.push(row);
        }
        submitPuzzleAnswer(answer);
    }

    // Make puzzle functions globally accessible
    window.cyclePuzzleSymbol = cyclePuzzleSymbol;
    window.submitSymbolGrid = submitSymbolGrid;
    window.resetSymbolGrid = resetSymbolGrid;
    window.rotatePipe = rotatePipe;
    window.submitPipeNetwork = submitPipeNetwork;
    window.toggleMatrixCell = toggleMatrixCell;
    window.submitToggleMatrix = submitToggleMatrix;

    function setupQuickmenuKeyHandler(data) {
        quickmenuData = data;

        // Remove any existing handler
        if (quickmenuKeyHandler) {
            document.removeEventListener('keydown', quickmenuKeyHandler);
        }

        quickmenuKeyHandler = (e) => {
            if (!quickmenuData || !quickmenuData.options) return;

            const key = e.key;
            let selectedOption = null;

            // Check for numeric keys 1-9
            if (key >= '1' && key <= '9') {
                const index = parseInt(key) - 1;
                if (index < quickmenuData.options.length) {
                    selectedOption = quickmenuData.options[index];
                }
            }

            // Check for matching option key
            if (!selectedOption) {
                selectedOption = quickmenuData.options.find(opt => opt.key === key);
            }

            if (selectedOption) {
                e.preventDefault();
                submitQuickmenuResponse(quickmenuData.interaction_id, selectedOption.key);
            } else if (key === 'Escape') {
                e.preventDefault();
                cancelQuickmenuInteraction(quickmenuData.interaction_id);
            }
        };

        document.addEventListener('keydown', quickmenuKeyHandler);
    }

    function clearQuickmenuHandler() {
        if (quickmenuKeyHandler) {
            document.removeEventListener('keydown', quickmenuKeyHandler);
            quickmenuKeyHandler = null;
        }
        quickmenuData = null;
    }

    function selectQuickmenuOption(element) {
        const key = element.dataset.key;
        const interactionId = element.dataset.interactionId;
        if (key && interactionId) {
            submitQuickmenuResponse(interactionId, key);
        }
    }
    window.selectQuickmenuOption = selectQuickmenuOption;

    async function submitQuickmenuResponse(interactionId, selectedKey) {
        hideTempResult();
        clearQuickmenuHandler();

        try {
            // Send through normal command flow - InputInterceptorService
            // matches the pending quickmenu and routes the response
            const response = await apiPost('/api/messages', { content: selectedKey, type: 'say' });

            if (response.ok) {
                const data = await response.json();
                if (data.success) {
                    // Route response the same way sendMessage does
                    // Handle minimap toggle
                    if (data.data?.action === 'minimap') {
                        toggleMinimap();
                        if (data.message?.content) {
                            showTempResult('', data.message.content, 'right');
                        }
                    } else if (data.target_panel === 'left_observe_window') {
                        showLeftObservationPanel(data);
                    } else if (data.target_panel === 'right_observe_window') {
                        showInObserveWindow(data);
                    } else if ((data.display_type === 'quickmenu' || data.type === 'quickmenu') && data.data) {
                        showObservationPanel('quickmenu', data.data, 'right');
                    } else if (data.output_category === 'info') {
                        const displayType = data.display_type || data.type;
                        let displayData = data.data || data.structured;
                        // For canvas types, inject canvas command string from message
                        if (displayType === 'canvas' && data.message?.content) {
                            displayData = { ...displayData, canvas_data: data.message.content };
                        }
                        // For SVG types, ensure svg data is available
                        if (displayType === 'svg' && !displayData?.svg && data.message?.content) {
                            displayData = { ...displayData, svg: data.message.content };
                        }
                        if (displayType && displayData && OBSERVATION_PANEL_TYPES.includes(displayType)) {
                            showObservationPanel(displayType, displayData, 'right');
                            if (displayType === 'room') {
                                setRoomConsentNotice(displayData.content_consent || null);
                            }
                        } else if (data.message?.content) {
                            showTempResult('', data.message.content, 'right');
                        }
                    } else if (data.message?.content) {
                        const panel = getMessagePanel(data.message.message_type || 'system');
                        addMessage(data.message, panel);
                    }
                } else if (data.error) {
                    addMessage({ content: data.error, message_type: 'error' }, 'right');
                }
            } else {
                addMessage({ content: 'Failed to submit selection.', message_type: 'error' }, 'right');
            }
        } catch (err) {
            console.error('Quickmenu response error:', err);
            addMessage({ content: 'Error submitting selection.', message_type: 'error' }, 'right');
        }
    }

    async function cancelQuickmenuInteraction(interactionId) {
        hideTempResult();
        clearQuickmenuHandler();

        try {
            await apiPost('/api/agent/interaction/cancel', { interaction_id: interactionId });
        } catch (err) {
            console.error('Quickmenu cancel error:', err);
        }
    }

    // ====== FORM RENDERER ======

    let formData = null;

    function renderFormDisplay(data) {
        formData = data;

        let html = '<div class="obs-form">';
        html += `<div class="obs-form-title">${escapeHtml(data.title || 'Form')}</div>`;
        html += `<form class="obs-form-body" onsubmit="submitFormResponse(event, '${escapeHtml(data.interaction_id || '')}')">`;

        const fields = data.fields || [];
        fields.forEach(field => {
            html += '<div class="obs-form-field">';
            html += `<label for="form-${escapeHtml(field.name)}">${escapeHtml(field.label || field.name)}`;
            if (field.required) {
                html += '<span class="obs-required">*</span>';
            }
            html += '</label>';
            html += renderFormFieldInput(field);
            html += '</div>';
        });

        html += '<div class="obs-form-actions">';
        html += '<button type="submit" class="obs-form-submit">Submit</button>';
        html += `<button type="button" class="obs-form-cancel" onclick="cancelFormInteraction('${escapeHtml(data.interaction_id || '')}')">Cancel</button>`;
        html += '</div>';
        html += '</form>';
        html += '</div>';

        return html;
    }

    function renderFormFieldInput(field) {
        const name = escapeHtml(field.name);
        const placeholder = field.placeholder ? `placeholder="${escapeHtml(field.placeholder)}"` : '';
        const required = field.required ? 'required' : '';
        const defaultVal = field.default !== undefined ? escapeHtml(String(field.default)) : '';

        switch (field.type) {
            case 'textarea':
                return `<textarea id="form-${name}" name="${name}" ${placeholder} ${required}>${defaultVal}</textarea>`;

            case 'richtext':
                // Rich text editor with formatting toolbar (uses DescriptionEditor if available)
                const placeholderText = field.placeholder || 'Enter your description...';
                return `<div id="form-${name}-editor" class="form-richtext-container" data-field="${name}" data-placeholder="${escapeHtml(placeholderText)}"></div>
                        <input type="hidden" id="form-${name}" name="${name}" value="${defaultVal}">`;

            case 'select':
                let selectHtml = `<select id="form-${name}" name="${name}" ${required}>`;
                (field.options || []).forEach(opt => {
                    const optVal = typeof opt === 'object' ? opt.value : opt;
                    const optLabel = typeof opt === 'object' ? opt.label : opt;
                    const selected = optVal === field.default ? 'selected' : '';
                    selectHtml += `<option value="${escapeHtml(optVal)}" ${selected}>${escapeHtml(optLabel)}</option>`;
                });
                selectHtml += '</select>';
                return selectHtml;

            case 'checkbox':
                const checked = field.default ? 'checked' : '';
                return `<input type="checkbox" id="form-${name}" name="${name}" ${checked}>`;

            case 'number':
                const min = field.min !== undefined ? `min="${field.min}"` : '';
                const max = field.max !== undefined ? `max="${field.max}"` : '';
                return `<input type="number" id="form-${name}" name="${name}" value="${defaultVal}" ${min} ${max} ${required}>`;

            default:
                return `<input type="${field.type || 'text'}" id="form-${name}" name="${name}" value="${defaultVal}" ${placeholder} ${required}>`;
        }
    }

    // Initialize rich text editors after form is rendered
    function initFormRichTextEditors() {
        document.querySelectorAll('.form-richtext-container').forEach(container => {
            const fieldName = container.dataset.field;
            const placeholder = container.dataset.placeholder;
            const hiddenInput = document.getElementById(`form-${fieldName}`);

            if (typeof DescriptionEditor !== 'undefined') {
                // Use the full-featured DescriptionEditor
                const editor = new DescriptionEditor(container, {
                    placeholder: placeholder,
                    onChange: (content) => {
                        if (hiddenInput) hiddenInput.value = content;
                    }
                });
                // Set initial value if present
                if (hiddenInput && hiddenInput.value) {
                    editor.setContent(hiddenInput.value);
                }
                container._editor = editor;
            } else {
                // Fallback to simple contenteditable
                container.innerHTML = `<div class="desc-editor">
                    <div class="desc-editor-content" contenteditable="true" data-placeholder="${escapeHtml(placeholder)}"></div>
                </div>`;
                const content = container.querySelector('.desc-editor-content');
                if (hiddenInput && hiddenInput.value) {
                    content.innerHTML = hiddenInput.value;
                }
                content.addEventListener('input', () => {
                    if (hiddenInput) hiddenInput.value = content.innerHTML;
                });
            }
        });
    }

    async function submitFormResponse(event, interactionId) {
        event.preventDefault();
        const form = event.target;
        const formDataObj = new FormData(form);
        const values = {};

        // Convert FormData to plain object, handling checkboxes specially
        formDataObj.forEach((value, key) => {
            values[key] = value;
        });

        // Handle unchecked checkboxes (they won't be in FormData)
        if (formData && formData.fields) {
            formData.fields.forEach(field => {
                if (field.type === 'checkbox' && !values.hasOwnProperty(field.name)) {
                    values[field.name] = false;
                } else if (field.type === 'checkbox') {
                    values[field.name] = true;
                }
            });
        }

        hideTempResult();

        try {
            const response = await apiPost('/api/agent/interaction/respond', {
                    interaction_id: interactionId,
                    response: values
            });

            if (response.ok) {
                const result = await response.json();
                if (result.message) {
                    appendMessage(result.message, 'system');
                }
            } else {
                appendMessage('Failed to submit form.', 'error');
            }
        } catch (err) {
            console.error('Form response error:', err);
            appendMessage('Error submitting form.', 'error');
        }

        formData = null;
    }

    async function cancelFormInteraction(interactionId) {
        hideTempResult();
        formData = null;

        try {
            await apiPost('/api/agent/interaction/cancel', { interaction_id: interactionId });
        } catch (err) {
            console.error('Form cancel error:', err);
        }
    }

    // ====== DISAMBIGUATION RENDERER ======

    function renderDisambiguationDisplay(data) {
        let html = '<div class="obs-disambiguation">';

        html += `<div class="obs-disambiguation-prompt">Which '${escapeHtml(data.query || 'target')}' do you mean?</div>`;
        html += '<div class="obs-disambiguation-options">';

        if (data.matches && data.matches.length > 0) {
            data.matches.forEach((match, index) => {
                const key = match.key || (index + 1).toString();
                const displayNum = key.length === 1 ? key : (index + 1).toString();
                html += `<div class="obs-disambiguation-option" data-key="${escapeHtml(key)}" data-type="${escapeHtml(match.type || '')}" data-id="${match.id || ''}" onclick="selectDisambiguationOption(this, '${escapeHtml(data.callback_command || 'look')}')">`;
                html += `<span class="obs-option-number">[${escapeHtml(displayNum)}]</span>`;
                html += `<span class="obs-option-label">${escapeHtml(match.label || 'Unknown')}</span>`;
                if (match.type) {
                    html += `<span class="obs-option-type">(${escapeHtml(match.type)})</span>`;
                }
                html += `</div>`;
            });
        }

        html += '</div>';
        html += '<div class="obs-disambiguation-hint">Click or press 1-9 to select</div>';
        html += '</div>';

        // Set up keyboard handler for disambiguation
        setupDisambiguationKeyHandler(data);

        return html;
    }

    let disambiguationData = null;
    let disambiguationKeyHandler = null;

    function setupDisambiguationKeyHandler(data) {
        disambiguationData = data;

        // Remove any existing handler
        if (disambiguationKeyHandler) {
            document.removeEventListener('keydown', disambiguationKeyHandler);
        }

        disambiguationKeyHandler = (e) => {
            if (!disambiguationData || !disambiguationData.matches) return;

            const key = e.key;
            let selectedIndex = -1;

            if (key >= '1' && key <= '9') {
                selectedIndex = parseInt(key) - 1;
            }

            if (selectedIndex >= 0 && selectedIndex < disambiguationData.matches.length) {
                e.preventDefault();
                const match = disambiguationData.matches[selectedIndex];
                executeDisambiguationSelection(match, disambiguationData.callback_command || 'look');
            } else if (key === 'Escape') {
                e.preventDefault();
                hideTempResult();
                clearDisambiguationHandler();
            }
        };

        document.addEventListener('keydown', disambiguationKeyHandler);
    }

    function clearDisambiguationHandler() {
        if (disambiguationKeyHandler) {
            document.removeEventListener('keydown', disambiguationKeyHandler);
            disambiguationKeyHandler = null;
        }
        disambiguationData = null;
    }

    function selectDisambiguationOption(element, callbackCommand) {
        const matchType = element.dataset.type;
        const matchId = element.dataset.id;

        // Find the match in disambiguationData
        const match = disambiguationData?.matches?.find(m =>
            m.type === matchType && String(m.id) === String(matchId)
        );

        if (match) {
            executeDisambiguationSelection(match, callbackCommand);
        }
    }

    async function executeDisambiguationSelection(match, callbackCommand) {
        hideTempResult();
        clearDisambiguationHandler();

        // Execute the look command with the specific target
        // We construct a command that will directly target the match
        const command = `${callbackCommand} ${match.label}`;

        // Send the command
        if (messageInput) {
            messageInput.value = command;
            messageInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter' }));
            // Or use the sendMessage function if available
            // For now, just set the input and let the user press enter
            messageInput.focus();
        }
    }

