    // Get delve time display string
    function getDelveTimeDisplay() {
        if (!delveActive) return getCurrentTime();

        // Display server-provided time in seconds (delve time is action-based, not real-time)
        const totalSecs = Math.max(0, Math.floor(delveTimeRemaining));

        const mins = Math.floor(totalSecs / 60);
        const secs = totalSecs % 60;

        if (totalSecs <= 0) {
            return '⏱️ TIME UP!';
        } else if (totalSecs <= 300) {
            return `⚠️ ${mins}:${secs.toString().padStart(2, '0')}`;
        } else {
            return `⏱️ ${mins}:${secs.toString().padStart(2, '0')}`;
        }
    }

    // Update delve status from server response (toolbar indicator only)
    // Note: delve HUD show/hide is controlled by handleDelveMapUpdate/exitDelveMap,
