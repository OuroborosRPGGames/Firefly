        if (!status) {
            delveActive = false;
            delveTimeRemaining = 0;
            updateLeftStatus();
            return;
        }

        delveActive = status.active || false;
        delveTimeRemaining = status.time_remaining || 0;

        // Update HUD timer if in delve
        if (inDelve) updateDelveTimer();

        // Update toolbar (secondary indicator)
