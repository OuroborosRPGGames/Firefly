    window.openDescriptionsPopout = openDescriptionsPopout;

    // ====== TOP IMPRINT/STATUS BAR ======
    // Yellow notification bar at top of screen

    let imprintTimeout = null;

    function showImprint(message, duration = 5000, icon = '⚡') {
        if (!imprintEl) return;

        imprintEl.innerHTML = `
            <div class="imprint-message">
                <span class="imprint-icon">${icon}</span>
                <span class="imprint-text">${escapeHtml(message)}</span>
                <span class="imprint-dismiss" onclick="hideImprint()">×</span>
            </div>
        `;

        imprintEl.classList.add('visible');

        // Clear any existing timeout
        if (imprintTimeout) {
            clearTimeout(imprintTimeout);
        }

        // Auto-hide after duration (0 = persistent)
        if (duration > 0) {
            imprintTimeout = setTimeout(hideImprint, duration);
        }
    }

    function hideImprint() {
        if (imprintEl) {
            imprintEl.classList.remove('visible');
        }
        if (imprintTimeout) {
            clearTimeout(imprintTimeout);
            imprintTimeout = null;
        }
    }

    function consentCodeLabel(code) {
        if (!code) return '';
        return String(code)
            .toLowerCase()
            .replace(/_/g, ' ')
            .replace(/\b\w/g, (c) => c.toUpperCase());
    }

    function setRoomConsentNotice(consentInfo) {
        roomConsentInfo = consentInfo || null;
        if (!consentNoticeBadgeEl || !consentNoticeTriggerEl || !consentNoticeTooltipEl) return;

        const allowed = Array.isArray(consentInfo?.allowed_content) ? consentInfo.allowed_content : [];
        if (allowed.length === 0) {
            consentNoticeBadgeEl.classList.remove('visible');
            consentNoticeBadgeEl.setAttribute('aria-hidden', 'true');
            consentNoticeTooltipEl.innerHTML = '';
            return;
        }

        const labels = allowed.map(consentCodeLabel).filter(Boolean);
        if (labels.length === 0) {
            consentNoticeBadgeEl.classList.remove('visible');
            consentNoticeBadgeEl.setAttribute('aria-hidden', 'true');
            consentNoticeTooltipEl.innerHTML = '';
            return;
        }
        const stableAt = consentInfo?.stable_since ? new Date(consentInfo.stable_since) : null;
        const stableText = stableAt && !Number.isNaN(stableAt.getTime())
            ? stableAt.toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' })
            : null;

        consentNoticeTooltipEl.innerHTML = `
            <div class="consent-tooltip-title">Allowed in this room</div>
            <div class="consent-tooltip-body">${escapeHtml(labels.join(', '))}</div>
            ${stableText ? `<div class="consent-tooltip-meta">Stable since ${escapeHtml(stableText)}</div>` : ''}
        `;
        consentNoticeTriggerEl.setAttribute('aria-label', `Allowed content: ${labels.join(', ')}`);
        consentNoticeBadgeEl.classList.add('visible');
        consentNoticeBadgeEl.setAttribute('aria-hidden', 'false');
    }

    function applyPrivateModeStatusStyling() {
        document.body.classList.toggle('private-mode-active', !!privateModeActive);
    }

    // ====== MINIMAP ======
    // Shows area layout on left side

    // Draw minimap from server data (SVG or legacy canvas commands)
    function drawMinimap(mapData) {
        if (!minimapWindowEl) return;

        // New: SVG object with svg key
        if (mapData && typeof mapData === 'object' && mapData.svg) {
            drawMinimapSvg(mapData.svg, mapData.metadata);
            return;
        }

        // Legacy canvas format: "width|||height|||command1;;;command2;;;..."
        if (typeof mapData === 'string' && mapData.includes('|||')) {
            drawMinimapCanvas(mapData);
            return;
        }
    }

    // Legacy canvas minimap renderer
    function drawMinimapCanvas(mapData) {
        if (!minimapCanvasEl || !mapData) return;

        // Show canvas, hide SVG container if present
        if (minimapCanvasEl) minimapCanvasEl.style.display = '';
        const svgContainer = minimapWindowEl.querySelector('.minimap-svg-container');
        if (svgContainer) svgContainer.style.display = 'none';

        const parts = mapData.split('|||');
        if (parts.length < 3) return;

        const width = parseInt(parts[0]) || 200;
        const height = parseInt(parts[1]) || 176;
        const commands = parts[2].split(';;;');

        minimapCanvasEl.width = width;
        minimapCanvasEl.height = height;

        const ctx = minimapCanvasEl.getContext('2d');
        ctx.clearRect(0, 0, width, height);

        // Execute drawing commands safely (no eval!)
        for (const cmd of commands) {
            if (cmd.trim()) {
                executeCanvasCommand(ctx, cmd.trim(), width, height);
            }
        }
    }

    // SVG minimap renderer - injects SVG string into minimap panel
    let minimapViewport = null; // Stored viewport for coordinate conversion

    function drawMinimapSvg(svgString, metadata) {
        if (!minimapWindowEl) return;

        // Store viewport metadata for minimap animation
        if (metadata && metadata.viewport) {
            minimapViewport = {
                min_x: metadata.viewport.min_x,
                max_x: metadata.viewport.max_x,
                min_y: metadata.viewport.min_y,
                max_y: metadata.viewport.max_y,
                svg_width: metadata.svg_width || 400,
                svg_height: metadata.svg_height || 400
            };
        }

        let svgContainer = minimapWindowEl.querySelector('.minimap-svg-container');
        if (!svgContainer) {
            svgContainer = document.createElement('div');
            svgContainer.className = 'minimap-svg-container';
            minimapWindowEl.appendChild(svgContainer);
        }

        // Hide canvas, show SVG container
        if (minimapCanvasEl) minimapCanvasEl.style.display = 'none';
        svgContainer.style.display = '';

        svgContainer.innerHTML = svgString;

        const svg = svgContainer.querySelector('svg');
        if (svg) {
            svg.addEventListener('click', handleMapClick);
        }
    }

    let minimapAnimFrame = null; // Track active animation

    // Animate the player's minimap dot from current position to the exit point.
    function animateMinimapDot(worldX, worldY, durationMs) {
        if (!minimapViewport || !minimapWindowEl) return;
        if (minimapAnimFrame) cancelAnimationFrame(minimapAnimFrame);

        const svgContainer = minimapWindowEl.querySelector('.minimap-svg-container');
        if (!svgContainer) return;

        const charId = characterInstanceId;
        const circle = svgContainer.querySelector('circle[data-char-id="' + charId + '"]');
        if (!circle) return;

        // Convert world coordinates to SVG coordinates (same as server-side world_to_svg)
        const vp = minimapViewport;
        const vpWidth = vp.max_x - vp.min_x;
        const vpHeight = vp.max_y - vp.min_y;
        if (vpWidth <= 0 || vpHeight <= 0) return;

        const normX = (worldX - vp.min_x) / vpWidth;
        const normY = (worldY - vp.min_y) / vpHeight;
        const targetX = normX * vp.svg_width;
        const targetY = (1.0 - normY) * vp.svg_height; // Flip Y

        const startX = parseFloat(circle.getAttribute('cx'));
        const startY = parseFloat(circle.getAttribute('cy'));
        const startTime = performance.now();

        function step(now) {
            const elapsed = now - startTime;
            const t = Math.min(elapsed / durationMs, 1.0);

            circle.setAttribute('cx', startX + (targetX - startX) * t);
            circle.setAttribute('cy', startY + (targetY - startY) * t);

            if (t < 1.0) {
                minimapAnimFrame = requestAnimationFrame(step);
            } else {
                minimapAnimFrame = null;
            }
        }
        minimapAnimFrame = requestAnimationFrame(step);
    }

    // Handle lightweight minimap position updates.
    // Moves character dot positions without a full SVG re-render.
    // Message format: { type: 'minimap_position', characters: [{ id, x, y }, ...] }
    function handleMinimapPositionUpdate(msg) {
        if (!minimapWindowEl) return;

        const svgContainer = minimapWindowEl.querySelector('.minimap-svg-container');
        if (!svgContainer) return;

        const characters = msg.characters || [];
        characters.forEach(function(charData) {
            const circle = svgContainer.querySelector('circle[data-char-id="' + charData.id + '"]');
            if (circle) {
                circle.setAttribute('cx', charData.x);
                circle.setAttribute('cy', charData.y);
            }
        });
    }

    // Delegated click handler for SVG map elements
    function handleMapClick(e) {
        const target = e.target.closest('[data-room-id]');
        if (!target) {
            dismissMapTooltip();
            return;
        }

        const roomId = target.dataset.roomId;
        const roomName = target.dataset.roomName;
        const roomType = target.dataset.roomType;

        showMapTooltip(e.clientX, e.clientY, {
            roomId: roomId,
            name: roomName,
            type: roomType
        });
    }

    // Show tooltip with room info and navigation action
    function showMapTooltip(clientX, clientY, data) {
        dismissMapTooltip();

        const tooltip = document.createElement('div');
        tooltip.id = 'map-tooltip';
        tooltip.className = 'map-tooltip';
        tooltip.innerHTML = `
            <div class="map-tooltip-name">${escapeHtml(data.name || 'Unknown')}</div>
            <div class="map-tooltip-type">${escapeHtml(data.type || '').replace(/_/g, ' ')}</div>
            <div class="map-tooltip-actions">
                <button class="btn btn-xs btn-primary map-tooltip-go" data-room-id="${data.roomId}">Go</button>
                <button class="btn btn-xs btn-ghost map-tooltip-dismiss">Dismiss</button>
            </div>
        `;

        tooltip.style.left = (clientX + 10) + 'px';
        tooltip.style.top = (clientY - 10) + 'px';

        document.body.appendChild(tooltip);

        tooltip.querySelector('.map-tooltip-go').addEventListener('click', function() {
            const roomName = this.closest('.map-tooltip').querySelector('.map-tooltip-name').textContent;
            dismissMapTooltip();
            messageInput.innerHTML = escapeHtml('walk to ' + roomName);
            sendMessage();
        });

        tooltip.querySelector('.map-tooltip-dismiss').addEventListener('click', dismissMapTooltip);

        setTimeout(() => {
            mapTooltipOutsideClickHandler = function(e) {
                if (!e.target.closest('#map-tooltip')) {
                    dismissMapTooltip();
                }
            };
            document.addEventListener('click', mapTooltipOutsideClickHandler);
        }, 100);
    }

    let mapTooltipOutsideClickHandler = null;

    function dismissMapTooltip() {
        const existing = document.getElementById('map-tooltip');
        if (existing) existing.remove();
        if (mapTooltipOutsideClickHandler) {
            document.removeEventListener('click', mapTooltipOutsideClickHandler);
            mapTooltipOutsideClickHandler = null;
        }
    }

    // Safe canvas command execution
    // Commands: line, rect, frect, fcircle, circle, text, textrect, coltext,
    //           poly, fpoly, roundrect, froundrect, arc, gradient, dashed, vtext, img
    function executeCanvasCommand(ctx, cmd, canvasWidth, canvasHeight) {
        const colonIndex = cmd.indexOf('::');
        if (colonIndex === -1) return;

        const command = cmd.substring(0, colonIndex);
        const args = cmd.substring(colonIndex + 2);

        switch (command) {
            case 'line': {
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x1 = parseInt(parts[1]);
                const y1 = parseInt(parts[2]);
                const x2 = parseInt(parts[3]);
                const y2 = parseInt(parts[4]);
                ctx.save();
                ctx.strokeStyle = color || '#C3C3C3';
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'rect': {
                const coords = args.split(',').map(s => parseInt(s.trim()));
                ctx.save();
                ctx.strokeStyle = '#C3C3C3';
                ctx.strokeRect(coords[0], coords[1], coords[2] - coords[0], coords[3] - coords[1]);
                ctx.restore();
                break;
            }

            case 'frect': {
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x1 = parseInt(parts[1]);
                const y1 = parseInt(parts[2]);
                const x2 = parseInt(parts[3]);
                const y2 = parseInt(parts[4]);
                ctx.save();
                ctx.fillStyle = color;
                ctx.fillRect(x1, y1, x2 - x1, y2 - y1);
                ctx.restore();
                break;
            }

            case 'fcircle': {
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x = parseInt(parts[1]);
                const y = parseInt(parts[2]);
                const radius = parseInt(parts[3]);
                ctx.save();
                ctx.fillStyle = color;
                ctx.beginPath();
                ctx.arc(x, y, radius, 0, 2 * Math.PI);
                ctx.fill();
                ctx.restore();
                break;
            }

            case 'text': {
                const [coordsStr, fontStr, text] = args.split('||');
                const coords = coordsStr.split(',').map(s => parseInt(s.trim()));
                ctx.save();
                ctx.fillStyle = '#C3C3C3';
                ctx.font = `12px ${fontStr || 'sans-serif'}`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text || '', coords[0], coords[1]);
                ctx.restore();
                break;
            }

            case 'textrect': {
                // Auto-sizing text with word wrap within bounding box
                const [coordsStr, fontFamily, text] = args.split('||');
                const coords = coordsStr.split(',').map(s => parseInt(s.trim()));
                const x1 = coords[0], y1 = coords[1], x2 = coords[2], y2 = coords[3];
                const boxWidth = (x2 - x1) * 0.95;
                const boxHeight = y2 - y1;
                const font = fontFamily || 'sans-serif';
                const displayText = text || '';

                ctx.save();
                ctx.fillStyle = '#ffffff';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';

                let fontSize = Math.min(20, boxHeight * 0.3);
                ctx.font = `${fontSize}px ${font}`;

                // Single line fits? Draw it directly
                if (ctx.measureText(displayText).width <= boxWidth) {
                    ctx.fillText(displayText, x1 + (x2 - x1) / 2, y1 + boxHeight / 2);
                    ctx.restore();
                    break;
                }

                // Word-wrap into multiple lines
                const trWords = displayText.split(/\s+/);
                const trLineSpacing = 1.2;

                function trWrap(fs) {
                    ctx.font = `${fs}px ${font}`;
                    const ls = [];
                    let cur = trWords[0] || '';
                    for (let i = 1; i < trWords.length; i++) {
                        const test = cur + ' ' + trWords[i];
                        if (ctx.measureText(test).width <= boxWidth) { cur = test; }
                        else { ls.push(cur); cur = trWords[i]; }
                    }
                    ls.push(cur);
                    return ls;
                }

                let trLines = trWrap(fontSize);
                while (trLines.length * fontSize * trLineSpacing > boxHeight && fontSize > 10) {
                    fontSize -= 0.5;
                    trLines = trWrap(fontSize);
                }

                const trTotalH = trLines.length * fontSize * trLineSpacing;
                const trStartY = y1 + (boxHeight - trTotalH) / 2 + fontSize * 0.6;
                const trCX = x1 + (x2 - x1) / 2;

                for (let i = 0; i < trLines.length; i++) {
                    ctx.fillText(trLines[i], trCX, trStartY + i * fontSize * trLineSpacing);
                }

                ctx.restore();
                break;
            }

            case 'coltext': {
                const [colorAndCoords, fontStr, text] = args.split('||');
                const parts = colorAndCoords.split(',').map(s => s.trim());
                const color = parts[0];
                const x = parseInt(parts[1]);
                const y = parseInt(parts[2]);
                ctx.save();
                ctx.fillStyle = color;
                ctx.font = `16px ${fontStr || 'sans-serif'}`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text || '', x, y);
                ctx.restore();
                break;
            }

            case 'circle': {
                // Circle outline (unfilled)
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const cx = parseInt(parts[1]);
                const cy = parseInt(parts[2]);
                const radius = parseInt(parts[3]);
                ctx.save();
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(cx, cy, radius, 0, 2 * Math.PI);
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'poly': {
                // Polygon outline
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const coords = parts.slice(1).map(s => parseInt(s));
                if (coords.length < 4) break;
                ctx.save();
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.moveTo(coords[0], coords[1]);
                for (let i = 2; i < coords.length; i += 2) {
                    ctx.lineTo(coords[i], coords[i + 1]);
                }
                ctx.closePath();
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'fpoly': {
                // Filled polygon
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const coords = parts.slice(1).map(s => parseInt(s));
                if (coords.length < 4) break;
                ctx.save();
                ctx.fillStyle = color;
                ctx.beginPath();
                ctx.moveTo(coords[0], coords[1]);
                for (let i = 2; i < coords.length; i += 2) {
                    ctx.lineTo(coords[i], coords[i + 1]);
                }
                ctx.closePath();
                ctx.fill();
                ctx.restore();
                break;
            }

            case 'roundrect': {
                // Rounded rectangle outline
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x1 = parseInt(parts[1]);
                const y1 = parseInt(parts[2]);
                const x2 = parseInt(parts[3]);
                const y2 = parseInt(parts[4]);
                const radius = parseInt(parts[5]) || 5;
                const width = x2 - x1;
                const height = y2 - y1;
                ctx.save();
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.roundRect(x1, y1, width, height, radius);
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'froundrect': {
                // Filled rounded rectangle
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x1 = parseInt(parts[1]);
                const y1 = parseInt(parts[2]);
                const x2 = parseInt(parts[3]);
                const y2 = parseInt(parts[4]);
                const radius = parseInt(parts[5]) || 5;
                const width = x2 - x1;
                const height = y2 - y1;
                ctx.save();
                ctx.fillStyle = color;
                ctx.beginPath();
                ctx.roundRect(x1, y1, width, height, radius);
                ctx.fill();
                ctx.restore();
                break;
            }

            case 'arc': {
                // Arc (partial circle)
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const cx = parseInt(parts[1]);
                const cy = parseInt(parts[2]);
                const radius = parseInt(parts[3]);
                const startAngle = parseFloat(parts[4]) * Math.PI / 180;
                const endAngle = parseFloat(parts[5]) * Math.PI / 180;
                ctx.save();
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.beginPath();
                ctx.arc(cx, cy, radius, startAngle, endAngle);
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'gradient': {
                // Linear gradient filled rectangle
                // Format: gradient::#c1,#c2,dir,x1,y1,x2,y2
                const parts = args.split(',').map(s => s.trim());
                const color1 = parts[0];
                const color2 = parts[1];
                const dir = parts[2];
                const x1 = parseInt(parts[3]);
                const y1 = parseInt(parts[4]);
                const x2 = parseInt(parts[5]);
                const y2 = parseInt(parts[6]);
                ctx.save();
                let gradient;
                if (dir === 'h') {
                    gradient = ctx.createLinearGradient(x1, y1, x2, y1);
                } else if (dir === 'd') {
                    gradient = ctx.createLinearGradient(x1, y1, x2, y2);
                } else {
                    // vertical (default)
                    gradient = ctx.createLinearGradient(x1, y1, x1, y2);
                }
                gradient.addColorStop(0, color1);
                gradient.addColorStop(1, color2);
                ctx.fillStyle = gradient;
                ctx.fillRect(x1, y1, x2 - x1, y2 - y1);
                ctx.restore();
                break;
            }

            case 'dashed': {
                // Dashed line
                const parts = args.split(',').map(s => s.trim());
                const color = parts[0];
                const x1 = parseInt(parts[1]);
                const y1 = parseInt(parts[2]);
                const x2 = parseInt(parts[3]);
                const y2 = parseInt(parts[4]);
                const dashLen = parseInt(parts[5]) || 5;
                const gapLen = parseInt(parts[6]) || 3;
                ctx.save();
                ctx.strokeStyle = color;
                ctx.lineWidth = 2;
                ctx.setLineDash([dashLen, gapLen]);
                ctx.beginPath();
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
                ctx.stroke();
                ctx.restore();
                break;
            }

            case 'vtext': {
                // Rotated/vertical text
                const [colorAndCoords, fontStr, text] = args.split('||');
                const parts = colorAndCoords.split(',').map(s => s.trim());
                const color = parts[0];
                const x = parseInt(parts[1]);
                const y = parseInt(parts[2]);
                const angle = parseFloat(parts[3]) || -90;
                ctx.save();
                ctx.translate(x, y);
                ctx.rotate(angle * Math.PI / 180);
                ctx.fillStyle = color;
                ctx.font = `12px ${fontStr || 'sans-serif'}`;
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.fillText(text || '', 0, 0);
                ctx.restore();
                break;
            }

            case 'img': {
                // Draw image
                // Format: img::url,x,y,width,height
                const parts = args.split(',').map(s => s.trim());
                const url = parts[0];
                const x = parseInt(parts[1]);
                const y = parseInt(parts[2]);
                const imgWidth = parseInt(parts[3]);
                const imgHeight = parseInt(parts[4]);
                const img = new Image();
                img.onload = () => {
                    ctx.drawImage(img, x, y, imgWidth, imgHeight);
                };
                img.src = url;
                break;
            }

            default:
                console.warn('Unknown canvas command:', command);
        }
    }

    // ========================================================================
    // CANVAS INTERACTIVITY SYSTEM
    // Enables click detection, hover tooltips, and navigation on canvas elements
    // ========================================================================

    // Parse hit regions from canvas data (4th segment, base64 encoded JSON)
    // @param canvasData [String] Full canvas format: width|||height|||commands|||hitRegions
    // @return [Array] Array of hit region objects, or empty array if none
    function parseCanvasHitRegions(canvasData) {
        if (!canvasData) return [];
        const parts = canvasData.split('|||');
        if (parts.length < 4) return [];

        try {
            const decoded = atob(parts[3]);
            return JSON.parse(decoded);
        } catch (e) {
            console.warn('Failed to parse canvas hit regions:', e);
            return [];
        }
    }

    // Check if a point is inside a hit region
    // @param x [Number] X coordinate
    // @param y [Number] Y coordinate
    // @param region [Object] Hit region with shape and geometry
    // @return [Boolean] True if point is inside region
    function pointInRegion(x, y, region) {
        switch (region.shape) {
            case 'rect':
                return x >= region.x && x <= region.x + region.width &&
                       y >= region.y && y <= region.y + region.height;
            case 'circle':
                const dx = x - region.cx;
                const dy = y - region.cy;
                return (dx * dx + dy * dy) <= (region.radius * region.radius);
            case 'polygon':
                return pointInPolygon(x, y, region.points);
            default:
                return false;
        }
    }

    // Ray-casting algorithm for point-in-polygon test
    // @param x [Number] X coordinate
    // @param y [Number] Y coordinate
    // @param points [Array] Array of [x, y] coordinate pairs
    // @return [Boolean] True if point is inside polygon
    function pointInPolygon(x, y, points) {
        if (!points || points.length < 3) return false;

        let inside = false;
        for (let i = 0, j = points.length - 1; i < points.length; j = i++) {
            const xi = points[i][0], yi = points[i][1];
            const xj = points[j][0], yj = points[j][1];

            if (((yi > y) !== (yj > y)) &&
                (x < (xj - xi) * (y - yi) / (yj - yi) + xi)) {
                inside = !inside;
            }
        }
        return inside;
    }

    // Find which hit region (if any) contains a point
    // @param x [Number] X coordinate
    // @param y [Number] Y coordinate
    // @param hitRegions [Array] Array of hit region objects
    // @return [Object|null] The hit region, or null if none
    function findHitRegion(x, y, hitRegions) {
        // Search in reverse order (topmost element first)
        for (let i = hitRegions.length - 1; i >= 0; i--) {
            if (pointInRegion(x, y, hitRegions[i])) {
                return hitRegions[i];
            }
        }
        return null;
    }

    // Set up interactivity handlers on a canvas element
    // @param canvas [HTMLCanvasElement] The canvas element
    // @param hitRegions [Array] Array of hit region objects
    // @param options [Object] Callbacks: onClick(region, event), onHover(region), onHoverEnd()
    function setupCanvasInteractivity(canvas, hitRegions, options = {}) {
        if (!canvas || !hitRegions || hitRegions.length === 0) return;

        let currentHoverRegion = null;
        let tooltip = null;

        // Get coordinates relative to canvas
        function getCanvasCoords(event) {
            const rect = canvas.getBoundingClientRect();
            const scaleX = canvas.width / rect.width;
            const scaleY = canvas.height / rect.height;
            return {
                x: (event.clientX - rect.left) * scaleX,
                y: (event.clientY - rect.top) * scaleY
            };
        }

        // Show tooltip near cursor
        function showTooltip(text, pageX, pageY) {
            if (!tooltip) {
                tooltip = document.createElement('div');
                tooltip.className = 'canvas-tooltip';
                document.body.appendChild(tooltip);
            }
            tooltip.textContent = text;
            tooltip.style.left = (pageX + 10) + 'px';
            tooltip.style.top = (pageY + 10) + 'px';
            tooltip.style.display = 'block';
        }

        // Hide tooltip
        function hideTooltip() {
            if (tooltip) {
                tooltip.style.display = 'none';
            }
        }

        // Named handlers so cleanup can remove them
        function handleClick(event) {
            const coords = getCanvasCoords(event);
            const region = findHitRegion(coords.x, coords.y, hitRegions);

            if (region) {
                hideTooltip();

                // Call custom click handler
                if (options.onClick) {
                    options.onClick(region, event);
                }

                // Handle built-in actions
                if (region.data) {
                    if (region.data.action === 'navigate' && region.data.command) {
                        sendCommand(region.data.command);
                    } else if (region.data.action === 'select' && region.data.value) {
                        if (options.onSelect) {
                            options.onSelect(region.data.value, region);
                        }
                    }
                }
            }
        }

        function handleMouseMove(event) {
            const coords = getCanvasCoords(event);
            const region = findHitRegion(coords.x, coords.y, hitRegions);

            if (region !== currentHoverRegion) {
                if (currentHoverRegion) {
                    hideTooltip();
                    if (options.onHoverEnd) {
                        options.onHoverEnd(currentHoverRegion);
                    }
                }

                currentHoverRegion = region;

                if (region) {
                    canvas.style.cursor = 'pointer';

                    if (region.data && region.data.tooltip) {
                        showTooltip(region.data.tooltip, event.pageX, event.pageY);
                    }

                    if (options.onHover) {
                        options.onHover(region);
                    }
                } else {
                    canvas.style.cursor = 'default';
                }
            } else if (region && region.data && region.data.tooltip && tooltip) {
                tooltip.style.left = (event.pageX + 10) + 'px';
                tooltip.style.top = (event.pageY + 10) + 'px';
            }
        }

        function handleMouseLeave() {
            if (currentHoverRegion) {
                hideTooltip();
                if (options.onHoverEnd) {
                    options.onHoverEnd(currentHoverRegion);
                }
                currentHoverRegion = null;
                canvas.style.cursor = 'default';
            }
        }

        canvas.addEventListener('click', handleClick);
        canvas.addEventListener('mousemove', handleMouseMove);
        canvas.addEventListener('mouseleave', handleMouseLeave);

        // Return cleanup function that removes all listeners
        return function cleanup() {
            canvas.removeEventListener('click', handleClick);
            canvas.removeEventListener('mousemove', handleMouseMove);
            canvas.removeEventListener('mouseleave', handleMouseLeave);
            if (tooltip && tooltip.parentNode) {
                tooltip.parentNode.removeChild(tooltip);
            }
        };
    }

    // Enhanced minimap renderer with interactivity support
    // Wraps the existing minimap rendering and adds click/hover
    function drawMinimapInteractive(canvasData, options = {}) {
        const minimapCanvas = document.getElementById('minimapCanvas');
        if (!minimapCanvas) return;

        // Parse and draw the minimap
        drawMinimap(canvasData);

        // Set up interactivity
        const hitRegions = parseCanvasHitRegions(canvasData);
        if (hitRegions.length > 0) {
            setupCanvasInteractivity(minimapCanvas, hitRegions, {
                onClick: options.onClick || function(region, event) {
                    // Default: navigate if action is navigate
                    if (region.data && region.data.action === 'navigate' && region.data.command) {
                        sendCommand(region.data.command);
                    }
                },
                onHover: options.onHover,
                onHoverEnd: options.onHoverEnd
            });
        }
    }

    // ========================================================================
    // END CANVAS INTERACTIVITY SYSTEM
    // ========================================================================

    // Draw text that auto-sizes to fit within a box
    function drawTextInBox(ctx, text, x, y, maxWidth, maxHeight, color) {
        if (!text) return;

        ctx.save();
        ctx.fillStyle = color || '#ffffff';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        const usableWidth = maxWidth * 0.9;

        // Try single line first at a readable size
        let fontSize = Math.min(16, maxHeight * 0.25);
        ctx.font = `${fontSize}px sans-serif`;

        if (ctx.measureText(text).width <= usableWidth) {
            // Fits on one line
            ctx.fillText(text, x + maxWidth / 2, y + maxHeight / 2);
            ctx.restore();
            return;
        }

        // Word-wrap into multiple lines
        const words = text.split(/\s+/);
        let lines = [];
        let currentLine = words[0] || '';

        for (let i = 1; i < words.length; i++) {
            const testLine = currentLine + ' ' + words[i];
            if (ctx.measureText(testLine).width <= usableWidth) {
                currentLine = testLine;
            } else {
                lines.push(currentLine);
                currentLine = words[i];
            }
        }
        lines.push(currentLine);

        // Shrink font if lines don't fit vertically
        const lineSpacing = 1.2;
        while (lines.length * fontSize * lineSpacing > maxHeight && fontSize > 10) {
            fontSize -= 0.5;
            ctx.font = `${fontSize}px sans-serif`;
            // Re-wrap at new font size
            lines = [];
            currentLine = words[0] || '';
            for (let i = 1; i < words.length; i++) {
                const testLine = currentLine + ' ' + words[i];
                if (ctx.measureText(testLine).width <= usableWidth) {
                    currentLine = testLine;
                } else {
                    lines.push(currentLine);
                    currentLine = words[i];
                }
            }
            lines.push(currentLine);
        }

        // Draw wrapped lines centered in box
        const totalHeight = lines.length * fontSize * lineSpacing;
        const startY = y + (maxHeight - totalHeight) / 2 + fontSize * 0.6;
        const centerX = x + maxWidth / 2;

        for (let i = 0; i < lines.length; i++) {
            ctx.fillText(lines[i], centerX, startY + i * fontSize * lineSpacing);
        }

        ctx.restore();
    }

    // Get door rectangle position at room edge
    function getDoorPosition(direction, cx, cy, roomSize) {
        const half = roomSize / 2;
        const doorW = 16;
        const doorH = 6;

        switch (direction.toLowerCase()) {
            case 'north':
            case 'n':
                return { x: cx - doorW/2, y: cy - half - doorH, w: doorW, h: doorH };
            case 'south':
            case 's':
                return { x: cx - doorW/2, y: cy + half, w: doorW, h: doorH };
            case 'east':
            case 'e':
                return { x: cx + half, y: cy - doorW/2, w: doorH, h: doorW };
            case 'west':
            case 'w':
                return { x: cx - half - doorH, y: cy - doorW/2, w: doorH, h: doorW };
            default:
                return null;
        }
    }

    // Simple minimap showing current room and exits with room names
    function drawSimpleMinimap(roomName, exits = []) {
        if (!minimapCanvasEl) return;

        const ctx = minimapCanvasEl.getContext('2d');
        const w = minimapCanvasEl.width;
        const h = minimapCanvasEl.height;

        // Clear with dark background
        ctx.fillStyle = '#0a0a0a';
        ctx.fillRect(0, 0, w, h);

        const cx = w / 2;
        const cy = h / 2;
        const roomSize = 120;
        const exitRoomSize = 100;

        // Exit positions (as canvas coordinates) - scaled to canvas size
        const exitPositions = {
            'north': { x: cx, y: 55 },
            'south': { x: cx, y: h - 55 },
            'east': { x: w - 60, y: cy },
            'west': { x: 60, y: cy },
            'northeast': { x: w - 70, y: 65 },
            'northwest': { x: 70, y: 65 },
            'southeast': { x: w - 70, y: h - 65 },
            'southwest': { x: 70, y: h - 65 },
            'up': { x: cx - 80, y: 65 },
            'down': { x: cx + 80, y: h - 65 },
            'n': { x: cx, y: 55 },
            's': { x: cx, y: h - 55 },
            'e': { x: w - 60, y: cy },
            'w': { x: 60, y: cy },
            'u': { x: cx - 80, y: 65 },
            'd': { x: cx + 80, y: h - 65 }
        };

        // Draw exit rooms first (so they're behind center room)
        exits.forEach(exitData => {
            // Handle both string format and object format
            const dir = typeof exitData === 'string' ? exitData : (exitData.direction || exitData.dir);
            const exitRoomName = typeof exitData === 'object' ? (exitData.to_room_name || exitData.room_name) : null;
            const arrow = typeof exitData === 'object' ? (exitData.direction_arrow || '') : '';

            const pos = exitPositions[dir.toLowerCase()];
            if (!pos) return;

            // Exit room rectangle
            ctx.fillStyle = '#2a2a2a';
            ctx.fillRect(pos.x - exitRoomSize/2, pos.y - exitRoomSize/2, exitRoomSize, exitRoomSize);

            // Exit room name (auto-sized) - leave space for arrow at bottom
            if (exitRoomName) {
                drawTextInBox(ctx, exitRoomName,
                    pos.x - exitRoomSize/2 + 4, pos.y - exitRoomSize/2 + 4,
                    exitRoomSize - 8, exitRoomSize - 24,
                    '#aaaaaa');
            } else {
                // Show direction if no room name
                drawTextInBox(ctx, dir.charAt(0).toUpperCase(),
                    pos.x - exitRoomSize/2 + 4, pos.y - exitRoomSize/2 + 4,
                    exitRoomSize - 8, exitRoomSize - 24,
                    '#666666');
            }

            // Direction arrow at bottom of exit room
            ctx.fillStyle = '#666666';
            ctx.font = '16px sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(arrow || dir.charAt(0).toUpperCase(), pos.x, pos.y + exitRoomSize/2 - 10);
        });

        // Draw doors at center room edges (small rectangles)
        exits.forEach(exitData => {
            const dir = typeof exitData === 'string' ? exitData : (exitData.direction || exitData.dir);
            const doorPos = getDoorPosition(dir, cx, cy, roomSize);
            if (doorPos) {
                ctx.fillStyle = '#666666';
                ctx.fillRect(doorPos.x, doorPos.y, doorPos.w, doorPos.h);
            }
        });

        // Draw current room (center) on top
        ctx.fillStyle = '#00bcd4';
        ctx.fillRect(cx - roomSize/2, cy - roomSize/2, roomSize, roomSize);

        // Current room name with auto-sizing
        drawTextInBox(ctx, roomName || 'Here',
            cx - roomSize/2 + 6, cy - roomSize/2 + 6,
            roomSize - 12, roomSize - 12,
            '#ffffff');

        // Minimap defaults to closed - user can open with /map
    }

    // ====== SPATIAL MINIMAP ======
    // Renders rooms using actual polygon geometry from the server

    let currentMinimapData = null;
    let minimapCleanup = null;

    // Draw a spatially accurate minimap from server-provided room polygon data
    // @param minimapData [Object] { current_room, character_position, nearby_rooms, viewport }
    // @param options [Object] { highlightRoomId: string } optional highlight for hover
    function drawSpatialMinimap(minimapData, options = {}) {
        if (!minimapCanvasEl || !minimapData || !minimapData.current_room) return;

        currentMinimapData = minimapData;

        // Clean up previous interactivity handlers
        if (minimapCleanup) {
            minimapCleanup();
            minimapCleanup = null;
        }

        const ctx = minimapCanvasEl.getContext('2d');
        const canvasW = minimapCanvasEl.width;
        const canvasH = minimapCanvasEl.height;

        // Calculate coordinate transform from world space to canvas space
        const vp = minimapData.viewport;
        const worldW = vp.max_x - vp.min_x;
        const worldH = vp.max_y - vp.min_y;

        if (worldW <= 0 || worldH <= 0) return;

        const padding = 10;
        const usableW = canvasW - padding * 2;
        const usableH = canvasH - padding * 2;

        // Uniform scale to preserve aspect ratio
        const scale = Math.min(usableW / worldW, usableH / worldH);

        // Center content within canvas
        const offsetX = padding + (usableW - worldW * scale) / 2;
        const offsetY = padding + (usableH - worldH * scale) / 2;

        // Transform world coordinates to canvas coordinates (Y-axis inverted)
        function toCanvas(wx, wy) {
            return {
                x: (wx - vp.min_x) * scale + offsetX,
                y: canvasH - ((wy - vp.min_y) * scale + offsetY)
            };
        }

        // Draw room polygon helper
        function drawRoomPoly(polygon, fillColor, strokeColor, lineWidth, dashPattern) {
            if (!polygon || polygon.length < 3) return;

            ctx.beginPath();
            const first = toCanvas(polygon[0].x, polygon[0].y);
            ctx.moveTo(first.x, first.y);
            for (let i = 1; i < polygon.length; i++) {
                const p = toCanvas(polygon[i].x, polygon[i].y);
                ctx.lineTo(p.x, p.y);
            }
            ctx.closePath();

            ctx.fillStyle = fillColor;
            ctx.fill();

            ctx.setLineDash(dashPattern || []);
            ctx.lineWidth = lineWidth || 1;
            ctx.strokeStyle = strokeColor;
            ctx.stroke();
            ctx.setLineDash([]);
        }

        // Calculate rendered size of a room in pixels
        function roomPixelSize(room) {
            const b = room.bounds;
            if (!b) return { w: 0, h: 0 };
            return {
                w: (b.max_x - b.min_x) * scale,
                h: (b.max_y - b.min_y) * scale
            };
        }

        // --- Background ---
        ctx.fillStyle = '#0a0a0a';
        ctx.fillRect(0, 0, canvasW, canvasH);

        // --- Sort rooms by draw order ---
        // container (back) → siblings → adjacent → current → contained (front, drawn inside current)
        const drawOrder = { container: 0, sibling: 1, adjacent: 2, current: 3, contained: 4 };

        const allRooms = [
            { ...minimapData.current_room, relationship: 'current', passable: true }
        ].concat(minimapData.nearby_rooms || []);

        allRooms.sort((a, b) => {
            const orderA = drawOrder[a.relationship] ?? 2;
            const orderB = drawOrder[b.relationship] ?? 2;
            return orderA - orderB;
        });

        // --- Draw rooms ---
        allRooms.forEach(room => {
            const isHighlighted = options.highlightRoomId === `room_${room.id}`;
            let fillColor, strokeColor, lineWidth, dashPattern;

            switch (room.relationship) {
                case 'container':
                    fillColor = '#141414';
                    strokeColor = '#555555';
                    lineWidth = 1;
                    dashPattern = [4, 4];
                    break;
                case 'sibling':
                case 'contained':
                    fillColor = isHighlighted ? '#3a3a3a' : '#252525';
                    strokeColor = isHighlighted ? '#88cc88' : '#555555';
                    lineWidth = 1;
                    break;
                case 'adjacent':
                    if (room.passable) {
                        fillColor = isHighlighted ? '#3a3a3a' : '#2a2a2a';
                        strokeColor = isHighlighted ? '#88cc88' : '#447744';
                        lineWidth = isHighlighted ? 2 : 1;
                    } else {
                        fillColor = '#2a2a2a';
                        strokeColor = '#663333';
                        lineWidth = 1;
                    }
                    break;
                case 'current':
                    fillColor = '#00bcd4';
                    strokeColor = '#00e5ff';
                    lineWidth = 2;
                    break;
                default:
                    fillColor = '#1e1e1e';
                    strokeColor = '#333333';
                    lineWidth = 1;
            }

            drawRoomPoly(room.polygon, fillColor, strokeColor, lineWidth, dashPattern);

            // --- Room name labels ---
            const size = roomPixelSize(room);
            if (size.w >= 20 && size.h >= 20 && room.name) {
                const topLeft = toCanvas(room.bounds.min_x, room.bounds.max_y);
                const labelColor = room.relationship === 'current' ? '#ffffff' : '#aaaaaa';
                const displayName = size.w < 50 ? (room.name.split(' ')[0] || room.name) : room.name;
                drawTextInBox(ctx, displayName,
                    topLeft.x + 2, topLeft.y + 2,
                    size.w - 4, size.h - 4,
                    labelColor);
            }
        });

        // --- Character position dot ---
        if (minimapData.character_position) {
            const cp = toCanvas(minimapData.character_position.x, minimapData.character_position.y);
            const dotRadius = 5;

            // White outline for visibility
            ctx.beginPath();
            ctx.arc(cp.x, cp.y, dotRadius + 1.5, 0, Math.PI * 2);
            ctx.fillStyle = '#ffffff';
            ctx.fill();

            // Red dot
            ctx.beginPath();
            ctx.arc(cp.x, cp.y, dotRadius, 0, Math.PI * 2);
            ctx.fillStyle = '#ff4444';
            ctx.fill();
        }

        // --- Interactivity (click-to-navigate + hover) ---
        const hitRegions = [];
        (minimapData.nearby_rooms || []).forEach(room => {
            // Adjacent/passable rooms: click sends direction command (north, south, etc.)
            // Contained rooms: click sends "walk <name>" to enter the sub-room
            if (room.relationship === 'contained') {
                const canvasPoints = room.polygon.map(p => {
                    const cp = toCanvas(p.x, p.y);
                    return [cp.x, cp.y];
                });
                hitRegions.push({
                    id: `room_${room.id}`,
                    shape: 'polygon',
                    points: canvasPoints,
                    data: {
                        tooltip: room.name,
                        action: 'navigate',
                        command: `walk ${room.name}`
                    }
                });
            } else if (room.passable && room.direction) {
                const canvasPoints = room.polygon.map(p => {
                    const cp = toCanvas(p.x, p.y);
                    return [cp.x, cp.y];
                });
                hitRegions.push({
                    id: `room_${room.id}`,
                    shape: 'polygon',
                    points: canvasPoints,
                    data: {
                        tooltip: room.name,
                        action: 'navigate',
                        command: room.direction
                    }
                });
            }
        });

        if (hitRegions.length > 0) {
            minimapCleanup = setupCanvasInteractivity(minimapCanvasEl, hitRegions, {
                onHover: (region) => {
                    drawSpatialMinimap(currentMinimapData, { highlightRoomId: region.id });
                },
                onHoverEnd: () => {
                    drawSpatialMinimap(currentMinimapData);
                }
            });
        }
    }

    // ====== OBSERVATION BOX ======
    // Temporary left side panel for observing things

    function startObservation(target, initialContent = '') {
        if (!observeWindowEl) return;

        currentObservation = target;

        const targetEl = observeWindowEl.querySelector('.observe-target');
        const contentEl = observeWindowEl.querySelector('.observe-content');

        if (targetEl) targetEl.textContent = target;
        if (contentEl) {
            contentEl.innerHTML = `
                <div class="observe-status">Watching...</div>
                ${processContentForDisplay(initialContent)}
            `;
        }

        observeWindowEl.classList.add('visible');

        // Setup close button
        const closeBtn = observeWindowEl.querySelector('.observe-close');
        if (closeBtn) {
            closeBtn.onclick = stopObservation;
        }
    }

    function updateObservation(content) {
        if (!observeWindowEl || !currentObservation) return;

        const contentEl = observeWindowEl.querySelector('.observe-content');
        if (contentEl) {
            contentEl.innerHTML = `
                <div class="observe-status">Watching...</div>
                ${processContentForDisplay(content)}
            `;
            contentEl.classList.add('observe-update');
            setTimeout(() => contentEl.classList.remove('observe-update'), 500);
        }
    }

    function stopObservation() {
        if (observeWindowEl) {
            observeWindowEl.classList.remove('visible');
        }
        currentObservation = null;
    }

    // ====== RICH CONTENT SUPPORT ======
    // Process images and YouTube embeds in messages

    function processRichContent(content) {
        if (!content) return '';

        let processed = content;

        // Process image URLs - [img]url[/img] or direct image links
        processed = processed.replace(/\[img\](.*?)\[\/img\]/gi, (match, url) => {
            return createImageEmbed(url);
        });

        // Process direct image URLs (jpg, png, gif, webp)
        processed = processed.replace(/(https?:\/\/[^\s<>"]+\.(?:jpg|jpeg|png|gif|webp))/gi, (match, url) => {
            return createImageEmbed(url);
        });

        // Process YouTube URLs - [youtube]url[/youtube] or direct links
        processed = processed.replace(/\[youtube\](.*?)\[\/youtube\]/gi, (match, url) => {
            return createYouTubeEmbed(url);
        });

        // Process direct YouTube URLs
        processed = processed.replace(/(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})(?:[^\s<]*)?/g, (match, videoId) => {
            return createYouTubeEmbed(`https://www.youtube.com/watch?v=${videoId}`);
        });

        return processed;
    }

    function createImageEmbed(url) {
        const safeUrl = escapeHtml(url);
        return `
            <div class="message-image-container">
                <img class="message-image" src="${safeUrl}" alt="Image" onclick="openLightbox('${safeUrl}')" onerror="this.parentElement.style.display='none'">
                <span class="expand-icon">Click to enlarge</span>
            </div>
        `;
    }

    function createYouTubeEmbed(url) {
        // Extract video ID
        const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
        if (!match) return escapeHtml(url);

        const videoId = match[1];
        const thumbnailUrl = `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`;

        return `
            <div class="youtube-embed" data-video-id="${videoId}">
                <div class="youtube-placeholder" onclick="loadYouTubeVideo(this, '${videoId}')">
                    <img src="${thumbnailUrl}" alt="YouTube video thumbnail">
                    <div class="youtube-play-button"></div>
                </div>
            </div>
        `;
    }

    function loadYouTubeVideo(placeholder, videoId) {
        const container = placeholder.parentElement;
        container.innerHTML = `
            <div style="position: relative; padding-bottom: 56.25%; height: 0;">
                <iframe
                    src="https://www.youtube.com/embed/${videoId}?autoplay=1"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen>
                </iframe>
            </div>
        `;
    }

    // Image lightbox - uses shared /js/lightbox.js
    window.loadYouTubeVideo = loadYouTubeVideo;
    window.hideImprint = hideImprint;
    window.hideTempResult = hideTempResult;
    window.stopObservation = stopObservation;

    // ====== OBSERVATION PANEL RENDERERS ======
    // Rich display type renderers for Look command results

    function showObservationPanel(displayType, data, side = 'right') {
        let html = '';
        let title = 'Look';

        switch (displayType) {
            case 'character_display':
            case 'character':
                html = renderCharacterDisplay(data);
                title = data.name || 'Character';
                break;
            case 'room_display':
            case 'room':
                html = renderRoomDisplay(data);
                title = data.room?.name || 'Room';
                // Apply environment effects based on room type
                applyEnvironmentEffects(data.room || data);
                // Update background image from room data
                const roomBgUrl = data.room?.background_picture_url || data.background_picture_url;
                if (roomBgUrl) updateRoomBackgroundImage(roomBgUrl);
                // Handle delve map in room displays
                if (data.delve_map_svg) {
                    handleDelveMapUpdate(data);
                } else if (data.in_delve === false && inDelve) {
                    exitDelveMap();
                }
                // Update minimap when a room display arrives (covers WebSocket broadcasts)
                if (!inDelve) {
                    if (data.minimap_data && data.minimap_data.svg) {
                        const roomName = data.room?.name || currentRoomName;
                        currentRoomName = roomName;
                        updateRightStatus(roomName);
                        drawMinimapSvg(data.minimap_data.svg, data.minimap_data.metadata);
                        showMinimap();
                    } else if (data.minimap_data && data.minimap_data.current_room) {
                        const roomName = data.room?.name || currentRoomName;
                        currentRoomName = roomName;
                        updateRightStatus(roomName);
                        drawSpatialMinimap(data.minimap_data);
                    } else if (data.exits && data.exits.length > 0) {
                        const roomName = data.room?.name || currentRoomName;
                        currentRoomName = roomName;
                        updateRightStatus(roomName);
                        drawSimpleMinimap(roomName, data.exits);
                    }
                }
                break;
            case 'place_display':
            case 'place':
                html = renderPlaceDisplay(data);
                title = data.name || 'Place';
                break;
            case 'decoration_display':
            case 'decoration':
                html = renderDecorationDisplay(data);
                title = data.name || 'Decoration';
                break;
            case 'item_display':
            case 'item':
                html = renderItemDisplay(data);
                title = data.name || 'Item';
                break;
            case 'exit_display':
            case 'exit':
                html = renderExitDisplay(data);
                title = data.direction || 'Exit';
                break;
            case 'feature_display':
            case 'feature':
                html = renderFeatureDisplay(data);
                title = data.name || 'Feature';
                break;
            case 'disambiguation':
                html = renderDisambiguationDisplay(data);
                title = 'Select Target';
                break;
            case 'quickmenu':
                html = renderQuickmenuDisplay(data);
                title = 'Choose';
                break;
            case 'form':
                html = renderFormDisplay(data);
                title = data.title || 'Form';
                // Initialize rich text editors after form is shown
                setTimeout(() => initFormRichTextEditors(), 50);
                break;
            case 'shop_list':
                html = renderShopListDisplay(data);
                title = data.shop_name || 'Shop';
                break;
            case 'canvas':
                html = renderCanvasDisplay(data);
                title = data.room_name || data.location_name || 'Map';
                break;
            case 'svg':
                html = renderSvgDisplay(data);
                title = data.location_name || data.room_name || 'Map';
                break;
            case 'puzzle':
                html = renderPuzzleDisplay(data);
                title = 'Puzzle';
                break;
            default:
                // Fallback to raw content
                return false;
        }

        showTempResult(title, html, side);
        return true;
    }

    function renderCharacterDisplay(data) {
        let html = '<div class="obs-character-display">';

        // Profile pic floated left with status overlays
        if (data.profile_pic_url) {
            html += `<div class="portrait-container">`;
            html += `<img class="obs-profile-pic" src="${escapeHtml(data.profile_pic_url)}" alt="${escapeHtml(data.name)}" onclick="openLightbox('${escapeHtml(data.profile_pic_url)}')" onerror="this.style.display='none'">`;

            // Water drops overlay for wet characters
            if (data.wetness_level && data.wetness_level > 0) {
                const wetOpacity = Math.min(0.3 + (data.wetness_level / 100) * 0.4, 0.7);
                html += `<img class="portrait-overlay wet-overlay" src="/images/water_drops.png" style="opacity: ${wetOpacity}" alt="">`;
            }

            // Blood spatter overlay for injured characters
            if (data.injury_level && data.injury_level > 0) {
                const bloodSrc = data.injury_level <= 2 ? 'blood_light.png'
                               : data.injury_level <= 4 ? 'blood_medium.png'
                               : 'blood_heavy.png';
                const bloodOpacity = data.injury_level <= 2 ? 0.4
                                   : data.injury_level <= 4 ? 0.6
                                   : 0.8;
                html += `<img class="portrait-overlay blood-overlay" src="/images/${bloodSrc}" style="opacity: ${bloodOpacity}" alt="">`;
            }

            html += `</div>`;
        }

        // Name line: "Steven 'Steve' Testerman, a tall man"
        const nameLine = data.name_line || (data.short_desc ? `${data.name || 'Unknown'}, ${data.short_desc}` : (data.name || 'Unknown'));
        html += `<div class="obs-character-name-line">${escapeHtml(nameLine)}`;
        // Status inline after name (skip 'alive' as it's the default state)
        if (data.status && data.status !== 'alive') {
            html += ` <span class="obs-character-status">(${escapeHtml(data.status)})</span>`;
        }
        html += `</div>`;

        // Roomtitle if set
        if (data.roomtitle) {
            html += `<div class="obs-character-roomtitle">${escapeHtml(data.roomtitle)}</div>`;
        }

        // Intro text: "He is a slender Caucasian man in his mid forties standing at 5'11\" / 180cm."
        if (data.intro) {
            html += `<p class="obs-character-intro">${escapeHtml(data.intro)}</p>`;
        }

        // Eyes/hair line: "He has red-blue eyes and spikey pink hair."
        if (data.eyes_hair_line) {
            html += `<p class="obs-character-eyes-hair">${escapeHtml(data.eyes_hair_line)}</p>`;
        }

        // Description elements with player-chosen separators
        if (data.descriptions && data.descriptions.length > 0) {
            let descHtml = '';
            let previousSuffix = null;

            // Determine pronouns based on character gender
            const gender = (data.gender || '').toLowerCase();
            let pronoun, hasVerb, isVerb;
            if (gender === 'female') {
                pronoun = 'She'; hasVerb = 'has'; isVerb = 'is';
            } else if (gender === 'male') {
                pronoun = 'He'; hasVerb = 'has'; isVerb = 'is';
            } else {
                pronoun = 'They'; hasVerb = 'have'; isVerb = 'are';
            }

            data.descriptions.forEach((desc, index) => {
                if (desc.content_type === 'text') {
                    const prefix = desc.prefix || 'none';
                    let prefixHtml = '';
                    switch (prefix) {
                        case 'pronoun_has': prefixHtml = `${pronoun} ${hasVerb} `; break;
                        case 'pronoun_is': prefixHtml = `${pronoun} ${isVerb} `; break;
                        case 'and': prefixHtml = 'and '; break;
                        default: prefixHtml = ''; break;
                    }
                    const suffix = desc.suffix || 'period';
                    let suffixHtml = '';
                    switch (suffix) {
                        case 'newline': suffixHtml = '.<br>'; break;
                        case 'double_newline': suffixHtml = '.<br><br>'; break;
                        case 'comma': suffixHtml = ', '; break;
                        case 'space': suffixHtml = ' '; break;
                        case 'period':
                        default: suffixHtml = '. '; break;
                    }
                    let content = desc.content || '';
                    if (prefixHtml) {
                        content = content.length > 0 ? content.charAt(0).toLowerCase() + content.slice(1) : content;
                    } else if (index > 0 && previousSuffix && ['comma', 'space'].includes(previousSuffix)) {
                        content = content.length > 0 ? content.charAt(0).toLowerCase() + content.slice(1) : content;
                    } else {
                        content = content.length > 0 ? content.charAt(0).toUpperCase() + content.slice(1) : content;
                    }
                    descHtml += `<span class="obs-desc-text">${prefixHtml}${safeHtml(content)}${suffixHtml}</span>`;
                    previousSuffix = suffix;
                } else if (desc.content_type === 'image' && desc.content) {
                    descHtml += `<div class="obs-desc-image"><img src="${escapeHtml(desc.content)}" alt="${escapeHtml(desc.name || 'Description')}" onclick="openLightbox('${escapeHtml(desc.content)}')" onerror="this.style.display='none'"></div>`;
                }
            });
            if (descHtml) {
                html += `<p class="obs-character-descriptions">${descHtml}</p>`;
            }
        }

        // Thumbnail gallery - held items on their own row, then body thumbnails head-to-toe
        if (data.thumbnails && data.thumbnails.length > 0) {
            const heldThumbs = data.thumbnails.filter(t => t.type === 'held_item');
            const bodyThumbs = data.thumbnails.filter(t => t.type !== 'held_item');

            if (heldThumbs.length > 0) {
                html += '<div class="obs-thumbnails obs-thumbnails-held">';
                heldThumbs.forEach(thumb => {
                    const imgUrl = thumb.full_url || thumb.image_url || thumb.url || thumb;
                    const thumbUrl = thumb.url || thumb.thumbnail_url || imgUrl;
                    html += `<img class="obs-thumb" src="${escapeHtml(thumbUrl)}" alt="Thumbnail" onclick="openLightbox('${escapeHtml(imgUrl)}')" onerror="this.style.display='none'">`;
                });
                html += '</div>';
            }

            if (bodyThumbs.length > 0) {
                html += '<div class="obs-thumbnails">';
                bodyThumbs.forEach(thumb => {
                    const imgUrl = thumb.full_url || thumb.image_url || thumb.url || thumb;
                    const thumbUrl = thumb.url || thumb.thumbnail_url || imgUrl;
                    html += `<img class="obs-thumb" src="${escapeHtml(thumbUrl)}" alt="Thumbnail" onclick="openLightbox('${escapeHtml(imgUrl)}')" onerror="this.style.display='none'">`;
                });
                html += '</div>';
            }
        }

        // Combined "is using" section (held items + worn items head-to-toe)
        const usingItems = data.using_items || [];
        const hasUsingItems = usingItems.length > 0;
        const legacyHasItems = (!hasUsingItems) && ((data.clothing && data.clothing.length > 0) || (data.held_items && data.held_items.length > 0));

        if (hasUsingItems) {
            const displayName = data.casual_name || data.name || 'They';
            html += `<div class="obs-using-section"><div class="obs-section-label">${escapeHtml(displayName)} is using:</div><div class="obs-using-list">`;

            let lastItemType = null;
            usingItems.forEach(item => {
                if (lastItemType === 'held' && item.item_type === 'worn') {
                    html += '<div class="obs-using-separator"></div>';
                }
                lastItemType = item.item_type;

                html += `<div class="obs-using-item obs-using-${item.item_type}">`;
                html += `<span class="obs-item-name">${safeHtml(item.name)}</span>`;
                if (item.item_type === 'held' && item.hand) {
                    html += ` <span class="obs-item-hand">(${escapeHtml(item.hand)})</span>`;
                }
                html += `</div>`;
            });
            html += '</div></div>';
        } else if (legacyHasItems) {
            if (data.held_items && data.held_items.length > 0) {
                html += '<div class="obs-held-section"><div class="obs-section-label">Holding:</div><div class="obs-held-list">';
                data.held_items.forEach(item => {
                    html += `<div class="obs-held-item">`;
                    html += `<span class="obs-item-name">${safeHtml(item.name)}</span>`;
                    if (item.hand) {
                        html += ` <span class="obs-item-hand">(${escapeHtml(item.hand)})</span>`;
                    }
                    html += `</div>`;
                });
                html += '</div></div>';
            }

            if (data.clothing && data.clothing.length > 0) {
                html += '<div class="obs-clothing-section"><div class="obs-section-label">Wearing:</div><div class="obs-clothing-list">';
                data.clothing.forEach(item => {
                    html += `<div class="obs-clothing-item">`;
                    html += `<span class="obs-item-name">${safeHtml(item.name)}</span>`;
                    html += `</div>`;
                });
                html += '</div></div>';
            }
        }

        html += '</div>';
        return html;
    }

    function renderRoomDisplay(data) {
        setRoomConsentNotice(data?.content_consent || null);
        let html = '<div class="obs-room-display">';

        const room = data.room || data;
        const displayMode = data.display_mode || 'full';

        // 1. Room name (always shown)
        if (room.name) {
            html += `<div class="obs-room-name">${escapeHtml(room.name)}</div>`;
        }

        // Transit mode: minimal - just name and characters
        if (displayMode === 'transit') {
            // Characters (quick glance)
            html += renderCharacterList(data);
            html += '</div>';
            return html;
        }

        // Arrival mode: name + description + exits + characters
        if (displayMode === 'arrival') {
            if (room.description) {
                const desc = room.description.replace(/\n/g, '<br>');
                html += `<div class="obs-room-description">${desc}</div>`;
            }
            html += renderExits(data);
            html += renderContextHints(data);
            html += renderCharacterList(data);
            html += '</div>';
            return html;
        }

        // Full mode: Name → Description → Weather → Places → Decorations → Exits → People/Items

        // 2. Description
        if (room.description) {
            const desc = room.description.replace(/\n/g, '<br>');
            html += `<div class="obs-room-description">${desc}</div>`;
        }

        // 3. Weather prose
        if (data.weather && data.weather.prose) {
            let weatherText = '';
            if (data.weather.prefix) {
                weatherText += `<span class="obs-weather-prefix">${escapeHtml(data.weather.prefix)}:</span> `;
            }
            weatherText += escapeHtml(data.weather.prose);
            html += `<div class="obs-weather">${weatherText}</div>`;
        }

        // 4. Places (comma-separated list of names)
        if (data.places && data.places.length > 0) {
            const placeNames = data.places.map(p => `<span class="obs-place-name">${escapeHtml(p.name)}</span>`).join(', ');
            html += `<div class="obs-places"><span class="obs-section-label">Places:</span> ${placeNames}</div>`;
        }

        // 5. Decorations
        if (data.decorations && data.decorations.length > 0) {
            html += '<div class="obs-decorations"><span class="obs-section-label">Decorations:</span><ul>';
            data.decorations.forEach(dec => {
                html += `<li class="obs-decoration-item">`;
                html += `<span class="obs-decoration-name">${safeHtml(dec.name)}</span>`;
                html += `</li>`;
            });
            html += '</ul></div>';
        }

        // 6. Exits
        html += renderExits(data);

        // Context hints
        html += renderContextHints(data);

        // 7. Background image thumbnails
        if (data.thumbnails && data.thumbnails.length > 0) {
            const bgThumbs = data.thumbnails.filter(t => t.type === 'background');
            if (bgThumbs.length > 0) {
                html += '<div class="obs-thumbnails obs-thumbnails-bg">';
                bgThumbs.forEach(thumb => {
                    const imgUrl = thumb.url;
                    html += `<img class="obs-thumb obs-thumb-bg" src="${escapeHtml(imgUrl)}" alt="${escapeHtml(thumb.alt || 'Room background')}" title="Room background" onclick="openLightbox('${escapeHtml(imgUrl)}')" onerror="this.style.display='none'">`;
                });
                html += '</div>';
            }
        }

        // 8. Characters (ungrouped)
        html += renderCharacterList(data);

        // 9. Objects on ground (stacked by name)
        if (data.objects && data.objects.length > 0) {
            html += '<div class="obs-objects"><span class="obs-section-label">On the ground:</span><ul>';
            const objectCounts = {};
            const objectOrder = [];
            data.objects.forEach(obj => {
                const name = obj.name || 'unknown item';
                if (objectCounts[name]) {
                    objectCounts[name]++;
                } else {
                    objectCounts[name] = 1;
                    objectOrder.push(name);
                }
            });
            objectOrder.forEach(name => {
                const count = objectCounts[name];
                html += `<li class="obs-object-item">`;
                html += `<span class="obs-object-name">${safeHtml(name)}</span>`;
                if (count > 1) {
                    html += `<span style="color:#666; font-size:11px;"> (x${count})</span>`;
                }
                html += `</li>`;
            });
            html += '</ul></div>';
        }

        html += '</div>';
        return html;
    }

    // Helper: render exits section
    function renderExits(data) {
        if (!data.exits || data.exits.length === 0) return '';
        let html = '<div class="obs-exits"><span class="obs-section-label">Exits:</span> ';
        html += data.exits.map(e => {
            const dir = e.direction || e;
            const roomName = e.to_room_styled_name
                ? e.to_room_styled_name
                : escapeHtml(e.to_room_name || dir);
            const arrow = e.direction_arrow || '';
            const dist = e.distance || 0;
            const tag = (dist > 0 && arrow) ? `<sup>${arrow}${dist}ft</sup>` : '';
            const lockedClass = e.locked ? ' obs-exit-locked' : '';
            return `<a href="#" class="obs-exit${lockedClass}" data-direction="${escapeHtml(dir)}" onclick="navigateToExit(event, '${escapeHtml(dir)}')">${roomName}${tag}</a>`;
        }).join(', ');
        html += '</div>';
        return html;
    }

    // Helper: render context hints
    function renderContextHints(data) {
        if (!data.context_hints || data.context_hints.length === 0) return '';
        let html = '<div class="obs-context-hints">';
        data.context_hints.forEach(hint => {
            html += `<div class="obs-context-hint">${escapeHtml(hint.message)}</div>`;
        });
        html += '</div>';
        return html;
    }

    // Helper: render all characters (ungrouped + from places)
    function renderCharacterList(data) {
        const allChars = [...(data.characters_ungrouped || [])];
        if (data.places) {
            data.places.forEach(p => { if (p.characters) allChars.push(...p.characters); });
        }
        if (allChars.length === 0) return '';
        let html = '<div class="obs-characters"><span class="obs-section-label">Here:</span>';
        html += '<ul class="obs-char-list">';
        allChars.forEach(char => {
            html += `<li class="obs-char-item">`;
            html += `<span class="obs-char-name">${escapeHtml(char.name)}</span>`;
            if (char.presence) {
                const p = char.presence;
                const mins = p.minutes ? ` ${p.minutes}` : '';
                const timestamp = p.until_timestamp ? ` data-until="${escapeHtml(p.until_timestamp)}"` : '';
                html += `<sup class="obs-presence obs-presence-${escapeHtml(p.status)}"${timestamp}>(${escapeHtml(p.status)}${mins})</sup>`;
            }
            if (char.short_desc && !char.name_is_short_desc) {
                html += `, <span class="obs-char-short">${escapeHtml(char.short_desc)}</span>`;
            }
            if (char.status_line) {
                html += `, <span class="obs-char-status">${escapeHtml(char.status_line)}</span>`;
            }
            const dist = char.distance || 0;
            const arrow = char.direction_arrow || '';
            html += `<sup class="obs-char-distance">${arrow}${dist}ft</sup>`;
            html += `</li>`;
        });
        html += '</ul></div>';
        return html;
    }

    function renderPlaceDisplay(data) {
        let html = '<div class="obs-place-display">';

        html += `<div class="obs-place-name">${escapeHtml(data.name || 'Place')}</div>`;
        if (data.description) {
            html += `<div class="obs-place-description">${escapeHtml(data.description)}</div>`;
        }
        if (data.place_type) {
            html += `<div class="obs-place-type">${escapeHtml(data.place_type)}</div>`;
        }

        // Characters at this place
        if (data.characters && data.characters.length > 0) {
            html += '<div class="obs-place-chars"><span class="obs-section-label">Here:</span>';
            html += '<ul class="obs-char-list">';
            data.characters.forEach(char => {
                html += `<li class="obs-char-at-place">`;
                html += `<span class="obs-char-name">${escapeHtml(char.name)}</span>`;
                if (char.presence) {
                    const p = char.presence;
                    const mins = p.minutes ? ` ${p.minutes}` : '';
                    const timestamp = p.until_timestamp ? ` data-until="${escapeHtml(p.until_timestamp)}"` : '';
                    html += `<sup class="obs-presence obs-presence-${escapeHtml(p.status)}"${timestamp}>(${escapeHtml(p.status)}${mins})</sup>`;
                }
                if (char.short_desc && !char.name_is_short_desc) {
                    html += `, <span class="obs-char-short">${escapeHtml(char.short_desc)}</span>`;
                }
                if (char.status_line) {
                    html += `, <span class="obs-char-status">${escapeHtml(char.status_line)}</span>`;
                }
                const dist = char.distance || 0;
                const arrow = char.direction_arrow || '';
                html += `<sup class="obs-char-distance">${arrow}${dist}ft</sup>`;
                html += `</li>`;
            });
            html += '</ul></div>';
        } else {
            html += '<div class="obs-place-empty">Nobody is here.</div>';
        }

        html += '</div>';
        return html;
    }

    function renderDecorationDisplay(data) {
        let html = '<div class="obs-decoration-display">';

        html += `<div class="obs-decoration-name">${safeHtml(data.name || 'Decoration')}</div>`;
        if (data.description) {
            html += `<div class="obs-decoration-description">${safeHtml(data.description)}</div>`;
        }

        // Image
        if (data.image_url) {
            html += `<div class="obs-decoration-image"><img src="${escapeHtml(data.image_url)}" alt="${escapeHtml(data.name)}" onclick="openLightbox('${escapeHtml(data.image_url)}')" onerror="this.style.display='none'"></div>`;
        }

        html += '</div>';
        return html;
    }

    function renderItemDisplay(data) {
        let html = '<div class="obs-item-display">';

        // Item name with owner
        if (data.owner) {
            html += `<div class="obs-item-owner">${escapeHtml(data.owner)}'s</div>`;
        }
        html += `<div class="obs-item-name">${safeHtml(data.name || 'Item')}</div>`;

        // Image
        if (data.image_url) {
            html += `<div class="obs-item-image"><img src="${escapeHtml(data.image_url)}" alt="${escapeHtml(data.name)}" onclick="openLightbox('${escapeHtml(data.image_url)}')" onerror="this.style.display='none'"></div>`;
        } else if (data.thumbnail_url) {
            html += `<div class="obs-item-image"><img src="${escapeHtml(data.thumbnail_url)}" alt="${escapeHtml(data.name)}" onclick="openLightbox('${escapeHtml(data.thumbnail_url)}')" onerror="this.style.display='none'"></div>`;
        }

        // Description
        if (data.description) {
            html += `<div class="obs-item-description">${safeHtml(data.description)}</div>`;
        }

        // Condition
        if (data.condition) {
            html += `<div class="obs-item-condition">Condition: ${escapeHtml(data.condition)}</div>`;
        }

        html += '</div>';
        return html;
    }

    // ====== SHOP LIST DISPLAY ======
    let shopPreviewEl = null;
    window.currentShopItems = [];

    function renderShopListDisplay(data) {
        let html = '<div class="obs-shop-display">';

        // Shop header
        html += `<div class="obs-shop-header">${escapeHtml(data.shop_name || 'Shop')}</div>`;
        if (data.category) {
            html += `<div class="obs-shop-category">Showing: ${escapeHtml(data.category)}</div>`;
        }

        // Items list
        html += '<div class="obs-shop-items">';

        if (data.items && data.items.length > 0) {
            data.items.forEach((item, index) => {
                const hasImage = item.image_url && item.image_url.trim();
                const priceText = item.price === 0 ? 'FREE' : (item.price_formatted || `${item.price}`);
                const stockText = item.unlimited ? '' : ` (${item.stock} left)`;

                html += `<div class="shop-item"
                             data-item-index="${index}"
                             onmouseenter="showShopItemPreview(event, ${index})"
                             onmouseleave="hideShopItemPreview()"
                             onclick="openShopItemPopup(${index})">`;

                // Thumbnail if available
                if (hasImage) {
                    html += `<div class="shop-item-thumb">
                        <img src="${escapeHtml(item.image_url)}"
                             alt="${escapeHtml(item.name)}"
                             onerror="this.parentElement.style.display='none'">
                    </div>`;
                }

                // Item info
                html += `<div class="shop-item-info">`;
                html += `<div class="shop-item-name">${safeHtml(item.name || 'Unknown')}</div>`;
                html += `<div class="shop-item-price">${escapeHtml(priceText)}${escapeHtml(stockText)}</div>`;
                html += `</div>`;

                html += `</div>`;
            });
        } else {
            html += '<div class="shop-empty">No items available.</div>';
        }

        html += '</div>'; // .obs-shop-items

        // Footer
        html += `<div class="obs-shop-footer">${data.count || 0} item(s). Use 'buy &lt;item&gt;' to purchase.</div>`;

        html += '</div>'; // .obs-shop-display

        // Store items data for popup access
        window.currentShopItems = data.items || [];

        return html;
    }

    function showShopItemPreview(event, index) {
        const item = window.currentShopItems?.[index];
        if (!item) return;

        // Create preview element if needed
        if (!shopPreviewEl) {
            shopPreviewEl = document.createElement('div');
            shopPreviewEl.className = 'shop-item-preview';
            document.body.appendChild(shopPreviewEl);
        }

        // Build preview content
        let html = '';
        if (item.image_url) {
            html += `<img src="${escapeHtml(item.image_url)}"
                         alt="${escapeHtml(item.name)}"
                         onerror="this.style.display='none'">`;
        }
        if (item.description) {
            html += `<div class="preview-desc">${safeHtml(item.description)}</div>`;
        }

        if (!html) {
            html = '<div class="preview-desc">No preview available.</div>';
        }

        shopPreviewEl.innerHTML = html;

        // Position near cursor
        const rect = event.target.closest('.shop-item').getBoundingClientRect();
        shopPreviewEl.style.left = (rect.right + 10) + 'px';
        shopPreviewEl.style.top = rect.top + 'px';
        shopPreviewEl.style.display = 'block';
    }

    function hideShopItemPreview() {
        if (shopPreviewEl) {
            shopPreviewEl.style.display = 'none';
        }
    }

    function openShopItemPopup(index) {
        const item = window.currentShopItems?.[index];
        if (!item) return;

        hideShopItemPreview();

        // Show popup with item details
        openShopLightbox(item);
    }

    function openShopLightbox(item) {
        // Create overlay
        const overlay = document.createElement('div');
        overlay.className = 'shop-lightbox-overlay';
        overlay.onclick = (e) => {
            if (e.target === overlay) overlay.remove();
        };

        let html = '<div class="shop-lightbox-content">';
        html += `<div class="shop-lightbox-header">${safeHtml(item.name || 'Item')}</div>`;

        if (item.image_url) {
            html += `<img src="${escapeHtml(item.image_url)}" alt="${escapeHtml(item.name)}">`;
        }

        if (item.description) {
            html += `<div class="shop-lightbox-desc">${safeHtml(item.description)}</div>`;
        }

        const priceText = item.price === 0 ? 'FREE' : (item.price_formatted || `${item.price}`);
        html += `<div class="shop-lightbox-price">Price: ${escapeHtml(priceText)}</div>`;

        html += '<button class="shop-lightbox-close" onclick="this.closest(\'.shop-lightbox-overlay\').remove()">Close</button>';
        html += '</div>';

        overlay.innerHTML = html;
        document.body.appendChild(overlay);
    }

    // ====== SHOP BUY MODAL (from chat listing clicks) ======
    function openShopBuyModal(itemData) {
        // Remove any existing modal
        document.querySelector('.shop-buy-overlay')?.remove();

        const overlay = document.createElement('div');
        overlay.className = 'shop-buy-overlay';
        overlay.onclick = (e) => {
            if (e.target === overlay) overlay.remove();
        };

        let html = '<div class="shop-buy-modal">';

        // Image
        if (itemData.img) {
            html += `<img class="shop-buy-modal-img" src="${escapeHtml(itemData.img)}" alt="${escapeHtml(itemData.name)}" onerror="this.style.display='none'">`;
        }

        html += '<div class="shop-buy-modal-body">';

        // Name (render HTML for colored item names)
        html += `<div class="shop-buy-modal-name">${itemData.name}</div>`;

        // Description (only if it's actual text, not same as name)
        const plainName = itemData.name.replace(/<[^>]*>/g, '');
        if (itemData.desc && itemData.desc !== plainName) {
            html += `<div class="shop-buy-modal-desc">${safeHtml(itemData.desc)}</div>`;
        }

        // Price
        html += `<div class="shop-buy-modal-price">${escapeHtml(itemData.pf)}</div>`;

        // Stock info
        if (itemData.stock >= 0) {
            html += `<div style="font-size:12px;color:oklch(var(--bc)/0.5);margin-bottom:12px">${itemData.stock} in stock</div>`;
        }

        // Quantity selector
        const maxStock = itemData.stock < 0 ? 99 : itemData.stock;
        html += '<div class="shop-buy-modal-qty">';
        html += '<label>Qty</label>';
        html += '<div class="shop-buy-modal-qty-controls">';
        html += `<button class="shop-buy-modal-qty-btn" data-action="dec">&minus;</button>`;
        html += `<input class="shop-buy-modal-qty-input" type="number" value="1" min="1" max="${maxStock}">`;
        html += `<button class="shop-buy-modal-qty-btn" data-action="inc">+</button>`;
        html += '</div>';
        html += '</div>';

        // Buttons
        html += '<div class="shop-buy-modal-actions">';
        html += `<button class="shop-cancel-btn" data-action="cancel">Cancel</button>`;
        html += `<button class="shop-buy-btn" data-action="buy" data-item-number="${itemData.n}">Buy</button>`;
        html += '</div>';

        html += '</div>'; // .shop-buy-modal-body
        html += '</div>'; // .shop-buy-modal

        overlay.innerHTML = html;
        document.body.appendChild(overlay);

        // Wire up controls
        const modal = overlay.querySelector('.shop-buy-modal');
        const qtyInput = modal.querySelector('.shop-buy-modal-qty-input');

        modal.querySelector('[data-action="dec"]').onclick = () => {
            const v = parseInt(qtyInput.value) || 1;
            qtyInput.value = Math.max(1, v - 1);
        };
        modal.querySelector('[data-action="inc"]').onclick = () => {
            const v = parseInt(qtyInput.value) || 1;
            qtyInput.value = Math.min(maxStock, v + 1);
        };
        modal.querySelector('[data-action="cancel"]').onclick = () => overlay.remove();
        modal.querySelector('[data-action="buy"]').onclick = () => {
            const qty = parseInt(qtyInput.value) || 1;
            const itemNum = itemData.n;
            const cmd = qty > 1 ? `buy ${qty} ${itemNum}` : `buy ${itemNum}`;
            overlay.remove();
            sendCommand(cmd);
        };

        // Focus the buy button
        modal.querySelector('[data-action="buy"]').focus();

        // Escape to close
        const escHandler = (e) => {
            if (e.key === 'Escape') {
                overlay.remove();
                document.removeEventListener('keydown', escHandler);
            }
        };
        document.addEventListener('keydown', escHandler);
    }

    // Event delegation for shop listing item clicks
    document.addEventListener('click', (e) => {
        const itemEl = e.target.closest('.shop-listing-item');
        if (!itemEl) return;

        const container = itemEl.closest('.shop-listing');
        if (!container) return;

        const idx = parseInt(itemEl.dataset.itemIdx);
        if (isNaN(idx)) return;

        try {
            const items = JSON.parse(container.dataset.shopItems || '[]');
            if (items[idx]) {
                openShopBuyModal(items[idx]);
            }
        } catch (err) {
            // Fallback: just send buy command
            sendCommand(`buy ${idx + 1}`);
        }
    });

    window.openShopBuyModal = openShopBuyModal;

    // Expose functions globally for inline event handlers
    window.showShopItemPreview = showShopItemPreview;
    window.hideShopItemPreview = hideShopItemPreview;
    window.openShopItemPopup = openShopItemPopup;
    // ====== END SHOP LIST DISPLAY ======

    function renderExitDisplay(data) {
        let html = '<div class="obs-exit-display">';

        html += `<div class="obs-exit-direction">${escapeHtml(data.direction || 'Exit')}</div>`;
        if (data.to_room_name) {
            html += `<div class="obs-exit-dest">Leads to: ${escapeHtml(data.to_room_name)}</div>`;
        }
        if (data.description) {
            html += `<div class="obs-exit-description">${escapeHtml(data.description)}</div>`;
        }
        if (data.locked) {
            html += `<div class="obs-exit-locked">🔒 Locked</div>`;
        }

        html += '</div>';
        return html;
    }

    function renderFeatureDisplay(data) {
        let html = '<div class="obs-feature-display">';

        html += `<div class="obs-feature-name">${escapeHtml(data.name || 'Feature')}</div>`;
        if (data.feature_type) {
            html += `<div class="obs-feature-type">${escapeHtml(data.feature_type)}</div>`;
        }
        if (data.description) {
            html += `<div class="obs-feature-description">${escapeHtml(data.description)}</div>`;
        }

        html += '</div>';
        return html;
