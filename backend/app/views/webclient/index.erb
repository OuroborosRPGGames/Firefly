                const tempUnit = currentSettings.temp_unit || 'F';
                const tempValue = tempUnit === 'C'
                    ? weatherData.temperature_c
                    : weatherData.temperature_f;
                if (tempValue != null) {
                    const tempText = `${Math.round(tempValue)}°${tempUnit}`;
                    const tempColor = temperatureColor(weatherData.temperature_c);
                    weatherEl.innerHTML = `<span style="color:${tempColor}">${symbol} ${tempText}</span>`;
                } else {
                    weatherEl.textContent = symbol;
                }
            } else {
                weatherEl.textContent = '';
            }
        }
    }

    // Map temperature in Celsius to a color from deep blue (cold) to deep red (hot)
    function temperatureColor(tempC) {
        if (tempC == null) return '#cccccc';
        // Color stops: <= -10°C deep blue, 0°C blue, 15°C teal, 22°C green, 30°C yellow, 38°C orange, >= 45°C red
        const stops = [
            { t: -10, r: 70,  g: 130, b: 220 },
            { t:   0, r: 100, g: 160, b: 240 },
            { t:  15, r:  80, g: 210, b: 200 },
            { t:  22, r: 100, g: 210, b: 100 },
            { t:  30, r: 240, g: 210, b:  60 },
            { t:  38, r: 240, g: 120, b:  30 },
            { t:  45, r: 220, g:  40, b:  40 },
        ];
        if (tempC <= stops[0].t) return `rgb(${stops[0].r},${stops[0].g},${stops[0].b})`;
        if (tempC >= stops[stops.length - 1].t) { const s = stops[stops.length - 1]; return `rgb(${s.r},${s.g},${s.b})`; }
        for (let i = 0; i < stops.length - 1; i++) {
            if (tempC >= stops[i].t && tempC <= stops[i + 1].t) {
                const ratio = (tempC - stops[i].t) / (stops[i + 1].t - stops[i].t);
                const r = Math.round(stops[i].r + (stops[i + 1].r - stops[i].r) * ratio);
                const g = Math.round(stops[i].g + (stops[i + 1].g - stops[i].g) * ratio);
                const b = Math.round(stops[i].b + (stops[i + 1].b - stops[i].b) * ratio);
                return `rgb(${r},${g},${b})`;
            }
        }
        return '#cccccc';
    }

    // Apply time-of-day color gradient to text (like Ravencroft)
    function applyTimeGradient(text, hour, timeData) {
        const dawnHour = (timeData && timeData.sunrise_hour) || 6;
        const duskHour = (timeData && timeData.sunset_hour) || 18;

        let startColor, endColor;

        if (hour < dawnHour - 2 || hour > duskHour + 2) {
            // Night - solid dark gray
            return `<span style="color:#666666">${escapeHtml(text)}</span>`;
        } else if (hour === dawnHour) {
            // Sunrise - orange to teal
            startColor = '#E94D23';
            endColor = '#7DB2B4';
        } else if (hour === duskHour) {
            // Sunset - teal to orange
            startColor = '#7DB2B4';
            endColor = '#E94D23';
        } else if (hour < 12) {
            // Morning - blue-green to yellow
            startColor = '#57C8CF';
            endColor = '#FBF492';
        } else {
            // Afternoon - blue-green to yellow (fading)
            startColor = '#57C8CF';
            endColor = '#FBE192';
        }

        return renderCharacterGradient(text, startColor, endColor);
    }

    // Render character-by-character color gradient
    function renderCharacterGradient(text, startColor, endColor) {
        const start = hexToRgb(startColor);
        const end = hexToRgb(endColor);
        const chars = text.split('');

        return chars.map((char, i) => {
            const ratio = i / (chars.length - 1 || 1);
            const r = Math.round(start.r + (end.r - start.r) * ratio);
            const g = Math.round(start.g + (end.g - start.g) * ratio);
            const b = Math.round(start.b + (end.b - start.b) * ratio);
            return `<span style="color:rgb(${r},${g},${b})">${char === ' ' ? '&nbsp;' : escapeHtml(char)}</span>`;
        }).join('');
    }

    // Convert hex color to RGB object
    function hexToRgb(hex) {
        const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
        return result ? {
            r: parseInt(result[1], 16),
            g: parseInt(result[2], 16),
            b: parseInt(result[3], 16)
        } : {r: 136, g: 136, b: 136};
    }

    // Update both status bars
    function updateStatusBars() {
        updateLeftStatusBar();
        updateRightStatusBar();
        applyPrivateModeStatusStyling();
    }

    // Update status bar data from server response
    // Server sends: { left: { time: {...}, channel: {...} }, right: { action_text: '...', presence: {...} } }
    function updateStatusBarFromServer(statusData) {
        if (!statusData) return;

        // Handle LEFT status bar data (channel, time, moon phase)
        if (statusData.left) {
            const left = statusData.left;

            // Update game time from nested structure
            if (left.time) {
                gameTimeData = {
                    hour: left.time.hour ?? gameTimeData.hour,
                    formatted: left.time.formatted || gameTimeData.formatted,
                    time_of_day: left.time.time_of_day || gameTimeData.time_of_day,
                    season: left.time.season || gameTimeData.season,
                    is_historical: left.time.is_historical ?? gameTimeData.is_historical
                };
            }

            // Update time gradient
            if (left.time_gradient) {
                gameTimeData.gradient = left.time_gradient;
            }

            // Update channel info
            if (left.channel) {
                currentChannelName = left.channel.display || left.channel.name || currentChannelName;
            }

            if (left.private_mode !== undefined) {
                privateModeActive = !!left.private_mode;
            }
        }

        // Handle RIGHT status bar data (action, presence)
        if (statusData.right) {
            const right = statusData.right;

            // Update character status/action
            if (right.action_text !== undefined) {
                characterStatusLine = right.action_text || '';
            }

            // Update presence (AFK, GTG, etc.)
            if (right.presence) {
                characterPresence = right.presence;
            }
        }

        // Legacy format support (flat structure)
        if (statusData.game_time) {
            gameTimeData = {
                hour: statusData.game_time.hour ?? gameTimeData.hour,
                formatted: statusData.game_time.formatted || gameTimeData.formatted,
                sunrise_hour: statusData.game_time.sunrise_hour || gameTimeData.sunrise_hour,
                sunset_hour: statusData.game_time.sunset_hour || gameTimeData.sunset_hour
            };
        }
        if (statusData.weather) {
            weatherData = {
                condition: statusData.weather.condition,
                temperature_f: statusData.weather.temperature_f,
                temperature_c: statusData.weather.temperature_c,
                intensity: statusData.weather.intensity,
                is_outdoor: statusData.weather.is_outdoor
            };
            // Apply visual weather effects based on condition and outdoor status
            applyWeatherEffects(statusData.weather);
        }
        // Track HP changes from status bar for blood effects + status bar display
        if (statusData.combat) {
            combatStatusData = statusData.combat;
            onCharacterHpUpdate(statusData.combat.current_hp, statusData.combat.max_hp);
        } else {
            combatStatusData = null;
        }
        if (statusData.character_status !== undefined) {
            characterStatusLine = statusData.character_status || '';
        }

        if (statusData.private_mode !== undefined) {
            privateModeActive = !!statusData.private_mode;
        }

        // Refresh the status bars with new data
        updateStatusBars();
    }

    function scrollToBottom(el) {
        if (el) {
            el.scrollTop = el.scrollHeight;
        }
    }

    function setupInputHandlers() {
        if (!messageInput) return;

        document.addEventListener('keydown', (e) => {
            // Formatting shortcuts - Ctrl+B, Ctrl+I, Ctrl+U, Ctrl+S
            if (e.ctrlKey && document.activeElement === messageInput) {
                if (e.key === 'b' || e.key === 'B') {
                    e.preventDefault();
                    handleFormat('bold');
                    return;
                }
                if (e.key === 'i' || e.key === 'I') {
                    e.preventDefault();
                    handleFormat('italic');
                    return;
                }
                if (e.key === 'u' || e.key === 'U') {
                    e.preventDefault();
                    handleFormat('underline');
                    return;
                }
                if (e.key === 's' || e.key === 'S') {
                    e.preventDefault();
                    handleFormat('strike');
                    return;
                }
            }

            // Tab to swap panes
            if (e.key === 'Tab' && !e.altKey) {
                e.preventDefault();
                tabFunction();
            }

            // Enter to send (without shift)
            if (e.key === 'Enter' && !e.shiftKey && document.activeElement === messageInput) {
                e.preventDefault();
                sendMessage();
            }

            // Escape to clear input
            if (e.key === 'Escape' && document.activeElement === messageInput) {
                messageInput.innerHTML = '';
            }

            // Up arrow for history
            if (e.key === 'ArrowUp' && !e.shiftKey && document.activeElement === messageInput) {
                const side = messageSide.value;
                if (side === 'l') {
                    // Left panel: cycle through address history (channels/PMs)
                    e.preventDefault();
                    cycleAddressHistory('up');
                } else if (messageInput.textContent.length < 2) {
                    // Right panel: command history (unchanged)
                    e.preventDefault();
                    navigateHistory('up', 'right');
                }
            }

            // Down arrow for history
            if (e.key === 'ArrowDown' && !e.shiftKey && document.activeElement === messageInput) {
                const side = messageSide.value;
                if (side === 'l') {
                    // Left panel: cycle through address history (channels/PMs)
                    e.preventDefault();
                    cycleAddressHistory('down');
                } else {
                    // Right panel: command history (unchanged)
                    e.preventDefault();
                    navigateHistory('down', 'right');
                }
            }

            // Shift+Page Up/Down for scrolling current panel
            if ((e.key === 'PageUp' || e.key === 'PageDown') && document.activeElement === messageInput) {
                const targetWindow = messageSide.value === 'l' ? lMessageWindow : rMessageWindow;
                if (targetWindow) {
                    e.preventDefault();
                    const delta = targetWindow.clientHeight * 0.8;
                    targetWindow.scrollTop += e.key === 'PageUp' ? -delta : delta;
                }
            }
        });
    }

    // Store text for each side separately
    const sideText = { l: '', r: '' };
    // Default placeholders per side
    const defaultPlaceholder = { l: 'OOC chat... Tab to swap to Roleplay', r: 'Say, emote, pose... Tab to swap to OOC' };
    // Last-sent command per side (overrides default placeholder)
    const lastSent = { l: '', r: '' };

    // ====== GHOST DRAFT TEXT ======
    // When switching panes, save current text as ghost draft in the pane being left
    function updateGhostDraft(side, text) {
        const draftEl = document.getElementById(side === 'l' ? 'ldraft' : 'rdraft');
        if (draftEl) {
            if (text && text.trim().length > 0) {
                draftEl.textContent = text;
                draftEl.classList.add('visible');
            } else {
                draftEl.textContent = '';
                draftEl.classList.remove('visible');
            }
        }
    }

    function clearGhostDraft(side) {
        const draftEl = document.getElementById(side === 'l' ? 'ldraft' : 'rdraft');
        if (draftEl) {
            draftEl.classList.remove('visible');
            // Keep the text but fade it - clear on next switch
        }
    }

    // Update inactive side's placeholder with last sent text or default
    function updateInactivePlaceholder() {
        const currentSide = messageSide.value;
        const lPlaceholder = document.getElementById('linactivePlaceholder');
        const rPlaceholder = document.getElementById('rinactivePlaceholder');
        if (currentSide === 'l') {
            // Left is active, right is inactive - show right's last sent or default
            if (lPlaceholder) lPlaceholder.textContent = '';
            if (rPlaceholder) rPlaceholder.textContent = lastSent.r || defaultPlaceholder.r;
        } else {
            // Right is active, left is inactive - show left's last sent or default
            if (rPlaceholder) rPlaceholder.textContent = '';
            if (lPlaceholder) lPlaceholder.textContent = lastSent.l || defaultPlaceholder.l;
        }
    }

    function tabFunction() {
        const currentSide = messageSide.value;
        const inputWrapper = document.getElementById('inputwrapper');
        const currentText = messageInput.innerHTML;

        // Save current text
        sideText[currentSide] = currentText;

        // Show ghost draft of what was being typed in the pane we're leaving
        // Use textContent for the ghost draft display
        updateGhostDraft(currentSide, messageInput.textContent);

        if (currentSide === 'r') {
            // Switch to LEFT (OOC) side
            messageSide.value = 'l';
            inputWrapper.style.left = '0';
            inputWrapper.style.right = '';
            messageInput.innerHTML = sideText.l;
            messageInput.setAttribute('data-placeholder', lastSent.l || defaultPlaceholder.l);
            // Clear the ghost draft on the side we're switching TO
            clearGhostDraft('l');
            // Update toolbar status for OOC mode
            updateToolbarStatus('l');
        } else {
            // Switch to RIGHT (RP) side
            messageSide.value = 'r';
            inputWrapper.style.left = '';
            inputWrapper.style.right = '0';
            messageInput.innerHTML = sideText.r;
            messageInput.setAttribute('data-placeholder', lastSent.r || defaultPlaceholder.r);
            // Clear the ghost draft on the side we're switching TO
            clearGhostDraft('r');
            // Update toolbar status for RP mode
            updateToolbarStatus('r');
        }

        resizeClient();
        messageInput.focus();
        updateInactivePlaceholder();

        // Move cursor to end of contenteditable
        const range = document.createRange();
        const sel = window.getSelection();
        if (messageInput.childNodes.length > 0) {
            range.selectNodeContents(messageInput);
            range.collapse(false);
            sel.removeAllRanges();
            sel.addRange(range);
        }
    }

    let selectedColor = 'c'; // Default cyan

    function setupToolbar() {
        // ====== STYLE DROPDOWN ======
        setupStyleDropdown();

        // ====== EMOJI PICKER (full popup) ======
        setupEmojiPicker();

        // ====== GRADIENT PICKER (in toolbar for legacy support) ======
        setupGradientPicker();
    }

    // Style dropdown setup - consolidates B/I/U/S, color, gradient, emoji
    function setupStyleDropdown() {
        const styleMenu = document.getElementById('styleDropdownMenu');
        if (!styleMenu) return;

        // Get all style buttons (in status bars)
        const leftStyleBtn = document.querySelector('#leftToolbar .toolbar-style');
        const rightStyleBtn = document.querySelector('#rightToolbar .toolbar-style');
        const leftSettingsBtn = document.querySelector('#leftToolbar .toolbar-settings');
        const rightSettingsBtn = document.querySelector('#rightToolbar .toolbar-settings');

        // Toggle dropdown from either status bar's style button
        function toggleStyleMenu(e, btn) {
            e.preventDefault();
            e.stopPropagation();

            // Position the menu near the clicked button
            const rect = btn.getBoundingClientRect();
            styleMenu.style.bottom = (window.innerHeight - rect.top + 4) + 'px';
            styleMenu.style.right = (window.innerWidth - rect.right) + 'px';
            styleMenu.style.left = 'auto';

            styleMenu.classList.toggle('visible');

            // Render quick emoji grid when opened
            if (styleMenu.classList.contains('visible')) {
                renderQuickEmojis();
            }
        }

        if (leftStyleBtn) {
            leftStyleBtn.addEventListener('click', (e) => toggleStyleMenu(e, leftStyleBtn));
        }
        if (rightStyleBtn) {
            rightStyleBtn.addEventListener('click', (e) => toggleStyleMenu(e, rightStyleBtn));
        }

        // Settings buttons open settings page
        function handleSettingsClick(e) {
            e.preventDefault();
            e.stopPropagation();
            // Call the global openSettings function
            if (window.openSettings) {
                window.openSettings();
            }
        }

        if (leftSettingsBtn) {
            leftSettingsBtn.addEventListener('click', handleSettingsClick);
        }
        if (rightSettingsBtn) {
            rightSettingsBtn.addEventListener('click', handleSettingsClick);
        }

        // Format buttons inside dropdown (B, I, U, S)
        const formatBtns = styleMenu.querySelectorAll('.style-btn[data-format]');
        formatBtns.forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                handleFormat(btn.dataset.format);
                // Don't close dropdown - allow multiple format operations
            });
        });

        // Color swatches inside dropdown
        const swatches = styleMenu.querySelectorAll('.color-swatch');
        swatches.forEach(swatch => {
            swatch.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                selectedColor = swatch.dataset.color;
                applyColor(selectedColor);
                styleMenu.classList.remove('visible');
            });
        });

        // Custom color in style dropdown
        const customColor = document.getElementById('styleCustomColor');
        if (customColor) {
            customColor.addEventListener('input', (e) => {
                e.stopPropagation();
            });
            customColor.addEventListener('change', (e) => {
                e.stopPropagation();
                applyColor(customColor.value);
                styleMenu.classList.remove('visible');
            });
        }

        // "More Emoji" button opens full emoji picker
        const moreBtn = document.getElementById('emojiMoreBtn');
        if (moreBtn) {
            moreBtn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                styleMenu.classList.remove('visible');
                toggleEmojiPicker();
            });
        }

        // Click outside to close style dropdown
        document.addEventListener('click', (e) => {
            if (styleMenu.classList.contains('visible')) {
                // Check if click is on any toolbar style button
                const isOnStyleBtn = e.target.closest('.toolbar-style');
                if (!styleMenu.contains(e.target) && !isOnStyleBtn) {
                    styleMenu.classList.remove('visible');
                }
            }
        });

        // Initialize inline gradient picker
        setupInlineGradientPicker();
    }

    // Render quick emoji grid (recent/default emojis)
    function renderQuickEmojis() {
        const grid = document.getElementById('emojiQuickGrid');
        if (!grid) return;

        // Show recent emojis (first 16) or defaults
        const defaultEmojis = ['😀', '😊', '😂', '❤️', '👍', '👋', '🎉', '✨',
                               '🔥', '💯', '😎', '🤔', '😢', '😡', '🙏', '💪'];
        const emojis = recentEmojis.length > 0
            ? recentEmojis.slice(0, 16)
            : defaultEmojis;

        grid.innerHTML = emojis.map(emoji =>
            `<div class="emoji-item" data-emoji="${emoji}">${emoji}</div>`
        ).join('');

        // Add click handlers
        grid.querySelectorAll('.emoji-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                insertEmoji(item.dataset.emoji);
                document.getElementById('styleDropdownMenu')?.classList.remove('visible');
            });
        });
    }

    // Setup inline gradient picker within style dropdown
    function setupInlineGradientPicker() {
        const container = document.getElementById('gradientPickerInline');
        if (!container) return;

        if (typeof GradientPicker === 'undefined') {
            // GradientPicker not loaded - show placeholder
            container.innerHTML = '<span style="color:#666;font-size:11px;">Select text first, then choose gradient</span>';
            return;
        }

        // Create inline gradient picker
        try {
            new GradientPicker({
                buttonContainer: container,
                apiEndpoint: '/api/gradients',
                position: 'inline',
                onSelect: (gradient) => {
                    applyGradientToSelection(gradient);
                    document.getElementById('styleDropdownMenu')?.classList.remove('visible');
                }
            });
        } catch (e) {
            console.warn('Failed to initialize inline gradient picker:', e);
            container.innerHTML = '<span style="color:#666;font-size:11px;">Gradient unavailable</span>';
        }
    }

