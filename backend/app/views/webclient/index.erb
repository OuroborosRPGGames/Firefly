    window.openWardrobePopout = openWardrobePopout;

    // Open descriptions editor as a pop-out window
    function openDescriptionsPopout(charId) {
        const id = charId || characterId;
        const width = 1000;
        const height = 750;
        const left = (screen.width - width) / 2;
        const top = (screen.height - height) / 2;

        window.open(
            `/characters/${id}/descriptions?popout=true`,
            'descriptionsPopout',
            `width=${width},height=${height},left=${left},top=${top},menubar=no,toolbar=no,location=no,status=no,resizable=yes,scrollbars=yes`
        );
