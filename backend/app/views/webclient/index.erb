    function getCurrentTime() {
        return new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
    }

    function formatTimestamp(dateString) {
        if (!dateString) return new Date().toLocaleString();
        const date = new Date(dateString);
        if (Number.isNaN(date.getTime())) return new Date().toLocaleString();
        return date.toLocaleString();
    }

    // Format damage summary with colored markup
    // Input: "(Lin dmg Bob for 8[2HP]; Bob KO'd)"
    // Output: styled HTML with colored names, damage numbers, and HP
    function formatDamageSummary(text) {
        if (!text) return '';
        // Escape the text first
        let s = escapeHtml(text);
        // Color damage entries: "Name dmg Target for RAW[XHP]"
        s = s.replace(/(\w[\w\s]*?) dmg (\w[\w\s]*?) for (\d+)\[(\d+)HP\]/g,
            '<span class="dmg-actor">$1</span> dmg <span class="dmg-target">$2</span> for <span class="dmg-raw">$3</span>[<span class="dmg-hp">$4</span>HP]'
        );
        // Color status effects: "Name effect"
        s = s.replace(/(\w+) KO'd/g, '<span class="dmg-target">$1</span> <span class="dmg-ko">KO\'d</span>');
        return s;
    }

    // Safe HTML sanitization matching DraftCharacterPreviewService#safe_html
    // Allows: span (with style for color/font-weight/font-style/text-decoration), font (with color), b, i, u, s, strong, em
    function safeHtml(text) {
        if (!text) return '';
        let s = escapeHtml(text);
        // Note: escapeHtml uses div.textContent/innerHTML which escapes < > & but NOT "
        // So after escaping, quotes remain as literal " not &quot;
        // Restore span with safe style attributes
        s = s.replace(/&lt;span style="((?:(?:color|font-weight|font-style|text-decoration):[^"<>]+;?\s*)+)"&gt;/gi, '<span style="$1">');
        s = s.replace(/&lt;\/span&gt;/g, '</span>');
        // Restore font with color attribute
        s = s.replace(/&lt;font color="(#[0-9a-fA-F]{3,6}|[a-zA-Z]+)"&gt;/gi, '<font color="$1">');
        s = s.replace(/&lt;\/font&gt;/g, '</font>');
        // Restore simple formatting tags
        ['b', 'i', 'u', 's', 'strong', 'em'].forEach(tag => {
            s = s.replace(new RegExp(`&lt;${tag}&gt;`, 'g'), `<${tag}>`);
            s = s.replace(new RegExp(`&lt;\/${tag}&gt;`, 'g'), `</${tag}>`);
        });
        return s;
    }

