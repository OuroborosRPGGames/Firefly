    // Update toolbar status - time updates
    function updateLeftStatus() {
        const timeEl = document.getElementById('toolbarTime');
        if (timeEl) {
            if (delveActive && delveTimeRemaining !== null) {
                // Show delve time remaining instead of clock
                const displayTime = getDelveTimeDisplay();
                timeEl.textContent = displayTime;
                timeEl.classList.add('delve-time');
