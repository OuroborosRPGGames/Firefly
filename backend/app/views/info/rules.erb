<!-- Page Banner -->
<section class="page-banner" style="background-image: url('/images/library.jpg');">
  <div class="container mx-auto px-4">
    <div class="page-banner-content">
      <nav aria-label="breadcrumb">
        <div class="breadcrumbs text-sm">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/info">Game Info</a></li>
            <li>Rules</li>
          </ul>
        </div>
      </nav>
      <h1>Community Rules</h1>
    </div>
  </div>
</section>

<section class="py-12">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Main Content -->
      <div class="lg:col-span-8">
        <div class="card bg-base-200 mb-6">
          <div class="card-body">
            <p class="text-lg mb-6">
              Welcome to <%= game_name %>! Our community thrives on mutual respect and collaborative storytelling.
              Please review these guidelines to ensure everyone has a positive experience.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-1-circle mr-2"></i>Respect All Players</h3>
            <p class="text-base-content/70 mb-6">
              Treat all players with respect and courtesy, both in and out of character. Harassment, discrimination,
              or hostile behavior toward other players will not be tolerated. Remember that behind every character
              is a real person.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-2-circle mr-2"></i>Age Requirement</h3>
            <p class="text-base-content/70 mb-6">
              All players must be 18 years of age or older. All characters must also be 18+ years old.
              This is strictly enforced and violations will result in immediate account termination.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-3-circle mr-2"></i>Consent in Roleplay</h3>
            <p class="text-base-content/70 mb-6">
              Always obtain OOC (out of character) consent before involving another player's character in
              significant plot events, especially those that could result in harm, death, or other permanent
              consequences. When in doubt, ask first.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-4-circle mr-2"></i>Keep IC and OOC Separate</h3>
            <p class="text-base-content/70 mb-6">
              Maintain a clear separation between in-character (IC) actions and out-of-character (OOC) interactions.
              Do not let IC conflicts spill over into OOC hostility, and do not use OOC knowledge to unfairly
              advantage your character.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-5-circle mr-2"></i>Quality Over Quantity</h3>
            <p class="text-base-content/70 mb-6">
              We value thoughtful, well-written roleplay. Take time to craft your posts and give others
              something to respond to. One-liners are generally discouraged in scene roleplay, though
              casual chat is more flexible.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-6-circle mr-2"></i>Content Guidelines</h3>
            <p class="text-base-content/70 mb-6">
              Mature themes may be explored in designated areas, but extreme content (torture, excessive gore,
              etc.) should be handled with care and proper warnings. Always check area-specific rules and
              respect others' boundaries.
            </p>

            <h3 class="text-lg text-primary font-bold mb-3"><i class="bi bi-7-circle mr-2"></i>Staff Decisions are Final</h3>
            <p class="text-base-content/70 mb-0">
              Game staff work hard to maintain a fair and enjoyable environment. If you disagree with a
              decision, you may respectfully appeal through proper channels, but ultimately staff decisions
              are final.
            </p>
          </div>
        </div>

        <div class="card bg-base-200">
          <div class="card-body">
            <h3 class="card-title mb-4">
              <i class="bi bi-shield-check mr-2"></i>Enforcement
            </h3>
            <p class="text-base-content/70 mb-3">Violations of these rules may result in:</p>
            <ul class="text-base-content/70 mb-4 list-disc list-inside">
              <li>Verbal warning</li>
              <li>Temporary suspension</li>
              <li>Permanent ban</li>
            </ul>
            <p class="text-base-content/70 mb-0">
              The severity of the consequence depends on the nature and frequency of the violation.
              Serious violations may result in immediate permanent bans.
            </p>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-4">
        <div class="card bg-base-200 mb-4">
          <div class="card-body p-0">
            <div class="p-4 border-b border-base-content/10">
              <h3 class="font-bold text-sm">
                <i class="bi bi-info-circle mr-2"></i>Quick Links
              </h3>
            </div>
            <ul class="menu">
              <li><a href="/info/getting-started"><i class="bi bi-rocket-takeoff mr-2 text-primary"></i>Getting Started</a></li>
              <li><a href="/world/lore"><i class="bi bi-journal-text mr-2 text-primary"></i>World Lore</a></li>
              <li><a href="/world/locations"><i class="bi bi-map mr-2 text-primary"></i>Locations</a></li>
            </ul>
          </div>
        </div>

        <div class="card bg-base-200">
          <div class="card-body">
            <h3 class="font-bold text-sm mb-3">
              <i class="bi bi-question-circle mr-2"></i>Need Help?
            </h3>
            <p class="text-base-content/70 text-sm mb-3">
              If you have questions about the rules or need to report a violation, please contact staff.
            </p>
            <a href="/contact" class="btn btn-ghost btn-sm btn-block">
              <i class="bi bi-envelope mr-1"></i>Contact Staff
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
