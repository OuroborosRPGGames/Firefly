<div class="h-[calc(100vh-8rem)] flex flex-col">
  <!-- Game Header -->
  <div class="navbar bg-base-100 rounded-t-lg border-b border-base-300 px-4">
    <div class="navbar-start">
      <span class="text-lg font-bold"><%= h @character.full_name %></span>
      <span class="ml-4 text-sm text-base-content/70">in <%= h(@room&.name || 'The Void') %></span>
    </div>
    <div class="navbar-end">
      <div class="flex items-center gap-4">
        <!-- Health/Energy indicators -->
        <div class="flex items-center gap-2">
          <span class="text-xs">HP</span>
          <progress class="progress progress-success w-20" value="<%= @character_instance&.health || 100 %>" max="100"></progress>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-xs">EN</span>
          <progress class="progress progress-info w-20" value="<%= @character_instance&.mana || 100 %>" max="100"></progress>
        </div>
        <!-- Settings -->
        <button class="btn btn-ghost btn-circle btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Main Game Area -->
  <div class="flex-1 flex overflow-hidden">
    <!-- Left Panel - Game Output -->
    <div class="flex-1 flex flex-col bg-base-100">
      <!-- Tabs -->
      <div class="tabs tabs-boxed bg-base-200" x-data="{ activeTab: 'main' }">
        <a class="tab" :class="{ 'tab-active': activeTab === 'main' }" @click="activeTab = 'main'">Main</a>
        <a class="tab" :class="{ 'tab-active': activeTab === 'combat' }" @click="activeTab = 'combat'">Combat</a>
        <a class="tab" :class="{ 'tab-active': activeTab === 'social' }" @click="activeTab = 'social'">Social</a>
        <a class="tab" :class="{ 'tab-active': activeTab === 'system' }" @click="activeTab = 'system'">System</a>
      </div>
      
      <!-- Message Display Area -->
      <div id="game-output" class="flex-1 overflow-y-auto p-4 mud-terminal">
        <div class="space-y-2">
          <!-- Room Description -->
          <div class="mb-4 p-3 bg-base-200 rounded">
            <h3 class="font-bold text-primary mb-2"><%= h(@room&.name || 'The Void') %></h3>
            <p class="text-sm"><%= h(@room&.long_description || @room&.short_description || 'You float in an endless void.') %></p>
            <% spatial_exits = @room&.passable_spatial_exits || [] %>
            <% if spatial_exits.any? %>
              <div class="mt-2 text-sm text-base-content/70">
                Exits: <%= spatial_exits.map { |e| e[:direction].to_s.capitalize }.join(', ') %>
              </div>
            <% end %>
          </div>

          <!-- Unread News Notification -->
          <% if @unread_news && @unread_news.values.sum > 0 %>
            <div class="mb-4 p-3 bg-warning/20 border border-warning rounded">
              <span class="font-bold text-warning">You have unread news!</span>
              <span class="text-sm ml-2">
                <%
                  parts = []
                  parts << "#{@unread_news['announcement']} announcements" if @unread_news['announcement']&.positive?
                  parts << "#{@unread_news['ic']} IC news" if @unread_news['ic']&.positive?
                  parts << "#{@unread_news['ooc']} OOC news" if @unread_news['ooc']&.positive?
                %>
                <%= parts.join(', ') %>.
                Type <code class="bg-base-300 px-1 rounded">news</code> to view.
              </span>
            </div>
          <% end %>
          
          <!-- Messages -->
          <% if @messages && @messages.any? %>
            <% @messages.each do |msg| %>
              <div class="message flex items-start gap-2">
                <span class="text-primary font-bold"><%= h msg.character&.name || 'System' %>:</span>
                <span class="flex-1"><%= msg.content %></span>
                <span class="text-xs text-base-content/50"><%= msg.created_at&.strftime('%H:%M') %></span>
              </div>
            <% end %>
          <% else %>
            <div class="text-base-content/50 italic">No messages yet. Start your adventure!</div>
          <% end %>
        </div>
      </div>
      
      <!-- Input Area -->
      <div class="p-4 border-t border-base-300">
        <form id="command-form" class="flex gap-2">
          <input type="text" 
                 id="command-input"
                 placeholder="Enter command or message..." 
                 class="input input-bordered flex-1"
                 autocomplete="off">
          <button type="submit" class="btn btn-primary">Send</button>
        </form>
        
        <!-- Quick Commands -->
        <div class="flex gap-2 mt-2">
          <button onclick="sendCommand('look')" class="btn btn-xs btn-ghost">look</button>
          <button onclick="sendCommand('inventory')" class="btn btn-xs btn-ghost">inventory</button>
          <button onclick="sendCommand('who')" class="btn btn-xs btn-ghost">who</button>
          <button onclick="sendCommand('help')" class="btn btn-xs btn-ghost">help</button>
        </div>
      </div>
    </div>
    
    <!-- Right Panel - Info/Map -->
    <div class="w-80 border-l border-base-300 bg-base-200 p-4 hidden lg:block overflow-y-auto">
      <!-- Mini Map -->
      <div class="card bg-base-100 mb-4">
        <div class="card-body p-4">
          <h3 class="font-bold mb-2">Map</h3>
          <div class="grid grid-cols-3 gap-1 text-center">
            <div></div>
            <div class="btn btn-xs btn-ghost">N</div>
            <div></div>
            <div class="btn btn-xs btn-ghost">W</div>
            <div class="btn btn-xs btn-primary">[X]</div>
            <div class="btn btn-xs btn-ghost">E</div>
            <div></div>
            <div class="btn btn-xs btn-ghost">S</div>
            <div></div>
          </div>
        </div>
      </div>
      
      <!-- Room Occupants -->
      <div class="card bg-base-100 mb-4">
        <div class="card-body p-4">
          <h3 class="font-bold mb-2">Here Now</h3>
          <div class="space-y-1 text-sm">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-success rounded-full"></div>
              <span>You (<%= h @character.full_name %>)</span>
            </div>
            <!-- Other characters would be listed here -->
          </div>
        </div>
      </div>
      
      <!-- Inventory Quick View -->
      <div class="card bg-base-100">
        <div class="card-body p-4">
          <h3 class="font-bold mb-2">Quick Inventory</h3>
          <div class="space-y-1 text-sm">
            <div>• Basic Clothes</div>
            <div>• Traveler's Pack</div>
            <div>• 10 gold coins</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- WebSocket and game logic -->
<script>
// Initialize game connection
let gameSocket = null;
let reconnectAttempts = 0;

function initGameConnection() {
  // In production, this would be a WebSocket connection
  console.log('Initializing game connection...');
  
  // Simulate receiving messages
  setTimeout(() => {
    addMessage('System', 'Welcome to the game! Type "help" for commands.');
  }, 1000);
}

function addMessage(sender, content, type = 'normal') {
  const output = document.getElementById('game-output');
  const messageDiv = document.createElement('div');
  messageDiv.className = 'message flex items-start gap-2';
  
  const time = new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
  
  messageDiv.innerHTML = `
    <span class="text-primary font-bold">${sender}:</span>
    <span class="flex-1">${content}</span>
    <span class="text-xs text-base-content/50">${time}</span>
  `;
  
  output.querySelector('.space-y-2').appendChild(messageDiv);
  output.scrollTop = output.scrollHeight;
}

function sendCommand(cmd) {
  const input = document.getElementById('command-input');
  if (cmd) {
    input.value = cmd;
  }
  
  const command = input.value.trim();
  if (!command) return;
  
  // Display the command
  addMessage('<%= h @character.full_name %>', command);
  
  // Send to server via API
  fetch('/api/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
    },
    body: JSON.stringify({ content: command, type: 'command' })
  })
  .then(response => response.json())
  .then(data => {
    if (data.error) {
      addMessage('System', data.error, 'error');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    addMessage('System', 'Failed to send command', 'error');
  });
  
  input.value = '';
}

// Form submission
document.getElementById('command-form').addEventListener('submit', (e) => {
  e.preventDefault();
  sendCommand();
});

// Initialize on page load
document.addEventListener('DOMContentLoaded', () => {
  initGameConnection();
  
  // Focus input
  document.getElementById('command-input').focus();
  
  // Command history
  let commandHistory = [];
  let historyIndex = -1;
  
  document.getElementById('command-input').addEventListener('keydown', (e) => {
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (historyIndex < commandHistory.length - 1) {
        historyIndex++;
        e.target.value = commandHistory[commandHistory.length - 1 - historyIndex];
      }
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (historyIndex > 0) {
        historyIndex--;
        e.target.value = commandHistory[commandHistory.length - 1 - historyIndex];
      } else {
        historyIndex = -1;
        e.target.value = '';
      }
    }
  });
  
  // Save commands to history
  const originalSend = window.sendCommand;
  window.sendCommand = function(cmd) {
    const input = document.getElementById('command-input');
    const command = cmd || input.value.trim();
    if (command) {
      commandHistory.push(command);
      if (commandHistory.length > 50) commandHistory.shift();
      historyIndex = -1;
    }
    originalSend(cmd);
  };
});
</script>