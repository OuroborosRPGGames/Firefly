<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @title || game_name %></title>

  <!-- Tailwind + DaisyUI -->
  <link rel="stylesheet" href="/css/daisyui.css">
  <link rel="stylesheet" href="/css/tailwind.css">

  <!-- Bootstrap Icons (standalone) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/firefly.css">
  <link rel="stylesheet" href="/css/wardrobe.css">
  <link rel="stylesheet" href="/css/descriptions.css?v=3">
  <link rel="stylesheet" href="/css/gradient-components.css">

  <style>
    body {
      background: #000;
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
    }

    .popout-header {
      background: rgba(0, 0, 0, 0.3);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      padding: 0.5rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .popout-header h1 {
      font-size: 1.2rem;
      margin: 0;
      color: #fff;
    }

    .popout-header .character-name {
      color: #adb5bd;
      font-size: 0.9rem;
    }

    .card-glass {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
    }
  </style>
</head>
<body class="popout-mode">
  <header class="popout-header">
    <div>
      <h1><i class="bi bi-<%= @popout_icon || 'briefcase' %> mr-2"></i><%= @title || game_name %></h1>
      <% if @character %>
        <span class="character-name"><%= h @character.full_name %></span>
      <% end %>
    </div>
    <button type="button" class="btn btn-sm btn-ghost" onclick="window.close()">
      <i class="bi bi-x-lg"></i>
    </button>
  </header>

  <main>
    <%= yield %>
  </main>

  <script src="/js/utils.js"></script>
  <script src="/js/modal-system.js"></script>
  <script src="/js/gradient-ciede2000.js"></script>
  <script src="/js/gradient-creator.js?v=3"></script>
  <script src="/js/gradient-picker.js?v=4"></script>
</body>
</html>
