<% @page_title = 'New Pattern - Admin' %>
<% @breadcrumbs = [{ label: 'Admin', path: '/admin' }, { label: 'Pattern Designer', path: '/admin/patterns' }, { label: 'New' }] %>

<div class="container mx-auto px-4 py-6">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <!-- Sidebar -->
    <div class="lg:col-span-2">
      <div class="card bg-base-200 shadow-lg">
        <div class="card-body p-0">
          <div class="flex items-center gap-2 px-4 py-3 border-b border-base-content/10">
            <i class="bi bi-shield-lock text-primary"></i>
            <h5 class="font-semibold text-base-content">Admin Console</h5>
          </div>
          <%= partial 'admin/sidebar' %>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="lg:col-span-10">
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <i class="bi bi-plus-circle"></i>New Pattern
        </h2>
        <a href="/admin/patterns" class="btn btn-outline btn-neutral">
          <i class="bi bi-arrow-left"></i>Back to Patterns
        </a>
      </div>

      <%= partial 'admin/patterns/form' %>
    </div>
  </div>
</div>
