<%
  online_count = CharacterInstance.where(online: true).count rescue 0
  restart_status = ServerRestartService.status rescue { pending: false }
%>

<dialog id="restart_server_modal" class="modal">
  <div class="modal-box bg-base-200 max-w-md">
    <h3 class="font-bold text-lg flex items-center gap-2">
      <i class="bi bi-arrow-repeat"></i>
      Restart Server
    </h3>

    <div class="mt-4">
      <div class="alert alert-warning text-sm mb-4">
        <i class="bi bi-exclamation-triangle"></i>
        <span><strong><%= online_count %></strong> player<%= online_count == 1 ? '' : 's' %> currently online</span>
      </div>

      <form action="/admin/server/restart" method="post" id="restart_form">
        <%== csrf_tag if respond_to?(:csrf_tag) %>

        <div class="form-control mb-4">
          <label class="label"><span class="label-text font-medium">Restart Type</span></label>
          <div class="flex flex-col gap-2">
            <label class="label cursor-pointer justify-start gap-3">
              <input type="radio" name="type" value="phased" class="radio radio-sm radio-primary" checked />
              <div>
                <span class="font-medium">Phased</span>
                <p class="text-xs text-base-content/60">Workers replaced one at a time. Near-zero downtime.</p>
              </div>
            </label>
            <label class="label cursor-pointer justify-start gap-3">
              <input type="radio" name="type" value="full" class="radio radio-sm radio-error" />
              <div>
                <span class="font-medium">Full</span>
                <p class="text-xs text-base-content/60">Complete restart. All connections drop for ~3-5 seconds.</p>
              </div>
            </label>
          </div>
        </div>

        <div class="form-control mb-4">
          <label class="label"><span class="label-text font-medium">Countdown</span></label>
          <select name="delay" class="select select-bordered select-sm w-full">
            <option value="0">Immediately</option>
            <option value="30">30 seconds</option>
            <option value="60" selected>1 minute</option>
            <option value="120">2 minutes</option>
            <option value="300">5 minutes</option>
          </select>
        </div>

        <div class="modal-action">
          <button type="button" class="btn btn-ghost btn-sm" onclick="document.getElementById('restart_server_modal').close()">Cancel</button>
          <button type="submit" class="btn btn-error btn-sm" onclick="return confirm('Are you sure? This will restart the server.')">
            <i class="bi bi-arrow-repeat"></i>
            Restart Server
          </button>
        </div>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
