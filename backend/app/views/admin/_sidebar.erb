<!-- Server Restart Button -->
<div class="p-2 border-b border-base-300" id="restart-button-container">
  <button class="btn btn-outline btn-error btn-sm w-full gap-1" onclick="document.getElementById('restart_server_modal').showModal()" id="restart-btn">
    <i class="bi bi-arrow-repeat"></i>
    <span>Restart Server</span>
  </button>
</div>

<script>
function cancelRestart() {
  fetch('/admin/server/restart/cancel', { method: 'POST' })
    .then(() => location.reload())
    .catch(() => location.reload());
}

(function() {
  let pollTimer = null;

  function pollRestartStatus() {
    fetch('/admin/server/restart/status')
      .then(r => r.json())
      .then(data => {
        const container = document.getElementById('restart-button-container');
        if (!container) return;

        if (data.pending) {
          const mins = Math.floor(data.remaining_seconds / 60);
          const secs = data.remaining_seconds % 60;
          const timeStr = mins > 0 ? `${mins}m ${secs}s` : `${secs}s`;

          container.innerHTML = `
            <div class="flex items-center gap-2 p-2">
              <span class="text-error text-sm font-medium flex-1">
                <i class="bi bi-arrow-repeat animate-spin"></i>
                Restart in ${timeStr}
              </span>
              <button type="button" class="btn btn-ghost btn-xs" onclick="cancelRestart()">Cancel</button>
            </div>
          `;

          if (!pollTimer) {
            pollTimer = setInterval(pollRestartStatus, 2000);
          }
        } else {
          if (!document.getElementById('restart-btn')) {
            container.innerHTML = `
              <button class="btn btn-outline btn-error btn-sm w-full gap-1" onclick="document.getElementById('restart_server_modal').showModal()" id="restart-btn">
                <i class="bi bi-arrow-repeat"></i>
                <span>Restart Server</span>
              </button>
            `;
          }
          if (pollTimer) {
            clearInterval(pollTimer);
            pollTimer = null;
          }
        }
      })
      .catch(() => {});
  }

  pollRestartStatus();
})();
</script>

<%= partial 'admin/restart_modal' %>

<div class="flex flex-col">
  <% sections.each do |key, section| %>
    <%
      # Check permission requirements
      next if section[:requires] && !current_user&.send(section[:requires])

      # Determine if section should be open (check if current path matches any section path)
      is_active = section[:paths] && section[:paths].any? { |p| request.path.start_with?(p) }
    %>

    <!-- Collapsible section -->
      <div class="collapse collapse-arrow bg-base-200/50 rounded-none border-b border-base-300">
        <input type="checkbox" class="peer" <%= 'checked' if is_active %> />
        <div class="collapse-title flex items-center gap-2 text-sm font-medium py-2 min-h-0 <%= is_active ? 'text-primary' : 'text-base-content' %>">
          <i class="bi bi-<%= section[:icon] %>"></i>
          <span><%= section[:label] %></span>
        </div>
        <div class="collapse-content px-0 pb-0">
          <% section[:items].each do |item| %>
            <%
              # Strip hash from path for comparison
              item_path = item[:path].split('#').first
              item_active = item[:exact] ? request.path == item_path : request.path.start_with?(item_path)
            %>
            <a href="<%= item[:path] %>"
               class="flex items-center gap-2 pl-8 pr-4 py-2 text-sm hover:bg-base-300 transition-colors <%= item_active ? 'bg-primary/20 text-primary border-l-2 border-primary' : 'text-base-content/80' %>">
              <i class="bi bi-<%= item[:icon] %> text-xs"></i>
              <span><%= item[:label] %></span>
              <% if item[:badge] && open_ticket_count > 0 %>
                <span class="badge badge-error badge-sm ml-auto"><%= open_ticket_count %></span>
              <% end %>
            </a>
          <% end %>
        </div>
      </div>
  <% end %>
</div>
