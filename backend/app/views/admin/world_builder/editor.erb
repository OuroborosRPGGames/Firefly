      <!-- Earth Mode -->
      <div class="fieldset mb-3">
        <label class="label cursor-pointer justify-start gap-3">
          <input type="checkbox" id="city-earth-mode" class="checkbox checkbox-sm checkbox-info">
          <div>
            <span class="fieldset-legend">Earth Mode</span>
            <p class="text-xs text-base-content/60">Use realistic street names from real-world location</p>
          </div>
        </label>
      </div>
      <div id="earth-mode-fields" class="bg-base-300 p-3 rounded mb-3" style="display:none;">
        <div class="grid grid-cols-2 gap-2 mb-2">
          <div class="fieldset">
            <label class="label py-1"><span class="fieldset-legend text-xs">Latitude</span></label>
            <input type="number" step="0.0001" id="city-latitude" class="input input-sm" placeholder="40.7128">
          </div>
          <div class="fieldset">
            <label class="label py-1"><span class="fieldset-legend text-xs">Longitude</span></label>
            <input type="number" step="0.0001" id="city-longitude" class="input input-sm" placeholder="-74.0060">
          </div>
        </div>
        <div id="city-country-preview" class="text-sm text-info"></div>
      </div>
    </form>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button type="submit" form="city-form" class="btn btn-warning">
