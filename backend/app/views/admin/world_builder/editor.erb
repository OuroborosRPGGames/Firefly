<script>
  const WORLD_ID = <%= @world.id %>;
  const API_BASE = '/admin/world_builder/<%= @world.id %>/api';
  const CSRF_TOKEN = '<%= Rack::Utils.escape_html(csrf_token) %>';

  // Initial globe camera position: center of non-ocean traversable hexes
  <%
    # Use a fast approximate query: find a land hex to center the camera on
    # Uses the world_hexes_world_lat_lon_idx partial index (WHERE traversable = true)
    focus = WorldHex.where(world_id: @world.id).where(Sequel.lit('traversable = true'))
                    .exclude(terrain_type: 'ocean')
                    .select(:latitude, :longitude)
                    .limit(1)
                    .first
    # Fallback to any traversable hex if no land found
    focus ||= WorldHex.where(world_id: @world.id).where(Sequel.lit('traversable = true'))
                      .select(:latitude, :longitude)
                      .limit(1)
                      .first
    focus_lat = focus ? focus.latitude.to_f.round(2) : 20
    focus_lon = focus ? focus.longitude.to_f.round(2) : 0
  %>
  const INITIAL_LAT = <%= focus_lat %>;
  const INITIAL_LNG = <%= focus_lon %>;
  const GRID_LOCKED = <%= @world.grid_locked ? 'true' : 'false' %>;

  // Test mode: skip globe loading (add ?test_mode=1 to URL)
  const TEST_MODE = new URLSearchParams(window.location.search).get('test_mode') === '1';

  // Expose globals for external modules
  window.API_BASE = API_BASE;
  window.WORLD_ID = WORLD_ID;

  // Promise-based plain zone modal — used by sub-hex-editor.js
  window.showPlainZoneModal = function() {
    return new Promise((resolve, reject) => {
      const modal = document.getElementById('plainZoneModal');
      const form = document.getElementById('plain-zone-modal-form');
      const nameInput = document.getElementById('plain-zone-modal-name');
      const typeSelect = document.getElementById('plain-zone-modal-type');

      form.reset();
      nameInput.focus();

      const onSubmit = (e) => {
        e.preventDefault();
        const name = nameInput.value.trim();
        if (!name) return;
        cleanup();
        modal.close();
        resolve({ name, zoneType: typeSelect.value });
      };

      const onClose = () => {
        cleanup();
        reject(new Error('cancelled'));
      };

      function cleanup() {
        form.removeEventListener('submit', onSubmit);
        modal.removeEventListener('close', onClose);
      }

      form.addEventListener('submit', onSubmit);
      modal.addEventListener('close', onClose);
      modal.showModal();
    });
  };

  // Promise-based location modal — used by sub-hex-editor.js
  window.showLocationModal = function() {
    return new Promise((resolve, reject) => {
      const modal = document.getElementById('locationModal');
      const form = document.getElementById('location-modal-form');
      const nameInput = document.getElementById('loc-modal-name');
      const typeSelect = document.getElementById('loc-modal-type');

      form.reset();
      nameInput.focus();

      const onSubmit = (e) => {
        e.preventDefault();
        const name = nameInput.value.trim();
        if (!name) return;
        cleanup();
        modal.close();
        resolve({ name, locationType: typeSelect.value });
      };

      const onClose = () => {
        cleanup();
        reject(new Error('cancelled'));
      };

      function cleanup() {
        form.removeEventListener('submit', onSubmit);
        modal.removeEventListener('close', onClose);
      }

      form.addEventListener('submit', onSubmit);
      modal.addEventListener('close', onClose);
      modal.showModal();
    });
  };

  const TERRAIN_TYPES = [
    // Water - natural blues
    { id: 'ocean', label: 'Ocean', color: '#2d5f8a' },
    { id: 'lake', label: 'Lake', color: '#4a8ab5' },
    // Coastal - warm naturals
    { id: 'rocky_coast', label: 'Rocky Coast', color: '#8a8a7d' },
    { id: 'sandy_coast', label: 'Sandy Coast', color: '#d4c9a8' },
    // Plains - muted sage
    { id: 'grassy_plains', label: 'Grass Plains', color: '#a8b878' },
    { id: 'rocky_plains', label: 'Rocky Plains', color: '#b0a88a' },
    // Forest - natural greens
    { id: 'light_forest', label: 'Light Forest', color: '#6d9a52' },
    { id: 'dense_forest', label: 'Dense Forest', color: '#3a6632' },
    { id: 'jungle', label: 'Jungle', color: '#2d5a2d' },
    // Wetland
    { id: 'swamp', label: 'Swamp', color: '#5a6b48' },
    // Mountains/Hills - warm earthy tones
    { id: 'mountain', label: 'Mountain', color: '#8a7d6b' },
    { id: 'grassy_hills', label: 'Grass Hills', color: '#96a07a' },
    { id: 'rocky_hills', label: 'Rocky Hills', color: '#9a8d78' },
    // Cold
    { id: 'tundra', label: 'Tundra', color: '#c8d5d8' },
    // Arid - muted sand
    { id: 'desert', label: 'Desert', color: '#c8b48a' },
    // Volcanic
    { id: 'volcanic', label: 'Volcanic', color: '#4a2828' },
    // Urban - lighter grays
    { id: 'urban', label: 'Urban', color: '#7a7a7a' },
    { id: 'light_urban', label: 'Light Urban', color: '#9a9a9a' }
  ];

  const FEATURE_TYPES = [
    { id: 'road', label: 'Road', color: '#7f8c8d' },
    { id: 'highway', label: 'Highway', color: '#2c3e50' },
    { id: 'street', label: 'Street', color: '#bdc3c7' },
    { id: 'trail', label: 'Trail', color: '#a04000' },
    { id: 'river', label: 'River', color: '#3498db' },
    { id: 'canal', label: 'Canal', color: '#2e86c1' },
    { id: 'railway', label: 'Railway', color: '#1c2833' }
  ];

  // ===== STATE =====
  let globeView = null;
  let hexEditor = null;
  let minimap = null;
  let currentMode = 'globe'; // 'globe' or 'editor'
  let currentTool = 'select';
  let selectedTerrain = 'grassy_plains';
  let selectedFeature = 'road';
  let currentEditHex = null;

  // ===== API FUNCTIONS =====
  async function fetchGlobeHexes() {
    try {
      const response = await fetch(`${API_BASE}/globe_hexes`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const data = await response.json();
      return data.hexes || [];
    } catch (error) {
      console.error('Failed to fetch globe hexes:', error);
      return [];
    }
  }

  function updateHexDetailLabel() {
    if (!hexEditor) return;
    const el = document.getElementById('hex-detail-label');
    const recenterBtn = document.getElementById('btn-native-recenter');
    if (!el) return;
    const nativePatchReady = !!hexEditor.hasLoadedProjectedNativePatch;
    const nativeLoading = hexEditor.isUnwrappedNativeMode && (!nativePatchReady || hexEditor.isLoading);
    if (hexEditor.cellSize === 'native') {
      el.textContent = nativeLoading ? 'Loading 5 km...' : '5 km hexes';
    } else {
      const km = hexEditor.cellSize * 111;
      el.textContent = `${km.toFixed(0)} km`;
    }
    if (recenterBtn) {
      // Show button only in native mode with the Voronoi renderer
      recenterBtn.style.display = hexEditor.cellSize === 'native' ? '' : 'none';
    }
  }

  function setEditorViewportControls(enabled) {
    const zoomInBtn = document.getElementById('btn-zoom-in');
    const zoomOutBtn = document.getElementById('btn-zoom-out');
    const zoomLabel = document.getElementById('zoom-level-display');
    const editorLocked = enabled && !!hexEditor && (
      hexEditor.isLoading ||
      (hexEditor.isUnwrappedNativeMode && !hexEditor.hasLoadedProjectedNativePatch)
    );

    if (zoomInBtn) zoomInBtn.disabled = !enabled || editorLocked;
    if (zoomOutBtn) zoomOutBtn.disabled = !enabled || editorLocked;
    if (zoomLabel) {
      zoomLabel.textContent = !enabled
        ? 'World'
        : (editorLocked ? 'Loading...' : 'Hex View');
    }
  }

  function setEditorLoading(isLoading, message = 'Loading hex region...') {
    const overlay = document.getElementById('editor-loading');
    const text = document.getElementById('editor-loading-text');
    if (!overlay) return;
    if (text && message) text.textContent = message;
    overlay.classList.toggle('hidden', !isLoading);
  }

  async function fetchRegion(face, x, y, size = 6) {
    try {
      const cs = window.hexEditor?.cellSize ?? 1.0;
      const params = new URLSearchParams({ face, x, y, size, cell_size: cs });
      const response = await fetch(`${API_BASE}/globe_region?${params}`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('Failed to fetch region:', error);
      return { hexes: [], origin: { face, x, y }, size };
    }
  }

  async function saveRegionToAPI(data) {
    try {
      const response = await fetch(`${API_BASE}/globe_region`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
        body: JSON.stringify({
          face: data.origin.face || 0,
          origin_x: data.origin.x || 0,
          origin_y: data.origin.y || 0,
          hexes: data.hexes.map((hex, i) => ({
            id: hex.id,
            globe_hex_id: hex.globe_hex_id,
            x: hex.x !== undefined ? hex.x : i % 6,
            y: hex.y !== undefined ? hex.y : Math.floor(i / 6),
            terrain: hex.terrain,
            traversable: hex.traversable !== false
          }))
        })
      });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('Failed to save region:', error);
      return { success: false, error: error.message };
    }
  }

  // ===== TOOL SELECTION =====
  function selectTool(tool) {
    currentTool = tool;

    document.querySelectorAll('.tool-btn').forEach(btn => {
      const isActive = btn.dataset.tool === tool;
      btn.classList.toggle('active', isActive);
      // For non-colored buttons, toggle between primary and ghost
      if (!btn.classList.contains('btn-outline')) {
        btn.classList.toggle('btn-primary', isActive);
        btn.classList.toggle('btn-ghost', !isActive);
      }
    });

    // Show/hide palettes
    document.getElementById('terrain-palette-container').style.display = (tool === 'terrain') ? 'block' : 'none';
    document.getElementById('feature-palette-container').style.display = (tool === 'feature') ? 'block' : 'none';
    document.getElementById('named-features-container').style.display = (tool === 'feature') ? 'block' : 'none';
    if (tool === 'feature') refreshNamedFeaturesList();

    if (hexEditor && currentMode === 'editor') {
      hexEditor.setTool(tool);
    }
  }

  function selectTerrain(terrain) {
    selectedTerrain = terrain;
    document.querySelectorAll('.terrain-swatch').forEach(swatch => {
      swatch.classList.toggle('active', swatch.dataset.terrain === terrain);
    });
    if (hexEditor) hexEditor.setTerrain(terrain);
  }

  function selectFeature(feature) {
    selectedFeature = feature;
    document.querySelectorAll('.feature-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.feature === feature);
    });
    if (hexEditor) hexEditor.setFeature(feature);
  }

  // ===== NAMED FEATURES MANAGEMENT =====
  async function refreshNamedFeaturesList() {
    const list = document.getElementById('named-features-list');
    if (!hexEditor || !hexEditor.namedFeatures || hexEditor.namedFeatures.length === 0) {
      list.innerHTML = '<span class="opacity-50">No named features yet</span>';
      return;
    }

    list.innerHTML = '';
    hexEditor.namedFeatures.forEach(f => {
      const row = document.createElement('div');
      row.className = 'flex items-center justify-between gap-1 py-0.5';

      const colorDot = hexEditor.featureColors[f.feature_type] || '#888';
      row.innerHTML = `
        <span class="flex items-center gap-1 truncate">
          <span style="color:${colorDot}">●</span>
          <span class="named-feature-name" data-id="${f.id}" title="Click to rename">${f.name}</span>
          <span class="opacity-40">(${f.feature_type})</span>
        </span>
        <button class="btn btn-ghost btn-xs text-error named-feature-delete" data-id="${f.id}" title="Delete">
          <i class="bi bi-trash"></i>
        </button>
      `;
      list.appendChild(row);
    });

    // Rename on click
    list.querySelectorAll('.named-feature-name').forEach(el => {
      el.style.cursor = 'pointer';
      el.addEventListener('click', async () => {
        const newName = prompt('Rename feature:', el.textContent);
        if (newName && newName.trim() && newName.trim() !== el.textContent) {
          await renameNamedFeature(el.dataset.id, newName.trim());
        }
      });
    });

    // Delete on click
    list.querySelectorAll('.named-feature-delete').forEach(el => {
      el.addEventListener('click', async () => {
        if (confirm('Delete this named feature? The drawn lines will remain.')) {
          await deleteNamedFeature(el.dataset.id);
        }
      });
    });
  }

  async function renameNamedFeature(featureId, newName) {
    try {
      const apiBase = window.API_BASE || `/admin/world_builder/${hexEditor.worldId}/api`;
      const csrfToken = window.CSRF_TOKEN || document.querySelector('meta[name="csrf-token"]')?.content;
      const resp = await fetch(`${apiBase}/named_features/${featureId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
        body: JSON.stringify({ name: newName })
      });
      if (resp.ok) {
        await hexEditor.loadFeatures();
        refreshNamedFeaturesList();
      }
    } catch (e) { console.error('Rename failed:', e); }
  }

  async function deleteNamedFeature(featureId) {
    try {
      const apiBase = window.API_BASE || `/admin/world_builder/${hexEditor.worldId}/api`;
      const csrfToken = window.CSRF_TOKEN || document.querySelector('meta[name="csrf-token"]')?.content;
      const resp = await fetch(`${apiBase}/named_features/${featureId}`, {
        method: 'DELETE',
        headers: { 'X-CSRF-Token': csrfToken }
      });
      if (resp.ok) {
        await hexEditor.loadFeatures();
        refreshNamedFeaturesList();
      }
    } catch (e) { console.error('Delete failed:', e); }
  }

  // ===== MODE SWITCHING =====
  async function openEditor(hex) {
    if (currentMode === 'editor') return;

    currentMode = 'editor';
    currentEditHex = hex;
    setEditorViewportControls(true);

    // Hide globe/fallback, show editor
    const fallback = document.getElementById('globe-fallback');
    if (fallback) {
      fallback.classList.add('hidden');
      fallback.classList.remove('flex');
    }
    document.getElementById('globe-container').style.display = 'none';
    document.getElementById('editor-container').style.display = 'block';

    // Show loading overlay while fetching region data
    setEditorLoading(true, 'Loading hex region...');

    // Show mini globe
    document.getElementById('globe-mini').classList.remove('hidden');

    // Initialize minimap as a small Globe.gl instance (same rendering as main globe)
    if (!minimap) {
      const miniContainer = document.getElementById('globe-mini');
      const miniGlobe = Globe()
        .backgroundColor('#000011')
        .width(150)
        .height(150)
        .showAtmosphere(false)
        .atmosphereAltitude(0.1);

      // Use same terrain texture as the main globe
      const textureUrl = `${API_BASE}/terrain_texture.png?t=${Date.now()}`;
      miniGlobe.globeImageUrl(textureUrl);

      // Mount to container
      miniGlobe(miniContainer);

      // Disable user interaction (click closes editor instead)
      miniGlobe.controls().enabled = false;
      miniGlobe.controls().enableZoom = false;

      // Point at the clicked hex location
      if (hex.lat !== undefined && hex.lng !== undefined) {
        miniGlobe.pointOfView({ lat: hex.lat, lng: hex.lng, altitude: 2.0 }, 0);
      }

      // Store minimap reference with Globe.gl API
      minimap = {
        globe: miniGlobe,
        setViewport: (x, y, width, height) => {
          // Convert viewport grid coords back to lat/lng
          const centerLng = (x + width / 2) - 180;
          const centerLat = 90 - (y + height / 2);
          miniGlobe.pointOfView({ lat: centerLat, lng: centerLng, altitude: 2.0 }, 300);
        }
      };
    } else if (minimap && hex.lat !== undefined && hex.lng !== undefined) {
      // Re-point existing minimap at the new clicked location
      minimap.globe.pointOfView({ lat: hex.lat, lng: hex.lng, altitude: 2.0 }, 300);
    }

    // Initialize hex editor if needed
    if (!hexEditor) {
      hexEditor = new HexEditor('editor-container', {
        worldId: WORLD_ID,
        onSave: handleEditorSave,
        onClose: closeEditor,
        onLoadingStateChange: ({ isLoading, message }) => {
          if (currentMode !== 'editor') return;
          setEditorLoading(isLoading, message || 'Loading hex region...');
          setEditorViewportControls(true);
          updateHexDetailLabel();
        },
        onViewportChange: (viewport) => {
          document.getElementById('coords-display').textContent =
            `Position: (${Math.round(viewport.x)}, ${Math.round(viewport.y)})`;
        }
      });
      window.hexEditor = hexEditor;
      // Wire hex selection in native mode to update coords display
      hexEditor.onHexSelect = function(hexData) {
        var coords = document.getElementById('coords-display');
        if (coords) {
          coords.textContent = hexData.terrain_type + ' (' +
            hexData.latitude.toFixed(2) + '°, ' + hexData.longitude.toFixed(2) + '°)';
        }
      };
      // Connect minimap to editor
      if (minimap) {
        hexEditor.minimap = minimap;
      }

      // Hex detail zoom buttons
      document.getElementById('btn-hex-zoom-in')?.addEventListener('click', () => {
        if (!hexEditor) return;
        hexEditor.zoomCellSizeIn();
        setEditorViewportControls(true);
        updateHexDetailLabel();
      });
      document.getElementById('btn-hex-zoom-out')?.addEventListener('click', () => {
        if (!hexEditor) return;
        hexEditor.zoomCellSizeOut();
        setEditorViewportControls(true);
        updateHexDetailLabel();
      });
      document.getElementById('btn-native-recenter')?.addEventListener('click', () => {
        if (!hexEditor || !hexEditor.nativeHexRenderer) return;
        var r = hexEditor.nativeHexRenderer;
        r.hexCache = {};
        r._lastViewport = null;
        r._pendingFetch = false;
        r._centerLat = INITIAL_LAT;
        r._centerLon = INITIAL_LNG;
        r._viewSize = 2.0;
        r._updateCamera();
      });
    }

    if (hex.lat !== undefined && hex.lng !== undefined) {
      hexEditor.nativeCenterLat = hex.lat;
      hexEditor.nativeCenterLng = hex.lng;
      hexEditor.pendingPatchCenterHexId = hex.globe_hex_id ?? hexEditor.pendingPatchCenterHexId;
    }

    // Determine coordinates - use lat/lng for globe worlds, ico coords for others
    let face, x, y, displayCoords;

    const regionSize = 20;

    if (hex.lat !== undefined && hex.lng !== undefined) {
      // Globe world: convert lat/lng to pseudo-grid coords using current cell size
      const cs = hexEditor ? hexEditor.effectiveCellSize : 1.0;
      face = 0;
      x = Math.floor((hex.lng + 180) / cs) - Math.floor(regionSize / 2);
      y = Math.floor((90 - hex.lat) / cs) - Math.floor(regionSize / 2);
      displayCoords = `(${hex.lat.toFixed(1)}°, ${hex.lng.toFixed(1)}°)`;

      // Show hex detail controls for globe worlds
      document.getElementById('hex-detail-controls').style.display = 'block';
      updateHexDetailLabel();
    } else {
      // Icosahedral world: use face/ico coords
      face = hex.faceIndex ?? hex.ico_face ?? 0;
      x = Math.floor(hex.ico_x || 0) - Math.floor(regionSize / 2);
      y = Math.floor(hex.ico_y || 0) - Math.floor(regionSize / 2);
      displayCoords = `Face ${face} (${x}, ${y})`;
    }

    document.getElementById('coords-display').textContent = `Loading ${displayCoords}...`;

    if (hexEditor.isUnwrappedNativeMode && hex.lat !== undefined && hex.lng !== undefined) {
      hexEditor.nativeCenterLat = hex.lat;
      hexEditor.nativeCenterLng = hex.lng;
      hexEditor.pendingPatchCenterHexId = hex.globe_hex_id ?? null;
      hexEditor.clearLocalPatchCache();
      await hexEditor.show();
      setEditorLoading(false);
    } else {
      const regionData = await fetchRegion(face, x, y, regionSize);
      setEditorLoading(false);
      hexEditor.loadRegion({ face, x, y }, regionData.hexes || [], { isGlobeWorld: regionData.is_globe_world });
      await hexEditor.show();

      if (hex.lat !== undefined && hex.lng !== undefined) {
        const focusHex = (hex.globe_hex_id != null
          ? hexEditor.hexCache.get(`ghid:${hex.globe_hex_id}`)
          : null) || hexEditor.findLocalPatchHexByLatLng(hex.lat, hex.lng);

        if (focusHex && focusHex.worldX != null && focusHex.worldY != null) {
          hexEditor.nativeCenterLat = focusHex.lat ?? hexEditor.nativeCenterLat;
          hexEditor.nativeCenterLng = focusHex.lng ?? hexEditor.nativeCenterLng;
          hexEditor.pendingPatchCenterHexId = focusHex.globe_hex_id ?? hexEditor.pendingPatchCenterHexId;
          hexEditor.navigateTo(focusHex.worldX, focusHex.worldY);
        }
      }
    }

    hexEditor.setTool(currentTool);
    hexEditor.setTerrain(selectedTerrain);
    hexEditor.setFeature(selectedFeature);
    setEditorViewportControls(true);
    updateHexDetailLabel();

    document.getElementById('coords-display').textContent = `Editing ${displayCoords}`;
  }

  function closeEditor() {
    if (currentMode === 'globe') return;

    currentMode = 'globe';
    setEditorViewportControls(false);

    // Hide editor and loading overlay, show globe/fallback
    document.getElementById('editor-container').style.display = 'none';
    setEditorLoading(false);
    document.getElementById('globe-mini').classList.add('hidden');
    document.getElementById('hex-detail-controls').style.display = 'none';

    if (hexEditor) hexEditor.hide();

    // Show globe or fallback
    if (globeView && globeView.globe) {
      document.getElementById('globe-container').style.display = 'block';
    } else {
      document.getElementById('globe-fallback')?.classList.remove('hidden');
    }

    document.getElementById('coords-display').textContent = 'Position: (0, 0)';
    currentEditHex = null;
  }

  async function handleEditorSave(data) {
    const coordsDisplay = document.getElementById('coords-display');
    const originalText = coordsDisplay.textContent;
    coordsDisplay.textContent = 'Saving...';

    try {
      const result = await saveRegionToAPI(data);
      if (result.success) {
        coordsDisplay.textContent = `Saved ${result.saved || 0} hexes`;
        if (globeView?.refreshData) await globeView.refreshData();
        setTimeout(() => { coordsDisplay.textContent = originalText; }, 2000);
      } else {
        coordsDisplay.textContent = `Error: ${result.error || 'Save failed'}`;
        setTimeout(() => { coordsDisplay.textContent = originalText; }, 3000);
      }
    } catch (error) {
      coordsDisplay.textContent = `Error: ${error.message}`;
      setTimeout(() => { coordsDisplay.textContent = originalText; }, 3000);
    }
  }

  // ===== PALETTE INITIALIZATION =====
  function initTerrainPalette() {
    const palette = document.getElementById('terrain-palette');
    palette.innerHTML = '';
    TERRAIN_TYPES.forEach(terrain => {
      const swatch = document.createElement('div');
      swatch.className = 'terrain-swatch' + (terrain.id === selectedTerrain ? ' active' : '');
      swatch.style.backgroundColor = terrain.color;
      swatch.dataset.terrain = terrain.id;
      swatch.title = terrain.label;
      swatch.addEventListener('click', () => selectTerrain(terrain.id));
      palette.appendChild(swatch);
    });
  }

  function initFeaturePalette() {
    const palette = document.getElementById('feature-palette');
    palette.innerHTML = '';
    FEATURE_TYPES.forEach(feature => {
      const btn = document.createElement('button');
      btn.className = 'btn btn-sm btn-ghost feature-btn' + (feature.id === selectedFeature ? ' active' : '');
      btn.dataset.feature = feature.id;
      btn.innerHTML = `<span style="color:${feature.color}">■</span> ${feature.label}`;
      btn.addEventListener('click', () => selectFeature(feature.id));
      palette.appendChild(btn);
    });
  }

  // ===== EVENT BINDING =====
  function bindToolButtons() {
    document.querySelectorAll('.tool-btn').forEach(btn => {
      btn.addEventListener('click', () => selectTool(btn.dataset.tool));
    });
  }

  function bindGranularitySlider() {
    const slider = document.getElementById('granularity-slider');
    const display = document.getElementById('granularity-display');
    const counts = { 1: '~80', 2: '~320', 3: '~1.3K', 4: '~5K' };

    slider.addEventListener('input', (e) => {
      const level = parseInt(e.target.value);
      display.textContent = counts[level] || '?';
      if (globeView) globeView.setGranularity(level);
    });
  }

  function bindEditorNavigationButtons() {
    const zoomInBtn = document.getElementById('btn-zoom-in');
    const zoomOutBtn = document.getElementById('btn-zoom-out');

    if (zoomInBtn && !zoomInBtn.dataset.editorZoomBound) {
      zoomInBtn.dataset.editorZoomBound = 'true';
      zoomInBtn.addEventListener('click', (e) => {
        if (currentMode !== 'editor' || !hexEditor) return;
        e.preventDefault();
        e.stopImmediatePropagation();
        if (hexEditor.nativeHexRenderer && hexEditor.nativeHexRenderer.isActive()) {
          hexEditor.nativeHexRenderer.zoomIn();
        } else {
          hexEditor.zoomViewportIn();
        }
      }, true);
    }

    if (zoomOutBtn && !zoomOutBtn.dataset.editorZoomBound) {
      zoomOutBtn.dataset.editorZoomBound = 'true';
      zoomOutBtn.addEventListener('click', (e) => {
        if (currentMode !== 'editor' || !hexEditor) return;
        e.preventDefault();
        e.stopImmediatePropagation();
        if (hexEditor.nativeHexRenderer && hexEditor.nativeHexRenderer.isActive()) {
          hexEditor.nativeHexRenderer.zoomOut();
        } else {
          hexEditor.zoomViewportOut();
        }
      }, true);
    }
  }

  // ===== INITIALIZATION =====
  document.addEventListener('DOMContentLoaded', async () => {
    initTerrainPalette();
    initFeaturePalette();
    bindToolButtons();
    bindGranularitySlider();
    bindEditorNavigationButtons();
    setEditorViewportControls(false);

    // Mini globe click to close editor
    document.getElementById('globe-mini').addEventListener('click', closeEditor);

    // Initialize globe (unless test mode)
    let globeInitialized = false;
    const globeFallback = document.getElementById('globe-fallback');

    if (TEST_MODE) {
      console.log('TEST MODE: Skipping globe initialization');
    } else {
      try {
        globeView = new GlobeView('globe-container', {
          initialLat: INITIAL_LAT,
          initialLng: INITIAL_LNG,
          onHexClick: (hex) => {
            if (currentMode === 'globe') {
              if (currentTool === 'city') {
                // Open city modal with hex coordinates
                document.getElementById('city-hex-x').value = hex.lng || 0;
                document.getElementById('city-hex-y').value = hex.lat || 0;
                const globeHexIdField = document.getElementById('city-globe-hex-id');
                if (globeHexIdField) globeHexIdField.value = hex.globe_hex_id ?? '';
                document.getElementById('city-coords-display').textContent =
                  hex.globe_hex_id != null
                    ? `Hex #${hex.globe_hex_id} (${(hex.lat || 0).toFixed(1)}°, ${(hex.lng || 0).toFixed(1)}°)`
                    : `Hex: (${(hex.lat || 0).toFixed(1)}°, ${(hex.lng || 0).toFixed(1)}°)`;
                document.getElementById('cityModal').showModal();
              } else if (currentTool === 'link') {
                // Open link cities modal
                document.getElementById('linkCitiesModal').showModal();
              } else if (currentTool === 'zone') {
                // Open zone modal
                document.getElementById('zoneModal').showModal();
              } else {
                // Default: open editor for other tools
                openEditor(hex);
              }
            }
          }
        });
        globeInitialized = true;
      } catch (error) {
        console.error('Globe init failed:', error);
      }
    }

    // Show fallback if needed
    if (!globeInitialized || !globeView?.globe) {
      document.getElementById('globe-container').classList.add('hidden');
      globeFallback.classList.remove('hidden');
      globeFallback.classList.add('flex');
      document.getElementById('globe-loading').classList.add('hidden');

      globeFallback.addEventListener('click', () => {
        openEditor({ id: 'mock-hex-0', lat: 0, lng: 0, faceIndex: 0, ico_face: 0, ico_x: 0, ico_y: 0 });
      });
    }

    // ========================================
    // World Generation Functions
    // ========================================

    // Random seed button
    document.getElementById('btn-random-seed')?.addEventListener('click', () => {
      document.getElementById('gen-seed').value = Math.floor(Math.random() * 1000000);
    });

    // Generate procedural button
    document.getElementById('btn-generate-procedural')?.addEventListener('click', async () => {
      const preset = document.getElementById('gen-preset').value;
      const seed = document.getElementById('gen-seed').value || null;
      const worldSize = parseFloat(document.getElementById('gen-world-size')?.value || '0.5');

      // Calculate approximate hex count for confirmation
      const hexCounts = {
        0.1: '~280,000',
        0.25: '~1.8 million',
        0.5: '~7 million',
        0.75: '~15 million',
        1.0: '~28 million'
      };
      const hexCount = hexCounts[worldSize] || '~7 million';

      const confirmMsg = `This will generate ${hexCount} hexes at 3-mile resolution. This process may take several minutes for larger worlds. Continue?`;

      if (!confirm(confirmMsg)) {
        return;
      }

      // Show progress
      const progressContainer = document.getElementById('generation-progress');
      const progressBar = document.getElementById('progress-bar');
      const progressStatus = document.getElementById('progress-status');
      progressContainer.style.display = 'block';
      progressBar.value = 0;
      progressStatus.textContent = 'Starting generation...';

      try {
        const response = await fetch(`${API_BASE}/generate`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': CSRF_TOKEN
          },
          body: JSON.stringify({
            type: 'procedural',
            options: { preset, seed, flat_grid: true, world_size: worldSize }
          })
        });

        const data = await response.json();
        if (data.success) {
          pollGenerationStatus();
        } else {
          progressStatus.textContent = 'Error: ' + (data.error || 'Unknown error');
        }
      } catch (error) {
        console.error('Generation failed:', error);
        progressStatus.textContent = 'Error: ' + error.message;
      }
    });

    // Poll generation status
    let pollRetryCount = 0;
    const MAX_POLL_RETRIES = 15;

    async function pollGenerationStatus() {
      const progressBar = document.getElementById('progress-bar');
      const progressStatus = document.getElementById('progress-status');

      try {
        const response = await fetch(`${API_BASE}/generation_status`);

        // Check for non-JSON response (e.g. HTML error page or redirect)
        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error('Server returned non-JSON response (database may be busy)');
        }

        if (!response.ok) {
          const errData = await response.json().catch(() => ({}));
          throw new Error(errData.error || `HTTP ${response.status}: ${response.statusText}`);
        }
        const data = await response.json();
        pollRetryCount = 0; // Reset on success

        if (data.job) {
          const pct = data.job.progress_percentage || 0;
          progressBar.value = pct;

          const phaseNames = {
            'tectonics': 'Generating tectonic plates...',
            'elevation': 'Calculating elevation...',
            'climate': 'Simulating climate...',
            'rivers': 'Tracing rivers...',
            'biomes': 'Mapping biomes...',
            'saving': 'Saving to database...',
            'aggregating': 'Aggregating regions...',
            'texture': 'Generating texture...'
          };
          const subphaseNames = {
            'grid': 'Building hex grid...',
            'neighbors': 'Building neighbor cache...',
            'plates': 'Assigning tectonic plates...'
          };
          const subphase = data.job.subphase;
          progressStatus.textContent = subphaseNames[subphase] || phaseNames[data.job.phase] || 'Processing...';

          if (data.job.status === 'running' || data.job.status === 'pending') {
            setTimeout(pollGenerationStatus, 2000);
          } else if (data.job.status === 'completed') {
            progressStatus.textContent = 'Complete! Refreshing map...';
            if (globeView && typeof globeView.refreshData === 'function') {
              await globeView.refreshData();
            }
            setTimeout(() => {
              document.getElementById('generation-progress').style.display = 'none';
            }, 2000);
          } else if (data.job.status === 'failed') {
            progressStatus.textContent = 'Failed: ' + (data.job.error_message || 'Unknown error');
            progressBar.classList.remove('progress-bar-animated');
            progressBar.classList.add('progress-error');
          }
        }
      } catch (error) {
        console.error('Status poll failed:', error);
        pollRetryCount++;
        if (pollRetryCount < MAX_POLL_RETRIES) {
          // Use longer backoff during heavy DB operations (aggregation/texture phases)
          const delay = pollRetryCount > 5 ? 5000 : 3000;
          progressStatus.textContent = `Database busy, retrying... (${pollRetryCount}/${MAX_POLL_RETRIES})`;
          setTimeout(pollGenerationStatus, delay);
        } else {
          progressStatus.textContent = 'Lost connection to server. Generation may still be running - try refreshing the page.';
        }
      }
    }

    // Import Earth button
    document.getElementById('btn-import-earth')?.addEventListener('click', async () => {
      const confirmMsg = 'This will import real Earth terrain data (~21 million hexes). This process may take several hours. Continue?';

      if (!confirm(confirmMsg)) {
        return;
      }

      // Show progress
      const progressContainer = document.getElementById('generation-progress');
      const progressBar = document.getElementById('progress-bar');
      const progressStatus = document.getElementById('progress-status');

      if (progressContainer) progressContainer.style.display = 'block';
      if (progressBar) {
        progressBar.value = 0;
        progressBar.classList.remove('progress-error');
      }
      if (progressStatus) progressStatus.textContent = 'Starting Earth import (this takes 30-60 min)...';

      try {
        const response = await fetch(`${API_BASE}/generate`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': CSRF_TOKEN
          },
          body: JSON.stringify({
            type: 'earth_import',
            options: { subdivisions: 10 }  // 20 * 4^10 = ~21 million hexes
          })
        });

        const data = await response.json();
        if (data.success) {
          pollEarthImportStatus();
        } else {
          if (progressStatus) progressStatus.textContent = 'Error: ' + (data.error || 'Unknown error');
        }
      } catch (error) {
        console.error('Earth import failed:', error);
        if (progressStatus) progressStatus.textContent = 'Error: ' + error.message;
      }
    });

    // Poll Earth import status
    let earthPollRetryCount = 0;

    async function pollEarthImportStatus() {
      const progressBar = document.getElementById('progress-bar');
      const progressStatus = document.getElementById('progress-status');
      const progressContainer = document.getElementById('generation-progress');

      try {
        const response = await fetch(`${API_BASE}/generation_status`);
        if (!response.ok) {
          throw new Error(`HTTP ${response.status}: ${response.statusText}`);
        }
        const data = await response.json();
        earthPollRetryCount = 0;

        if (data.job) {
          const pct = data.job.progress_percentage || 0;
          if (progressBar) {
            progressBar.value = pct;
          }

          const phaseNames = {
            'download': 'Downloading Earth data...',
            'parse': 'Generating hex grid...',
            'setup': 'Building land mask...',
            'generate': 'Generating hexes (may take 30+ min)...',
            'aggregate': 'Aggregating regions...',
            'texture': 'Generating texture cache...',
            'elevation': 'Processing elevation...',
            'terrain': 'Mapping terrain types...',
            'rivers': 'Tracing rivers...',
            'save': 'Saving to database...'
          };

          const phase = data.job.config?.current_phase;
          if (progressStatus) {
            progressStatus.textContent = phaseNames[phase] || 'Processing...';
          }

          if (data.job.status === 'running' || data.job.status === 'pending') {
            setTimeout(pollEarthImportStatus, 2000);
          } else if (data.job.status === 'completed') {
            if (progressStatus) progressStatus.textContent = 'Complete! Refreshing map...';
            if (typeof globeView !== 'undefined' && globeView && globeView.refreshData) {
              await globeView.refreshData();
            }
            setTimeout(() => {
              if (progressContainer) progressContainer.style.display = 'none';
            }, 2000);
          } else if (data.job.status === 'failed') {
            if (progressStatus) progressStatus.textContent = 'Failed: ' + (data.job.error_message || 'Unknown error');
            if (progressBar) {
              progressBar.classList.add('progress-error');
            }
          }
        }
      } catch (error) {
        console.error('Status poll failed:', error);
        earthPollRetryCount++;
        if (earthPollRetryCount < MAX_POLL_RETRIES) {
          if (progressStatus) progressStatus.textContent = `Connection issue, retrying... (${earthPollRetryCount}/${MAX_POLL_RETRIES})`;
          setTimeout(pollEarthImportStatus, 3000);
        } else {
          if (progressStatus) progressStatus.textContent = 'Error checking status: ' + error.message;
        }
      }
    }

    // Globe uses texture-based rendering + server-side click detection
    // No need to load all hex data client-side
    if (globeInitialized && globeView) {
      globeView.hideLoading();
      // Load city markers so they're clickable on the globe
      try {
        const citiesRes = await fetch(`${API_BASE}/cities`);
        const citiesData = await citiesRes.json();
        if (citiesData.success && citiesData.cities) {
          globeView.setCities(citiesData.cities);
        }
      } catch (e) {
        console.warn('Failed to load globe city markers:', e);
      }
    }

    // Link cities modal handler
    const linkToolBtn = document.querySelector('[data-tool="link"]');
    if (linkToolBtn) {
      linkToolBtn.addEventListener('click', async () => {
        try {
          const response = await fetch(`${API_BASE}/cities`);
          const data = await response.json();
          const cities = data.cities || [];
          const fromSelect = document.getElementById('link-from-city');
          const toSelect = document.getElementById('link-to-city');
          fromSelect.innerHTML = toSelect.innerHTML = '<option value="">Select city...</option>';
          cities.forEach(city => {
            fromSelect.innerHTML += `<option value="${city.id}">${city.name}</option>`;
            toSelect.innerHTML += `<option value="${city.id}">${city.name}</option>`;
          });
        } catch (e) { console.error(e); }
        document.getElementById('linkModal').showModal();
      });
    }

    // Link form submission
    document.getElementById('link-cities-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fromId = document.getElementById('link-from-city').value;
      const toId = document.getElementById('link-to-city').value;
      if (!fromId || !toId || fromId === toId) return alert('Select two different cities');

      const response = await fetch(`${API_BASE}/link_cities`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
        body: JSON.stringify({
          from_city_id: parseInt(fromId),
          to_city_id: parseInt(toId),
          feature_type: document.getElementById('link-type').value
        })
      });
      const result = await response.json();
      if (result.success) {
        document.getElementById('linkModal').close();
        if (globeView?.refreshData) globeView.refreshData();
      } else {
        alert('Failed: ' + (result.error || 'Unknown error'));
      }
    });

    // ========================================
    // City Form Submission
    // ========================================

    // Earth mode toggle
    document.getElementById('city-earth-mode')?.addEventListener('change', (e) => {
      const earthFields = document.getElementById('earth-mode-fields');
      if (earthFields) {
        earthFields.style.display = e.target.checked ? 'block' : 'none';
      }
    });

    // City form submission
    // City modal: size preset buttons
    document.querySelectorAll('.city-size-preset').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('city-horizontal-streets').value = btn.dataset.streets;
        document.getElementById('city-vertical-streets').value = btn.dataset.avenues;
        document.getElementById('city-max-height').value = btn.dataset.height;
        // Highlight selected preset
        document.querySelectorAll('.city-size-preset').forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('btn-outline');
        });
        btn.classList.add('btn-primary');
        btn.classList.remove('btn-outline');
      });
    });

    // City modal: toggle visibility based on individual controls
    document.getElementById('city-gen-buildings-toggle')?.addEventListener('change', (e) => {
      const on = e.target.checked;
      const roomDescRow = document.getElementById('city-room-desc-row');
      const greenSpaceRow = document.getElementById('city-green-space-row');
      const imageConfig = document.getElementById('city-image-config');
      const inventoryRow = document.getElementById('city-inventory-row');
      const aiNamesRow = document.getElementById('city-ai-names-row');
      if (roomDescRow) roomDescRow.style.display = on ? 'block' : 'none';
      if (greenSpaceRow) greenSpaceRow.style.display = on ? 'block' : 'none';
      if (imageConfig) imageConfig.style.display = on ? 'block' : 'none';
      if (inventoryRow) inventoryRow.style.display = on ? 'block' : 'none';
      if (aiNamesRow) aiNamesRow.style.display = on ? 'block' : 'none';
      // If buildings off, also turn off NPCs
      if (!on) {
        const npcsToggle = document.getElementById('city-gen-npcs-toggle');
        if (npcsToggle) { npcsToggle.checked = false; npcsToggle.dispatchEvent(new Event('change')); }
      }
    });

    document.getElementById('city-gen-npcs-toggle')?.addEventListener('change', (e) => {
      const npcConfig = document.getElementById('city-npc-config');
      if (npcConfig) npcConfig.style.display = e.target.checked ? 'block' : 'none';
    });

    document.getElementById('city-green-space')?.addEventListener('input', (e) => {
      const label = document.getElementById('city-green-space-label');
      if (label) label.textContent = e.target.value + '%';
    });

    document.getElementById('city-npc-density')?.addEventListener('input', (e) => {
      const label = document.getElementById('city-npc-density-label');
      if (label) label.textContent = ['Sparse', 'Normal', 'Dense'][parseInt(e.target.value) - 1] || 'Normal';
    });

    // City modal: toggle name field based on generate toggle
    document.getElementById('city-generate-name')?.addEventListener('change', (e) => {
      const nameField = document.getElementById('city-name');
      if (nameField) {
        nameField.placeholder = e.target.checked
          ? 'Leave blank to AI-generate, or enter a name'
          : 'Enter city name (required)';
      }
    });

    // City form submission
    document.getElementById('city-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = e.target.querySelector('button[type="submit"]') ||
                        document.querySelector('#cityModal .btn-warning');
      const originalText = submitBtn?.innerHTML;
      if (submitBtn) {
        submitBtn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Creating...';
        submitBtn.disabled = true;
      }

      const globeHexIdVal = document.getElementById('city-globe-hex-id')?.value;
      const zoneId = document.getElementById('city-form')?.dataset?.zoneId;

      const payload = {
        name: document.getElementById('city-name').value,
        center_x: parseFloat(document.getElementById('city-hex-x').value),
        center_y: parseFloat(document.getElementById('city-hex-y').value),
        globe_hex_id: globeHexIdVal ? parseInt(globeHexIdVal) : null,
        horizontal_streets: parseInt(document.getElementById('city-horizontal-streets').value) || 10,
        vertical_streets: parseInt(document.getElementById('city-vertical-streets').value) || 10,
        max_building_height: parseInt(document.getElementById('city-max-height').value) || 200,
        use_earth_names: document.getElementById('city-earth-mode')?.checked || false,
        latitude: parseFloat(document.getElementById('city-latitude')?.value) || null,
        longitude: parseFloat(document.getElementById('city-longitude')?.value) || null,
        // Enhanced fields
        description: document.getElementById('city-description')?.value || null,
        setting: document.getElementById('city-setting')?.value || 'fantasy',
        generate_name: document.getElementById('city-generate-name')?.checked ?? true,
        zone_id: zoneId ? parseInt(zoneId) : null,
        // Individual generation controls
        generate_buildings: document.getElementById('city-gen-buildings-toggle')?.checked ?? true,
        generate_room_descriptions: document.getElementById('city-gen-room-desc')?.checked ?? true,
        generate_inventory: document.getElementById('city-gen-inventory')?.checked ?? true,
        use_ai_names: document.getElementById('city-gen-ai-names')?.checked ?? true,
        green_space_ratio: (parseInt(document.getElementById('city-green-space')?.value) || 50) / 100,
        generate_npcs: document.getElementById('city-gen-npcs-toggle')?.checked ?? false,
        generate_portraits: document.getElementById('city-gen-portraits')?.checked ?? false,
        generate_schedules: document.getElementById('city-gen-schedules')?.checked ?? false,
        npc_density: parseInt(document.getElementById('city-npc-density')?.value) || 2,
        generate_images: {
          overview: document.getElementById('city-gen-overview')?.checked ?? false,
          street: document.getElementById('city-gen-street')?.checked ?? false,
          buildings: document.getElementById('city-gen-buildings')?.checked ?? false
        }
      };

      try {
        const response = await fetch(`${API_BASE}/city`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify(payload)
        });
        const result = await response.json();

        if (result.success) {
          document.getElementById('cityModal').close();
          // Clear zone_id after successful creation
          delete document.getElementById('city-form')?.dataset?.zoneId;

          // Show success message
          const cityName = result.city?.name || payload.name;
          console.log('City created:', result);

          // Refresh globe if available
          if (globeView?.refreshData) await globeView.refreshData();

          // Navigate to city builder if location was created
          if (result.location_id) {
            if (confirm(`City "${cityName}" created! Open in City Builder?`)) {
              window.location.href = `/admin/city_builder/${result.location_id}`;
            }
          } else {
            alert(`City "${cityName}" zone created successfully.`);
          }
        } else {
          const errorMsg = result.errors?.join(', ') || result.error || 'Unknown error';
          alert('Failed to create city: ' + errorMsg);
        }
      } catch (error) {
        console.error('City creation failed:', error);
        alert('Error: ' + error.message);
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      }
    });

    // Zone form submission
    document.getElementById('zone-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = document.querySelector('#zoneModal .btn-info');
      const originalText = submitBtn?.innerHTML;
      if (submitBtn) {
        submitBtn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Creating...';
        submitBtn.disabled = true;
      }

      const pointsJson = document.getElementById('zone-polygon-points')?.value;
      let polygonPoints = [];
      try {
        polygonPoints = JSON.parse(pointsJson || '[]');
      } catch (err) {
        console.error('Failed to parse zone points:', err);
      }

      const zoneType = document.getElementById('zone-type').value;
      const payload = {
        name: document.getElementById('zone-name').value,
        zone_type: zoneType,
        zone_subtype: zoneType === 'area' ? (document.getElementById('zone-subtype').value || null) : null,
        danger_level: parseInt(document.getElementById('zone-danger').value) || 1,
        polygon_points: polygonPoints
      };

      try {
        const response = await fetch(`${API_BASE}/zone`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify(payload)
        });
        const result = await response.json();

        if (result.success) {
          document.getElementById('zoneModal').close();

          // Reset zone drawing state
          if (hexEditor) {
            hexEditor.zonePoints = [];
            hexEditor.isDrawingZone = false;
            hexEditor.render();
          }

          // Refresh data
          if (globeView?.refreshData) await globeView.refreshData();

          alert(`Zone "${result.zone?.name}" created successfully.`);
        } else {
          const errorMsg = result.errors?.join(', ') || result.error || 'Unknown error';
          alert('Failed to create zone: ' + errorMsg);
        }
      } catch (error) {
        console.error('Zone creation failed:', error);
        alert('Error: ' + error.message);
      } finally {
        if (submitBtn) {
          submitBtn.innerHTML = originalText;
          submitBtn.disabled = false;
        }
      }
    });

    // ========================================
    // Bulk Traversable Buttons
    // ========================================

    document.getElementById('btn-all-traversable')?.addEventListener('click', async () => {
      if (!confirm('Mark ALL hexes as traversable? This affects pathfinding for the entire world.')) return;

      const btn = document.getElementById('btn-all-traversable');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Updating...';
      btn.disabled = true;

      try {
        const response = await fetch(`${API_BASE}/bulk_traversable`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify({ traversable: true })
        });
        const result = await response.json();
        if (result.success) {
          alert(`Success! Updated ${result.updated_hexes || 'all'} hexes to traversable.`);
        } else {
          alert('Failed: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error: ' + error.message);
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    document.getElementById('btn-none-traversable')?.addEventListener('click', async () => {
      if (!confirm('Mark ALL hexes as non-traversable? This will block all pathfinding until you enable specific regions.')) return;

      const btn = document.getElementById('btn-none-traversable');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Updating...';
      btn.disabled = true;

      try {
        const response = await fetch(`${API_BASE}/bulk_traversable`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify({ traversable: false })
        });
        const result = await response.json();
        if (result.success) {
          alert(`Success! Updated ${result.updated_hexes || 'all'} hexes to non-traversable.`);
        } else {
          alert('Failed: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error: ' + error.message);
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    });

    // ========================================
    // Landmass Traversable Toggle
    // ========================================

    let landmassMode = null; // null, 'traversable', or 'non-traversable'

    document.getElementById('btn-landmass-traversable')?.addEventListener('click', () => {
      if (landmassMode) {
        // Cancel landmass mode
        landmassMode = null;
        document.getElementById('btn-landmass-traversable').classList.remove('btn-active');
        document.getElementById('coords-display').textContent = 'Landmass mode cancelled';
        setTimeout(() => {
          document.getElementById('coords-display').textContent = 'Position: (0, 0)';
        }, 1500);
        return;
      }

      const makeTraversable = confirm('Make landmass traversable?\n\nOK = Traversable\nCancel = Non-traversable');
      landmassMode = makeTraversable ? 'traversable' : 'non-traversable';
      document.getElementById('btn-landmass-traversable').classList.add('btn-active');
      document.getElementById('coords-display').textContent = `Click a land hex to set landmass ${landmassMode}`;
    });

    // Patch hex editor click handler for landmass mode when it becomes available
    const landmassObserver = setInterval(() => {
      if (hexEditor && !hexEditor._landmassPatched) {
        const originalHandleHexClick = hexEditor.handleHexClick.bind(hexEditor);
        hexEditor.handleHexClick = function(worldX, worldY) {
          if (landmassMode) {
            performLandmassToggle(worldX, worldY);
            return;
          }
          originalHandleHexClick(worldX, worldY);
        };
        hexEditor._landmassPatched = true;
        clearInterval(landmassObserver);
      }
    }, 500);

    async function performLandmassToggle(worldX, worldY) {
      const key = `${worldX},${worldY}`;
      const hexInfo = hexEditor.hexCache.get(key) || {};
      const traversable = landmassMode === 'traversable';

      const btn = document.getElementById('btn-landmass-traversable');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Processing...';
      btn.disabled = true;

      document.getElementById('coords-display').textContent = 'Flood-filling landmass...';

      try {
        const payload = { traversable };
        if (hexInfo.globe_hex_id != null) {
          payload.globe_hex_id = hexInfo.globe_hex_id;
        } else if (hexInfo.lat != null && hexInfo.lng != null) {
          payload.lat = hexInfo.lat;
          payload.lng = hexInfo.lng;
        }

        const response = await fetch(`${API_BASE}/landmass_traversable`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
          body: JSON.stringify(payload)
        });
        const result = await response.json();

        if (result.success) {
          alert(`Updated ${result.updated_hexes} hexes to ${traversable ? 'traversable' : 'non-traversable'}.`);
          // Reload hex data to reflect changes
          hexEditor.hexCache.clear();
          hexEditor.loadVisibleHexes();
        } else {
          alert('Failed: ' + (result.error || 'Unknown error'));
        }
      } catch (error) {
        alert('Error: ' + error.message);
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
        btn.classList.remove('btn-active');
        landmassMode = null;
        document.getElementById('coords-display').textContent = 'Position: (0, 0)';
      }
    }

    console.log('World Builder initialized');
  });
</script>
