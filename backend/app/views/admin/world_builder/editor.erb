<div class="h-full overflow-hidden">
  <div class="flex h-full flex-nowrap">
    <!-- Left sidebar - Tools (collapsible sections) -->
    <div class="w-[260px] h-full bg-base-300 border-r border-base-content/10 flex flex-col flex-shrink-0">
      <!-- Header - fixed -->
      <div class="p-2 border-b border-base-content/10">
        <div class="flex items-center">
          <a href="/admin/world_builder" class="btn btn-ghost btn-sm mr-2">
            <i class="bi bi-arrow-left"></i>
          </a>
          <h6 class="mb-0 truncate font-semibold"><%= h @world.name %></h6>
        </div>
      </div>

      <!-- Scrollable sections -->
      <div class="flex-grow overflow-auto" style="scrollbar-width: thin;">
        <div class="join join-vertical w-full" id="sidebarAccordion">

          <!-- Tools Section (always visible, most important) -->
          <div class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200">
            <input type="checkbox" name="sidebar-accordion" checked />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-tools mr-2"></i><small class="font-bold">TOOLS</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div class="flex flex-wrap gap-1">
                <button class="btn btn-primary btn-sm tool-btn active" data-tool="select" title="Select / Zoom">
                  <i class="bi bi-cursor"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="terrain" title="Paint Terrain">
                  <i class="bi bi-paint-bucket"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="feature" title="Draw Features">
                  <i class="bi bi-signpost"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="traversable" title="Toggle Traversable">
                  <i class="bi bi-lock"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="city" title="Place City">
                  <i class="bi bi-building text-warning"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="zone" title="Draw Zone">
                  <i class="bi bi-hexagon text-info"></i>
                </button>
                <button class="btn btn-ghost btn-sm tool-btn" data-tool="link" title="Link Cities">
                  <i class="bi bi-diagram-3 text-success"></i>
                </button>
              </div>
            </div>
          </div>

          <!-- Terrain Palette (shown when Paint Terrain selected) -->
          <div id="terrain-palette-container" class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200" style="display: none;">
            <input type="checkbox" name="sidebar-accordion" checked />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-palette mr-2"></i><small class="font-bold">TERRAIN</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div id="terrain-palette" class="flex flex-wrap gap-1">
                <!-- Terrain swatches added by JS -->
              </div>
            </div>
          </div>

          <!-- Feature Palette (shown when Draw Features selected) -->
          <div id="feature-palette-container" class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200" style="display: none;">
            <input type="checkbox" name="sidebar-accordion" checked />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-signpost mr-2"></i><small class="font-bold">FEATURES</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div id="feature-palette" class="flex flex-wrap gap-1">
                <!-- Feature buttons added by JS -->
              </div>
            </div>
          </div>

          <!-- Named Features List (shown when Draw Features selected) -->
          <div id="named-features-container" class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200" style="display: none;">
            <input type="checkbox" name="sidebar-accordion" />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-list-ul mr-2"></i><small class="font-bold">NAMED FEATURES</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div id="named-features-list" class="flex flex-col gap-1 max-h-48 overflow-y-auto text-xs">
                <span class="opacity-50">No named features yet</span>
              </div>
            </div>
          </div>

          <!-- Navigation Section -->
          <div class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200">
            <input type="checkbox" name="sidebar-accordion" />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-compass mr-2"></i><small class="font-bold">NAVIGATION</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div class="flex justify-between items-center mb-2">
                <small>Zoom</small>
                <span id="zoom-level-display" class="badge badge-primary badge-sm">0 - World</span>
              </div>
              <div class="join w-full mb-2">
                <button id="btn-zoom-out" class="btn btn-ghost btn-sm join-item" disabled>
                  <i class="bi bi-zoom-out"></i>
                </button>
                <button id="btn-zoom-in" class="btn btn-ghost btn-sm join-item">
                  <i class="bi bi-zoom-in"></i>
                </button>
                <button id="btn-rotate-left" class="btn btn-ghost btn-sm join-item">
                  <i class="bi bi-arrow-counterclockwise"></i>
                </button>
                <button id="btn-rotate-right" class="btn btn-ghost btn-sm join-item">
                  <i class="bi bi-arrow-clockwise"></i>
                </button>
              </div>
              <div class="flex justify-between items-center">
                <small>Detail</small>
                <span id="granularity-display" class="badge badge-info badge-sm">~320</span>
              </div>
              <input type="range" id="granularity-slider" class="range range-sm" min="1" max="4" value="2" step="1">

              <!-- Hex data resolution (only visible when hex editor is open for globe worlds) -->
              <div id="hex-detail-controls" class="mt-3 pt-3 border-t border-base-content/10" style="display:none;">
                <div class="flex justify-between items-center mb-2">
                  <small>Hex Detail</small>
                  <span id="hex-detail-label" class="badge badge-secondary badge-sm">111 km</span>
                </div>
                <div class="join w-full">
                  <button id="btn-hex-zoom-out" class="btn btn-ghost btn-sm join-item flex-1">
                    <i class="bi bi-zoom-out"></i> Less
                  </button>
                  <button id="btn-hex-zoom-in" class="btn btn-ghost btn-sm join-item flex-1">
                    <i class="bi bi-zoom-in"></i> More
                  </button>
                </div>
                <button id="btn-native-recenter" class="btn btn-outline btn-sm w-full mt-2">
                  <i class="bi bi-geo-alt mr-1"></i>Center on Island
                </button>
              </div>
            </div>
          </div>

          <!-- Generation Section -->
          <div class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200">
            <input type="checkbox" name="sidebar-accordion" />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-globe mr-2"></i><small class="font-bold">GENERATION</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <div class="mb-2">
                <small>Planet Type</small>
                <select id="gen-preset" class="select select-sm w-full">
                  <option value="earth_like" selected>Earth-like</option>
                  <option value="pangaea">Pangaea</option>
                  <option value="archipelago">Archipelago</option>
                  <option value="ice_age">Ice Age</option>
                  <option value="waterworld">Waterworld</option>
                  <option value="arid">Arid</option>
                </select>
              </div>
              <div class="mb-2">
                <small>Seed</small>
                <div class="join w-full">
                  <input type="number" id="gen-seed" class="input input-sm join-item flex-1" placeholder="Random">
                  <button id="btn-random-seed" class="btn btn-sm btn-ghost join-item" type="button" title="Random seed">
                    <i class="bi bi-shuffle"></i>
                  </button>
                </div>
              </div>
              <div class="mb-2">
                <small>World Size</small>
                <select id="gen-world-size" class="select select-sm w-full">
                  <option value="0.1">Tiny (~328K hexes)</option>
                  <option value="0.25">Small (~1.3M hexes)</option>
                  <option value="0.5" selected>Medium (~5.2M hexes)</option>
                  <option value="0.75">Large (~21M hexes)</option>
                  <option value="1.0">Earth-size (~21M hexes)</option>
                </select>
              </div>
              <button id="btn-generate-procedural" class="btn btn-success btn-sm w-full mb-2">
                <i class="bi bi-globe mr-1"></i>Generate World
              </button>
              <button id="btn-import-earth" class="btn btn-outline btn-info btn-sm w-full mb-1">
                <i class="bi bi-download mr-1"></i>Import Earth
              </button>
              <div id="generation-progress" class="mt-2" style="display: none;">
                <progress id="progress-bar" class="progress progress-primary w-full" value="0" max="100"></progress>
                <small id="progress-status" class="text-base-content/70">Starting...</small>
              </div>
            </div>
          </div>

          <!-- Bulk Operations Section -->
          <div class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200">
            <input type="checkbox" name="sidebar-accordion" />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-grid mr-2"></i><small class="font-bold">BULK OPS</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <button id="btn-all-traversable" class="btn btn-outline btn-success btn-sm w-full mb-1">
                <i class="bi bi-unlock mr-1"></i>All Traversable
              </button>
              <button id="btn-none-traversable" class="btn btn-outline btn-error btn-sm w-full mb-1">
                <i class="bi bi-lock mr-1"></i>None Traversable
              </button>
              <button id="btn-landmass-traversable" class="btn btn-outline btn-warning btn-sm w-full">
                <i class="bi bi-globe-americas mr-1"></i>Toggle Landmass
              </button>
              <small class="text-base-content/50 block mt-1">Click a land hex after pressing</small>
            </div>
          </div>

          <!-- Weather Grid Section -->
          <div class="collapse collapse-arrow join-item border-b border-base-content/10 bg-base-200">
            <input type="checkbox" name="sidebar-accordion" />
            <div class="collapse-title py-2 px-3 min-h-0">
              <i class="bi bi-cloud-sun mr-2"></i><small class="font-bold">WEATHER GRID</small>
            </div>
            <div class="collapse-content py-2 px-3">
              <form method="post" action="/admin/world_builder/<%= @world.id %>/weather_grid">
                <input type="hidden" name="enabled" value="<%= @world.use_grid_weather ? 'false' : 'true' %>">
                <input type="hidden" name="_csrf" value="<%= csrf_token %>">
                <label class="label cursor-pointer justify-start gap-2 py-1">
                  <input type="checkbox" class="toggle toggle-sm toggle-primary"
                         <%= @world.use_grid_weather ? 'checked' : '' %>
                         onchange="this.form.submit()">
                  <span class="fieldset-legend text-xs">Enable Grid Weather</span>
                </label>
              </form>

              <% if @world.use_grid_weather %>
                <div id="weather-grid-status" class="mt-2">
                  <div class="flex flex-wrap gap-1 mb-2">
                    <span class="badge badge-info badge-xs" id="wg-tick-count">...</span>
                    <span class="badge badge-ghost badge-xs" id="wg-last-tick">...</span>
                  </div>

                  <small class="font-semibold block mb-1">Active Storms</small>
                  <div id="wg-storms">
                    <small class="text-base-content/50">Loading...</small>
                  </div>
                </div>

                <div class="mt-2">
                  <form method="post" action="/admin/world_builder/<%= @world.id %>/weather_grid/reset"
                        onsubmit="return confirm('Reset weather grid? This clears all simulation state.')">
                    <input type="hidden" name="_csrf" value="<%= csrf_token %>">
                    <button type="submit" class="btn btn-error btn-xs w-full">
                      <i class="bi bi-arrow-counterclockwise mr-1"></i>Reset Grid
                    </button>
                  </form>
                </div>

                <script>
                  (function() {
                    function refreshWeatherStatus() {
                      fetch('/admin/world_builder/<%= @world.id %>/weather_grid/status')
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                          var tickEl = document.getElementById('wg-tick-count');
                          var lastEl = document.getElementById('wg-last-tick');
                          if (tickEl) tickEl.textContent = 'Ticks: ' + (data.tick_count || 0);
                          if (lastEl) {
                            lastEl.textContent = data.last_tick_at
                              ? 'Last: ' + new Date(data.last_tick_at).toLocaleTimeString()
                              : 'Not ticked';
                          }

                          var stormsEl = document.getElementById('wg-storms');
                          if (!stormsEl) return;

                          if (data.storms && data.storms.length > 0) {
                            var html = '';
                            data.storms.forEach(function(s) {
                              var phaseClass = s.phase === 'mature' ? 'badge-error'
                                : s.phase === 'forming' ? 'badge-warning' : 'badge-ghost';
                              html += '<div class="flex items-center gap-1 mb-1">' +
                                '<span class="badge badge-xs ' + phaseClass + '">' + (s.phase || '?') + '</span>' +
                                '<small>' + (s.name || s.type || 'Storm') + '</small>' +
                                '<small class="text-base-content/50 ml-auto">' +
                                (s.intensity != null ? Math.round(s.intensity * 100) + '%' : '') + '</small>' +
                                '</div>';
                            });
                            stormsEl.innerHTML = html;
                          } else {
                            stormsEl.innerHTML = '<small class="text-base-content/50">No active storms</small>';
                          }
                        })
                        .catch(function() {});
                    }
                    refreshWeatherStatus();
                    setInterval(refreshWeatherStatus, 30000);
                  })();
                </script>
              <% end %>
            </div>
          </div>

        </div>
      </div>

      <!-- Status bar - fixed at bottom -->
      <div class="p-2 border-t border-base-content/10 bg-base-300">
        <small id="coords-display" class="text-base-content/50">Position: (0, 0)</small>
      </div>
    </div>

    <!-- Main map area -->
    <div class="flex-1 bg-black flex items-center justify-center relative min-w-0 overflow-hidden">
      <!-- Loading spinner overlay -->
      <div id="globe-loading" class="globe-loading">
        <span class="loading loading-spinner loading-lg text-primary"></span>
        <div class="mt-2">Loading world...</div>
      </div>

      <!-- Globe container (3D view) -->
      <div id="globe-container" class="w-full h-full"></div>

      <!-- Fallback placeholder for testing when Globe.gl fails to load -->
      <div id="globe-fallback" class="w-full h-full hidden absolute top-0 left-0 items-center justify-center" style="background: radial-gradient(circle at 40% 40%, #2d5f8a 0%, #1a3a5a 50%, #000011 100%); cursor: pointer;">
        <div class="text-center text-white">
          <div style="width: 250px; height: 250px; border-radius: 50%; background: radial-gradient(circle at 30% 30%, #4a8ab5 0%, #2d5f8a 40%, #1a3a5a 70%, #000011 100%); box-shadow: 0 0 60px rgba(58, 126, 207, 0.3); margin: 0 auto 20px;"></div>
          <p class="mt-3">Click anywhere to open hex editor</p>
          <small class="text-base-content/50">(Globe placeholder)</small>
        </div>
      </div>

      <!-- 2D Hex Editor container (hidden by default) -->
      <div id="editor-container" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #111;">
        <!-- Hex grid will be rendered here by HexEditor -->
      </div>

      <!-- Loading overlay (shown while fetching region data) -->
      <div id="editor-loading" class="hidden absolute inset-0 z-50 flex items-center justify-center" style="background: rgba(0,0,0,0.85);">
        <div class="text-center">
          <span class="loading loading-spinner loading-lg text-primary"></span>
          <p id="editor-loading-text" class="mt-3 text-base-content/70 text-sm">Loading hex region...</p>
        </div>
      </div>

      <!-- Mini world map (shown during hex editing) -->
      <div id="globe-mini" class="fixed hidden" style="bottom: 20px; right: 20px; width: 150px; height: 150px; cursor: pointer; z-index: 1000;">
        <!-- Mini Globe.gl instance will be rendered here -->
      </div>
    </div>
  </div>
</div>

<style>
  /* Prevent page scrollbars - constrain full chain so h-full works below navbar */
  html, body, .drawer, .drawer-content, main {
    overflow: hidden !important;
    height: 100% !important;
    margin: 0;
    padding: 0;
  }

  /* DaisyUI collapse styling for sidebar */
  #sidebarAccordion .collapse-title {
    min-height: 2.5rem;
    padding: 0.5rem 0.75rem;
  }
  #sidebarAccordion .collapse-content {
    padding: 0.5rem 0.75rem;
    background: oklch(var(--b3));
  }
  #sidebarAccordion .collapse-arrow > .collapse-title:after {
    top: 0.75rem;
  }

  /* Loading overlay */
  .globe-loading {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: white;
    text-align: center;
    z-index: 200;
  }
  .globe-loading.hidden {
    display: none;
  }

  /* Globe container */
  #globe-container {
    position: relative;
  }

  /* Globe thumbnail mode */
  #globe-container.globe-thumbnail {
    position: absolute !important;
    bottom: 20px;
    right: 20px;
    width: 120px !important;
    height: 120px !important;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    overflow: hidden;
    z-index: 100;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }
  #globe-container.globe-thumbnail:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Hex editor container */
  #editor-container svg {
    width: 100%;
    height: 100%;
  }

  /* Tool buttons */
  .tool-btn {
    width: 36px;
    height: 36px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tool-btn.active {
    background-color: oklch(var(--p)) !important;
    border-color: oklch(var(--p)) !important;
    color: oklch(var(--pc)) !important;
  }

  /* Terrain swatches */
  .terrain-swatch {
    width: 28px;
    height: 28px;
    border-radius: 4px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: transform 0.1s, border-color 0.1s;
  }
  .terrain-swatch:hover {
    transform: scale(1.1);
  }
  .terrain-swatch.active {
    border-color: #fff;
    box-shadow: 0 0 5px rgba(255, 255, 255, 0.5);
  }

  .feature-btn.active {
    background-color: oklch(var(--p)) !important;
    border-color: oklch(var(--p)) !important;
    color: oklch(var(--pc)) !important;
  }

  /* Hex styling */
  .editor-hex {
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .editor-hex:hover {
    opacity: 0.8;
  }

  /* Mini globe */
  #globe-mini:hover {
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Slim scrollbar */
  .overflow-auto::-webkit-scrollbar {
    width: 6px;
  }
  .overflow-auto::-webkit-scrollbar-track {
    background: oklch(var(--b3));
  }
  .overflow-auto::-webkit-scrollbar-thumb {
    background: oklch(var(--bc) / 0.3);
    border-radius: 3px;
  }
</style>

<!-- City Creation Modal -->
<dialog class="modal" id="cityModal">
  <div class="modal-box bg-base-200 max-w-2xl max-h-[90vh]">
    <div class="flex justify-between items-center mb-4">
      <h3 class="font-bold text-lg"><i class="bi bi-building mr-2"></i>Create City</h3>
      <form method="dialog">
        <button class="btn btn-sm btn-circle btn-ghost">✕</button>
      </form>
    </div>
    <form id="city-form" class="overflow-y-auto max-h-[calc(90vh-10rem)] pr-1">
      <input type="hidden" id="city-hex-x">
      <input type="hidden" id="city-hex-y">
      <input type="hidden" id="city-globe-hex-id">
      <div class="mb-3 text-base-content/70 text-sm" id="city-coords-display">Hex: (0, 0)</div>

      <!-- City Name + Generate Toggle -->
      <div class="fieldset mb-3">
        <label class="label"><span class="fieldset-legend">City Name</span></label>
        <input type="text" id="city-name" class="input w-full" placeholder="Enter city name or leave blank to generate">
        <label class="label cursor-pointer justify-start gap-3 mt-1">
          <input type="checkbox" id="city-generate-name" class="toggle toggle-sm toggle-primary" checked>
          <span class="text-sm text-base-content/70">AI-generate city name</span>
        </label>
      </div>

      <!-- Description -->
      <div class="fieldset mb-3">
        <label class="label"><span class="fieldset-legend">Description</span></label>
        <textarea id="city-description" class="textarea w-full h-24"
          placeholder="Describe this city... A bustling port town on a sheltered bay, known for its fish market and ancient lighthouse. The cobblestone streets wind uphill from the docks to a crumbling stone keep."></textarea>
        <label class="label py-0.5"><span class="fieldset-label text-base-content/50">Used as seed for AI generation of names, buildings, and NPCs</span></label>
      </div>

      <!-- Setting -->
      <div class="fieldset mb-3">
        <label class="label"><span class="fieldset-legend">Setting</span></label>
        <select id="city-setting" class="select w-full">
          <option value="fantasy" selected>Fantasy</option>
          <option value="medieval">Medieval</option>
          <option value="modern">Modern</option>
          <option value="scifi">Sci-Fi</option>
          <option value="steampunk">Steampunk</option>
          <option value="noir">Noir</option>
          <option value="horror">Horror</option>
        </select>
      </div>

      <!-- Size Presets -->
      <div class="fieldset mb-3">
        <label class="label"><span class="fieldset-legend">City Size</span></label>
        <div class="flex flex-wrap gap-2 mb-2">
          <button type="button" class="btn btn-sm btn-outline city-size-preset" data-streets="3" data-avenues="3" data-height="40">Village</button>
          <button type="button" class="btn btn-sm btn-outline city-size-preset" data-streets="5" data-avenues="5" data-height="60">Town</button>
          <button type="button" class="btn btn-sm btn-outline city-size-preset" data-streets="7" data-avenues="7" data-height="100">Small City</button>
          <button type="button" class="btn btn-sm btn-outline city-size-preset btn-primary" data-streets="10" data-avenues="10" data-height="150">City</button>
          <button type="button" class="btn btn-sm btn-outline city-size-preset" data-streets="15" data-avenues="15" data-height="200">Large City</button>
          <button type="button" class="btn btn-sm btn-outline city-size-preset" data-streets="20" data-avenues="20" data-height="300">Metropolis</button>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <div class="fieldset">
            <label class="label py-1"><span class="fieldset-legend text-xs">Streets (E-W)</span></label>
            <input type="number" id="city-horizontal-streets" class="input input-sm w-full" value="10" min="2" max="50">
          </div>
          <div class="fieldset">
            <label class="label py-1"><span class="fieldset-legend text-xs">Avenues (N-S)</span></label>
            <input type="number" id="city-vertical-streets" class="input input-sm w-full" value="10" min="2" max="50">
          </div>
          <div class="fieldset">
            <label class="label py-1"><span class="fieldset-legend text-xs">Max Height (ft)</span></label>
            <input type="number" id="city-max-height" class="input input-sm w-full" value="150" min="20" max="1000">
          </div>
        </div>
      </div>

      <!-- Generation Options -->
      <div class="fieldset mb-3">
        <label class="label"><span class="fieldset-legend">Generation Options</span></label>
        <div class="bg-base-300 p-3 rounded space-y-2">
          <!-- Generate Buildings toggle -->
          <label class="label cursor-pointer justify-start gap-3 py-1">
            <input type="checkbox" id="city-gen-buildings-toggle" class="toggle toggle-sm toggle-primary" checked>
            <div>
              <span class="font-medium text-sm">Generate Buildings</span>
              <p class="text-xs text-base-content/60">Create taverns, shops, temples, etc.</p>
            </div>
          </label>
          <!-- Room Descriptions (indented, shown when buildings on) -->
          <div id="city-room-desc-row" class="ml-8">
            <label class="label cursor-pointer justify-start gap-3 py-0.5">
              <input type="checkbox" id="city-gen-room-desc" class="toggle toggle-xs toggle-primary" checked>
              <span class="text-sm">Room Descriptions</span>
            </label>
          </div>
          <!-- Shop Inventories (indented, shown when buildings on) -->
          <div id="city-inventory-row" class="ml-8">
            <label class="label cursor-pointer justify-start gap-3 py-0.5">
              <input type="checkbox" id="city-gen-inventory" class="toggle toggle-xs toggle-primary" checked>
              <span class="text-sm">Shop Inventories</span>
            </label>
          </div>
          <!-- AI Street Names (indented, shown when buildings on) -->
          <div id="city-ai-names-row" class="ml-8">
            <label class="label cursor-pointer justify-start gap-3 py-0.5">
              <input type="checkbox" id="city-gen-ai-names" class="toggle toggle-xs toggle-primary" checked>
              <span class="text-sm">AI Street Names</span>
            </label>
          </div>
          <!-- Green Space slider (shown when buildings on) -->
          <div id="city-green-space-row" class="ml-8">
            <div class="fieldset">
              <label class="label py-1">
                <span class="fieldset-legend text-sm">Green Space</span>
                <span class="fieldset-label" id="city-green-space-label">50%</span>
              </label>
              <input type="range" id="city-green-space" min="0" max="100" value="50" step="10" class="range range-xs range-success">
            </div>
          </div>
          <div class="divider my-1"></div>
          <!-- Generate NPCs toggle -->
          <label class="label cursor-pointer justify-start gap-3 py-1">
            <input type="checkbox" id="city-gen-npcs-toggle" class="toggle toggle-sm toggle-secondary">
            <div>
              <span class="font-medium text-sm">Generate NPCs</span>
              <p class="text-xs text-base-content/60">Populate buildings with characters</p>
            </div>
          </label>
        </div>
      </div>

      <!-- NPC Configuration (shown when NPC toggle is on) -->
      <div id="city-npc-config" class="fieldset mb-3" style="display:none;">
        <label class="label"><span class="fieldset-legend">NPC Options</span></label>
        <div class="bg-base-300 p-3 rounded space-y-2">
          <label class="label cursor-pointer justify-start gap-3 py-0.5">
            <input type="checkbox" id="city-gen-portraits" class="toggle toggle-xs toggle-accent">
            <span class="text-sm">Generate NPC portraits</span>
          </label>
          <label class="label cursor-pointer justify-start gap-3 py-0.5">
            <input type="checkbox" id="city-gen-schedules" class="toggle toggle-xs toggle-accent">
            <span class="text-sm">Generate NPC daily schedules</span>
          </label>
          <div class="fieldset mt-2">
            <label class="label py-1">
              <span class="fieldset-legend text-xs">NPC Density</span>
              <span class="fieldset-label" id="city-npc-density-label">Normal</span>
            </label>
            <input type="range" id="city-npc-density" min="1" max="3" value="2" class="range range-xs range-primary">
          </div>
        </div>
      </div>

      <!-- Image Generation (shown when buildings on) -->
      <div id="city-image-config" class="fieldset mb-3" style="display:none;">
        <label class="label"><span class="fieldset-legend">Image Generation</span></label>
        <div class="bg-base-300 p-3 rounded space-y-1">
          <label class="label cursor-pointer justify-start gap-3 py-0.5">
            <input type="checkbox" id="city-gen-overview" class="toggle toggle-xs toggle-info" checked>
            <span class="text-sm">City overview (aerial view)</span>
          </label>
          <label class="label cursor-pointer justify-start gap-3 py-0.5">
            <input type="checkbox" id="city-gen-street" class="toggle toggle-xs toggle-info">
            <span class="text-sm">Street scene</span>
          </label>
          <label class="label cursor-pointer justify-start gap-3 py-0.5">
            <input type="checkbox" id="city-gen-buildings" class="toggle toggle-xs toggle-info">
            <span class="text-sm">Building exteriors</span>
          </label>
