<% @title = 'New Broadcast' %>
<% @breadcrumbs = [
  { label: 'Admin', path: '/admin' },
  { label: 'Broadcasts', path: '/admin/broadcasts' },
  { label: 'New', path: '/admin/broadcasts/new' }
] %>

<%= admin_content_start %>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <div class="lg:col-span-9">
          <h2 class="text-2xl font-bold mb-4"><i class="bi bi-megaphone mr-2"></i>New Broadcast</h2>

          <form method="post" action="/admin/broadcasts/new">
            <div class="card bg-base-200 mb-4">
              <div class="card-body">
                <div class="form-control mb-4">
                  <label for="content" class="label">
                    <span class="label-text">Broadcast Message</span>
                  </label>
                  <textarea name="content" id="content" class="textarea textarea-bordered h-32" data-grammar-check required
                            placeholder="Enter your broadcast message here..."></textarea>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">This message will be sent to all players immediately.</span>
                  </label>
                </div>

                <div class="alert alert-warning mb-4">
                  <i class="bi bi-exclamation-triangle"></i>
                  <span><strong>Warning:</strong> Clicking "Send Broadcast" will immediately deliver this message to all
                  currently online players. Offline players will receive it when they next log in.</span>
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send mr-1"></i>Send Broadcast
                  </button>
                  <a href="/admin/broadcasts" class="btn btn-outline">Cancel</a>
                </div>
              </div>
            </div>
          </form>
        </div>

        <!-- Tips Sidebar -->
        <div class="lg:col-span-3">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title"><i class="bi bi-lightbulb mr-2"></i>Tips</h5>
              <ul class="text-sm text-base-content/70 space-y-2">
                <li>
                  <strong>Be concise.</strong> Keep broadcasts short and clear.
                </li>
                <li>
                  <strong>Use sparingly.</strong> Frequent broadcasts can be disruptive.
                </li>
                <li>
                  <strong>For news</strong> that doesn't need immediate attention,
                  consider using the <a href="/admin/news" class="link">News</a> system instead.
                </li>
                <li>
                  <strong>In-game:</strong> Staff can also use the <code class="kbd kbd-sm">broadcast</code>
                  command for quick broadcasts.
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
<%= admin_content_end %>