<% @page_title = 'Game Settings - Admin' %>
<% @breadcrumbs = [{ label: 'Admin', path: '/admin' }, { label: 'Settings', path: '/admin/settings' }] %>

<%= admin_content_start %>
      <h2 class="mb-4 text-2xl font-bold">Game Settings</h2>

      <!-- Settings Tabs -->
      <div role="tablist" class="tabs tabs-boxed mb-4" id="settingsTabs">
        <button type="button" role="tab" class="tab tab-active" data-tab="general">
          <i class="bi bi-gear mr-1"></i>General
        </button>
        <button type="button" role="tab" class="tab" data-tab="time">
          <i class="bi bi-clock mr-1"></i>Time
        </button>
        <button type="button" role="tab" class="tab" data-tab="weather">
          <i class="bi bi-cloud-sun mr-1"></i>Weather
        </button>
        <button type="button" role="tab" class="tab" data-tab="ai">
          <i class="bi bi-robot mr-1"></i>AI
        </button>
        <button type="button" role="tab" class="tab" data-tab="delve">
          <i class="bi bi-map mr-1"></i>Delve
        </button>
        <button type="button" role="tab" class="tab" data-tab="email">
          <i class="bi bi-envelope mr-1"></i>Email
        </button>
        <button type="button" role="tab" class="tab" data-tab="storage">
          <i class="bi bi-cloud-upload mr-1"></i>Storage
        </button>
      </div>

      <div id="settingsTabContent">
        <!-- General Settings -->
        <div class="tab-panel" id="general-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">General Settings</h5>
              <form action="/admin/settings/general" method="post">
                <div class="form-control mb-3">
                  <label for="game_name" class="label">
                    <span class="label-text">Game Name</span>
                  </label>
                  <input type="text" class="input input-bordered" id="game_name" name="game_name"
                         value="<%= @settings[:general][:game_name] %>" placeholder="Firefly">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Displayed in page titles, navigation, footers, and emails throughout the interface.</span>
                  </label>
                </div>

                <div class="form-control mb-3">
                  <label for="world_type" class="label">
                    <span class="label-text">World Type</span>
                  </label>
                  <select class="select select-bordered" id="world_type" name="world_type">
                    <option value="earth_based" <%= @settings[:general][:world_type] == 'earth_based' ? 'selected' : '' %>>Earth-Based</option>
                    <option value="fictional" <%= @settings[:general][:world_type] == 'fictional' ? 'selected' : '' %>>Fictional</option>
                  </select>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Earth-based worlds can use real timezones and weather data.</span>
                  </label>
                </div>

                <div class="form-control mb-3">
                  <label for="time_period" class="label">
                    <span class="label-text">Time Period</span>
                  </label>
                  <select class="select select-bordered" id="time_period" name="time_period">
                    <option value="medieval" <%= @settings[:general][:time_period] == 'medieval' ? 'selected' : '' %>>Medieval</option>
                    <option value="gaslight" <%= @settings[:general][:time_period] == 'gaslight' ? 'selected' : '' %>>Gaslight (Victorian)</option>
                    <option value="modern" <%= @settings[:general][:time_period] == 'modern' ? 'selected' : '' %>>Modern</option>
                    <option value="near_future" <%= @settings[:general][:time_period] == 'near_future' ? 'selected' : '' %>>Near Future</option>
                    <option value="scifi" <%= @settings[:general][:time_period] == 'scifi' ? 'selected' : '' %>>Sci-Fi</option>
                  </select>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Affects name generation, NPC behavior, and AI content style.</span>
                  </label>
                </div>

                <div class="divider"></div>

                <div class="form-control mb-3">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input type="checkbox" class="toggle toggle-warning" name="test_account_enabled" value="on"
                           <%= @settings[:general][:test_account_enabled] ? 'checked' : '' %>>
                    <div>
                      <span class="label-text font-medium">Development Mode</span>
                      <p class="text-xs text-base-content/60 mt-1">
                        Enables development and testing features. <strong>Disable for production.</strong>
                        When off, the following are blocked:
                      </p>
                      <ul class="text-xs text-base-content/60 mt-1 list-disc ml-4">
                        <li>Test admin account (Firefly_Test) hidden from login page and blocked</li>
                        <li>Test API endpoints (<code>/api/test/*</code>) disabled</li>
                        <li>Test pages (<code>/test/*</code>) disabled</li>
                      </ul>
                    </div>
                  </label>
                </div>

                <div class="divider"></div>
                <div class="flex items-center gap-2 mb-2">
                  <i class="bi bi-geo-alt text-base-content/60"></i>
                  <span class="text-sm text-base-content/70">Spawn settings have moved to <a href="/admin/spawn_settings" class="link link-primary">World Building &rarr; Spawn Settings</a></span>
                </div>

                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check-lg mr-1"></i>Save General Settings
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Time Settings -->
        <div class="tab-panel hidden" id="time-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">Time Settings</h5>
              <form action="/admin/settings/time" method="post">
                <div class="form-control mb-3">
                  <label for="clock_mode" class="label">
                    <span class="label-text">Clock Mode</span>
                  </label>
                  <select class="select select-bordered" id="clock_mode" name="clock_mode">
                    <option value="earth_timezone" <%= @settings[:time][:clock_mode] == 'earth_timezone' ? 'selected' : '' %>>Earth Timezone</option>
                    <option value="fictional" <%= @settings[:time][:clock_mode] == 'fictional' ? 'selected' : '' %>>Fictional Time</option>
                  </select>
                </div>

                <div class="form-control mb-3" id="earth_timezone_group">
                  <label for="earth_timezone" class="label">
                    <span class="label-text">Earth Timezone</span>
                  </label>
                  <select class="select select-bordered" id="earth_timezone" name="earth_timezone">
                    <option value="America/New_York" <%= @settings[:time][:earth_timezone] == 'America/New_York' ? 'selected' : '' %>>Eastern (New York)</option>
                    <option value="America/Chicago" <%= @settings[:time][:earth_timezone] == 'America/Chicago' ? 'selected' : '' %>>Central (Chicago)</option>
                    <option value="America/Denver" <%= @settings[:time][:earth_timezone] == 'America/Denver' ? 'selected' : '' %>>Mountain (Denver)</option>
                    <option value="America/Los_Angeles" <%= @settings[:time][:earth_timezone] == 'America/Los_Angeles' ? 'selected' : '' %>>Pacific (Los Angeles)</option>
                    <option value="Europe/London" <%= @settings[:time][:earth_timezone] == 'Europe/London' ? 'selected' : '' %>>London (GMT/BST)</option>
                    <option value="Europe/Paris" <%= @settings[:time][:earth_timezone] == 'Europe/Paris' ? 'selected' : '' %>>Paris (CET)</option>
                    <option value="Asia/Tokyo" <%= @settings[:time][:earth_timezone] == 'Asia/Tokyo' ? 'selected' : '' %>>Tokyo (JST)</option>
                    <option value="Australia/Sydney" <%= @settings[:time][:earth_timezone] == 'Australia/Sydney' ? 'selected' : '' %>>Sydney (AEST)</option>
                    <option value="UTC" <%= @settings[:time][:earth_timezone] == 'UTC' ? 'selected' : '' %>>UTC</option>
                  </select>
                </div>

                <div class="form-control mb-3" id="fictional_time_group">
                  <label for="fictional_time_ratio" class="label">
                    <span class="label-text">Time Ratio (Game:Real)</span>
                  </label>
                  <input type="text" class="input input-bordered" id="fictional_time_ratio" name="fictional_time_ratio"
                         value="<%= @settings[:time][:fictional_time_ratio] %>" placeholder="2:1">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Example: "2:1" means 2 game hours per 1 real hour. "1:1" is real-time.</span>
                  </label>
                </div>

                <div class="form-control mb-3">
                  <label for="fictional_current_date" class="label">
                    <span class="label-text">Fictional Current Date</span>
                  </label>
                  <input type="text" class="input input-bordered" id="fictional_current_date" name="fictional_current_date"
                         value="<%= @settings[:time][:fictional_current_date] %>" placeholder="1892-03-15">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">The current in-game date (YYYY-MM-DD format).</span>
                  </label>
                </div>

                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check-lg mr-1"></i>Save Time Settings
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Weather Settings -->
        <div class="tab-panel hidden" id="weather-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">Weather Settings</h5>
              <div class="alert alert-info mb-4">
                <i class="bi bi-cloud-sun mr-2"></i>
                <span><strong>OpenWeatherMap API:</strong> This game uses <a href="https://openweathermap.org/api" target="_blank" class="link">OpenWeatherMap</a> for real-world weather data.
                Sign up for a free API key at <a href="https://home.openweathermap.org/users/sign_up" target="_blank" class="link">openweathermap.org</a>.
                The free tier allows 1,000 API calls per day, which is sufficient for most games.</span>
              </div>

              <form action="/admin/settings/weather" method="post">
                <div class="form-control mb-3">
                  <label for="weather_source" class="label">
                    <span class="label-text">Weather Source</span>
                  </label>
                  <select class="select select-bordered" id="weather_source" name="weather_source">
                    <option value="earth" <%= @settings[:weather][:weather_source] == 'earth' ? 'selected' : '' %>>Earth (Real Weather API)</option>
                    <option value="generated" <%= @settings[:weather][:weather_source] == 'generated' ? 'selected' : '' %>>Generated (Procedural)</option>
                  </select>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Earth weather pulls real weather data from OpenWeatherMap based on location coordinates.</span>
                  </label>
                </div>

                <div class="form-control mb-3">
                  <label for="weather_api_key" class="label">
                    <span class="label-text">OpenWeatherMap API Key</span>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="weather_api_key" name="weather_api_key"
                           placeholder="<%= @settings[:weather][:weather_api_key] ? 'Key configured' : 'Enter API key' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('weather_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Leave blank to keep existing key. <% if @settings[:weather][:weather_api_key] %><span class="text-success">Key is configured.</span><% end %></span>
                  </label>
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg mr-1"></i>Save Weather Settings
                  </button>
                  <% if @settings[:weather][:weather_api_key] %>
                  <button type="button" class="btn btn-outline btn-error" onclick="clearApiKey('weather_api_key')">
                    <i class="bi bi-trash mr-1"></i>Clear Key
                  </button>
                  <% end %>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- AI Settings -->
        <div class="tab-panel hidden" id="ai-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">AI Provider Settings</h5>
              <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle mr-2"></i>
                <span>Configure API keys for AI providers. The system will use providers in order of preference, falling back to the next available provider if one fails.</span>
              </div>

              <form action="/admin/settings/ai" method="post">
                <!-- Anthropic -->
                <div class="form-control mb-4">
                  <label for="anthropic_api_key" class="label">
                    <span class="label-text font-bold">Anthropic (Claude)</span>
                    <% if @settings[:ai][:anthropic_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="anthropic_api_key" name="anthropic_api_key"
                           placeholder="<%= @settings[:ai][:anthropic_configured] ? 'Key configured - enter new key to replace' : 'sk-ant-...' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('anthropic_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                </div>

                <!-- OpenAI -->
                <div class="form-control mb-4">
                  <label for="openai_api_key" class="label">
                    <span class="label-text font-bold">OpenAI (GPT)</span>
                    <% if @settings[:ai][:openai_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="openai_api_key" name="openai_api_key"
                           placeholder="<%= @settings[:ai][:openai_configured] ? 'Key configured - enter new key to replace' : 'sk-...' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('openai_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                </div>

                <!-- Google Gemini -->
                <div class="form-control mb-4">
                  <label for="google_gemini_api_key" class="label">
                    <span class="label-text font-bold">Google Gemini</span>
                    <% if @settings[:ai][:google_gemini_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="google_gemini_api_key" name="google_gemini_api_key"
                           placeholder="<%= @settings[:ai][:google_gemini_configured] ? 'Key configured - enter new key to replace' : 'Enter API key' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('google_gemini_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                </div>

                <!-- OpenRouter -->
                <div class="form-control mb-4">
                  <label for="openrouter_api_key" class="label">
                    <span class="label-text font-bold">OpenRouter</span>
                    <% if @settings[:ai][:openrouter_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="openrouter_api_key" name="openrouter_api_key"
                           placeholder="<%= @settings[:ai][:openrouter_configured] ? 'Key configured - enter new key to replace' : 'sk-or-...' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('openrouter_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                </div>

                <!-- Replicate (Image Upscaling) -->
                <div class="form-control mb-4">
                  <label for="replicate_api_key" class="label">
                    <span class="label-text font-bold">Replicate</span>
                    <% if @settings[:ai][:replicate_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="replicate_api_key" name="replicate_api_key"
                           placeholder="<%= @settings[:ai][:replicate_configured] ? 'Key configured - enter new key to replace' : 'r8_...' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('replicate_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Used for image upscaling. Get a key at replicate.com</span>
                  </label>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-braces mr-2"></i>Embeddings</h6>

                <!-- Voyage AI (Embeddings) -->
                <div class="form-control mb-4">
                  <label for="voyage_api_key" class="label">
                    <span class="label-text font-bold">Voyage AI (Embeddings)</span>
                    <% if @settings[:ai][:voyage_configured] %>
                      <span class="badge badge-success ml-2">Configured</span>
                    <% end %>
                  </label>
                  <div class="join w-full">
                    <input type="password" class="input input-bordered join-item flex-1" id="voyage_api_key" name="voyage_api_key"
                           placeholder="<%= @settings[:ai][:voyage_configured] ? 'Key configured - enter new key to replace' : 'pa-...' %>">
                    <button class="btn btn-outline join-item" type="button" onclick="togglePassword('voyage_api_key')">
                      <i class="bi bi-eye"></i>
                    </button>
                  </div>
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">Used for semantic search, NPC memory, and content similarity.</span>
                  </label>
                </div>

                <!-- Default Embedding Model -->
                <div class="form-control mb-4">
                  <label for="default_embedding_model" class="label">
                    <span class="label-text">Default Embedding Model</span>
                  </label>
                  <select class="select select-bordered" id="default_embedding_model" name="default_embedding_model">
                    <option value="voyage-3-large" <%= @settings[:ai][:default_embedding_model] == 'voyage-3-large' ? 'selected' : '' %>>voyage-3-large (Best quality)</option>
                    <option value="voyage-3.5" <%= @settings[:ai][:default_embedding_model] == 'voyage-3.5' ? 'selected' : '' %>>voyage-3.5 (Best balance)</option>
                    <option value="voyage-3.5-lite" <%= @settings[:ai][:default_embedding_model] == 'voyage-3.5-lite' ? 'selected' : '' %>>voyage-3.5-lite (Fastest/cheapest)</option>
                    <option value="voyage-code-3" <%= @settings[:ai][:default_embedding_model] == 'voyage-code-3' ? 'selected' : '' %>>voyage-code-3 (Code optimized)</option>
                  </select>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-lightning mr-2"></i>AI Features</h6>

                <!-- Combat LLM Enhancement -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="combat_llm_enhancement_enabled" name="combat_llm_enhancement_enabled"
                           <%= @settings[:ai][:combat_llm_enhancement_enabled] ? 'checked' : '' %>
                           <%= @settings[:ai][:google_gemini_configured] ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Enhanced Combat Prose</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:google_gemini_configured] %>
                        Uses Gemini to enhance combat narrative with more vivid, engaging prose while preserving accuracy.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires Google Gemini API key to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- AI Battle Maps -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="ai_battle_maps_enabled" name="ai_battle_maps_enabled"
                           <%= @settings[:ai][:ai_battle_maps_enabled] ? 'checked' : '' %>
                           <%= @settings[:ai][:google_gemini_configured] ? '' : 'disabled' %>>
                    <span class="label-text font-bold">AI Battle Maps</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:google_gemini_configured] %>
                        Generates battle maps from room descriptions using Gemini image generation. Falls back to procedural generation if disabled.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires Google Gemini API key to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- AI Weather Prose -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="ai_weather_prose_enabled" name="ai_weather_prose_enabled"
                           <%= @settings[:ai][:ai_weather_prose_enabled] ? 'checked' : '' %>>
                    <span class="label-text font-bold">AI Weather Prose</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      Generates atmospheric weather descriptions using AI. Falls back to template-based descriptions if disabled.
                    </span>
                  </label>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-puzzle mr-2"></i>Activity Features</h6>

                <!-- Activity Free Roll -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="activity_free_roll_enabled" name="activity_free_roll_enabled"
                           <%= @settings[:ai][:activity_free_roll_enabled] ? 'checked' : '' %>
                           <%= @settings[:ai][:anthropic_configured] ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Free Roll Rounds</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:anthropic_configured] %>
                        LLM acts as GM for open-ended problem solving. Players describe actions, LLM picks stat/DC and narrates outcomes.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires Anthropic API key to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- Activity Persuade -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="activity_persuade_enabled" name="activity_persuade_enabled"
                           <%= @settings[:ai][:activity_persuade_enabled] ? 'checked' : '' %>
                           <%= @settings[:ai][:openrouter_configured] ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Persuade Rounds</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:openrouter_configured] %>
                        LLM plays NPC in social skill check activities. Evaluates persuasiveness of player speech and adjusts difficulty.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires OpenRouter API key to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-robot mr-2"></i>AI Systems</h6>

                <!-- Auto-GM System -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="auto_gm_enabled" name="auto_gm_enabled"
                           <%= @settings[:ai][:auto_gm_enabled] ? 'checked' : '' %>
                           <%= (@settings[:ai][:anthropic_configured] && @settings[:ai][:openai_configured]) ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Auto-GM System</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:anthropic_configured] && @settings[:ai][:openai_configured] %>
                        Autonomous GM that generates spontaneous adventures, NPCs, and encounters. Uses multiple AI providers for diverse creative output.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires both Anthropic and OpenAI API keys to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- Abuse Monitoring -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="abuse_monitoring_enabled" name="abuse_monitoring_enabled"
                           <%= @settings[:ai][:abuse_monitoring_enabled] ? 'checked' : '' %>
                           <%= (@settings[:ai][:google_gemini_configured] && @settings[:ai][:anthropic_configured]) ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Abuse Monitoring</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:google_gemini_configured] && @settings[:ai][:anthropic_configured] %>
                        Two-tier AI moderation: Gemini screens messages, Claude verifies flagged content. Protects players from real-world abuse.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires both Google Gemini and Anthropic API keys to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- Player Help AI -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="autohelper_enabled" name="autohelper_enabled"
                           <%= @settings[:ai][:autohelper_enabled] ? 'checked' : '' %>
                           <%= @settings[:ai][:google_gemini_configured] ? '' : 'disabled' %>>
                    <span class="label-text font-bold">Player Help AI</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      <% if @settings[:ai][:google_gemini_configured] %>
                        When players ask questions via the help command, provides contextual AI-powered responses using helpfiles and recent activity.
                      <% else %>
                        <span class="text-warning"><i class="bi bi-exclamation-triangle mr-1"></i>Requires Google Gemini API key to be configured.</span>
                      <% end %>
                    </span>
                  </label>
                </div>

                <!-- Autohelper Ticket Threshold -->
                <div class="form-control mb-4 ml-8">
                  <label class="label">
                    <span class="label-text font-bold">Documentation Ticket Sensitivity</span>
                  </label>
                  <select class="select select-bordered select-sm w-full max-w-xs"
                          name="autohelper_ticket_threshold"
                          <%= @settings[:ai][:autohelper_enabled] ? '' : 'disabled' %>>
                    <option value="minor" <%= @settings[:ai][:autohelper_ticket_threshold] == 'minor' ? 'selected' : '' %>>Minor (catch everything)</option>
                    <option value="notable" <%= @settings[:ai][:autohelper_ticket_threshold] == 'notable' ? 'selected' : '' %>>Notable (default)</option>
                    <option value="critical" <%= @settings[:ai][:autohelper_ticket_threshold] == 'critical' ? 'selected' : '' %>>Critical (major gaps only)</option>
                  </select>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      When the help AI detects missing or incorrect documentation, auto-create a ticket if severity meets this threshold.
                    </span>
                  </label>
                </div>

                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check-lg mr-1"></i>Save AI Settings
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Delve Settings -->
        <div class="tab-panel hidden" id="delve-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">Delve Dungeon Settings</h5>
              <div class="alert alert-info mb-4">
                <i class="bi bi-info-circle mr-2"></i>
                <span>Configure skill checks, time costs, and other parameters for the procedural dungeon exploration system.</span>
              </div>

              <form action="/admin/settings/delve" method="post">
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-dice-5 mr-2"></i>Skill Check Configuration</h6>
                <p class="text-base-content/70 text-sm mb-3">Assign which stats are used for each type of obstacle skill check.</p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div>
                    <div class="form-control mb-3">
                      <label for="delve_barricade_stat" class="label">
                        <span class="label-text">Barricade (Breaking through)</span>
                      </label>
                      <select class="select select-bordered" id="delve_barricade_stat" name="delve_barricade_stat">
                        <% (@available_stats || [['STR', 'Strength'], ['DEX', 'Dexterity'], ['AGI', 'Agility']]).each do |abbr, name| %>
                          <option value="<%= abbr %>" <%= @settings[:delve][:barricade_stat] == abbr ? 'selected' : '' %>><%= name %> (<%= abbr %>)</option>
                        <% end %>
                      </select>
                      <label class="label">
                        <span class="label-text-alt text-base-content/70">Stat used for breaking through barricades.</span>
                      </label>
                    </div>

                    <div class="form-control mb-3">
                      <label for="delve_lockpick_stat" class="label">
                        <span class="label-text">Locked Door (Lockpicking)</span>
                      </label>
                      <select class="select select-bordered" id="delve_lockpick_stat" name="delve_lockpick_stat">
                        <% (@available_stats || [['STR', 'Strength'], ['DEX', 'Dexterity'], ['AGI', 'Agility']]).each do |abbr, name| %>
                          <option value="<%= abbr %>" <%= @settings[:delve][:lockpick_stat] == abbr ? 'selected' : '' %>><%= name %> (<%= abbr %>)</option>
                        <% end %>
                      </select>
                      <label class="label">
                        <span class="label-text-alt text-base-content/70">Stat used for picking locked doors.</span>
                      </label>
                    </div>
                  </div>

                  <div>
                    <div class="form-control mb-3">
                      <label for="delve_jump_stat" class="label">
                        <span class="label-text">Gap (Jumping)</span>
                      </label>
                      <select class="select select-bordered" id="delve_jump_stat" name="delve_jump_stat">
                        <% (@available_stats || [['STR', 'Strength'], ['DEX', 'Dexterity'], ['AGI', 'Agility']]).each do |abbr, name| %>
                          <option value="<%= abbr %>" <%= @settings[:delve][:jump_stat] == abbr ? 'selected' : '' %>><%= name %> (<%= abbr %>)</option>
                        <% end %>
                      </select>
                      <label class="label">
                        <span class="label-text-alt text-base-content/70">Stat used for jumping across gaps.</span>
                      </label>
                    </div>

                    <div class="form-control mb-3">
                      <label for="delve_balance_stat" class="label">
                        <span class="label-text">Narrow (Balancing)</span>
                      </label>
                      <select class="select select-bordered" id="delve_balance_stat" name="delve_balance_stat">
                        <% (@available_stats || [['STR', 'Strength'], ['DEX', 'Dexterity'], ['AGI', 'Agility']]).each do |abbr, name| %>
                          <option value="<%= abbr %>" <%= @settings[:delve][:balance_stat] == abbr ? 'selected' : '' %>><%= name %> (<%= abbr %>)</option>
                        <% end %>
                      </select>
                      <label class="label">
                        <span class="label-text-alt text-base-content/70">Stat used for balancing across narrow passages.</span>
                      </label>
                    </div>
                  </div>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-graph-up mr-2"></i>Difficulty Scaling</h6>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
                  <div class="form-control mb-3">
                    <label for="delve_base_skill_dc" class="label">
                      <span class="label-text">Base Skill DC</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_base_skill_dc" name="delve_base_skill_dc"
                           value="<%= @settings[:delve][:base_skill_dc] %>" min="1" max="30">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Base difficulty class for skill checks (default: 10).</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_dc_per_level" class="label">
                      <span class="label-text">DC Increase Per Level</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_dc_per_level" name="delve_dc_per_level"
                           value="<%= @settings[:delve][:dc_per_level] %>" min="0" max="10">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">How much DC increases per dungeon level (default: 2).</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_monster_move_threshold" class="label">
                      <span class="label-text">Monster Move Threshold</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_monster_move_threshold" name="delve_monster_move_threshold"
                           value="<%= @settings[:delve][:monster_move_threshold] %>" min="1" max="60">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Min. action time (seconds) that triggers monster movement (default: 10).</span>
                    </label>
                  </div>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-clock mr-2"></i>Time Costs (seconds)</h6>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                  <div class="form-control mb-3">
                    <label for="delve_time_move" class="label">
                      <span class="label-text">Move</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_move" name="delve_time_move"
                           value="<%= @settings[:delve][:time_move] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Moving to adjacent room.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_combat_round" class="label">
                      <span class="label-text">Combat Round</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_combat_round" name="delve_time_combat_round"
                           value="<%= @settings[:delve][:time_combat_round] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Per combat round.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_skill_check" class="label">
                      <span class="label-text">Skill Check</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_skill_check" name="delve_time_skill_check"
                           value="<%= @settings[:delve][:time_skill_check] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Attempting a skill check.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_trap_listen" class="label">
                      <span class="label-text">Trap Listen</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_trap_listen" name="delve_time_trap_listen"
                           value="<%= @settings[:delve][:time_trap_listen] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Listening for trap timing patterns.</span>
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
                  <div class="form-control mb-3">
                    <label for="delve_time_easier" class="label">
                      <span class="label-text">Make Easier</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_easier" name="delve_time_easier"
                           value="<%= @settings[:delve][:time_easier] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Studying an obstacle.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_recover" class="label">
                      <span class="label-text">Recover</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_recover" name="delve_time_recover"
                           value="<%= @settings[:delve][:time_recover] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Full heal action.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_focus" class="label">
                      <span class="label-text">Focus</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_focus" name="delve_time_focus"
                           value="<%= @settings[:delve][:time_focus] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Gaining willpower.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_study" class="label">
                      <span class="label-text">Study</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_study" name="delve_time_study"
                           value="<%= @settings[:delve][:time_study] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Studying enemy type.</span>
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div class="form-control mb-3">
                    <label for="delve_time_puzzle_attempt" class="label">
                      <span class="label-text">Puzzle Attempt</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_puzzle_attempt" name="delve_time_puzzle_attempt"
                           value="<%= @settings[:delve][:time_puzzle_attempt] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Attempting a puzzle answer.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_time_puzzle_help" class="label">
                      <span class="label-text">Puzzle Hint</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_time_puzzle_help" name="delve_time_puzzle_help"
                           value="<%= @settings[:delve][:time_puzzle_help] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Requesting a puzzle hint.</span>
                    </label>
                  </div>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-gem mr-2"></i>Treasure Settings</h6>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div class="form-control mb-3">
                    <label for="delve_base_treasure_min" class="label">
                      <span class="label-text">Base Treasure Min (Level 1)</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_base_treasure_min" name="delve_base_treasure_min"
                           value="<%= @settings[:delve][:base_treasure_min] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Minimum treasure value at level 1 (doubles each level).</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="delve_base_treasure_max" class="label">
                      <span class="label-text">Base Treasure Max (Level 1)</span>
                    </label>
                    <input type="number" class="input input-bordered" id="delve_base_treasure_max" name="delve_base_treasure_max"
                           value="<%= @settings[:delve][:base_treasure_max] %>" min="1">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Maximum treasure value at level 1 (doubles each level).</span>
                    </label>
                  </div>
                </div>

                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check-lg mr-1"></i>Save Delve Settings
                </button>
              </form>
            </div>
          </div>
        </div>

        <!-- Email Settings -->
        <div class="tab-panel hidden" id="email-panel">
          <div class="card bg-base-200 mb-4">
            <div class="card-body">
              <h5 class="card-title">Email Verification Settings</h5>
              <form action="/admin/settings/email" method="post">
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="email_require_verification" name="email_require_verification"
                           <%= @settings[:email][:require_verification] ? 'checked' : '' %>>
                    <span class="label-text font-bold">Require Email Verification</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      When enabled, users must verify their email address before creating a character.
                      Existing users will be automatically verified when this is first enabled.
                    </span>
                  </label>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-send mr-2"></i>SendGrid Configuration</h6>

                <% unless @settings[:email][:sendgrid_configured] %>
                  <div class="alert alert-warning mb-3">
                    <i class="bi bi-exclamation-triangle mr-2"></i>
                    <span>SendGrid is not configured. Email verification will not work until you add an API key.</span>
                  </div>
                <% end %>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="form-control mb-3">
                    <label for="sendgrid_api_key" class="label">
                      <span class="label-text">SendGrid API Key</span>
                      <% if @settings[:email][:sendgrid_configured] %>
                        <span class="badge badge-success ml-2">Configured</span>
                      <% end %>
                    </label>
                    <div class="join w-full">
                      <input type="password" class="input input-bordered join-item flex-1"
                             id="sendgrid_api_key" name="sendgrid_api_key"
                             placeholder="<%= @settings[:email][:sendgrid_configured] ? '••••••••••••••••' : 'Enter SendGrid API key' %>">
                      <button class="btn btn-outline join-item" type="button" onclick="togglePassword('sendgrid_api_key')">
                        <i class="bi bi-eye"></i>
                      </button>
                    </div>
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">
                        Get an API key from <a href="https://app.sendgrid.com/settings/api_keys" target="_blank" class="link">SendGrid</a>.
                      </span>
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="form-control mb-3">
                    <label for="email_from_address" class="label">
                      <span class="label-text">From Email Address</span>
                    </label>
                    <input type="email" class="input input-bordered"
                           id="email_from_address" name="email_from_address"
                           value="<%= @settings[:email][:from_address] %>"
                           placeholder="noreply@yourgame.com">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Must be verified in your SendGrid account.</span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="email_from_name" class="label">
                      <span class="label-text">From Name</span>
                    </label>
                    <input type="text" class="input input-bordered"
                           id="email_from_name" name="email_from_name"
                           value="<%= @settings[:email][:from_name] %>"
                           placeholder="<%= @settings[:general][:game_name] || 'Firefly' %>">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">Display name shown in recipient's inbox.</span>
                    </label>
                  </div>
                </div>

                <div class="form-control mb-3">
                  <label for="email_verification_subject" class="label">
                    <span class="label-text">Verification Email Subject</span>
                  </label>
                  <input type="text" class="input input-bordered"
                         id="email_verification_subject" name="email_verification_subject"
                         value="<%= @settings[:email][:verification_subject] %>"
                         placeholder="Verify your email address">
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg mr-1"></i>Save Email Settings
                  </button>
                  <% if @settings[:email][:sendgrid_configured] %>
                    <button type="button" class="btn btn-outline" onclick="clearApiKey('sendgrid_api_key')">
                      <i class="bi bi-trash mr-1"></i>Clear API Key
                    </button>
                    <button type="button" class="btn btn-outline btn-info" onclick="sendTestEmail()">
                      <i class="bi bi-envelope-arrow-up mr-1"></i>Send Test Email
                    </button>
                  <% end %>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- Storage Settings -->
        <div class="tab-panel hidden" id="storage-panel">
          <div class="card bg-base-200">
            <div class="card-body">
              <h5 class="card-title">Cloud Storage Settings</h5>
              <div class="alert alert-info mb-4">
                <i class="bi bi-cloud mr-2"></i>
                <span><strong>Cloudflare R2:</strong> Configure R2 bucket storage for uploaded images and generated media.
                When enabled, all new uploads will be stored in R2 instead of the local filesystem.
                <a href="https://developers.cloudflare.com/r2/" target="_blank" class="link">Learn more about R2</a>.</span>
              </div>

              <form action="/admin/settings/storage" method="post">
                <!-- Enable Toggle -->
                <div class="form-control mb-4">
                  <label class="label cursor-pointer justify-start gap-3">
                    <input class="toggle toggle-primary" type="checkbox"
                           id="storage_r2_enabled" name="storage_r2_enabled"
                           <%= @settings[:storage][:r2_enabled] ? 'checked' : '' %>>
                    <span class="label-text font-bold">Enable Cloudflare R2 Storage</span>
                  </label>
                  <label class="label pt-0">
                    <span class="label-text-alt text-base-content/70">
                      When enabled, all new images will be uploaded to R2. Existing local images will continue to work.
                    </span>
                  </label>
                </div>

                <div class="divider"></div>
                <h6 class="text-base-content/70 mb-3 font-semibold"><i class="bi bi-gear mr-2"></i>R2 Configuration</h6>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="form-control mb-3">
                    <label for="storage_r2_endpoint" class="label">
                      <span class="label-text">R2 Endpoint URL</span>
                    </label>
                    <input type="text" class="input input-bordered"
                           id="storage_r2_endpoint" name="storage_r2_endpoint"
                           value="<%= @settings[:storage][:endpoint] %>"
                           placeholder="https://xxxx.r2.cloudflarestorage.com">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">
                        Find this in Cloudflare R2 dashboard under "Bucket Details" > "S3 API".
                      </span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="storage_r2_bucket" class="label">
                      <span class="label-text">Bucket Name</span>
                    </label>
                    <input type="text" class="input input-bordered"
                           id="storage_r2_bucket" name="storage_r2_bucket"
                           value="<%= @settings[:storage][:bucket] %>"
                           placeholder="firefly-media">
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">
                        The name of your R2 bucket.
                      </span>
                    </label>
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="form-control mb-3">
                    <label for="storage_r2_access_key" class="label">
                      <span class="label-text">Access Key ID</span>
                      <% if @settings[:storage][:has_access_key] %>
                        <span class="badge badge-success ml-2">Configured</span>
                      <% end %>
                    </label>
                    <div class="join w-full">
                      <input type="password" class="input input-bordered join-item flex-1"
                             id="storage_r2_access_key" name="storage_r2_access_key"
                             placeholder="<%= @settings[:storage][:has_access_key] ? 'Leave blank to keep existing' : 'Enter access key ID' %>">
                      <button class="btn btn-outline join-item" type="button" onclick="togglePassword('storage_r2_access_key')">
                        <i class="bi bi-eye"></i>
                      </button>
                    </div>
                    <label class="label">
                      <span class="label-text-alt text-base-content/70">
                        Create an API token in R2 dashboard > "Manage R2 API Tokens".
                      </span>
                    </label>
                  </div>
                  <div class="form-control mb-3">
                    <label for="storage_r2_secret_key" class="label">
                      <span class="label-text">Secret Access Key</span>
                      <% if @settings[:storage][:has_secret_key] %>
                        <span class="badge badge-success ml-2">Configured</span>
                      <% end %>
                    </label>
                    <div class="join w-full">
                      <input type="password" class="input input-bordered join-item flex-1"
                             id="storage_r2_secret_key" name="storage_r2_secret_key"
                             placeholder="<%= @settings[:storage][:has_secret_key] ? 'Leave blank to keep existing' : 'Enter secret access key' %>">
                      <button class="btn btn-outline join-item" type="button" onclick="togglePassword('storage_r2_secret_key')">
                        <i class="bi bi-eye"></i>
                      </button>
                    </div>
                  </div>
                </div>

                <div class="form-control mb-3">
                  <label for="storage_r2_public_url" class="label">
                    <span class="label-text">Public URL Prefix</span>
                  </label>
                  <input type="text" class="input input-bordered"
                         id="storage_r2_public_url" name="storage_r2_public_url"
                         value="<%= @settings[:storage][:public_url] %>"
                         placeholder="https://media.yourdomain.com">
                  <label class="label">
                    <span class="label-text-alt text-base-content/70">
                      The public URL for accessing files. Use a custom domain or the R2.dev URL from "Public Access" settings.
                      Example: <code class="bg-base-300 px-1 rounded">https://pub-xxxx.r2.dev</code> or <code class="bg-base-300 px-1 rounded">https://media.yourgame.com</code>
                    </span>
                  </label>
                </div>

                <div class="flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg mr-1"></i>Save Storage Settings
                  </button>
                  <button type="button" class="btn btn-outline btn-info" onclick="testR2Connection()">
                    <i class="bi bi-plug mr-1"></i>Test Connection
                  </button>
                </div>
              </form>

              <!-- Connection Test Result -->
              <div id="r2-test-result" class="mt-3" style="display: none;"></div>
            </div>
          </div>
        </div>
      </div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('#settingsTabs .tab');
    const panels = document.querySelectorAll('#settingsTabContent .tab-panel');

    function activateTab(tabName) {
      tabs.forEach(t => t.classList.remove('tab-active'));
      panels.forEach(p => p.classList.add('hidden'));

      const tab = document.querySelector('#settingsTabs .tab[data-tab="' + tabName + '"]');
      const panel = document.getElementById(tabName + '-panel');
      if (tab) tab.classList.add('tab-active');
      if (panel) panel.classList.remove('hidden');
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', function() {
        activateTab(this.dataset.tab);
      });
    });

    // Activate tab from URL hash (e.g. /admin/settings#ai)
    const hash = window.location.hash.replace('#', '');
    if (hash && document.getElementById(hash + '-panel')) {
      activateTab(hash);
    }
  });
</script>

<%= admin_content_end %>
