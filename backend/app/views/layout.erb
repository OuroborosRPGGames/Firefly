<!DOCTYPE html>
<html lang="en" data-theme="dark" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrf_token %>">
    <title><%= @page_title ? "#{@page_title} - #{game_name}" : game_name %></title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&family=Crimson+Text:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons (standalone library) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Tailwind CSS + DaisyUI -->
    <link rel="stylesheet" href="/css/daisyui.css">
    <link rel="stylesheet" href="/css/tailwind.css">

    <!-- Firefly Custom Styles -->
    <link rel="stylesheet" href="/css/firefly.css">

    <!-- Animate.css for modal animations -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

    <!-- Modal System -->
    <link rel="stylesheet" href="/css/modal-system.css?v=2">

    <!-- Description Editor & Gradient Components -->
    <link rel="stylesheet" href="/css/descriptions.css">
    <link rel="stylesheet" href="/css/gradient-components.css">
    <link rel="stylesheet" href="/css/grammar-checker.css">

    <style>
      /* Tab panel visibility - panels show by default, hidden via .hidden class */
      /* Note: Most pages use .hidden class, legacy pages may use .active class */
      .tab-panel { display: block; }
      .tab-panel.hidden { display: none; }
      /* Legacy support for .active class pattern (all panels start hidden, active shows) */
      .tabs-legacy .tab-panel { display: none; }
      .tabs-legacy .tab-panel.active { display: block; }

      /* Form styling */
      .form-control, .form-select {
        background-color: #272b30;
        border: 1px solid #3a3f44;
        color: #e0e0e0;
        padding: 0.5rem 0.75rem;
        border-radius: 0.375rem;
      }
      .form-control:focus, .form-select:focus {
        background-color: #272b30;
        border-color: #86b7fe;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        color: #e0e0e0;
        outline: none;
      }

      /* Breadcrumb styling */
      .breadcrumb {
        display: flex;
        flex-wrap: wrap;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .breadcrumb-item + .breadcrumb-item::before {
        content: "/";
        padding: 0 0.5rem;
        color: rgba(255, 255, 255, 0.4);
      }
      .breadcrumb-item a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
      }
      .breadcrumb-item a:hover {
        color: rgba(255, 255, 255, 0.8);
      }
      .breadcrumb-item.active {
        color: rgba(255, 255, 255, 0.6);
      }

      /* Scroll-to-top button */
      .btn-scroll-top {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.3s, visibility 0.3s;
        z-index: 50;
      }
      .btn-scroll-top.visible {
        opacity: 1;
        visibility: visible;
      }
    </style>
</head>
<body class="bg-base-100 text-base-content">
    <!-- DaisyUI Navbar -->
    <div class="navbar bg-base-200 sticky top-0 z-50">
        <div class="navbar-start">
            <!-- Mobile hamburger -->
            <div class="dropdown">
                <label tabindex="0" class="btn btn-ghost lg:hidden">
                    <i class="bi bi-list text-xl"></i>
                </label>
                <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-200 rounded-box w-52">
                    <li><a href="/" class="<%= request.path == '/' ? 'active' : '' %>">Home</a></li>
                    <% if @current_user %>
                    <li><a href="/dashboard" class="<%= request.path == '/dashboard' ? 'active' : '' %>"><i class="bi bi-play-circle mr-1"></i>Play</a></li>
                    <% end %>
                    <li>
                        <a>Game Info</a>
                        <ul class="p-2 bg-base-200">
                            <li><a href="/info"><i class="bi bi-info-circle mr-2"></i>Overview</a></li>
                            <li><a href="/info/rules"><i class="bi bi-book mr-2"></i>Rules</a></li>
                            <li><a href="/info/getting-started"><i class="bi bi-rocket-takeoff mr-2"></i>Getting Started</a></li>
                            <li><a href="/info/commands"><i class="bi bi-terminal mr-2"></i>Commands</a></li>
                            <li><a href="/info/helps"><i class="bi bi-book mr-2"></i>Help Topics</a></li>
                            <li><a href="/info/systems"><i class="bi bi-collection mr-2"></i>Game Systems</a></li>
                            <li><a href="/info/terms"><i class="bi bi-file-text mr-2"></i>Terms</a></li>
                            <li><a href="/info/privacy"><i class="bi bi-shield-check mr-2"></i>Privacy</a></li>
                            <li><a href="/info/contact"><i class="bi bi-envelope mr-2"></i>Contact</a></li>
                        </ul>
                    </li>
                    <li>
                        <a>World</a>
                        <ul class="p-2 bg-base-200">
                            <li><a href="/world"><i class="bi bi-globe mr-2"></i>Overview</a></li>
                            <li><a href="/world/lore"><i class="bi bi-journal-text mr-2"></i>Lore</a></li>
                            <li><a href="/world/locations"><i class="bi bi-geo-alt mr-2"></i>Locations</a></li>
                            <li><a href="/world/factions"><i class="bi bi-people mr-2"></i>Factions</a></li>
                            <li><a href="/profiles"><i class="bi bi-person-badge mr-2"></i>Characters</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
            <!-- Brand -->
            <a class="btn btn-ghost text-xl" href="/">
                <i class="bi bi-fire mr-2"></i><%= game_name %>
            </a>
        </div>

        <!-- Desktop nav -->
        <div class="navbar-center hidden lg:flex">
            <ul class="menu menu-horizontal px-1">
                <li><a href="/" class="<%= request.path == '/' ? 'active' : '' %>">Home</a></li>
                <% if @current_user %>
                <li><a href="/dashboard" class="<%= request.path == '/dashboard' ? 'active' : '' %>"><i class="bi bi-play-circle mr-1"></i>Play</a></li>
                <% end %>
                <li>
                    <details>
                        <summary class="<%= request.path.start_with?('/info') ? 'active' : '' %>">Game Info</summary>
                        <ul class="p-2 bg-base-200 rounded-box w-52 z-50">
                            <li><a href="/info"><i class="bi bi-info-circle mr-2"></i>Overview</a></li>
                            <li><a href="/info/rules"><i class="bi bi-book mr-2"></i>Rules</a></li>
                            <li><a href="/info/getting-started"><i class="bi bi-rocket-takeoff mr-2"></i>Getting Started</a></li>
                            <li class="divider"></li>
                            <li><a href="/info/commands"><i class="bi bi-terminal mr-2"></i>Commands</a></li>
                            <li><a href="/info/helps"><i class="bi bi-book mr-2"></i>Help Topics</a></li>
                            <li><a href="/info/systems"><i class="bi bi-collection mr-2"></i>Game Systems</a></li>
                            <li class="divider"></li>
                            <li><a href="/info/terms"><i class="bi bi-file-text mr-2"></i>Terms of Service</a></li>
                            <li><a href="/info/privacy"><i class="bi bi-shield-check mr-2"></i>Privacy Policy</a></li>
                            <li><a href="/info/contact"><i class="bi bi-envelope mr-2"></i>Contact</a></li>
                        </ul>
                    </details>
                </li>
                <li>
                    <details>
                        <summary class="<%= request.path.start_with?('/world') || request.path.start_with?('/profiles') ? 'active' : '' %>">World</summary>
                        <ul class="p-2 bg-base-200 rounded-box w-48 z-50">
                            <li><a href="/world"><i class="bi bi-globe mr-2"></i>Overview</a></li>
                            <li><a href="/world/lore"><i class="bi bi-journal-text mr-2"></i>Lore</a></li>
                            <li><a href="/world/locations"><i class="bi bi-geo-alt mr-2"></i>Locations</a></li>
                            <li><a href="/world/factions"><i class="bi bi-people mr-2"></i>Factions</a></li>
                            <li class="divider"></li>
                            <li><a href="/profiles"><i class="bi bi-person-badge mr-2"></i>Characters</a></li>
                        </ul>
                    </details>
                </li>
            </ul>
        </div>

        <div class="navbar-end">
            <% if @current_user %>
                <% if @current_user.can_access_admin_console? %>
                <a href="/admin" class="btn btn-ghost btn-sm<%= request.path.start_with?('/admin') ? ' btn-active' : '' %>">
                    <i class="bi bi-shield-lock"></i>
                    <span class="hidden md:inline ml-1">Admin</span>
                </a>
                <% end %>
                <div class="dropdown dropdown-end">
                    <label tabindex="0" class="btn btn-ghost">
                        <i class="bi bi-person-circle mr-1"></i>
                        <span class="hidden md:inline"><%= h @current_user.username %></span>
                        <i class="bi bi-chevron-down text-xs ml-1"></i>
                    </label>
                    <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-200 rounded-box w-52">
                        <li><a href="/dashboard"><i class="bi bi-people mr-2"></i>Characters</a></li>
                        <li><a href="/settings"><i class="bi bi-gear mr-2"></i>Settings</a></li>
                        <% if @current_user.can_access_admin_console? %>
                        <li><a href="/admin"><i class="bi bi-shield-lock mr-2"></i>Admin Console</a></li>
                        <% end %>
                        <li class="divider"></li>
                        <li><a href="/logout"><i class="bi bi-box-arrow-right mr-2"></i>Logout</a></li>
                    </ul>
                </div>
            <% else %>
                <a href="/login" class="btn btn-ghost btn-sm<%= request.path == '/login' ? ' btn-active' : '' %>">
                    <i class="bi bi-box-arrow-in-right mr-1"></i>Login
                </a>
                <a href="/register" class="btn btn-primary btn-sm ml-2<%= request.path == '/register' ? ' btn-active' : '' %>">
                    <i class="bi bi-person-plus mr-1"></i>Register
                </a>
            <% end %>
        </div>
    </div>

    <!-- Breadcrumbs -->
    <% if @breadcrumbs && @breadcrumbs.any? %>
    <div class="bg-base-300 border-b border-base-200">
        <div class="container mx-auto px-4 py-2">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/"><i class="bi bi-house-door"></i></a></li>
                    <% @breadcrumbs.each_with_index do |crumb, index| %>
                        <% if index == @breadcrumbs.length - 1 %>
                            <li class="breadcrumb-item active" aria-current="page"><%= crumb[:label] %></li>
                        <% else %>
                            <li class="breadcrumb-item"><a href="<%= crumb[:path] %>"><%= crumb[:label] %></a></li>
                        <% end %>
                    <% end %>
                </ol>
            </nav>
        </div>
    </div>
    <% end %>

    <!-- Flash Messages -->
    <% if flash['error'] || flash['success'] || flash['warning'] || flash['info'] %>
    <div class="container mx-auto px-4 mt-3">
        <% if flash['error'] %>
        <div class="alert alert-error shadow-lg mb-3">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span><%= flash['error'] %></span>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% end %>

        <% if flash['success'] %>
        <div class="alert alert-success shadow-lg mb-3">
            <i class="bi bi-check-circle-fill"></i>
            <span><%= flash['success'] %></span>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% end %>

        <% if flash['warning'] %>
        <div class="alert alert-warning shadow-lg mb-3">
            <i class="bi bi-exclamation-circle-fill"></i>
            <span><%= flash['warning'] %></span>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% end %>

        <% if flash['info'] %>
        <div class="alert alert-info shadow-lg mb-3">
            <i class="bi bi-info-circle-fill"></i>
            <span><%= flash['info'] %></span>
            <button type="button" class="btn btn-sm btn-circle btn-ghost" onclick="this.parentElement.remove()">✕</button>
        </div>
        <% end %>
    </div>
    <% end %>

    <!-- Main Content -->
    <main>
        <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-base-300 text-base-content/60 py-4 mt-5 border-t border-base-200">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-12 gap-4">
                <div class="col-span-12 md:col-span-6">
                    <p class="mb-0">&copy; <%= Time.now.year %> <%= game_name %>. All rights reserved.</p>
                </div>
                <div class="col-span-12 md:col-span-6 md:text-right">
                    <a href="/info/terms" class="text-base-content/60 hover:text-base-content mr-3">Terms</a>
                    <a href="/info/privacy" class="text-base-content/60 hover:text-base-content mr-3">Privacy</a>
                    <a href="/info/contact" class="text-base-content/60 hover:text-base-content">Contact</a>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scroll to Top Button -->
    <button class="btn btn-primary btn-scroll-top" id="scrollToTop" title="Scroll to top">
        <i class="bi bi-chevron-up"></i>
    </button>

    <!-- Shared Utilities -->
    <script src="/js/utils.js"></script>

    <!-- Modal System -->
    <script src="/js/modal-system.js"></script>

    <!-- Grammar Checker -->
    <script src="/js/grammar-checker.js"></script>

    <!-- Custom Scripts -->
    <script>
        // Scroll to Top functionality
        (function() {
            const scrollBtn = document.getElementById('scrollToTop');

            window.addEventListener('scroll', function() {
                if (window.scrollY > 300) {
                    scrollBtn.classList.add('visible');
                } else {
                    scrollBtn.classList.remove('visible');
                }
            });

            scrollBtn.addEventListener('click', function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });
        })();

        // Tab functionality (for pages that use tabs)
        document.addEventListener('DOMContentLoaded', function() {
            const tabs = document.querySelectorAll('.tab');
            const panels = document.querySelectorAll('.tab-panel');

            tabs.forEach(tab => {
                tab.addEventListener('click', function() {
                    const targetPanel = this.getAttribute('data-tab');

                    tabs.forEach(t => t.classList.remove('active'));
                    panels.forEach(p => p.classList.remove('active'));

                    this.classList.add('active');
                    const panel = document.getElementById(targetPanel + '-panel');
                    if (panel) {
                        panel.classList.add('active');
                    }
                });
            });

            // Bootstrap compatibility: Handle data-bs-toggle="tab" and data-bs-toggle="collapse"
            document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tabTrigger => {
                tabTrigger.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetSelector = this.getAttribute('data-bs-target');
                    if (!targetSelector) return;

                    // Find all tabs in this tab group and deactivate
                    const tabList = this.closest('.nav, [role="tablist"]');
                    if (tabList) {
                        tabList.querySelectorAll('[data-bs-toggle="tab"]').forEach(t => {
                            t.classList.remove('active');
                            t.setAttribute('aria-selected', 'false');
                        });
                    }

                    // Deactivate all tab panes in the same content area
                    const targetPanel = document.querySelector(targetSelector);
                    if (targetPanel) {
                        const tabContent = targetPanel.parentElement;
                        tabContent.querySelectorAll('.tab-pane').forEach(pane => {
                            pane.classList.remove('show', 'active');
                        });
                        // Activate the target panel
                        targetPanel.classList.add('show', 'active');
                    }

                    // Activate this tab
                    this.classList.add('active');
                    this.setAttribute('aria-selected', 'true');
                });
            });

            // Bootstrap compatibility: Handle data-bs-toggle="collapse"
            document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(collapseTrigger => {
                collapseTrigger.addEventListener('click', function(e) {
                    e.preventDefault();
                    const targetSelector = this.getAttribute('data-bs-target');
                    if (!targetSelector) return;

                    const targetEl = document.querySelector(targetSelector);
                    if (targetEl) {
                        targetEl.classList.toggle('show');
                        this.setAttribute('aria-expanded', targetEl.classList.contains('show'));
                    }
                });
            });

            // Close other dropdowns when one opens (mutual exclusivity)
            document.querySelectorAll('.menu details').forEach(detail => {
                detail.addEventListener('toggle', function() {
                    if (this.open) {
                        document.querySelectorAll('.menu details').forEach(other => {
                            if (other !== this && other.open) {
                                other.removeAttribute('open');
                            }
                        });
                    }
                });
            });

            // Close dropdown menus when clicking elsewhere
            document.addEventListener('click', function(e) {
                const details = document.querySelectorAll('.menu details[open]');
                details.forEach(detail => {
                    if (!detail.contains(e.target)) {
                        detail.removeAttribute('open');
                    }
                });
            });
        });
    </script>
</body>
</html>
