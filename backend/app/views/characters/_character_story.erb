<!-- Character Story Card - Single Character -->
<div class="card bg-base-200 shadow-xl mt-6">
  <div class="card-body">
    <div class="flex justify-between items-center mb-4">
      <h2 class="card-title"><i class="bi bi-book mr-2"></i>Character Story</h2>
    </div>

    <!-- Summary Panel -->
    <div class="story-summary flex flex-col items-center py-3">
      <div class="story-stats flex gap-6 mb-4">
        <div class="story-stat text-center">
          <div class="stat-value text-3xl font-bold mb-1" id="chapters-count-<%= @character.id %>">
            <span class="loading loading-spinner loading-sm"></span>
          </div>
          <div class="stat-label text-sm text-base-content/70">Chapters</div>
        </div>
        <div class="story-stat text-center">
          <div class="stat-value text-3xl font-bold mb-1" id="words-count-<%= @character.id %>">
            <span class="loading loading-spinner loading-sm"></span>
          </div>
          <div class="stat-label text-sm text-base-content/70">Words</div>
        </div>
        <div class="story-stat text-center">
          <div class="stat-value text-3xl font-bold mb-1" id="read-time-<%= @character.id %>">
            <span class="loading loading-spinner loading-sm"></span>
          </div>
          <div class="stat-label text-sm text-base-content/70">Reading Time</div>
        </div>
      </div>

      <div class="flex gap-2">
        <button class="btn btn-primary read-story-btn"
                data-character-id="<%= @character.id %>"
                id="read-btn-<%= @character.id %>"
                disabled>
          <i class="bi bi-book-fill mr-1"></i>Read Story
        </button>
        <button class="btn btn-outline btn-neutral download-story-btn"
                data-character-id="<%= @character.id %>"
                id="download-btn-<%= @character.id %>"
                disabled>
          <i class="bi bi-download mr-1"></i>Download
        </button>
      </div>

      <!-- Empty state message -->
      <div class="story-empty text-center text-base-content/70 py-4 hidden" id="story-empty-<%= @character.id %>">
        <i class="bi bi-journal-text block text-4xl mb-2"></i>
        <p class="mb-0">No story content yet. Play the game to create your character's story!</p>
      </div>
    </div>
  </div>
</div>

<!-- Story Reader Modal -->
<dialog class="modal" id="storyReaderModal">
  <div class="modal-box w-full max-w-full h-full max-h-full rounded-none story-reader-modal">
    <!-- Top Bar -->
    <div class="flex justify-between items-center py-2 px-3 border-b border-base-300 story-reader-header">
      <div class="flex items-center gap-3">
        <i class="bi bi-book-fill text-primary"></i>
        <h5 class="font-bold" id="storyReaderModalLabel"><%= h @character.full_name %>'s Story</h5>
      </div>
      <div class="flex items-center gap-2">
        <button type="button" class="btn btn-sm btn-outline btn-neutral" id="readerDownloadBtn">
          <i class="bi bi-download mr-1"></i>Download
        </button>
        <form method="dialog">
          <button class="btn btn-sm btn-circle btn-ghost">&#x2715;</button>
        </form>
      </div>
    </div>

    <div class="flex p-0 story-reader-body h-[calc(100vh-64px)]">
      <!-- Left Sidebar: Chapter List -->
      <div class="story-sidebar w-64 border-r border-base-300" id="storySidebar">
        <div class="p-3 border-b border-base-300">
          <h6 class="mb-0 text-base-content/50">Chapters</h6>
        </div>
        <div class="px-3 py-2 border-b border-base-300">
          <div class="relative">
            <i class="bi bi-search absolute left-2.5 top-1/2 -translate-y-1/2 text-base-content/40 text-xs"></i>
            <input type="text" id="chapterSearchInput" placeholder="Search chapters..."
                   class="input input-sm input-bordered w-full pl-8 bg-base-300/50 text-sm" />
          </div>
        </div>
        <div class="sidebar-chapters overflow-y-auto" id="chapterList">
          <!-- Chapters populated by JS -->
        </div>
      </div>

      <!-- Main Reading Area -->
      <div class="story-content flex-grow flex flex-col">
        <!-- Chapter Header -->
        <div class="p-3 border-b border-base-300">
          <h4 class="font-bold mb-1" id="currentChapterTitle">Loading...</h4>
          <div class="text-base-content/70 text-sm" id="currentChapterMeta"></div>
        </div>

        <!-- Reading Content -->
        <div class="chapter-content flex-grow overflow-auto p-4" id="chapterContent">
          <div class="text-center py-12">
            <span class="loading loading-spinner loading-lg text-primary"></span>
          </div>
        </div>

        <!-- Navigation Footer -->
        <div class="flex justify-between items-center p-3 border-t border-base-300">
          <button class="btn btn-outline btn-neutral btn-sm" id="prevChapterBtn" disabled>
            <i class="bi bi-chevron-left mr-1"></i>Previous
          </button>
          <span class="text-base-content/70 text-sm" id="chapterProgress">Chapter 1 of 1</span>
          <button class="btn btn-outline btn-neutral btn-sm" id="nextChapterBtn" disabled>
            Next<i class="bi bi-chevron-right ml-1"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<style>
.story-stat .stat-value {
  font-weight: 600;
  color: var(--fallback-bc, oklch(var(--bc)));
}

/* Story Reader Modal Styles */
.story-reader-modal .modal-content {
  background: #0d0d0f;
  color: #e0e0e0;
}

.story-reader-header {
  background: linear-gradient(to bottom, #1a1a1f, #0d0d0f);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08) !important;
}

.story-reader-body {
  height: calc(100vh - 56px);
}

/* Sidebar */
.story-sidebar {
  width: 280px;
  min-width: 280px;
  background: #12121a;
  border-right: 1px solid rgba(255, 255, 255, 0.08);
  display: flex;
  flex-direction: column;
}

.sidebar-chapters {
  flex: 1;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
}

.sidebar-chapters::-webkit-scrollbar {
  width: 6px;
}

.sidebar-chapters::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 3px;
}

.chapter-item {
  padding: 0.75rem 1rem;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: all 0.2s ease;
}

.chapter-item:hover {
  background: rgba(255, 255, 255, 0.05);
}

.chapter-item.active {
  background: rgba(135, 206, 235, 0.1);
  border-left-color: var(--fallback-p, oklch(var(--p)));
}

.chapter-item-title {
  font-size: 0.9rem;
  font-weight: 500;
  color: #f0f0f0;
  margin-bottom: 0.25rem;
}

.chapter-item-date {
  font-size: 0.7rem;
  color: #aaa;
  margin-bottom: 0.15rem;
}

.chapter-item-meta {
  font-size: 0.75rem;
  color: #888;
}

/* Main Content Area */
.story-content {
  background: #1a1a1f;
}

.chapter-content {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.1rem;
  line-height: 1.8;
  color: #e0e0e0;
  max-width: 800px;
  margin: 0 auto;
  width: 100%;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.15) transparent;
}

.chapter-content::-webkit-scrollbar {
  width: 6px;
}

.chapter-content::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 3px;
}

.chapter-content p {
  margin-bottom: 1.25rem;
  text-indent: 1.5em;
}

.chapter-content p:first-child {
  text-indent: 0;
}

/* Responsive */
@media (max-width: 768px) {
  .story-sidebar {
    display: none;
  }

  .chapter-content {
    font-size: 1rem;
    padding: 1rem !important;
  }
}
</style>

<script src="/js/character_story_reader.js?v=2"></script>
