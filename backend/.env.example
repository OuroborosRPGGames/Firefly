# Firefly MUD Engine - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL connection URL
# Format: postgres://user:password@host:port/database
DATABASE_URL=postgres://prom_user:prom_password@localhost/firefly

# Alternative individual settings (override DATABASE_URL)
# DB_HOST=localhost
# DB_NAME=firefly
# DB_USER=prom_user
# DB_PASSWORD=prom_password

# Database pool sizing (auto-calculated if not set)
# Formula: (workers × threads) + overhead
# DB_POOL_SIZE=35

# Connection pool timeout in seconds
# DB_POOL_TIMEOUT=5

# Statement timeout (stricter in production)
# Development: 5s, Production: 500ms
# DB_STATEMENT_TIMEOUT=5s

# Connection validation interval in seconds
# DB_VALIDATION_TIMEOUT=300

# ============================================================
# REDIS CONFIGURATION
# ============================================================

# Redis URL for sessions, caching, and rate limiting
REDIS_URL=redis://localhost:6379/0

# Separate Redis URL for AnyCable WebSocket communication
# Using different database (1) to isolate WebSocket state
ANYCABLE_REDIS_URL=redis://localhost:6379/1

# ============================================================
# SERVER CONFIGURATION
# ============================================================

# Environment: development, test, or production
RACK_ENV=development

# HTTP server port
PORT=3000

# Puma workers (web concurrency)
# Set to 0 for single-process mode
# WEB_CONCURRENCY=4

# Puma threads per worker
# PUMA_THREADS=5

# ============================================================
# ANYCABLE (WEBSOCKET) CONFIGURATION
# ============================================================

# AnyCable RPC server host for gRPC communication
ANYCABLE_RPC_HOST=localhost:50051

# ============================================================
# FEATURE FLAGS
# ============================================================
# All flags use opt-in pattern (disabled by default)
# Valid values: true, 1, yes, on (case-insensitive)

# Enable Rack::Attack rate limiting
# Recommended: Enable in production
FEATURE_RATE_LIMITING=false

# Enable dual-mode output (human + structured JSON)
# Required for LLM agent integration
FEATURE_DUAL_OUTPUT=true

# ============================================================
# LLM/AI INTEGRATION (Optional)
# ============================================================

# Anthropic API key for Claude-powered agents
# Required for MCP multi-agent testing
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key for alternative LLM provider
# GEMINI_API_KEY=...

# ============================================================
# MCP TESTING (Development Only)
# ============================================================

# API token for MCP test server authentication
# Generate with: bundle exec ruby scripts/create_test_agent.rb
# FIREFLY_API_TOKEN=...

# Base URL for game server (MCP server uses this)
# FIREFLY_BASE_URL=http://localhost:3000

# ============================================================
# SECURITY (Production Only)
# ============================================================

# Secret key for session encryption
# Generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(64)'
# SESSION_SECRET=...

# Allowed hosts for CORS (comma-separated)
# CORS_ORIGINS=https://yourdomain.com

# ============================================================
# LOGGING
# ============================================================

# Log level: debug, info, warn, error
# LOG_LEVEL=info

# Enable SQL query logging (noisy in production)
# LOG_SQL=false
