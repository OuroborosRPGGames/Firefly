#!/usr/bin/env bash
set -e

cd "$(dirname "$0")/.."

if ! command -v foreman &> /dev/null; then
  echo "Installing foreman..."
  gem install foreman
fi

# Download Tailwind CLI if not present
if [ ! -f bin/tailwindcss ]; then
  echo "Downloading Tailwind CSS standalone CLI..."
  curl -sLo bin/tailwindcss https://github.com/tailwindlabs/tailwindcss/releases/latest/download/tailwindcss-linux-x64
  chmod +x bin/tailwindcss
fi

exec foreman start -f Procfile.dev "$@"
